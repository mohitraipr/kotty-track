<!-- views/bulkUpload.ejs -->
<%- include('partials/header', { pageTitle: 'Bulk Upload' }) %>
<%- include('partials/navbar', { user: user }) %>

<!-- Main Content -->
<main class="main-content" style="margin-left: 0;">
  <div class="container" style="max-width: 800px; margin: 0 auto;">

    <!-- Page Header -->
    <div class="page-header">
      <nav class="breadcrumbs">
        <a href="/fabric-manager/dashboard">Dashboard</a>
        <span class="separator"><i class="bi bi-chevron-right"></i></span>
        <span>Bulk Upload</span>
      </nav>
      <h1 class="page-title">Bulk Upload Fabric Invoices</h1>
      <p class="page-subtitle">Upload Excel files to import fabric invoice data in bulk</p>
    </div>

    <!-- Flash Messages -->
    <%- include('partials/flashMessages') %>

    <!-- Upload Form Card -->
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">
          <i class="bi bi-cloud-arrow-up me-2"></i>
          Upload for <%= tableName %>
        </h2>
      </div>
      <div class="card-body">
        <form action="/fabric-manager/bulk-upload/invoices" method="POST" enctype="multipart/form-data">
          <div class="form-group">
            <label for="excelFile" class="form-label">
              <i class="bi bi-file-earmark-excel text-success me-2"></i>
              Excel File (.xlsx)
            </label>
            <input type="file" class="form-control form-input" id="excelFile" name="excelFile" accept=".xlsx" required>
            <div class="form-text text-muted mt-2" style="font-size: var(--text-sm);">
              Ensure the Excel file follows the required format specified in the template below.
            </div>
          </div>

          <div class="d-flex gap-3 mt-4">
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-upload"></i>
              Upload
            </button>
            <a href="/fabric-manager/dashboard" class="btn btn-secondary">
              <i class="bi bi-x-circle"></i>
              Cancel
            </a>
          </div>
        </form>
      </div>
    </div>

    <!-- Vendor Mapping Info Card -->
    <div class="card mt-4">
      <div class="card-header">
        <h2 class="card-title">
          <i class="bi bi-diagram-3 me-2"></i>
          Vendor Mapping
        </h2>
      </div>
      <div class="card-body">
        <p class="mb-3" style="color: var(--text-secondary);">
          The system will automatically match the <strong class="text-terracotta">vendor_name</strong>
          in your Excel file to existing vendors. If a vendor does not exist, a new vendor will be created.
        </p>
        <div class="alert alert-info mb-0" style="border-left: 3px solid var(--info);">
          <div class="d-flex align-items-start">
            <i class="bi bi-info-circle-fill me-2"></i>
            <div>
              <strong>Note:</strong> Ensure that the <strong>vendor_name</strong> in your Excel matches
              the intended vendor names to avoid creating duplicate vendors.
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Excel Template Card -->
    <div class="card mt-4">
      <div class="card-header">
        <h2 class="card-title">
          <i class="bi bi-file-earmark-spreadsheet me-2"></i>
          Excel Template
        </h2>
      </div>
      <div class="card-body">
        <p class="mb-3" style="color: var(--text-secondary);">
          Download the Excel template to ensure your data is formatted correctly for upload.
        </p>
        <a href="/path-to-template/fabric_invoices_template.xlsx" download class="btn btn-outline">
          <i class="bi bi-download"></i>
          Download Template
        </a>
      </div>
    </div>

  </div>
</main>

<%- include('partials/footer') %>
