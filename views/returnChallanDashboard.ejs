            <label for="fDesc">Description</label>
            <textarea id="fDesc" name="description" placeholder="Item description, condition notes..."></textarea>
          </div>
          <div class="rc-field rc-field-full">
            <label>Images <span style="color: var(--text-3); text-transform: none; letter-spacing: normal; font-weight: 500;">(up to 15)</span></label>
            <div class="rc-gallery" id="imgGallery">
