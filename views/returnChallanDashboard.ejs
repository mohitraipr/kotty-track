          <button class="rc-btn primary" onclick="addNewField()">Add field</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ─── Image lightbox (with prev/next + dots) ─── -->
<div class="rc rc-light" id="lightbox" onclick="if(event.target.id==='lightbox')closeLightbox()">
  <div class="light-content">
    <button class="nav-btn prev" id="lightPrev" onclick="event.stopPropagation();lightboxNav(-1)" aria-label="Previous">‹</button>
    <img id="lightImg" />
    <button class="nav-btn next" id="lightNext" onclick="event.stopPropagation();lightboxNav(1)" aria-label="Next">›</button>
    <div class="counter" id="lightCounter">—</div>
    <div class="dots" id="lightDots"></div>
  </div>
</div>

<div class="rc rc-toasts" id="toasts"></div>

<script>
'use strict';

// ─── State ───────────────────────────────────────────
const MAX_IMAGES = 15;
let fields = [];          // active custom fields
let allFieldDefs = [];    // ALL field defs (for the modal)
let entries = [];
let currentPage = 1;
let totalPages = 1;
let totalCount = 0;
let searchQuery = '';
let searchT = null;

// Form image state. Three buckets:
//   existing:    images already saved on the server (edit mode only)
//                each: { id, key, url, removed: false }
//   added:       images uploaded during this form session (create or edit)
//                each: { tempId, key, url, uploading: false, failed: false }
// Counts: total = existing.length - existing.filter(removed).length + added.length
let formImages = { existing: [], added: [] };
let formImageTempSeq = 0;

// Lightbox state: list of {url, key} + current index
let lightbox = { images: [], index: 0 };

// ─── Helpers ─────────────────────────────────────────
const $ = (id) => document.getElementById(id);
const esc = (s) => String(s == null ? '' : s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":"&#39;"}[c]));
const fmtNum = (n) => Number(n || 0).toLocaleString('en-IN');
const fmtMoney = (n) => '₹ ' + Number(n || 0).toLocaleString('en-IN', { minimumFractionDigits: 0, maximumFractionDigits: 2 });
const fmtDate = (s) => {
  if (!s) return '—';
  const d = new Date(s);
  return Number.isNaN(d.getTime()) ? '—' : d.toLocaleDateString();
};
const fmtDateTime = (s) => {
  if (!s) return '—';
  const d = new Date(s);
  return Number.isNaN(d.getTime()) ? '—' : d.toLocaleString();
};

function toast(msg, kind) {
  const t = document.createElement('div');
  t.className = 'rc-toast ' + (kind || '');
  t.textContent = msg;
  $('toasts').appendChild(t);
  setTimeout(() => { t.style.opacity = '0'; t.style.transition = 'opacity 0.3s'; }, 3000);
  setTimeout(() => t.remove(), 3400);
}

async function api(method, url, body) {
  const opts = {
    method,
    credentials: 'include',
    headers: { 'Accept': 'application/json' },
  };
  if (body !== undefined) {
    opts.headers['Content-Type'] = 'application/json';
    opts.body = JSON.stringify(body);
  }
  const r = await fetch(url, opts);
  const data = await r.json().catch(() => ({}));
  if (!r.ok || !data.ok) throw new Error((data && data.error) || ('HTTP ' + r.status));
  return data;
}

// ─── Form open/close ─────────────────────────────────
function openForm(entry) {
  $('formCard').classList.add('show');
  $('imgInput').value = '';
  formImages = { existing: [], added: [] };
  if (entry) {
    $('formTitle').textContent = 'Edit return challan';
    $('editingPill').classList.add('show');
    $('fId').value = entry.id;
    $('fChallanNo').value = entry.challan_no || '';
    $('fChallanDate').value = entry.challan_date ? new Date(entry.challan_date).toISOString().slice(0, 10) : '';
    $('fName').value = entry.name || '';
    $('fPunching').value = entry.punching_no || '';
    $('fDept').value = entry.department || '';
    $('fCategory').value = entry.category || '';
    $('fBrand').value = entry.brand_name || '';
    $('fIsBranded').checked = !!entry.is_branded;
    $('fQty').value = entry.qty != null ? entry.qty : 0;
    $('fPrice').value = entry.price != null ? entry.price : 0;
    $('fDesc').value = entry.description || '';
    // Seed existing-images. Server returns images[] with id/key/url; for
    // legacy single-image entries the synthetic id is null — those rows
    // get a synthetic temp id so the user can "remove" them locally (the
    // server treats them as a removal of the legacy column on edit).
    formImages.existing = (entry.images || []).map((im) => ({
      id: im.id != null ? im.id : null,   // null => legacy single-image
      key: im.key,
      url: im.url,
      removed: false,
    }));
    populateCustomFieldsForm(entry.custom_data || {});
  } else {
    $('formTitle').textContent = 'New return challan';
    $('editingPill').classList.remove('show');
    $('entryForm').reset();
    $('fId').value = '';
    $('fChallanNo').value = '';
    $('fChallanDate').value = new Date().toISOString().slice(0, 10);
    populateCustomFieldsForm({});
  }
  renderGallery();
  $('formCard').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function closeForm() {
  $('formCard').classList.remove('show');
}

// ─── Multi-image gallery ────────────────────────────
function currentImageCount() {
  const kept = formImages.existing.filter(x => !x.removed).length;
  const added = formImages.added.filter(x => !x.failed).length;
  return kept + added;
}

function renderGallery() {
  const gal = $('imgGallery');
  // Wipe then re-add tiles + Add tile in order.
  gal.innerHTML = '';

  // Existing images (kept or queued-for-removal)
  formImages.existing.forEach((im, i) => {
    const tile = document.createElement('div');
    tile.className = 'tile' + (im.removed ? ' queued-remove' : '');
    tile.innerHTML = `
      <img src="${esc(im.url || '')}" alt="image" />
      <button type="button" class="x" title="${im.removed ? 'Restore' : 'Remove'}"
              onclick="toggleRemoveExisting(${i})">${im.removed ? '↺' : '×'}</button>
    `;
    tile.querySelector('img').onclick = () => openGalleryFromForm('existing', i);
    gal.appendChild(tile);
  });

  // Newly-added images
  formImages.added.forEach((im, i) => {
    const tile = document.createElement('div');
    tile.className = 'tile' + (im.failed ? ' failed' : '');
    tile.innerHTML = `
      <img src="${esc(im.url || '')}" alt="image" />
      <button type="button" class="x" title="Remove" onclick="removeAdded(${i})">×</button>
      ${im.uploading ? '<div class="upload-overlay">Uploading…</div>' :
        im.failed   ? '<div class="upload-overlay">Failed</div>' : ''}
    `;
    if (!im.uploading && !im.failed) {
      tile.querySelector('img').onclick = () => openGalleryFromForm('added', i);
    }
    gal.appendChild(tile);
  });

  // Add tile (or cap message)
  const count = currentImageCount();
  const addTile = document.createElement('div');
  if (count >= MAX_IMAGES) {
    addTile.className = 'add-tile';
    addTile.style.cursor = 'default';
    addTile.style.opacity = '0.5';
    addTile.innerHTML = `<i class="bi bi-check2-circle"></i><span class="lbl">15 / 15</span>`;
  } else {
    addTile.className = 'add-tile';
    addTile.id = 'addTile';
    addTile.onclick = () => $('imgInput').click();
    addTile.innerHTML = `<i class="bi bi-camera"></i><span class="lbl">Add</span>`;
  }
  gal.appendChild(addTile);

  const cnt = $('imgCount');
  if (count === 0) cnt.textContent = '';
  else if (count >= MAX_IMAGES) cnt.innerHTML = `<span class="cap">${count} / ${MAX_IMAGES} — remove one to add another.</span>`;
  else cnt.textContent = `${count} / ${MAX_IMAGES} images`;
}

window.toggleRemoveExisting = function(i) {
  const im = formImages.existing[i];
  if (!im) return;
  im.removed = !im.removed;
  renderGallery();
};

window.removeAdded = function(i) {
  const im = formImages.added[i];
  if (!im) return;
  formImages.added.splice(i, 1);
  renderGallery();
};

// Open lightbox over the current form gallery (kept existing + new added)
function openGalleryFromForm(bucket, idx) {
  const list = [];
  formImages.existing.forEach((im) => { if (!im.removed) list.push({ url: im.url, key: im.key }); });
  formImages.added.forEach((im) => { if (!im.failed && !im.uploading) list.push({ url: im.url, key: im.key }); });
  // Find the starting index in the unified list
  let start = 0;
  if (bucket === 'existing') {
    let n = 0;
    for (let i = 0; i <= idx; i++) if (!formImages.existing[i].removed) n++;
    start = Math.max(0, n - 1);
  } else {
    const existingKept = formImages.existing.filter(x => !x.removed).length;
    start = existingKept + idx;
  }
  openLightbox(list, start);
}

async function onImagesPicked(e) {
  const files = Array.from(e.target.files || []);
  e.target.value = ''; // allow re-picking same file
  if (!files.length) return;

  let count = currentImageCount();
  for (const file of files) {
    if (!file.type.startsWith('image/')) continue;
    if (count >= MAX_IMAGES) {
      toast(`Maximum ${MAX_IMAGES} images per challan.`, 'error');
      break;
    }
    count++;

    // Push a placeholder tile immediately
    const tempId = ++formImageTempSeq;
    const localUrl = URL.createObjectURL(file);
    const slot = { tempId, key: null, url: localUrl, uploading: true, failed: false };
    formImages.added.push(slot);
    renderGallery();

    // Upload in the background (don't await — let the user keep picking)
    uploadOne(file, slot);
  }
}

async function uploadOne(file, slot) {
  try {
    const ext = (file.name.split('.').pop() || 'jpg').replace(/[^a-z0-9]/gi, '').toLowerCase();
    const sign = await api('POST', '/return-challan/api/image/sign', { content_type: file.type, ext });
    const putRes = await fetch(sign.url, { method: 'PUT', body: file, headers: { 'Content-Type': file.type } });
    if (!putRes.ok) throw new Error('Upload failed (HTTP ' + putRes.status + ')');
    slot.key = sign.key;
    slot.uploading = false;
  } catch (err) {
    slot.uploading = false;
    slot.failed = true;
    toast('Upload failed: ' + (err.message || 'unknown'), 'error');
  } finally {
    renderGallery();
  }
}

// ─── Custom fields in form ───────────────────────────
function populateCustomFieldsForm(values) {
  const grid = $('cfGrid');
  if (!fields.length) {
    grid.innerHTML = '<div class="rc-cf-empty">No custom fields yet. <a href="#" onclick="event.preventDefault();openFields();">Add one →</a></div>';
    return;
  }
  grid.innerHTML = '';
  for (const f of fields) {
    const v = values[f.field_key];
    const id = 'cf_' + f.field_key;
    const wrap = document.createElement('div');
    wrap.className = 'rc-field';
    let inner = `<label for="${id}">${esc(f.label)}</label>`;
    if (f.field_type === 'select' && f.options && f.options.length) {
      inner += `<select id="${id}" data-cf="${esc(f.field_key)}" data-type="select"><option value=""></option>`;
      for (const opt of f.options) inner += `<option ${v === opt ? 'selected' : ''}>${esc(opt)}</option>`;
      inner += `</select>`;
    } else if (f.field_type === 'number') {
      inner += `<input type="number" id="${id}" data-cf="${esc(f.field_key)}" data-type="number" step="0.01" value="${v != null ? esc(v) : ''}"/>`;
    } else if (f.field_type === 'date') {
      inner += `<input type="date" id="${id}" data-cf="${esc(f.field_key)}" data-type="date" value="${v ? esc(String(v).slice(0,10)) : ''}"/>`;
    } else if (f.field_type === 'boolean') {
      inner = `<label for="${id}">${esc(f.label)}</label>
               <div class="check-row">
                 <input type="checkbox" id="${id}" data-cf="${esc(f.field_key)}" data-type="boolean" ${v ? 'checked' : ''}/>
                 <label for="${id}">Yes</label>
               </div>`;
    } else {
      inner += `<input type="text" id="${id}" data-cf="${esc(f.field_key)}" data-type="text" value="${v != null ? esc(v) : ''}"/>`;
    }
    wrap.innerHTML = inner;
    grid.appendChild(wrap);
  }
}

function collectCustomFields() {
  const out = {};
  document.querySelectorAll('#cfGrid [data-cf]').forEach((el) => {
    const k = el.dataset.cf;
    const t = el.dataset.type;
    if (t === 'boolean') out[k] = !!el.checked;
    else if (el.value === '' || el.value == null) out[k] = null;
    else out[k] = el.value;
  });
  return out;
}

// ─── Submit ──────────────────────────────────────────
$('entryForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const id = $('fId').value;

  // Refuse to submit while uploads are still in flight.
  if (formImages.added.some(x => x.uploading)) {
    toast('Wait for image uploads to finish.', 'error');
    return;
  }
  // Drop failed uploads from the payload.
  const newKeys = formImages.added.filter(x => !x.failed && x.key).map(x => x.key);

  const body = {
    description: $('fDesc').value,
    qty: $('fQty').value,
    category: $('fCategory').value,
    brand_name: $('fBrand').value,
    is_branded: $('fIsBranded').checked,
    price: $('fPrice').value,
    name: $('fName').value,
    challan_date: $('fChallanDate').value,
    punching_no: $('fPunching').value,
    department: $('fDept').value,
    custom_data: collectCustomFields(),
  };

  if (id) {
    // EDIT: send images_to_add (keys) and images_to_remove (server ids).
    // Legacy single-image entries: removing them clears image_s3_key.
    const toRemoveIds = formImages.existing
      .filter(x => x.removed && x.id != null)
      .map(x => x.id);
    const hasLegacyRemoval = formImages.existing.some(x => x.removed && x.id == null);
    body.images_to_add = newKeys;
    body.images_to_remove = toRemoveIds;
    if (hasLegacyRemoval) body.image_s3_key = null; // clear legacy column
  } else {
    // CREATE: pass the new keys as the initial array.
    body.image_s3_keys = newKeys;
  }

  const btn = $('saveBtn');
  btn.disabled = true; btn.textContent = id ? 'Saving…' : 'Creating…';
  try {
    if (id) {
      await api('PATCH', '/return-challan/api/entries/' + encodeURIComponent(id), body);
      toast('Updated ✓', 'success');
    } else {
      const res = await api('POST', '/return-challan/api/entries', body);
      toast('Created ' + res.challan_no + ' ✓', 'success');
    }
    closeForm();
    currentPage = 1;
    await loadEntries();
  } catch (err) {
    toast('Save failed: ' + err.message, 'error');
  } finally {
    btn.disabled = false; btn.textContent = 'Save entry';
  }
});

// ─── Load entries + render table ─────────────────────
async function loadEntries() {
  const body = $('rcBody');
  body.innerHTML = '<tr><td colspan="14" class="rc-empty">Loading…</td></tr>';
  try {
    const url = '/return-challan/api/entries?page=' + currentPage + '&search=' + encodeURIComponent(searchQuery);
    const r = await fetch(url, { credentials: 'include', headers: { Accept: 'application/json' } });
    const data = await r.json();
    if (!data.ok) {
      const msg = data.warning || data.error || 'Failed to load.';
      body.innerHTML = `<tr><td colspan="14" class="rc-empty"><span class="icon"><i class="bi bi-exclamation-triangle"></i></span>${esc(msg)}</td></tr>`;
      return;
    }
    entries = data.items;
    totalCount = data.total;
    totalPages = data.total_pages;
    renderTable();
    updatePagination();
    populateDatalists();
  } catch (err) {
    body.innerHTML = `<tr><td colspan="14" class="rc-empty">${esc(err.message)}</td></tr>`;
  }
}

function renderTable() {
  const head = $('rcHeadRow');
  const headCols = [
    'Challan',
    '<i class="bi bi-image"></i>',
    'Date',
    'Name',
    'Description',
    'Category',
    'Brand',
    'Branded',
    'Qty',
    'Price',
    'Punching',
    'Department',
    ...fields.map(f => esc(f.label)),
    'Created',
    '',
  ];
  head.innerHTML = headCols.map(h => `<th>${h}</th>`).join('');

  const body = $('rcBody');
  if (!entries.length) {
    body.innerHTML = `<tr><td colspan="${headCols.length}" class="rc-empty"><span class="icon"><i class="bi bi-inbox"></i></span>No challans yet. Click <strong>New entry</strong> to add the first one.</td></tr>`;
    return;
  }
  body.innerHTML = '';
  entries.forEach((e) => {
    const tr = document.createElement('tr');
    // Multi-image table cell: first image + "+N" badge for the rest.
    const imgs = Array.isArray(e.images) ? e.images : [];
    const firstUrl = imgs[0]?.url || e.thumbnail_url || null;
    const total = imgs.length || (e.thumbnail_url ? 1 : 0);
    const thumb = firstUrl
      ? `<div class="rc-thumb-wrap">
           <img src="${esc(firstUrl)}" class="thumb" alt="thumb"
                onclick="openGalleryForEntry(${e.id}, 0)" />
           ${total > 1 ? `<span class="rc-thumb-badge">+${total - 1}</span>` : ''}
         </div>`
      : `<span class="thumb-empty"><i class="bi bi-image"></i></span>`;
    const branded = e.is_branded
      ? `<span class="rc-pill branded">Branded</span>`
      : `<span class="rc-pill unbranded">Unbranded</span>`;
    const editBtn = e.editable
      ? `<button class="rc-mini-btn" onclick='editEntry(${e.id})'>Edit</button>`
      : `<button class="rc-mini-btn" disabled title="Edit window passed (24h)">Edit</button>`;
    const customCells = fields.map((f) => {
      const v = (e.custom_data || {})[f.field_key];
      if (v == null || v === '') return '<td>—</td>';
      if (f.field_type === 'boolean') return `<td>${v ? 'Yes' : 'No'}</td>`;
      if (f.field_type === 'date') return `<td>${esc(fmtDate(v))}</td>`;
      return `<td>${esc(v)}</td>`;
    }).join('');
    tr.innerHTML = `
      <td class="challan">${esc(e.challan_no)}</td>
      <td>${thumb}</td>
      <td>${esc(fmtDate(e.challan_date))}</td>
      <td>${esc(e.name || '—')}</td>
      <td class="desc">${esc(e.description || '—')}</td>
      <td>${esc(e.category || '—')}</td>
      <td>${esc(e.brand_name || '—')}</td>
      <td>${branded}</td>
      <td>${fmtNum(e.qty)}</td>
      <td>${fmtMoney(e.price)}</td>
      <td>${esc(e.punching_no || '—')}</td>
      <td>${esc(e.department || '—')}</td>
      ${customCells}
      <td><div style="white-space:nowrap;">${esc(fmtDateTime(e.created_at))}<br><span style="color:var(--text-3);font-size:0.7rem;">${esc(e.created_by_username || '')}</span></div></td>
      <td><div class="rc-actions-cell">${editBtn}</div></td>
    `;
    body.appendChild(tr);
  });
}

function updatePagination() {
  const start = (currentPage - 1) * 100 + 1;
  const end = Math.min(currentPage * 100, totalCount);
  $('pageInfo').textContent = totalCount === 0
    ? '0 entries'
    : `${start.toLocaleString()}–${end.toLocaleString()} of ${totalCount.toLocaleString()}`;
  $('pageLbl').textContent = `page ${currentPage} of ${totalPages}`;
  $('countTotal').textContent = totalCount === 1 ? '1 entry' : `${totalCount.toLocaleString()} entries`;
  $('prevBtn').disabled = currentPage <= 1;
  $('nextBtn').disabled = currentPage >= totalPages;

  // Update export URL to include search query
  // Export URL is now built by the popover at click time.
}

function goPage(delta) {
  const next = currentPage + delta;
  if (next < 1 || next > totalPages) return;
  currentPage = next;
  loadEntries();
}

async function editEntry(id) {
  const e = entries.find(x => x.id === id);
  if (!e) return;
  openForm(e);
}

// Populate datalists (department, category, brand) from existing entries
function populateDatalists() {
  const deps = new Set(), cats = new Set(), brands = new Set();
  for (const e of entries) {
    if (e.department) deps.add(e.department);
    if (e.category) cats.add(e.category);
    if (e.brand_name) brands.add(e.brand_name);
  }
  $('rcDeptList').innerHTML = [...deps].map(v => `<option value="${esc(v)}">`).join('');
  $('rcCatList').innerHTML = [...cats].map(v => `<option value="${esc(v)}">`).join('');
  $('rcBrandList').innerHTML = [...brands].map(v => `<option value="${esc(v)}">`).join('');
}

// ─── Search (debounced) ──────────────────────────────
$('search').addEventListener('input', (e) => {
  clearTimeout(searchT);
  const v = e.target.value;
  searchT = setTimeout(() => {
    searchQuery = v;
    currentPage = 1;
    loadEntries();
  }, 250);
});

// ─── Custom fields management modal ──────────────────
async function openFields() {
  $('fieldsModal').classList.add('show');
  await renderFieldDefs();
}
function closeFields() {
  $('fieldsModal').classList.remove('show');
}
async function renderFieldDefs() {
  const wrap = $('fieldsList');
  wrap.textContent = 'Loading…';
  try {
    const r = await fetch('/return-challan/api/fields/all', { credentials: 'include', headers: { Accept: 'application/json' } });
    const data = await r.json();
    if (!data.ok) { wrap.textContent = data.error || 'Failed.'; return; }
    allFieldDefs = data.fields;
    if (!allFieldDefs.length) {
      wrap.innerHTML = '<div style="color:var(--text-3);font-size:0.875rem;">No custom fields yet. Add the first one below.</div>';
      return;
    }
    wrap.innerHTML = allFieldDefs.map(f => `
      <div class="rc-fielddef-row ${f.is_active ? '' : 'is-inactive'}">
        <div>
          <div class="name">${esc(f.label)}</div>
          <div style="font-size:0.7rem;color:var(--text-3);">${esc(f.field_key)}</div>
        </div>
        <span class="type-pill">${esc(f.field_type)}</span>
        <button class="toggle" onclick='toggleField(${f.id}, ${f.is_active ? 0 : 1})'>
          ${f.is_active ? 'Hide' : 'Show'}
        </button>
      </div>
    `).join('');
  } catch (err) {
    wrap.textContent = err.message;
  }
}
async function toggleField(id, makeActive) {
  try {
    await api('PATCH', '/return-challan/api/fields/' + id, { is_active: !!makeActive });
    toast('Field updated', 'success');
    await loadActiveFields();
    await renderFieldDefs();
    populateCustomFieldsForm(collectCustomFields()); // keep current values
    renderTable();
  } catch (err) { toast(err.message, 'error'); }
}

// New-field form behaviour
$('newFieldType').addEventListener('change', (e) => {
  $('newFieldOptionsWrap').classList.toggle('show', e.target.value === 'select');
});
async function addNewField() {
  const label = $('newFieldLabel').value.trim();
  const fieldType = $('newFieldType').value;
  const optsRaw = $('newFieldOptions').value.trim();
  if (!label) { toast('Label required', 'error'); return; }
  const options = fieldType === 'select'
    ? optsRaw.split(',').map(s => s.trim()).filter(Boolean)
    : null;
  if (fieldType === 'select' && !options.length) { toast('Need at least one choice', 'error'); return; }
  try {
    await api('POST', '/return-challan/api/fields', { label, field_type: fieldType, options });
    $('newFieldLabel').value = ''; $('newFieldOptions').value = '';
    toast('Field added ✓', 'success');
    await loadActiveFields();
    await renderFieldDefs();
    populateCustomFieldsForm({});
    renderTable();
  } catch (err) { toast(err.message, 'error'); }
}

// ─── Image lightbox ──────────────────────────────────
// ─── Lightbox (with prev/next + dots) ───────────────
function openLightbox(images, startIdx) {
  if (!images || !images.length) return;
  lightbox.images = images;
  lightbox.index = Math.max(0, Math.min(startIdx || 0, images.length - 1));
  paintLightbox();
  $('lightbox').classList.add('show');
}
function paintLightbox() {
  const cur = lightbox.images[lightbox.index];
  if (!cur) return;
  $('lightImg').src = cur.url || '';
  $('lightCounter').textContent = (lightbox.index + 1) + ' / ' + lightbox.images.length;
  $('lightPrev').disabled = lightbox.index === 0;
  $('lightNext').disabled = lightbox.index === lightbox.images.length - 1;
  const single = lightbox.images.length <= 1;
  $('lightPrev').style.display = single ? 'none' : '';
  $('lightNext').style.display = single ? 'none' : '';
  $('lightCounter').style.display = single ? 'none' : '';
  const dots = $('lightDots');
  if (single) { dots.innerHTML = ''; return; }
  dots.innerHTML = lightbox.images
    .map((_, i) => `<button class="dot ${i === lightbox.index ? 'active' : ''}" onclick="event.stopPropagation();gotoLightbox(${i})"></button>`)
    .join('');
}
window.lightboxNav = function(delta) {
  const next = lightbox.index + delta;
  if (next < 0 || next >= lightbox.images.length) return;
  lightbox.index = next;
  paintLightbox();
};
window.gotoLightbox = function(i) {
  if (i < 0 || i >= lightbox.images.length) return;
  lightbox.index = i;
  paintLightbox();
};
function closeLightbox() { $('lightbox').classList.remove('show'); }

// Open from a table row id
window.openGalleryForEntry = function(entryId, startIdx) {
  const e = entries.find(x => x.id === entryId);
  if (!e) return;
  const imgs = (e.images && e.images.length) ? e.images :
               (e.thumbnail_url ? [{ url: e.thumbnail_url, key: e.image_s3_key }] : []);
  openLightbox(imgs, startIdx || 0);
};

// ─── Export popover ────────────────────────────────
function toggleExportPopover() {
  const p = $('exportPopover');
  if (p.classList.contains('show')) { closeExportPopover(); return; }
  // Default: include current search if there is one
  $('expIncludeSearch').checked = !!searchQuery;
  p.classList.add('show');
}
function closeExportPopover() {
  $('exportPopover').classList.remove('show');
}
function doExport() {
  const from = $('expFrom').value;
  const to   = $('expTo').value;
  const dateField = $('expDateField').value || 'challan_date';
  const includeSearch = $('expIncludeSearch').checked;
  const params = new URLSearchParams();
  if (from) params.set('from', from);
  if (to)   params.set('to', to);
  params.set('date_field', dateField);
  if (includeSearch && searchQuery) params.set('search', searchQuery);
  const qs = params.toString();
  closeExportPopover();
  window.location = '/return-challan/export.xlsx' + (qs ? ('?' + qs) : '');
}
// Click outside the popover to close
document.addEventListener('click', (e) => {
  const pop = $('exportPopover');
  if (!pop.classList.contains('show')) return;
  if (pop.contains(e.target) || $('exportBtn').contains(e.target)) return;
  closeExportPopover();
});

// ─── Loaders ─────────────────────────────────────────
async function loadActiveFields() {
  try {
    const r = await fetch('/return-challan/api/fields', { credentials: 'include', headers: { Accept: 'application/json' } });
    const data = await r.json();
    if (data.ok) fields = data.fields;
    else fields = [];
  } catch (_) { fields = []; }
}

// ─── Init ────────────────────────────────────────────
document.addEventListener('keydown', (e) => {
  // Lightbox: arrows + escape
  if ($('lightbox').classList.contains('show')) {
    if (e.key === 'Escape') closeLightbox();
    else if (e.key === 'ArrowLeft')  lightboxNav(-1);
    else if (e.key === 'ArrowRight') lightboxNav(1);
    return;
  }
  if (e.key === 'Escape') {
    if ($('fieldsModal').classList.contains('show')) closeFields();
    else if ($('exportPopover').classList.contains('show')) closeExportPopover();
  }
});

(async () => {
  await loadActiveFields();
  await loadEntries();
})();
</script>

