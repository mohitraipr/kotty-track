<%- include('partials/header', { pageTitle: 'Return Challans' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/return-challan' }) %>

<style>
  /* ─────────────────────────────────────────────────────────────
     Return Challan dashboard — professional admin console look.
     Indigo accent, Inter, cool-gray bg. Scoped under .rc so global
     theme styles don't leak in.
     ───────────────────────────────────────────────────────────── */
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

  body { background: #f5f7fb; }
  .rc {
    --bg:        #f5f7fb;
    --card:      #ffffff;
    --border:    #e5e8ee;
    --border-2:  #eef0f4;
    --text:      #0f172a;
    --text-2:    #475569;
    --text-3:    #94a3b8;
    --primary:   #4f46e5;
    --primary-h: #4338ca;
    --primary-s: #eef2ff;
    --success:   #16a34a;
    --success-s: #dcfce7;
    --warning:   #d97706;
    --warning-s: #fef3c7;
    --danger:    #dc2626;
    --danger-s:  #fee2e2;
    --shadow:    0 1px 3px rgba(15,23,42,0.05);
    --shadow-l:  0 10px 24px rgba(15,23,42,0.08);
    --shadow-xl: 0 24px 48px rgba(15,23,42,0.18);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    color: var(--text);
    -webkit-font-smoothing: antialiased;
  }
  .rc-page {
    max-width: 1400px;
    margin: 0 auto;
    padding: calc(var(--navbar-height, 60px) + 1.5rem) 1rem 4rem;
  }
  .rc-head {
    display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .rc-head h1 { font-size: 1.75rem; font-weight: 700; letter-spacing: -0.02em; margin: 0; }
  .rc-head .who { color: var(--text-2); font-size: 0.875rem; }

  .rc-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .rc-btn {
    border: 1px solid var(--border); background: var(--card); color: var(--text);
    padding: 0.5rem 0.875rem; border-radius: 10px;
    font-family: inherit; font-weight: 600; font-size: 0.875rem;
    cursor: pointer; transition: all 0.15s;
    display: inline-flex; align-items: center; gap: 0.375rem;
  }
  .rc-btn:hover { background: var(--bg); border-color: #cbd5e1; }
  .rc-btn.primary { background: var(--primary); color: #fff; border-color: var(--primary); box-shadow: 0 1px 2px rgba(79,70,229,0.25); }
  .rc-btn.primary:hover { background: var(--primary-h); }
  .rc-btn.success { background: var(--success); color: #fff; border-color: var(--success); }
  .rc-btn.success:hover { background: #15803d; }
  .rc-btn.ghost { background: transparent; }
  .rc-btn:disabled { opacity: 0.55; cursor: not-allowed; }

  /* Form panel */
  .rc-form-card {
    background: var(--card); border: 1px solid var(--border); border-radius: 16px;
    box-shadow: var(--shadow); margin-bottom: 1rem;
    overflow: hidden;
    display: none;
  }
  .rc-form-card.show { display: block; animation: slideIn 0.2s ease-out; }
  @keyframes slideIn { from { opacity: 0; transform: translateY(-6px); } to { opacity: 1; transform: translateY(0); } }
  .rc-form-head {
    padding: 0.875rem 1.125rem;
    border-bottom: 1px solid var(--border-2);
    display: flex; align-items: center; justify-content: space-between;
    background: linear-gradient(180deg, #fafbfd 0%, #ffffff 100%);
  }
  .rc-form-head h2 { font-size: 1rem; font-weight: 700; margin: 0; letter-spacing: -0.01em; }
  .rc-form-head .editing-pill {
    font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;
    background: var(--warning-s); color: var(--warning);
    padding: 0.2rem 0.5rem; border-radius: 9999px; margin-left: 0.5rem; display: none;
  }
  .rc-form-head .editing-pill.show { display: inline-block; }
  .rc-form-body { padding: 1rem 1.125rem 1.125rem; }

  .rc-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 0.875rem; }
  .rc-field { display: flex; flex-direction: column; gap: 0.25rem; }
  .rc-field label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-2); }
  .rc-field input[type="text"], .rc-field input[type="number"], .rc-field input[type="date"], .rc-field select, .rc-field textarea {
    border: 1px solid var(--border); border-radius: 10px;
    padding: 0.5rem 0.75rem;
    font-family: inherit; font-size: 0.9rem; color: var(--text);
    background: var(--card);
    transition: all 0.12s;
  }
  .rc-field input:focus, .rc-field select:focus, .rc-field textarea:focus {
    outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px var(--primary-s);
  }
  .rc-field textarea { resize: vertical; min-height: 4.5rem; }
  .rc-field .check-row { display: flex; align-items: center; gap: 0.5rem; padding-top: 0.5rem; }
  .rc-field .check-row label { font-size: 0.875rem; text-transform: none; letter-spacing: normal; font-weight: 500; color: var(--text); cursor: pointer; }

  .rc-field-full { grid-column: 1 / -1; }

  /* Image picker */
  .rc-image-zone {
    border: 2px dashed var(--border); border-radius: 12px;
    padding: 0.875rem; min-height: 9rem;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 0.5rem; text-align: center; cursor: pointer;
    transition: all 0.12s;
    background: #fafbfd;
  }
  .rc-image-zone:hover { border-color: var(--primary); background: var(--primary-s); }
  .rc-image-zone.has-image { padding: 0; border-style: solid; }
  .rc-image-zone .hint { color: var(--text-2); font-size: 0.875rem; }
  .rc-image-zone .icon { font-size: 1.75rem; color: var(--text-3); }
  .rc-image-zone img { max-width: 100%; max-height: 14rem; border-radius: 10px; }
  .rc-image-status {
    font-size: 0.75rem; color: var(--text-2); margin-top: 0.375rem;
  }
  .rc-image-status.uploading { color: var(--primary); }
  .rc-image-status.error { color: var(--danger); }
  .rc-image-status.done { color: var(--success); }

  .rc-form-footer {
    display: flex; gap: 0.5rem; justify-content: flex-end; flex-wrap: wrap;
    padding-top: 0.875rem; margin-top: 0.875rem;
    border-top: 1px solid var(--border-2);
  }

  /* Custom-fields section in form */
  .rc-cf-section { margin-top: 1rem; padding-top: 1rem; border-top: 1px dashed var(--border-2); }
  .rc-cf-section .cf-h {
    font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;
    color: var(--text-3); margin-bottom: 0.5rem;
  }
  .rc-cf-empty { color: var(--text-3); font-size: 0.875rem; }

  /* Listing table */
  .rc-table-card { background: var(--card); border: 1px solid var(--border); border-radius: 16px; box-shadow: var(--shadow); overflow: hidden; }
  .rc-toolbar {
    padding: 0.75rem 1rem;
    display: flex; align-items: center; gap: 0.625rem; flex-wrap: wrap;
    border-bottom: 1px solid var(--border-2);
    background: #fafbfd;
  }
  .rc-toolbar input[type="search"] {
    flex: 1 1 240px; min-width: 0;
    border: 1px solid var(--border); border-radius: 10px;
    padding: 0.5rem 0.75rem; font-family: inherit; font-size: 0.875rem;
  }
  .rc-toolbar input[type="search"]:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px var(--primary-s); }
  .rc-toolbar .count {
    font-size: 0.8rem; color: var(--text-2);
  }

  .rc-table-wrap { overflow-x: auto; }
  table.rc-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; min-width: 1100px; }
  .rc-table th, .rc-table td { padding: 0.625rem 0.75rem; border-top: 1px solid var(--border-2); text-align: left; vertical-align: top; }
  .rc-table th {
    background: #f8fafc; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.04em;
    color: var(--text-2); font-weight: 700; border-top: none; white-space: nowrap;
    position: sticky; top: 0; z-index: 1;
  }
  .rc-table tr:hover td { background: #fafbfd; }
  .rc-table td.challan { font-weight: 700; color: var(--text); letter-spacing: 0.02em; white-space: nowrap; }
  .rc-table td.desc { max-width: 280px; }
  .rc-table .thumb {
    width: 44px; height: 44px; border-radius: 8px; object-fit: cover;
    cursor: zoom-in; background: #f1f5f9;
    transition: transform 0.12s;
  }
  .rc-table .thumb:hover { transform: scale(1.05); }
  .rc-table .thumb-empty {
    width: 44px; height: 44px; border-radius: 8px; background: #f1f5f9;
    display: flex; align-items: center; justify-content: center;
    color: var(--text-3); font-size: 0.875rem;
  }
  .rc-pill {
    display: inline-flex; align-items: center; gap: 0.25rem;
    padding: 0.15rem 0.5rem; border-radius: 9999px;
    font-size: 0.7rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.04em;
  }
  .rc-pill.branded   { background: var(--success-s); color: var(--success); }
  .rc-pill.unbranded { background: #f1f5f9; color: var(--text-2); }

  .rc-actions-cell { display: flex; gap: 0.25rem; }
  .rc-mini-btn {
    padding: 0.25rem 0.5rem; border: 1px solid var(--border); border-radius: 6px;
    background: var(--card); cursor: pointer; font-family: inherit; font-size: 0.75rem; font-weight: 600;
    color: var(--text-2);
  }
  .rc-mini-btn:hover { background: var(--primary-s); color: var(--primary); border-color: var(--primary); }
  .rc-mini-btn:disabled { opacity: 0.4; cursor: not-allowed; }

  .rc-empty { padding: 3rem 1rem; text-align: center; color: var(--text-2); font-size: 0.9rem; }
  .rc-empty .icon { font-size: 2.5rem; color: var(--text-3); margin-bottom: 0.5rem; display: block; }

  .rc-pagination {
    display: flex; align-items: center; justify-content: space-between; gap: 0.625rem;
    padding: 0.75rem 1rem; border-top: 1px solid var(--border-2); flex-wrap: wrap; background: #fafbfd;
  }
  .rc-pagination .info { font-size: 0.8125rem; color: var(--text-2); }
  .rc-pagination .controls { display: flex; align-items: center; gap: 0.375rem; }
  .rc-pagination button {
    border: 1px solid var(--border); background: var(--card); color: var(--text);
    padding: 0.375rem 0.75rem; border-radius: 8px; cursor: pointer;
    font-family: inherit; font-weight: 600; font-size: 0.8125rem;
  }
  .rc-pagination button:disabled { opacity: 0.4; cursor: not-allowed; }
  .rc-pagination button:hover:not(:disabled) { background: var(--primary-s); color: var(--primary); border-color: var(--primary); }

  /* Toasts */
  .rc-toasts { position: fixed; bottom: 1rem; right: 1rem; display: flex; flex-direction: column; gap: 0.5rem; z-index: 3000; }
  .rc-toast {
    padding: 0.75rem 1rem; background: var(--text); color: #fff; border-radius: 10px;
    font-size: 0.875rem; box-shadow: var(--shadow-l);
    animation: rcUp 0.25s ease-out;
    max-width: 360px;
  }
  .rc-toast.success { background: var(--success); }
  .rc-toast.error { background: var(--danger); }
  @keyframes rcUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

  /* Modal (manage custom fields + image lightbox) */
  .rc-modal { position: fixed; inset: 0; background: rgba(15,23,42,0.55); backdrop-filter: blur(4px); z-index: 2500; display: none; align-items: flex-start; justify-content: center; padding: 3rem 1rem; }
  .rc-modal.show { display: flex; }
  .rc-modal-card { background: var(--card); border-radius: 16px; max-width: 700px; width: 100%; max-height: 86vh; display: flex; flex-direction: column; box-shadow: var(--shadow-xl); overflow: hidden; }
  .rc-modal-head { padding: 1rem 1.25rem; border-bottom: 1px solid var(--border-2); display: flex; align-items: center; justify-content: space-between; }
  .rc-modal-head h3 { margin: 0; font-size: 1.05rem; font-weight: 700; }
  .rc-modal-close { background: transparent; border: none; font-size: 1.5rem; line-height: 1; cursor: pointer; color: var(--text-2); }
  .rc-modal-body { padding: 1rem 1.25rem; overflow-y: auto; }

  .rc-fielddef-row {
    display: grid; grid-template-columns: 1fr auto auto auto; gap: 0.5rem; align-items: center;
    padding: 0.5rem 0; border-top: 1px solid var(--border-2);
  }
  .rc-fielddef-row:first-child { border-top: none; }
  .rc-fielddef-row .name { font-weight: 600; }
  .rc-fielddef-row .type-pill {
    font-size: 0.7rem; padding: 0.15rem 0.5rem; border-radius: 9999px; background: var(--primary-s); color: var(--primary); font-weight: 700;
  }
  .rc-fielddef-row .toggle {
    font-size: 0.75rem; padding: 0.25rem 0.625rem; border-radius: 6px; cursor: pointer; border: 1px solid var(--border);
    background: var(--card); color: var(--text-2); font-weight: 600;
  }
  .rc-fielddef-row.is-inactive .name { color: var(--text-3); text-decoration: line-through; }

  .rc-add-field-form { margin-top: 1rem; padding-top: 1rem; border-top: 1px dashed var(--border-2); }
  .rc-add-field-form .row { display: grid; grid-template-columns: 1fr 160px; gap: 0.5rem; }
  .rc-add-field-form input, .rc-add-field-form select {
    width: 100%; box-sizing: border-box;
    border: 1px solid var(--border); border-radius: 10px; padding: 0.5rem 0.75rem; font-family: inherit; font-size: 0.9rem;
  }
  .rc-add-field-form .options { margin-top: 0.5rem; display: none; }
  .rc-add-field-form .options.show { display: block; }

  /* Image lightbox */
  .rc-light { position: fixed; inset: 0; background: rgba(0,0,0,0.85); display: none; align-items: center; justify-content: center; z-index: 4000; cursor: zoom-out; padding: 1rem; }
  .rc-light.show { display: flex; }
  .rc-light img { max-width: 95%; max-height: 95%; border-radius: 8px; }

  @media (max-width: 640px) {
    .rc-grid { grid-template-columns: 1fr; }
    .rc-pagination { flex-direction: column; align-items: flex-start; }
  }
</style>

<main class="rc rc-page">
  <header class="rc-head">
    <div>
      <h1>Return Challans</h1>
      <div class="who">Signed in as <strong><%= user.username %></strong></div>
    </div>
    <div class="rc-actions">
      <button class="rc-btn" onclick="openFields()"><i class="bi bi-sliders"></i> Manage custom fields</button>
      <a class="rc-btn" id="exportBtn" href="/return-challan/export.xlsx"><i class="bi bi-file-earmark-excel"></i> Excel</a>
      <button class="rc-btn primary" onclick="openForm()"><i class="bi bi-plus-lg"></i> New entry</button>
    </div>
  </header>

  <!-- ─── Form panel ──────────────────────────────────── -->
  <section class="rc-form-card" id="formCard">
    <div class="rc-form-head">
      <div>
        <h2 id="formTitle">New return challan</h2>
        <span class="editing-pill" id="editingPill">EDITING</span>
      </div>
      <button class="rc-btn ghost" onclick="closeForm()" title="Close">✕</button>
    </div>
    <div class="rc-form-body">
      <form id="entryForm" autocomplete="off">
        <input type="hidden" name="id" id="fId" />
        <input type="hidden" name="image_s3_key" id="fImageKey" />

        <div class="rc-grid">
          <div class="rc-field">
            <label for="fChallanNo">Challan no</label>
            <input type="text" id="fChallanNo" disabled placeholder="Auto-generated on save" />
          </div>
          <div class="rc-field">
            <label for="fChallanDate">Date</label>
            <input type="date" id="fChallanDate" name="challan_date" />
          </div>
          <div class="rc-field">
            <label for="fName">Name</label>
            <input type="text" id="fName" name="name" placeholder="Person / vendor" />
          </div>
          <div class="rc-field">
            <label for="fPunching">Punching no</label>
            <input type="text" id="fPunching" name="punching_no" />
          </div>
          <div class="rc-field">
            <label for="fDept">Department</label>
            <input type="text" id="fDept" name="department" list="rcDeptList" />
            <datalist id="rcDeptList"></datalist>
          </div>
          <div class="rc-field">
            <label for="fCategory">Category</label>
            <input type="text" id="fCategory" name="category" list="rcCatList" />
            <datalist id="rcCatList"></datalist>
          </div>
          <div class="rc-field">
            <label for="fBrand">Brand</label>
            <input type="text" id="fBrand" name="brand_name" list="rcBrandList" />
            <datalist id="rcBrandList"></datalist>
          </div>
          <div class="rc-field">
            <label>&nbsp;</label>
            <div class="check-row">
              <input type="checkbox" id="fIsBranded" name="is_branded" />
              <label for="fIsBranded">This is a branded item</label>
            </div>
          </div>
          <div class="rc-field">
            <label for="fQty">Qty</label>
            <input type="number" id="fQty" name="qty" min="0" step="0.01" value="0" />
          </div>
          <div class="rc-field">
            <label for="fPrice">Price (₹)</label>
            <input type="number" id="fPrice" name="price" min="0" step="0.01" value="0" />
          </div>
          <div class="rc-field rc-field-full">
            <label for="fDesc">Description</label>
            <textarea id="fDesc" name="description" placeholder="Item description, condition notes..."></textarea>
          </div>
          <div class="rc-field rc-field-full">
            <label>Image</label>
            <div class="rc-image-zone" id="imgZone" onclick="document.getElementById('imgInput').click()">
              <div class="icon"><i class="bi bi-cloud-arrow-up"></i></div>
              <div class="hint">Tap to capture with camera or pick from gallery</div>
            </div>
            <input type="file" id="imgInput" accept="image/*" capture="environment" style="display:none;" onchange="onImagePicked(event)">
            <div class="rc-image-status" id="imgStatus"></div>
          </div>
        </div>

        <div class="rc-cf-section">
          <div class="cf-h">Custom fields</div>
          <div class="rc-grid" id="cfGrid">
            <div class="rc-cf-empty">No custom fields yet. <a href="#" onclick="event.preventDefault();openFields();">Add one →</a></div>
          </div>
        </div>

        <div class="rc-form-footer">
          <button type="button" class="rc-btn" onclick="closeForm()">Cancel</button>
          <button type="submit" class="rc-btn primary" id="saveBtn">Save entry</button>
        </div>
      </form>
    </div>
  </section>

  <!-- ─── Listing ─────────────────────────────────────── -->
  <section class="rc-table-card">
    <div class="rc-toolbar">
      <input type="search" id="search" placeholder="Search by challan no, name, category, brand, department…" />
      <span class="count" id="countTotal">—</span>
    </div>
    <div class="rc-table-wrap">
      <table class="rc-table" id="rcTable">
        <thead><tr id="rcHeadRow"></tr></thead>
        <tbody id="rcBody">
          <tr><td colspan="14" class="rc-empty">Loading…</td></tr>
        </tbody>
      </table>
    </div>
    <div class="rc-pagination">
      <div class="info" id="pageInfo">—</div>
      <div class="controls">
        <button id="prevBtn" onclick="goPage(-1)">Prev</button>
        <span class="info" id="pageLbl">page —</span>
        <button id="nextBtn" onclick="goPage(1)">Next</button>
      </div>
    </div>
  </section>
</main>

<!-- ─── Manage custom fields modal ─── -->
<div class="rc rc-modal" id="fieldsModal" onclick="if(event.target.id==='fieldsModal')closeFields()">
  <div class="rc-modal-card">
    <div class="rc-modal-head">
      <h3>Custom fields</h3>
      <button class="rc-modal-close" onclick="closeFields()">×</button>
    </div>
    <div class="rc-modal-body">
      <div id="fieldsList">Loading…</div>

      <div class="rc-add-field-form">
        <div style="font-size: 0.85rem; font-weight: 700; color: var(--text-2); margin-bottom: 0.5rem;">Add a new field</div>
        <div class="row">
          <input type="text" id="newFieldLabel" placeholder="Field label (e.g. Warranty Status)" maxlength="120" />
          <select id="newFieldType">
            <option value="text">Text</option>
            <option value="number">Number</option>
            <option value="date">Date</option>
            <option value="boolean">Yes / No</option>
            <option value="select">Choices</option>
          </select>
        </div>
        <div class="options" id="newFieldOptionsWrap">
          <input type="text" id="newFieldOptions" placeholder="Choices, separated by commas (e.g. Active, Expired)" />
        </div>
        <div style="display:flex; justify-content:flex-end; margin-top:0.625rem;">
          <button class="rc-btn primary" onclick="addNewField()">Add field</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ─── Image lightbox ─── -->
<div class="rc rc-light" id="lightbox" onclick="closeLightbox()"><img id="lightImg" /></div>

<div class="rc rc-toasts" id="toasts"></div>

<script>
'use strict';

// ─── State ───────────────────────────────────────────
let fields = [];          // active custom fields
let allFieldDefs = [];    // ALL field defs (for the modal)
let entries = [];
let currentPage = 1;
let totalPages = 1;
let totalCount = 0;
let searchQuery = '';
let searchT = null;

// ─── Helpers ─────────────────────────────────────────
const $ = (id) => document.getElementById(id);
const esc = (s) => String(s == null ? '' : s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":"&#39;"}[c]));
const fmtNum = (n) => Number(n || 0).toLocaleString('en-IN');
const fmtMoney = (n) => '₹ ' + Number(n || 0).toLocaleString('en-IN', { minimumFractionDigits: 0, maximumFractionDigits: 2 });
const fmtDate = (s) => {
  if (!s) return '—';
  const d = new Date(s);
  return Number.isNaN(d.getTime()) ? '—' : d.toLocaleDateString();
};
const fmtDateTime = (s) => {
  if (!s) return '—';
  const d = new Date(s);
  return Number.isNaN(d.getTime()) ? '—' : d.toLocaleString();
};

function toast(msg, kind) {
  const t = document.createElement('div');
  t.className = 'rc-toast ' + (kind || '');
  t.textContent = msg;
  $('toasts').appendChild(t);
  setTimeout(() => { t.style.opacity = '0'; t.style.transition = 'opacity 0.3s'; }, 3000);
  setTimeout(() => t.remove(), 3400);
}

async function api(method, url, body) {
  const opts = {
    method,
    credentials: 'include',
    headers: { 'Accept': 'application/json' },
  };
  if (body !== undefined) {
    opts.headers['Content-Type'] = 'application/json';
    opts.body = JSON.stringify(body);
  }
  const r = await fetch(url, opts);
  const data = await r.json().catch(() => ({}));
  if (!r.ok || !data.ok) throw new Error((data && data.error) || ('HTTP ' + r.status));
  return data;
}

// ─── Form open/close ─────────────────────────────────
function openForm(entry) {
  $('formCard').classList.add('show');
  $('imgInput').value = '';
  $('imgStatus').textContent = '';
  $('imgStatus').className = 'rc-image-status';
  resetImage();
  if (entry) {
    $('formTitle').textContent = 'Edit return challan';
    $('editingPill').classList.add('show');
    $('fId').value = entry.id;
    $('fChallanNo').value = entry.challan_no || '';
    $('fChallanDate').value = entry.challan_date ? new Date(entry.challan_date).toISOString().slice(0, 10) : '';
    $('fName').value = entry.name || '';
    $('fPunching').value = entry.punching_no || '';
    $('fDept').value = entry.department || '';
    $('fCategory').value = entry.category || '';
    $('fBrand').value = entry.brand_name || '';
    $('fIsBranded').checked = !!entry.is_branded;
    $('fQty').value = entry.qty != null ? entry.qty : 0;
    $('fPrice').value = entry.price != null ? entry.price : 0;
    $('fDesc').value = entry.description || '';
    $('fImageKey').value = entry.image_s3_key || '';
    if (entry.thumbnail_url) showImagePreview(entry.thumbnail_url);
    populateCustomFieldsForm(entry.custom_data || {});
  } else {
    $('formTitle').textContent = 'New return challan';
    $('editingPill').classList.remove('show');
    $('entryForm').reset();
    $('fId').value = '';
    $('fImageKey').value = '';
    $('fChallanNo').value = '';
    $('fChallanDate').value = new Date().toISOString().slice(0, 10);
    populateCustomFieldsForm({});
  }
  $('formCard').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function closeForm() {
  $('formCard').classList.remove('show');
}

// ─── Image upload ────────────────────────────────────
function resetImage() {
  $('imgZone').classList.remove('has-image');
  $('imgZone').innerHTML = `
    <div class="icon"><i class="bi bi-cloud-arrow-up"></i></div>
    <div class="hint">Tap to capture with camera or pick from gallery</div>
  `;
}
function showImagePreview(url) {
  $('imgZone').classList.add('has-image');
  $('imgZone').innerHTML = `<img src="${url}" alt="Captured image" />`;
}

async function onImagePicked(e) {
  const file = e.target.files && e.target.files[0];
  if (!file) return;
  if (!file.type.startsWith('image/')) {
    toast('Please choose an image file.', 'error');
    return;
  }
  // Preview locally
  const reader = new FileReader();
  reader.onload = (ev) => showImagePreview(ev.target.result);
  reader.readAsDataURL(file);

  // Sign + upload to S3
  const ext = (file.name.split('.').pop() || 'jpg').replace(/[^a-z0-9]/gi, '').toLowerCase();
  $('imgStatus').textContent = 'Uploading…';
  $('imgStatus').className = 'rc-image-status uploading';
  try {
    const sign = await api('POST', '/return-challan/api/image/sign', { content_type: file.type, ext });
    const putRes = await fetch(sign.url, { method: 'PUT', body: file, headers: { 'Content-Type': file.type } });
    if (!putRes.ok) throw new Error('Upload failed (HTTP ' + putRes.status + ')');
    $('fImageKey').value = sign.key;
    $('imgStatus').textContent = '✓ Image uploaded';
    $('imgStatus').className = 'rc-image-status done';
  } catch (err) {
    $('imgStatus').textContent = '✗ ' + (err.message || 'Upload failed');
    $('imgStatus').className = 'rc-image-status error';
    $('fImageKey').value = '';
  }
}

// ─── Custom fields in form ───────────────────────────
function populateCustomFieldsForm(values) {
  const grid = $('cfGrid');
  if (!fields.length) {
    grid.innerHTML = '<div class="rc-cf-empty">No custom fields yet. <a href="#" onclick="event.preventDefault();openFields();">Add one →</a></div>';
    return;
  }
  grid.innerHTML = '';
  for (const f of fields) {
    const v = values[f.field_key];
    const id = 'cf_' + f.field_key;
    const wrap = document.createElement('div');
    wrap.className = 'rc-field';
    let inner = `<label for="${id}">${esc(f.label)}</label>`;
    if (f.field_type === 'select' && f.options && f.options.length) {
      inner += `<select id="${id}" data-cf="${esc(f.field_key)}" data-type="select"><option value=""></option>`;
      for (const opt of f.options) inner += `<option ${v === opt ? 'selected' : ''}>${esc(opt)}</option>`;
      inner += `</select>`;
    } else if (f.field_type === 'number') {
      inner += `<input type="number" id="${id}" data-cf="${esc(f.field_key)}" data-type="number" step="0.01" value="${v != null ? esc(v) : ''}"/>`;
    } else if (f.field_type === 'date') {
      inner += `<input type="date" id="${id}" data-cf="${esc(f.field_key)}" data-type="date" value="${v ? esc(String(v).slice(0,10)) : ''}"/>`;
    } else if (f.field_type === 'boolean') {
      inner = `<label for="${id}">${esc(f.label)}</label>
               <div class="check-row">
                 <input type="checkbox" id="${id}" data-cf="${esc(f.field_key)}" data-type="boolean" ${v ? 'checked' : ''}/>
                 <label for="${id}">Yes</label>
               </div>`;
    } else {
      inner += `<input type="text" id="${id}" data-cf="${esc(f.field_key)}" data-type="text" value="${v != null ? esc(v) : ''}"/>`;
    }
    wrap.innerHTML = inner;
    grid.appendChild(wrap);
  }
}

function collectCustomFields() {
  const out = {};
  document.querySelectorAll('#cfGrid [data-cf]').forEach((el) => {
    const k = el.dataset.cf;
    const t = el.dataset.type;
    if (t === 'boolean') out[k] = !!el.checked;
    else if (el.value === '' || el.value == null) out[k] = null;
    else out[k] = el.value;
  });
  return out;
}

// ─── Submit ──────────────────────────────────────────
$('entryForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const id = $('fId').value;
  const body = {
    description: $('fDesc').value,
    qty: $('fQty').value,
    category: $('fCategory').value,
    brand_name: $('fBrand').value,
    is_branded: $('fIsBranded').checked,
    price: $('fPrice').value,
    image_s3_key: $('fImageKey').value || null,
    name: $('fName').value,
    challan_date: $('fChallanDate').value,
    punching_no: $('fPunching').value,
    department: $('fDept').value,
    custom_data: collectCustomFields(),
  };
  const btn = $('saveBtn');
  btn.disabled = true; btn.textContent = id ? 'Saving…' : 'Creating…';
  try {
    if (id) {
      await api('PATCH', '/return-challan/api/entries/' + encodeURIComponent(id), body);
      toast('Updated ✓', 'success');
    } else {
      const res = await api('POST', '/return-challan/api/entries', body);
      toast('Created ' + res.challan_no + ' ✓', 'success');
    }
    closeForm();
    currentPage = 1;
    await loadEntries();
  } catch (err) {
    toast('Save failed: ' + err.message, 'error');
  } finally {
    btn.disabled = false; btn.textContent = 'Save entry';
  }
});

// ─── Load entries + render table ─────────────────────
async function loadEntries() {
  const body = $('rcBody');
  body.innerHTML = '<tr><td colspan="14" class="rc-empty">Loading…</td></tr>';
  try {
    const url = '/return-challan/api/entries?page=' + currentPage + '&search=' + encodeURIComponent(searchQuery);
    const r = await fetch(url, { credentials: 'include', headers: { Accept: 'application/json' } });
    const data = await r.json();
    if (!data.ok) {
      const msg = data.warning || data.error || 'Failed to load.';
      body.innerHTML = `<tr><td colspan="14" class="rc-empty"><span class="icon"><i class="bi bi-exclamation-triangle"></i></span>${esc(msg)}</td></tr>`;
      return;
    }
    entries = data.items;
    totalCount = data.total;
    totalPages = data.total_pages;
    renderTable();
    updatePagination();
    populateDatalists();
  } catch (err) {
    body.innerHTML = `<tr><td colspan="14" class="rc-empty">${esc(err.message)}</td></tr>`;
  }
}

function renderTable() {
  const head = $('rcHeadRow');
  const headCols = [
    'Challan',
    '<i class="bi bi-image"></i>',
    'Date',
    'Name',
    'Description',
    'Category',
    'Brand',
    'Branded',
    'Qty',
    'Price',
    'Punching',
    'Department',
    ...fields.map(f => esc(f.label)),
    'Created',
    '',
  ];
  head.innerHTML = headCols.map(h => `<th>${h}</th>`).join('');

  const body = $('rcBody');
  if (!entries.length) {
    body.innerHTML = `<tr><td colspan="${headCols.length}" class="rc-empty"><span class="icon"><i class="bi bi-inbox"></i></span>No challans yet. Click <strong>New entry</strong> to add the first one.</td></tr>`;
    return;
  }
  body.innerHTML = '';
  entries.forEach((e) => {
    const tr = document.createElement('tr');
    const thumb = e.thumbnail_url
      ? `<img src="${esc(e.thumbnail_url)}" class="thumb" alt="thumb" onclick="zoomImage('${esc(e.thumbnail_url)}')" />`
      : `<span class="thumb-empty"><i class="bi bi-image"></i></span>`;
    const branded = e.is_branded
      ? `<span class="rc-pill branded">Branded</span>`
      : `<span class="rc-pill unbranded">Unbranded</span>`;
    const editBtn = e.editable
      ? `<button class="rc-mini-btn" onclick='editEntry(${e.id})'>Edit</button>`
      : `<button class="rc-mini-btn" disabled title="Edit window passed (24h)">Edit</button>`;
    const customCells = fields.map((f) => {
      const v = (e.custom_data || {})[f.field_key];
      if (v == null || v === '') return '<td>—</td>';
      if (f.field_type === 'boolean') return `<td>${v ? 'Yes' : 'No'}</td>`;
      if (f.field_type === 'date') return `<td>${esc(fmtDate(v))}</td>`;
      return `<td>${esc(v)}</td>`;
    }).join('');
    tr.innerHTML = `
      <td class="challan">${esc(e.challan_no)}</td>
      <td>${thumb}</td>
      <td>${esc(fmtDate(e.challan_date))}</td>
      <td>${esc(e.name || '—')}</td>
      <td class="desc">${esc(e.description || '—')}</td>
      <td>${esc(e.category || '—')}</td>
      <td>${esc(e.brand_name || '—')}</td>
      <td>${branded}</td>
      <td>${fmtNum(e.qty)}</td>
      <td>${fmtMoney(e.price)}</td>
      <td>${esc(e.punching_no || '—')}</td>
      <td>${esc(e.department || '—')}</td>
      ${customCells}
      <td><div style="white-space:nowrap;">${esc(fmtDateTime(e.created_at))}<br><span style="color:var(--text-3);font-size:0.7rem;">${esc(e.created_by_username || '')}</span></div></td>
      <td><div class="rc-actions-cell">${editBtn}</div></td>
    `;
    body.appendChild(tr);
  });
}

function updatePagination() {
  const start = (currentPage - 1) * 100 + 1;
  const end = Math.min(currentPage * 100, totalCount);
  $('pageInfo').textContent = totalCount === 0
    ? '0 entries'
    : `${start.toLocaleString()}–${end.toLocaleString()} of ${totalCount.toLocaleString()}`;
  $('pageLbl').textContent = `page ${currentPage} of ${totalPages}`;
  $('countTotal').textContent = totalCount === 1 ? '1 entry' : `${totalCount.toLocaleString()} entries`;
  $('prevBtn').disabled = currentPage <= 1;
  $('nextBtn').disabled = currentPage >= totalPages;

  // Update export URL to include search query
  $('exportBtn').href = '/return-challan/export.xlsx' + (searchQuery ? ('?search=' + encodeURIComponent(searchQuery)) : '');
}

function goPage(delta) {
  const next = currentPage + delta;
  if (next < 1 || next > totalPages) return;
  currentPage = next;
  loadEntries();
}

async function editEntry(id) {
  const e = entries.find(x => x.id === id);
  if (!e) return;
  openForm(e);
}

// Populate datalists (department, category, brand) from existing entries
function populateDatalists() {
  const deps = new Set(), cats = new Set(), brands = new Set();
  for (const e of entries) {
    if (e.department) deps.add(e.department);
    if (e.category) cats.add(e.category);
    if (e.brand_name) brands.add(e.brand_name);
  }
  $('rcDeptList').innerHTML = [...deps].map(v => `<option value="${esc(v)}">`).join('');
  $('rcCatList').innerHTML = [...cats].map(v => `<option value="${esc(v)}">`).join('');
  $('rcBrandList').innerHTML = [...brands].map(v => `<option value="${esc(v)}">`).join('');
}

// ─── Search (debounced) ──────────────────────────────
$('search').addEventListener('input', (e) => {
  clearTimeout(searchT);
  const v = e.target.value;
  searchT = setTimeout(() => {
    searchQuery = v;
    currentPage = 1;
    loadEntries();
  }, 250);
});

// ─── Custom fields management modal ──────────────────
async function openFields() {
  $('fieldsModal').classList.add('show');
  await renderFieldDefs();
}
function closeFields() {
  $('fieldsModal').classList.remove('show');
}
async function renderFieldDefs() {
  const wrap = $('fieldsList');
  wrap.textContent = 'Loading…';
  try {
    const r = await fetch('/return-challan/api/fields/all', { credentials: 'include', headers: { Accept: 'application/json' } });
    const data = await r.json();
    if (!data.ok) { wrap.textContent = data.error || 'Failed.'; return; }
    allFieldDefs = data.fields;
    if (!allFieldDefs.length) {
      wrap.innerHTML = '<div style="color:var(--text-3);font-size:0.875rem;">No custom fields yet. Add the first one below.</div>';
      return;
    }
    wrap.innerHTML = allFieldDefs.map(f => `
      <div class="rc-fielddef-row ${f.is_active ? '' : 'is-inactive'}">
        <div>
          <div class="name">${esc(f.label)}</div>
          <div style="font-size:0.7rem;color:var(--text-3);">${esc(f.field_key)}</div>
        </div>
        <span class="type-pill">${esc(f.field_type)}</span>
        <button class="toggle" onclick='toggleField(${f.id}, ${f.is_active ? 0 : 1})'>
          ${f.is_active ? 'Hide' : 'Show'}
        </button>
      </div>
    `).join('');
  } catch (err) {
    wrap.textContent = err.message;
  }
}
async function toggleField(id, makeActive) {
  try {
    await api('PATCH', '/return-challan/api/fields/' + id, { is_active: !!makeActive });
    toast('Field updated', 'success');
    await loadActiveFields();
    await renderFieldDefs();
    populateCustomFieldsForm(collectCustomFields()); // keep current values
    renderTable();
  } catch (err) { toast(err.message, 'error'); }
}

// New-field form behaviour
$('newFieldType').addEventListener('change', (e) => {
  $('newFieldOptionsWrap').classList.toggle('show', e.target.value === 'select');
});
async function addNewField() {
  const label = $('newFieldLabel').value.trim();
  const fieldType = $('newFieldType').value;
  const optsRaw = $('newFieldOptions').value.trim();
  if (!label) { toast('Label required', 'error'); return; }
  const options = fieldType === 'select'
    ? optsRaw.split(',').map(s => s.trim()).filter(Boolean)
    : null;
  if (fieldType === 'select' && !options.length) { toast('Need at least one choice', 'error'); return; }
  try {
    await api('POST', '/return-challan/api/fields', { label, field_type: fieldType, options });
    $('newFieldLabel').value = ''; $('newFieldOptions').value = '';
    toast('Field added ✓', 'success');
    await loadActiveFields();
    await renderFieldDefs();
    populateCustomFieldsForm({});
    renderTable();
  } catch (err) { toast(err.message, 'error'); }
}

// ─── Image lightbox ──────────────────────────────────
function zoomImage(url) {
  $('lightImg').src = url;
  $('lightbox').classList.add('show');
}
function closeLightbox() { $('lightbox').classList.remove('show'); }

// ─── Loaders ─────────────────────────────────────────
async function loadActiveFields() {
  try {
    const r = await fetch('/return-challan/api/fields', { credentials: 'include', headers: { Accept: 'application/json' } });
    const data = await r.json();
    if (data.ok) fields = data.fields;
    else fields = [];
  } catch (_) { fields = []; }
}

// ─── Init ────────────────────────────────────────────
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') {
    if ($('lightbox').classList.contains('show')) closeLightbox();
    else if ($('fieldsModal').classList.contains('show')) closeFields();
  }
});

(async () => {
  await loadActiveFields();
  await loadEntries();
})();
</script>

