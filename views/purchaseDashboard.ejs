<%- include('partials/header', { pageTitle: 'Purchase Dashboard' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/purchase' }) %>

<main class="main-content" style="margin-left: 0;">
  <div class="container-fluid" style="max-width: 1400px; margin: 0 auto;">

    <!-- Flash Messages -->
    <%- include('partials/flashMessages') %>

    <!-- Page Header -->
    <div class="page-header">
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
          <h1 class="page-title">
            <i class="bi bi-cart-fill me-3" style="color: var(--terracotta);"></i>Purchase Management
          </h1>
          <p class="page-subtitle">Manage suppliers, vendors, and manufacturing units</p>
        </div>
      </div>
    </div>

    <!-- Tab Navigation -->
    <div class="card mb-4">
      <div class="card-header" style="padding: 0; border-bottom: none;">
        <ul class="nav nav-tabs kotty-tabs" role="tablist" style="border-bottom: none; padding: 0 8px;">
          <li class="nav-item" role="presentation">
            <a class="nav-link active" href="/purchase">
              <i class="bi bi-cart-fill me-2"></i>Purchase
            </a>
          </li>
          <li class="nav-item" role="presentation">
            <a class="nav-link" href="/accounts-challan">
              <i class="bi bi-file-earmark-text me-2"></i>DC Challan
            </a>
          </li>
          <li class="nav-item" role="presentation">
            <a class="nav-link" href="/accounts-challan/list">
              <i class="bi bi-list-ul me-2"></i>Challan List
            </a>
          </li>
          <li class="nav-item" role="presentation">
            <a class="nav-link" href="/accounts-challan/gst">
              <i class="bi bi-receipt me-2"></i>GST Master
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Parties Section -->
    <div class="card mb-4">
      <div class="card-header">
        <div>
          <h4 class="card-title mb-1">
            <i class="bi bi-people-fill me-2" style="color: var(--terracotta);"></i>Parties Management
          </h4>
          <small class="text-secondary">Manage suppliers and vendors</small>
        </div>
      </div>
      <div class="card-body">
        <% if (user.roleName === 'accounts') { %>
        <!-- Bulk Upload Section -->
        <div class="alert alert-info mb-4" style="background: var(--info-light); border: none; border-left: 3px solid var(--info);">
          <h6 class="mb-2" style="color: var(--info);">
            <i class="bi bi-cloud-upload me-2"></i>Bulk Upload
          </h6>
          <div class="d-flex flex-wrap gap-2 align-items-center mt-3">
            <a href="/purchase/parties/template" class="btn btn-secondary btn-sm" data-bs-toggle="tooltip" data-bs-placement="top" title="Download Excel template with columns: Name, GST Number, State, Pincode, Due Payment Days">
              <i class="bi bi-download me-1"></i>Download Template
            </a>
            <form method="post" action="/purchase/parties/bulk" enctype="multipart/form-data" class="d-flex gap-2">
              <input type="file" name="excelFile" accept=".xlsx" required class="form-control form-control-sm" style="max-width: 250px;" data-bs-toggle="tooltip" data-bs-placement="top" title="Upload .xlsx file containing parties data">
              <button type="submit" class="btn btn-primary btn-sm">
                <i class="bi bi-upload me-1"></i>Upload
              </button>
            </form>
          </div>
        </div>

        <!-- Add Party Form -->
        <div class="mb-4 p-3" style="background: var(--gray-50); border-radius: var(--radius-lg); border: 1px solid var(--border-light);">
          <h6 class="mb-3" style="color: var(--text-primary);">
            <i class="bi bi-plus-circle me-2" style="color: var(--terracotta);"></i>Add New Party
          </h6>
          <form method="post" action="/purchase/parties">
            <div class="row g-3">
              <div class="col-md-3">
                <label class="form-label">Party Name <span class="text-danger">*</span></label>
                <input type="text" name="name" class="form-control" placeholder="Enter party name" required data-bs-toggle="tooltip" title="Full name of the party/vendor">
              </div>
              <div class="col-md-2">
                <label class="form-label">GST Number</label>
                <input type="text" name="gst_number" class="form-control" placeholder="GST Number" data-bs-toggle="tooltip" title="15-digit GSTIN">
              </div>
              <div class="col-md-2">
                <label class="form-label">State</label>
                <input type="text" name="state" class="form-control" placeholder="State" data-bs-toggle="tooltip" title="State name">
              </div>
              <div class="col-md-2">
                <label class="form-label">Pincode</label>
                <input type="text" name="pincode" class="form-control" placeholder="Pincode" data-bs-toggle="tooltip" title="6-digit pincode">
              </div>
              <div class="col-md-2">
                <label class="form-label">Due Days</label>
                <input type="number" name="due_payment_days" class="form-control" placeholder="Days" data-bs-toggle="tooltip" title="Payment due days">
              </div>
              <div class="col-md-1 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">
                  <i class="bi bi-plus-lg"></i> Add
                </button>
              </div>
            </div>
          </form>
        </div>
        <% } %>

        <!-- Parties Table -->
        <div class="table-container">
          <div class="table-responsive">
            <table class="table">
              <thead>
                <tr>
                  <th><i class="bi bi-person me-2"></i>Name</th>
                  <th><i class="bi bi-hash me-2"></i>GST Number</th>
                  <th><i class="bi bi-geo-alt me-2"></i>State</th>
                  <th><i class="bi bi-mailbox me-2"></i>Pincode</th>
                  <th><i class="bi bi-calendar-check me-2"></i>Due Days</th>
                  <% if (user.roleName === 'accounts') { %><th><i class="bi bi-gear me-2"></i>Action</th><% } %>
                </tr>
              </thead>
              <tbody>
              <% if (parties && parties.length > 0) { %>
                <% parties.forEach(p => { %>
                  <tr>
                    <form method="post" action="/purchase/parties/<%= p.id %>">
                      <td>
                        <input type="text" name="name" value="<%= p.name %>" class="form-control form-control-sm" data-bs-toggle="tooltip" title="Edit party name">
                      </td>
                      <td>
                        <input type="text" name="gst_number" value="<%= p.gst_number %>" class="form-control form-control-sm" data-bs-toggle="tooltip" title="Edit GST number">
                      </td>
                      <td>
                        <input type="text" name="state" value="<%= p.state %>" class="form-control form-control-sm" data-bs-toggle="tooltip" title="Edit state">
                      </td>
                      <td>
                        <input type="text" name="pincode" value="<%= p.pincode %>" class="form-control form-control-sm" data-bs-toggle="tooltip" title="Edit pincode">
                      </td>
                      <td>
                        <input type="number" name="due_payment_days" value="<%= p.due_payment_days %>" class="form-control form-control-sm" data-bs-toggle="tooltip" title="Edit due payment days">
                      </td>
                      <% if (user.roleName === 'accounts') { %>
                      <td>
                        <button type="submit" class="btn btn-sm btn-primary" data-bs-toggle="tooltip" title="Save changes">
                          <i class="bi bi-check-lg me-1"></i>Update
                        </button>
                      </td>
                      <% } %>
                    </form>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="6">
                    <div class="empty-state">
                      <div class="empty-state-icon">
                        <i class="bi bi-inbox" style="font-size: 48px;"></i>
                      </div>
                      <p class="empty-state-title">No Parties Found</p>
                      <p class="empty-state-text">Add your first party using the form above.</p>
                    </div>
                  </td>
                </tr>
              <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- Factories Section -->
    <div class="card mb-4">
      <div class="card-header">
        <div>
          <h4 class="card-title mb-1">
            <i class="bi bi-building me-2" style="color: var(--terracotta);"></i>Factories Management
          </h4>
          <small class="text-secondary">Manage manufacturing units and factories</small>
        </div>
      </div>
      <div class="card-body">
        <% if (user.roleName === 'accounts') { %>
        <!-- Add Factory Form -->
        <div class="mb-4 p-3" style="background: var(--gray-50); border-radius: var(--radius-lg); border: 1px solid var(--border-light);">
          <h6 class="mb-3" style="color: var(--text-primary);">
            <i class="bi bi-plus-circle me-2" style="color: var(--terracotta);"></i>Add New Factory
          </h6>
          <form method="post" action="/purchase/factories">
            <div class="row g-3">
              <div class="col-md-4">
                <label class="form-label">Factory Name <span class="text-danger">*</span></label>
                <input type="text" name="name" class="form-control" placeholder="Enter factory name" required data-bs-toggle="tooltip" title="Full name of the factory">
              </div>
              <div class="col-md-4">
                <label class="form-label">GST Number</label>
                <input type="text" name="gst_number" class="form-control" placeholder="GST Number" data-bs-toggle="tooltip" title="15-digit GSTIN">
              </div>
              <div class="col-md-3">
                <label class="form-label">State</label>
                <input type="text" name="state" class="form-control" placeholder="State" data-bs-toggle="tooltip" title="State name">
              </div>
              <div class="col-md-1 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">
                  <i class="bi bi-plus-lg"></i> Add
                </button>
              </div>
            </div>
          </form>
        </div>
        <% } %>

        <!-- Factories Table -->
        <div class="table-container">
          <div class="table-responsive">
            <table class="table">
              <thead>
                <tr>
                  <th><i class="bi bi-building me-2"></i>Name</th>
                  <th><i class="bi bi-hash me-2"></i>GST Number</th>
                  <th><i class="bi bi-geo-alt me-2"></i>State</th>
                  <% if (user.roleName === 'accounts') { %><th><i class="bi bi-gear me-2"></i>Action</th><% } %>
                </tr>
              </thead>
              <tbody>
              <% if (factories && factories.length > 0) { %>
                <% factories.forEach(f => { %>
                  <tr>
                    <form method="post" action="/purchase/factories/<%= f.id %>">
                      <td>
                        <input type="text" name="name" value="<%= f.name %>" class="form-control form-control-sm" data-bs-toggle="tooltip" title="Edit factory name">
                      </td>
                      <td>
                        <input type="text" name="gst_number" value="<%= f.gst_number %>" class="form-control form-control-sm" data-bs-toggle="tooltip" title="Edit GST number">
                      </td>
                      <td>
                        <input type="text" name="state" value="<%= f.state %>" class="form-control form-control-sm" data-bs-toggle="tooltip" title="Edit state">
                      </td>
                      <% if (user.roleName === 'accounts') { %>
                      <td>
                        <button type="submit" class="btn btn-sm btn-primary" data-bs-toggle="tooltip" title="Save changes">
                          <i class="bi bi-check-lg me-1"></i>Update
                        </button>
                      </td>
                      <% } %>
                    </form>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="4">
                    <div class="empty-state">
                      <div class="empty-state-icon">
                        <i class="bi bi-inbox" style="font-size: 48px;"></i>
                      </div>
                      <p class="empty-state-title">No Factories Found</p>
                      <p class="empty-state-text">Add your first factory using the form above.</p>
                    </div>
                  </td>
                </tr>
              <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

  </div>
</main>

<!-- Page-specific styles -->
<style>
  /* Tab Navigation Styling */
  .kotty-tabs {
    gap: 4px;
  }

  .kotty-tabs .nav-link {
    padding: 12px 20px;
    color: var(--text-secondary);
    border: none;
    border-bottom: 2px solid transparent;
    background: transparent;
    font-weight: 500;
    font-size: var(--text-sm);
    transition: all var(--transition-fast);
  }

  .kotty-tabs .nav-link:hover {
    color: var(--terracotta);
    background: var(--terracotta-bg);
    border-color: transparent;
  }

  .kotty-tabs .nav-link.active {
    color: var(--terracotta);
    background: transparent;
    border-color: var(--terracotta);
  }

  /* Form inputs in tables */
  .table .form-control-sm {
    border-color: var(--border-light);
    background: var(--bg-card);
  }

  .table .form-control-sm:focus {
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px var(--terracotta-bg);
  }

  /* Card header adjustments */
  .card-header {
    background: var(--bg-card);
  }

  /* Table styling enhancements */
  .table-container {
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  /* Alert info custom styling */
  .alert-info {
    color: var(--info);
  }

  .alert-info .btn-secondary {
    background: var(--bg-card);
    border-color: var(--border-medium);
  }

  .alert-info .btn-secondary:hover {
    background: var(--gray-100);
  }
</style>

<%- include('partials/footer') %>
