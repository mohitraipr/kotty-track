<%- include('partials/header', { pageTitle: 'Documentation' }) %>
<%- include('partials/navbar', { dashboardUrl: '/operator/dashboard' }) %>

<style>
  /* Documentation Page Styles */
  .doc-container {
    max-width: 1200px;
    margin: calc(var(--navbar-height) + 28px) auto 40px;
    padding: 0 24px;
  }

  /* Page Header */
  .doc-header {
    margin-bottom: 32px;
  }

  .doc-header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }

  .doc-header h1 {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    color: var(--text-primary);
    margin: 0;
  }

  .doc-header p {
    color: var(--text-secondary);
    margin-top: 8px;
    font-size: var(--text-base);
  }

  .header-actions {
    display: flex;
    gap: 12px;
  }

  /* Layout */
  .doc-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 32px;
  }

  @media (max-width: 768px) {
    .doc-layout {
      grid-template-columns: 1fr;
    }
    .doc-sidebar {
      display: none;
    }
  }

  /* Sidebar */
  .doc-sidebar {
    position: sticky;
    top: calc(var(--navbar-height) + 28px);
    height: fit-content;
  }

  .sidebar-nav {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 16px;
  }

  .sidebar-nav h6 {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 12px;
    padding: 0 12px;
  }

  .sidebar-nav a {
    display: block;
    padding: 10px 12px;
    color: var(--text-secondary);
    text-decoration: none;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    transition: all var(--transition-fast);
  }

  .sidebar-nav a:hover {
    background: var(--cream-dark);
    color: var(--text-primary);
  }

  .sidebar-nav a.active {
    background: var(--terracotta);
    color: white;
  }

  /* Doc Sections */
  .doc-section {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 24px;
    margin-bottom: 24px;
    box-shadow: var(--shadow-xs);
  }

  .doc-section h4 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--text-primary);
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 2px solid var(--border-light);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .doc-section h4 i {
    color: var(--terracotta);
    font-size: 20px;
  }

  .doc-section h5 {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--text-primary);
    margin: 24px 0 16px;
  }

  .doc-section p {
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* Flow Diagram */
  .flow-diagram {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    margin: 16px 0;
  }

  .flow-step {
    background: var(--terracotta-bg);
    color: var(--terracotta);
    padding: 10px 18px;
    border-radius: var(--radius-md);
    font-weight: 500;
    font-size: var(--text-sm);
    border: 1px solid var(--terracotta);
  }

  .flow-arrow {
    color: var(--text-muted);
    font-size: 20px;
  }

  /* Tables */
  .doc-table {
    width: 100%;
    font-size: var(--text-sm);
    border-collapse: collapse;
  }

  .doc-table th {
    background: var(--cream-dark);
    padding: 12px 14px;
    text-align: left;
    font-weight: 600;
    color: var(--text-secondary);
    text-transform: uppercase;
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    border-bottom: 1px solid var(--border-light);
  }

  .doc-table td {
    padding: 12px 14px;
    border-bottom: 1px solid var(--border-light);
    vertical-align: middle;
    color: var(--text-primary);
  }

  .doc-table tr:last-child td {
    border-bottom: none;
  }

  .doc-table tr:hover {
    background: var(--gray-50);
  }

  .doc-table strong {
    color: var(--text-primary);
  }

  /* Badges */
  .role-badge {
    display: inline-block;
    padding: 4px 10px;
    background: var(--cream-darker);
    border-radius: var(--radius-md);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--text-secondary);
    font-weight: 500;
  }

  .path-link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--terracotta);
    text-decoration: none;
    padding: 4px 8px;
    background: var(--terracotta-bg);
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
  }

  .path-link:hover {
    background: var(--terracotta);
    color: white;
  }

  /* Tech Doc Blocks */
  .tech-block {
    background: var(--cream);
    border-radius: var(--radius-lg);
    padding: 20px;
    margin-bottom: 20px;
    border-left: 4px solid var(--terracotta);
  }

  .tech-block.info {
    border-left-color: var(--info);
  }

  .tech-block.success {
    border-left-color: var(--success);
  }

  .tech-block.warning {
    border-left-color: var(--warning);
  }

  .tech-block.purple {
    border-left-color: #8b5cf6;
  }

  .tech-block h5 {
    font-family: var(--font-display);
    font-size: var(--text-base);
    color: var(--text-primary);
    margin: 0 0 12px 0;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .tech-block h5 i {
    font-size: 18px;
  }

  .tech-block p {
    font-size: var(--text-sm);
    margin-bottom: 12px;
  }

  .tech-block ol,
  .tech-block ul {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    padding-left: 20px;
    margin-bottom: 12px;
  }

  .tech-block li {
    margin-bottom: 6px;
  }

  .tech-block code {
    background: var(--cream-darker);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--terracotta-dark);
  }

  /* Roles Grid */
  .roles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 12px;
  }

  .role-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: var(--cream);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-light);
  }

  .role-item .role-badge {
    flex-shrink: 0;
  }

  .role-item span:last-child {
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  /* Quick Reference */
  .quick-ref-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 24px;
  }

  .quick-ref-section h6 {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border-light);
  }

  .quick-ref-section ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .quick-ref-section li {
    margin-bottom: 8px;
  }

  .quick-ref-section a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: var(--text-sm);
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 0;
    transition: all var(--transition-fast);
  }

  .quick-ref-section a:hover {
    color: var(--terracotta);
  }

  .quick-ref-section a::before {
    content: '';
    width: 4px;
    height: 4px;
    background: var(--border-medium);
    border-radius: 50%;
    transition: all var(--transition-fast);
  }

  .quick-ref-section a:hover::before {
    background: var(--terracotta);
  }

  /* Footer Note */
  .doc-footer {
    text-align: center;
    color: var(--text-muted);
    font-size: var(--text-sm);
    padding: 24px 0;
    border-top: 1px solid var(--border-light);
    margin-top: 16px;
  }
</style>

<div class="doc-container">
  <!-- Header -->
  <div class="doc-header">
    <div class="doc-header-content">
      <div>
        <h1>Documentation</h1>
        <p>Complete guide to Kotty Track features and workflows</p>
      </div>
      <div class="header-actions">
        <a href="/operator/system-health" class="btn btn-secondary">
          <i class="bi bi-heart-pulse"></i>
          System Health
        </a>
        <a href="/operator/dashboard" class="btn btn-primary">
          <i class="bi bi-arrow-left"></i>
          Dashboard
        </a>
      </div>
    </div>
  </div>

  <div class="doc-layout">
    <!-- Sidebar -->
    <div class="doc-sidebar">
      <div class="sidebar-nav">
        <h6>Sections</h6>
        <a href="#overview">Overview</a>
        <a href="#production">Production Flow</a>
        <a href="#features">Features</a>
        <a href="#integrations">Integrations</a>
        <a href="#technical">Technical Docs</a>
        <a href="#roles">Roles & Permissions</a>
      </div>
    </div>

    <!-- Main Content -->
    <div class="doc-content">
      <!-- Overview -->
      <div class="doc-section" id="overview">
        <h4><i class="bi bi-info-circle"></i>Overview</h4>
        <p>Kotty Track is a comprehensive ERP system for denim manufacturing and logistics. It tracks the entire production flow from cutting to finishing, manages inventory, handles returns, and integrates with e-commerce platforms.</p>

        <h5>Production Flow</h5>
        <div class="flow-diagram">
          <span class="flow-step">Cutting</span>
          <i class="bi bi-arrow-right flow-arrow"></i>
          <span class="flow-step">Stitching</span>
          <i class="bi bi-arrow-right flow-arrow"></i>
          <span class="flow-step">Assembly</span>
          <i class="bi bi-arrow-right flow-arrow"></i>
          <span class="flow-step">Washing</span>
          <i class="bi bi-arrow-right flow-arrow"></i>
          <span class="flow-step">Washing In</span>
          <i class="bi bi-arrow-right flow-arrow"></i>
          <span class="flow-step">Finishing</span>
        </div>
        <p style="font-size: var(--text-sm); font-style: italic;">
          Non-denim flow: Cutting -> Stitching -> Finishing (skips Assembly, Washing, Washing In)
        </p>
      </div>

      <!-- Production Departments -->
      <div class="doc-section" id="production">
        <h4><i class="bi bi-building"></i>Production Departments</h4>
        <table class="doc-table">
          <thead>
            <tr>
              <th>Department</th>
              <th>Description</th>
              <th>Path</th>
              <th>Role</th>
            </tr>
          </thead>
          <tbody>
            <% docs.production.forEach(function(d) { %>
            <tr>
              <td><strong><%= d.name %></strong></td>
              <td><%= d.desc %></td>
              <td><a href="<%= d.path %>" class="path-link"><%= d.path %></a></td>
              <td><span class="role-badge"><%= d.role %></span></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <!-- Features -->
      <div class="doc-section" id="features">
        <h4><i class="bi bi-grid"></i>Features</h4>
        <table class="doc-table">
          <thead>
            <tr>
              <th>Feature</th>
              <th>Description</th>
              <th>Path</th>
              <th>Role</th>
            </tr>
          </thead>
          <tbody>
            <% docs.features.forEach(function(f) { %>
            <tr>
              <td><strong><%= f.name %></strong></td>
              <td><%= f.desc %></td>
              <td><a href="<%= f.path %>" class="path-link"><%= f.path %></a></td>
              <td><span class="role-badge"><%= f.role %></span></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <!-- Integrations -->
      <div class="doc-section" id="integrations">
        <h4><i class="bi bi-plug"></i>External Integrations</h4>
        <table class="doc-table">
          <thead>
            <tr>
              <th>Integration</th>
              <th>Description</th>
            </tr>
          </thead>
          <tbody>
            <% docs.integrations.forEach(function(i) { %>
            <tr>
              <td><strong><%= i.name %></strong></td>
              <td><%= i.desc %></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <!-- Technical Documentation -->
      <div class="doc-section" id="technical">
        <h4><i class="bi bi-code-slash"></i>Technical Documentation</h4>

        <!-- Usage Analytics -->
        <div class="tech-block info">
          <h5><i class="bi bi-bar-chart"></i>Usage Analytics - How It Works</h5>
          <p><strong>Purpose:</strong> Tracks which features are being used, by whom, and how often.</p>

          <p><strong>How Page Hits Are Registered:</strong></p>
          <ol>
            <li><strong>Middleware Intercepts Requests:</strong> A middleware (<code>usageTrackerMiddleware</code>) runs on every GET request</li>
            <li><strong>Route Mapping:</strong> The URL is mapped to a feature name (e.g., <code>/cutting-manager/*</code> -> "Cutting")</li>
            <li><strong>Async Logging:</strong> After the page renders, the hit is logged to database asynchronously (doesn't slow down page load)</li>
            <li><strong>Data Stored:</strong> Feature name, route path, user ID, username, response time (ms), timestamp</li>
          </ol>

          <p><strong>Database Tables:</strong></p>
          <ul>
            <li><code>feature_usage</code> - Raw page hits (auto-cleaned after 7 days)</li>
            <li><code>feature_usage_daily</code> - Aggregated daily stats (permanent)</li>
          </ul>

          <p><strong>What's NOT Tracked:</strong></p>
          <ul>
            <li>Health check endpoints (<code>/health/*</code>)</li>
            <li>Static assets (CSS, JS, images)</li>
            <li>POST/PUT/DELETE requests (only GET page views)</li>
            <li>Socket.io connections</li>
          </ul>
        </div>

        <!-- System Health -->
        <div class="tech-block success">
          <h5><i class="bi bi-heart-pulse"></i>System Health - How It Works</h5>
          <p><strong>Purpose:</strong> Quick overview of system status and feature health.</p>

          <p><strong>What It Checks:</strong></p>
          <ul>
            <li><strong>Database Connection:</strong> Runs <code>SELECT 1</code> to verify MySQL connectivity</li>
            <li><strong>Active Users:</strong> Count of users with <code>is_active = 1</code></li>
            <li><strong>Sessions (24h):</strong> Distinct users who logged in within 24 hours</li>
            <li><strong>Raw Data Rows:</strong> Count of inventory/order rows with uncleared JSON data</li>
            <li><strong>Feature Status:</strong> Row count from each feature's main table</li>
          </ul>

          <p><strong>Performance:</strong> All queries run in parallel using <code>Promise.all()</code> for fast loading.</p>
        </div>

        <!-- Raw Data Clearing -->
        <div class="tech-block warning">
          <h5><i class="bi bi-trash"></i>Raw Data Clearing - How It Works</h5>
          <p><strong>Purpose:</strong> Clear large JSON blobs from webhook data to save database space.</p>

          <p><strong>What It Does:</strong></p>
          <ul>
            <li>Sets the <code>raw</code> column to NULL in <code>ee_inventory_snapshots</code> and <code>ee_orders</code> tables</li>
            <li>Processes in batches (50,000 rows at a time) to avoid timeouts</li>
            <li>Shows progress bar while clearing</li>
          </ul>

          <p><strong>Access:</strong> <span class="role-badge">Restricted</span></p>
          <p>Only these users can clear raw data:</p>
          <ul>
            <li><code>mohitOperator</code></li>
            <li><code>chandanSir</code></li>
            <li><code>sales</code></li>
            <li><code>sonuOpe</code></li>
            <li><code>mam</code></li>
          </ul>

          <p><strong>Where to Access:</strong></p>
          <ul>
            <li>Inventory: <a href="/webhook/logs">/webhook/logs</a> -> Click "Clear Raw Data"</li>
            <li>Orders: <a href="/webhook/order/logs">/webhook/order/logs</a> -> Click "Clear Raw Data"</li>
          </ul>
        </div>

        <!-- Product Links -->
        <div class="tech-block purple">
          <h5><i class="bi bi-link"></i>Product Links - How It Works</h5>
          <p><strong>Purpose:</strong> Store and display e-commerce platform links for products.</p>

          <p><strong>Features:</strong></p>
          <ul>
            <li><strong>Upload:</strong> Operator uploads Excel file with SKU and platform URLs</li>
            <li><strong>Brands:</strong> Supports NOWI and KOTTY brands</li>
            <li><strong>Platforms:</strong> Amazon, Myntra, Nykaa, Flipkart</li>
            <li><strong>Search:</strong> Client-side search (no server load)</li>
            <li><strong>AJAX Upload:</strong> No page refresh when uploading</li>
          </ul>

          <p><strong>Access:</strong></p>
          <ul>
            <li><span class="role-badge">operator</span> - Upload, delete, export</li>
            <li><span class="role-badge">productviewer</span> - View only</li>
          </ul>
        </div>
      </div>

      <!-- Roles -->
      <div class="doc-section" id="roles">
        <h4><i class="bi bi-people"></i>Roles & Permissions</h4>
        <div class="roles-grid">
          <% docs.roles.forEach(function(r) { %>
          <div class="role-item">
            <span class="role-badge"><%= r.name %></span>
            <span><%= r.desc %></span>
          </div>
          <% }); %>
        </div>
      </div>

      <!-- Quick Reference -->
      <div class="doc-section">
        <h4><i class="bi bi-bookmark"></i>Quick Reference</h4>
        <div class="quick-ref-grid">
          <div class="quick-ref-section">
            <h6>Operator Tools</h6>
            <ul>
              <li><a href="/operator/dashboard">Dashboard</a></li>
              <li><a href="/operator/system-health">System Health</a></li>
              <li><a href="/operator/usage-analytics">Usage Analytics</a></li>
              <li><a href="/operator/sku-management">SKU Management</a></li>
              <li><a href="/webhook/logs">Inventory Logs</a></li>
              <li><a href="/product-links">Product Links</a></li>
            </ul>
          </div>
          <div class="quick-ref-section">
            <h6>Reports</h6>
            <ul>
              <li><a href="/operator/dashboard/pic-report">PIC Report</a></li>
              <li><a href="/operator/dashboard/pic-size-report">Size PIC Report</a></li>
              <li><a href="/operator/stitching-tat">Stitching TAT</a></li>
              <li><a href="/returns/dashboard">Returns Dashboard</a></li>
            </ul>
          </div>
          <div class="quick-ref-section">
            <h6>Admin</h6>
            <ul>
              <li><a href="/admin">User Management</a></li>
              <li><a href="/po-admin/dashboard">PO Admin</a></li>
              <li><a href="/store-admin/dashboard">Store Admin</a></li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Footer -->
      <div class="doc-footer">
        Last updated: <%= new Date().toLocaleDateString('en-IN') %>
      </div>
    </div>
  </div>
</div>

<script>
  // Highlight active section on scroll
  const sections = document.querySelectorAll('.doc-section[id]');
  const navLinks = document.querySelectorAll('.sidebar-nav a');

  window.addEventListener('scroll', () => {
    let current = '';
    sections.forEach(section => {
      const sectionTop = section.offsetTop;
      if (scrollY >= sectionTop - 100) {
        current = section.getAttribute('id');
      }
    });
    navLinks.forEach(link => {
      link.classList.remove('active');
      if (link.getAttribute('href') === '#' + current) {
        link.classList.add('active');
      }
    });
  });
</script>

<%- include('partials/footer') %>
