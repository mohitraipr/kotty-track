<%- include('partials/header', { pageTitle: 'Pick your view' }) %>

<style>
  body { background: #f5f7fb; }
  .launcher-page {
    max-width: 960px;
    margin: 0 auto;
    padding: calc(var(--navbar-height, 60px) + 2rem) 1rem 4rem;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    color: #0f172a;
  }
  .launcher-head { margin-bottom: 1.5rem; }
  .launcher-head h1 { font-size: 1.75rem; font-weight: 700; letter-spacing: -0.02em; margin: 0 0 0.25rem; }
  .launcher-head .sub { color: #475569; font-size: 0.95rem; }
  .launcher-head .who { color: #0f172a; font-weight: 600; }

  .launcher-flash { padding: 0.75rem 1rem; border-radius: 10px; margin-bottom: 1rem; font-size: 0.9rem; }
  .launcher-flash.error { background: #fee2e2; color: #b91c1c; border: 1px solid #fecaca; }
  .launcher-flash.success { background: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }

  .launcher-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 0.875rem;
  }
  .role-card {
    background: #fff;
    border: 1px solid #e5e8ee;
    border-radius: 16px;
    padding: 1.125rem 1.125rem 1rem;
    box-shadow: 0 1px 3px rgba(15,23,42,0.05);
    transition: all 0.15s;
    display: flex; flex-direction: column; gap: 0.5rem;
    position: relative; overflow: hidden;
  }
  .role-card:hover { box-shadow: 0 10px 24px rgba(15,23,42,0.08); transform: translateY(-2px); border-color: #c7d2fe; }
  .role-card.is-active { border-color: #4f46e5; box-shadow: 0 0 0 1px #4f46e5; }
  .role-card.is-active::before {
    content: 'Active'; position: absolute; top: 0.5rem; right: 0.625rem;
    font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em;
    color: #4f46e5;
  }
  .role-card .icon {
    width: 44px; height: 44px; border-radius: 12px;
    background: #eef2ff; color: #4f46e5;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.25rem;
  }
  .role-card .label { font-size: 1.0625rem; font-weight: 700; color: #0f172a; letter-spacing: -0.01em; }
  .role-card .desc { font-size: 0.85rem; color: #475569; line-height: 1.45; }
  .role-card .meta { font-size: 0.7rem; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 0.25rem; }
  .role-card form { margin: 0; }
  .role-card button.go {
    width: 100%;
    background: #4f46e5; color: #fff; border: none;
    padding: 0.625rem 0.875rem; border-radius: 10px;
    font-family: inherit; font-weight: 600; font-size: 0.9rem;
    cursor: pointer; margin-top: 0.625rem;
    transition: background 0.15s;
  }
  .role-card button.go:hover { background: #4338ca; }
  .role-card.is-active button.go { background: #16a34a; }
  .role-card.is-active button.go:hover { background: #15803d; }

  /* Switch modal */
  .switch-overlay {
    position: fixed; inset: 0; background: rgba(15,23,42,0.55);
    backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
    z-index: 2000; display: none; align-items: center; justify-content: center;
    padding: 1rem;
  }
  .switch-overlay.show { display: flex; }
  .switch-card {
    background: #fff; border-radius: 16px;
    width: 100%; max-width: 420px;
    padding: 1.25rem 1.25rem 1.125rem;
    box-shadow: 0 24px 48px rgba(15,23,42,0.18);
  }
  .switch-card h3 { margin: 0 0 0.25rem; font-size: 1.125rem; font-weight: 700; }
  .switch-card .target { color: #4f46e5; font-weight: 700; }
  .switch-card p { color: #475569; font-size: 0.875rem; margin: 0 0 0.875rem; }
  .switch-card input[type="password"] {
    width: 100%; box-sizing: border-box;
    border: 1px solid #e5e8ee; border-radius: 10px;
    padding: 0.625rem 0.75rem; font-family: inherit; font-size: 0.95rem;
    margin-bottom: 0.875rem;
  }
  .switch-card input[type="password"]:focus { outline: none; border-color: #4f46e5; box-shadow: 0 0 0 3px #eef2ff; }
  .switch-card .actions { display: flex; gap: 0.5rem; justify-content: flex-end; }
  .switch-card button {
    border: none; cursor: pointer; padding: 0.625rem 1rem;
    border-radius: 10px; font-family: inherit; font-weight: 600; font-size: 0.875rem;
  }
  .switch-card button.cancel { background: #f1f5f9; color: #475569; }
  .switch-card button.cancel:hover { background: #e2e8f0; }
  .switch-card button.confirm { background: #4f46e5; color: #fff; }
  .switch-card button.confirm:hover { background: #4338ca; }
  .switch-card .err { color: #b91c1c; font-size: 0.8125rem; margin-top: 0.5rem; min-height: 1em; }
</style>

<main class="launcher-page">
  <header class="launcher-head">
    <h1>Pick your view</h1>
    <p class="sub">Welcome, <span class="who"><%= user.username %></span>. You have access to <%= roles.length %> roles.</p>
  </header>

  <% if (flash && flash.error && flash.error.length) { %>
    <% flash.error.forEach(function(m) { %><div class="launcher-flash error"><%= m %></div><% }) %>
  <% } %>
  <% if (flash && flash.success && flash.success.length) { %>
    <% flash.success.forEach(function(m) { %><div class="launcher-flash success"><%= m %></div><% }) %>
  <% } %>

  <section class="launcher-grid">
    <% roles.forEach(function(r) { %>
      <div class="role-card <%= r.isActive ? 'is-active' : '' %>">
        <div class="icon"><i class="bi bi-<%= r.icon %>"></i></div>
        <div class="label"><%= r.label %></div>
        <div class="desc"><%= r.desc %></div>
        <% if (r.isPrimary) { %><div class="meta">Primary role</div><% } %>
        <% if (r.isActive) { %>
          <a href="<%= r.url %>" style="text-decoration:none;">
            <button type="button" class="go">Continue as this</button>
          </a>
        <% } else { %>
          <button type="button" class="go" onclick="askSwitch('<%= r.role %>', '<%= r.label %>', '<%= r.url %>')">Switch to this</button>
        <% } %>
      </div>
    <% }) %>
  </section>
</main>

<div class="switch-overlay" id="switchOverlay" onclick="if(event.target.id==='switchOverlay')closeSwitch()">
  <form class="switch-card" id="switchForm" onsubmit="return submitSwitch(event)">
    <h3>Switch to <span class="target" id="switchTarget">—</span>?</h3>
    <p>Confirm your password to record this change in the audit log. You'll be taken to that view next.</p>
    <input type="password" name="password" id="switchPassword" placeholder="Password" autocomplete="current-password" required>
    <input type="hidden" name="role" id="switchRole" value="">
    <div class="actions">
      <button type="button" class="cancel" onclick="closeSwitch()">Cancel</button>
      <button type="submit" class="confirm" id="switchConfirm">Switch</button>
    </div>
    <div class="err" id="switchErr"></div>
  </form>
</div>

<script>
  let pendingDest = '';
  function askSwitch(role, label, url) {
    document.getElementById('switchRole').value = role;
    document.getElementById('switchTarget').textContent = label;
    document.getElementById('switchPassword').value = '';
    document.getElementById('switchErr').textContent = '';
    pendingDest = url;
    document.getElementById('switchOverlay').classList.add('show');
    setTimeout(() => document.getElementById('switchPassword').focus(), 50);
  }
  function closeSwitch() {
    document.getElementById('switchOverlay').classList.remove('show');
  }
  async function submitSwitch(e) {
    e.preventDefault();
    const btn = document.getElementById('switchConfirm');
    const errEl = document.getElementById('switchErr');
    const role = document.getElementById('switchRole').value;
    const password = document.getElementById('switchPassword').value;
    btn.disabled = true; btn.textContent = 'Switching…'; errEl.textContent = '';
    try {
      const r = await fetch('/switch-role', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ role, password }),
      });
      const data = await r.json();
      if (!r.ok || !data.ok) {
        errEl.textContent = data.error || 'Switch failed.';
        return false;
      }
      window.location = data.redirect || pendingDest;
    } catch (err) {
      errEl.textContent = err.message || 'Network error.';
    } finally {
      btn.disabled = false; btn.textContent = 'Switch';
    }
    return false;
  }
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSwitch();
  });
</script>

<%- include('partials/footer') %>
