<%- include('partials/header', { pageTitle: 'Assign Finishing' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/washingdashboard' }) %>

<style>
  .main-content {
    padding-top: calc(var(--navbar-height) + 2rem);
    padding-bottom: 3rem;
    min-height: 100vh;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .page-subtitle {
    color: var(--text-secondary);
    font-size: var(--text-base);
  }

  .search-section {
    background: var(--bg-card);
    border-radius: var(--radius-xl);
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    border: 1px solid var(--border-light);
    box-shadow: var(--shadow-sm);
  }

  .search-section .form-label {
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .search-section .form-control {
    border: 1px solid var(--border-medium);
    border-radius: var(--radius-md);
    padding: 0.75rem 1rem;
    font-size: var(--text-base);
    transition: all var(--transition-fast);
  }

  .search-section .form-control:focus {
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px var(--terracotta-bg);
    outline: none;
  }

  .assignment-card {
    background: var(--bg-card);
    border-radius: var(--radius-xl);
    border: 1px solid var(--border-light);
    box-shadow: var(--shadow-sm);
    margin-bottom: 1.25rem;
    overflow: hidden;
    transition: all var(--transition-fast);
  }

  .assignment-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--border-medium);
  }

  .assignment-card-header {
    background: var(--gray-100);
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border-light);
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
  }

  .assignment-card-header .lot-info {
    font-weight: 500;
    color: var(--text-primary);
  }

  .assignment-card-header .lot-info strong {
    color: var(--charcoal);
  }

  .assignment-card-header .badge-id {
    background: var(--cream-dark);
    color: var(--text-secondary);
    font-size: var(--text-xs);
    font-weight: 500;
    padding: 0.35rem 0.75rem;
    border-radius: var(--radius-full);
  }

  .assignment-card-body {
    padding: 0;
  }

  .assignment-table {
    width: 100%;
    margin: 0;
    border-collapse: collapse;
  }

  .assignment-table thead {
    background: var(--cream);
  }

  .assignment-table thead th {
    font-weight: 500;
    color: var(--text-secondary);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.025em;
    padding: 0.875rem 1.25rem;
    border-bottom: 1px solid var(--border-light);
  }

  .assignment-table tbody td {
    padding: 1rem 1.25rem;
    vertical-align: middle;
    border-bottom: 1px solid var(--border-light);
    color: var(--text-primary);
  }

  .assignment-table tbody tr:last-child td {
    border-bottom: none;
  }

  .assignment-table tbody tr:hover {
    background: var(--gray-50);
  }

  .assignment-table .size-label {
    font-weight: 500;
    color: var(--charcoal);
  }

  .assignment-table .pieces-count {
    font-weight: 600;
    color: var(--terracotta);
  }

  .assignment-table .form-select {
    border: 1px solid var(--border-medium);
    border-radius: var(--radius-md);
    padding: 0.5rem 2rem 0.5rem 0.75rem;
    font-size: var(--text-sm);
    background-color: var(--bg-card);
    transition: all var(--transition-fast);
    min-width: 200px;
  }

  .assignment-table .form-select:focus {
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px var(--terracotta-bg);
    outline: none;
  }

  .form-section {
    background: var(--bg-card);
    border-radius: var(--radius-xl);
    padding: 1.5rem;
    margin-top: 2rem;
    border: 1px solid var(--border-light);
    box-shadow: var(--shadow-sm);
  }

  .form-section .form-label {
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .form-section .form-control {
    border: 1px solid var(--border-medium);
    border-radius: var(--radius-md);
    padding: 0.75rem 1rem;
    font-size: var(--text-base);
    transition: all var(--transition-fast);
  }

  .form-section .form-control:focus {
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px var(--terracotta-bg);
    outline: none;
  }

  .btn-primary-kotty {
    background: var(--terracotta);
    color: white;
    border: none;
    padding: 0.75rem 1.5rem;
    font-size: var(--text-base);
    font-weight: 500;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--transition-fast);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .btn-primary-kotty:hover {
    background: var(--terracotta-dark);
    color: white;
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  .btn-primary-kotty:active {
    transform: translateY(0);
  }

  .empty-state {
    text-align: center;
    padding: 3rem 2rem;
    background: var(--bg-card);
    border-radius: var(--radius-xl);
    border: 1px dashed var(--border-medium);
  }

  .empty-state i {
    font-size: 3rem;
    color: var(--gray-400);
    margin-bottom: 1rem;
  }

  .empty-state p {
    color: var(--text-secondary);
    margin: 0;
  }

  .alert-kotty {
    border-radius: var(--radius-lg);
    padding: 1rem 1.25rem;
    margin-bottom: 1rem;
    border: 1px solid;
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .alert-kotty.alert-danger {
    background: var(--danger-light);
    border-color: var(--danger);
    color: var(--danger);
  }

  .alert-kotty.alert-success {
    background: var(--success-light);
    border-color: var(--success);
    color: var(--success);
  }

  .alert-kotty.alert-info {
    background: var(--info-light);
    border-color: var(--info);
    color: var(--info);
  }

  .alert-kotty.alert-warning {
    background: var(--warning-light);
    border-color: var(--warning);
    color: var(--warning);
  }

  .alert-kotty .btn-close {
    margin-left: auto;
    filter: none;
    opacity: 0.7;
  }

  .alert-kotty .btn-close:hover {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .main-content {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .page-title {
      font-size: var(--text-2xl);
    }

    .assignment-card-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .assignment-table thead {
      display: none;
    }

    .assignment-table tbody tr {
      display: block;
      padding: 1rem;
      border-bottom: 1px solid var(--border-light);
    }

    .assignment-table tbody td {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.5rem 0;
      border-bottom: none;
    }

    .assignment-table tbody td::before {
      content: attr(data-label);
      font-weight: 500;
      color: var(--text-secondary);
      font-size: var(--text-sm);
    }

    .assignment-table .form-select {
      min-width: auto;
      width: 100%;
    }
  }
</style>

<div class="container main-content">
  <!-- Flash Messages -->
  <% if (error && error.length > 0) { %>
    <% error.forEach(function(msg){ %>
      <div class="alert-kotty alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-circle"></i>
        <span><%= msg %></span>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% }) %>
  <% } %>
  <% if (success && success.length > 0) { %>
    <% success.forEach(function(msg){ %>
      <div class="alert-kotty alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i>
        <span><%= msg %></span>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% }) %>
  <% } %>

  <!-- Page Header -->
  <div class="page-header">
    <h1 class="page-title">
      <i class="bi bi-box-arrow-in-right me-2" style="color: var(--terracotta);"></i>
      Assign to Finishing
    </h1>
    <p class="page-subtitle">Assign partial sizes from washing to finishing operators</p>
  </div>

  <!-- Search Section -->
  <div class="search-section">
    <label for="searchInput" class="form-label">
      <i class="bi bi-search me-1"></i>
      Search by Lot or SKU
    </label>
    <input type="text" id="searchInput" class="form-control" placeholder="Type to filter assignments..." />
  </div>

  <!-- Container for leftover sizes -->
  <div id="assignmentsContainer"></div>

  <!-- Form for submission -->
  <form id="assignFinishingForm" method="POST" action="/washingdashboard/assign-finishing">
    <div class="form-section">
      <div class="row align-items-end">
        <div class="col-md-4 mb-3 mb-md-0">
          <label for="target_day" class="form-label">
            <i class="bi bi-calendar-event me-1"></i>
            Target Day (optional)
          </label>
          <input type="date" name="target_day" id="target_day" class="form-control" />
        </div>
        <div class="col-md-8 text-md-end">
          <button type="submit" class="btn-primary-kotty">
            <i class="bi bi-send"></i>
            Submit Assignments
          </button>
        </div>
      </div>
    </div>
  </form>
</div>

<script>
  let finishingUsers = [];
  let allData = []; // Array of objects: { washing_assignment_id, lot_no, sku, sizes: [ { size_label, pieces } ] }
  const searchInput = document.getElementById('searchInput');
  const assignmentsContainer = document.getElementById('assignmentsContainer');
  const assignFinishingForm = document.getElementById('assignFinishingForm');

  // Fetch finishing users (for washing, finishing users are fetched via the same endpoint)
  async function fetchFinishingUsers() {
    try {
      const resp = await fetch('/stitchingdashboard/assign-finishing/users');
      if (!resp.ok) throw new Error('HTTP ' + resp.status);
      const json = await resp.json();
      finishingUsers = json.data || [];
    } catch (err) {
      console.error('[ERROR] fetchFinishingUsers =>', err);
    }
  }

  // Fetch leftover sizes from washing assignments (via washing dashboard endpoint)
  async function fetchUnassignedData() {
    try {
      const resp = await fetch('/washingdashboard/assign-finishing/data');
      if (!resp.ok) throw new Error('HTTP ' + resp.status);
      const json = await resp.json();
      allData = json.data || [];
      renderData();
    } catch (err) {
      console.error('[ERROR] fetchUnassignedData =>', err);
      renderErrorState();
    }
  }

  function renderErrorState() {
    const container = assignmentsContainer;
    container.textContent = '';
    const alertDiv = document.createElement('div');
    alertDiv.className = 'alert-kotty alert-danger';
    const icon = document.createElement('i');
    icon.className = 'bi bi-exclamation-triangle';
    const span = document.createElement('span');
    span.textContent = 'Error loading data. Please refresh the page.';
    alertDiv.appendChild(icon);
    alertDiv.appendChild(span);
    container.appendChild(alertDiv);
  }

  function renderEmptyState(message) {
    const container = assignmentsContainer;
    container.textContent = '';
    const emptyDiv = document.createElement('div');
    emptyDiv.className = 'empty-state';
    const icon = document.createElement('i');
    icon.className = 'bi bi-inbox';
    const p = document.createElement('p');
    p.textContent = message;
    emptyDiv.appendChild(icon);
    emptyDiv.appendChild(p);
    container.appendChild(emptyDiv);
  }

  function renderWarningState(message) {
    const container = assignmentsContainer;
    container.textContent = '';
    const alertDiv = document.createElement('div');
    alertDiv.className = 'alert-kotty alert-warning';
    const icon = document.createElement('i');
    icon.className = 'bi bi-search';
    const span = document.createElement('span');
    span.textContent = message;
    alertDiv.appendChild(icon);
    alertDiv.appendChild(span);
    container.appendChild(alertDiv);
  }

  function renderData() {
    assignmentsContainer.textContent = '';
    if (!allData.length) {
      renderEmptyState('No unassigned sizes found');
      return;
    }
    const filterVal = searchInput.value.trim().toLowerCase();
    const filtered = allData.filter(entry => {
      const combined = (entry.lot_no + ' ' + entry.sku).toLowerCase();
      return combined.includes(filterVal);
    });
    if (!filtered.length) {
      renderWarningState('No matching results for your search.');
      return;
    }
    filtered.forEach(entry => {
      // entry: { washing_assignment_id, lot_no, sku, sizes: [ { size_label, pieces } ] }
      const card = document.createElement('div');
      card.classList.add('assignment-card');

      // Create header
      const header = document.createElement('div');
      header.className = 'assignment-card-header';

      const lotSpan = document.createElement('span');
      lotSpan.className = 'lot-info';
      const lotStrong = document.createElement('strong');
      lotStrong.textContent = 'Lot: ';
      lotSpan.appendChild(lotStrong);
      lotSpan.appendChild(document.createTextNode(entry.lot_no));

      const skuSpan = document.createElement('span');
      skuSpan.className = 'lot-info';
      const skuStrong = document.createElement('strong');
      skuStrong.textContent = 'SKU: ';
      skuSpan.appendChild(skuStrong);
      skuSpan.appendChild(document.createTextNode(entry.sku));

      const badgeSpan = document.createElement('span');
      badgeSpan.className = 'badge-id';
      badgeSpan.textContent = 'WAssign ID: ' + entry.washing_assignment_id;

      header.appendChild(lotSpan);
      header.appendChild(skuSpan);
      header.appendChild(badgeSpan);

      // Create body with table
      const body = document.createElement('div');
      body.className = 'assignment-card-body';

      const table = document.createElement('table');
      table.className = 'assignment-table';

      const thead = document.createElement('thead');
      const theadRow = document.createElement('tr');
      ['Size Label', 'Pieces', 'Assign Finishing User'].forEach(text => {
        const th = document.createElement('th');
        th.textContent = text;
        theadRow.appendChild(th);
      });
      thead.appendChild(theadRow);

      const tbody = document.createElement('tbody');
      tbody.id = 'tbody-asg-' + entry.washing_assignment_id;

      table.appendChild(thead);
      table.appendChild(tbody);
      body.appendChild(table);

      card.appendChild(header);
      card.appendChild(body);
      assignmentsContainer.appendChild(card);

      // Add rows for each size
      entry.sizes.forEach(sz => {
        const tr = document.createElement('tr');

        const td1 = document.createElement('td');
        td1.setAttribute('data-label', 'Size Label');
        const sizeSpan = document.createElement('span');
        sizeSpan.className = 'size-label';
        sizeSpan.textContent = sz.size_label;
        td1.appendChild(sizeSpan);

        const td2 = document.createElement('td');
        td2.setAttribute('data-label', 'Pieces');
        const piecesSpan = document.createElement('span');
        piecesSpan.className = 'pieces-count';
        piecesSpan.textContent = sz.pieces;
        td2.appendChild(piecesSpan);

        const td3 = document.createElement('td');
        td3.setAttribute('data-label', 'Finishing User');
        const select = document.createElement('select');
        select.className = 'form-select finishingSelect';

        const defaultOption = document.createElement('option');
        defaultOption.value = '';
        defaultOption.textContent = '-- Select Finishing User --';
        select.appendChild(defaultOption);

        finishingUsers.forEach(u => {
          const option = document.createElement('option');
          option.value = u.id;
          option.textContent = u.username;
          select.appendChild(option);
        });

        td3.appendChild(select);

        tr.appendChild(td1);
        tr.appendChild(td2);
        tr.appendChild(td3);
        tbody.appendChild(tr);
      });
    });
  }

  searchInput.addEventListener('input', renderData);

  // On form submit, build hidden input with finishing assignment data
  assignFinishingForm.addEventListener('submit', (e) => {
    // Remove existing hidden inputs
    document.querySelectorAll('.finishingAssignmentField').forEach(el => el.remove());
    const finalObj = {};
    allData.forEach(entry => {
      const wAssignId = entry.washing_assignment_id;
      const tbody = document.getElementById('tbody-asg-' + wAssignId);
      if (!tbody) return;
      const rows = tbody.querySelectorAll('tr');
      rows.forEach(r => {
        const sizeLabel = r.cells[0].textContent.trim();
        const finSelect = r.cells[2].querySelector('select.finishingSelect');
        const finUserVal = finSelect.value;
        if (finUserVal) {
          if (!finalObj[finUserVal]) finalObj[finUserVal] = [];
          finalObj[finUserVal].push({
            washing_assignment_id: wAssignId,
            size_label: sizeLabel
          });
        }
      });
    });
    console.log('[DEBUG] Final assignment object =>', finalObj);
    const hidden = document.createElement('input');
    hidden.type = 'hidden';
    hidden.name = 'finishingAssignments';
    hidden.value = JSON.stringify(finalObj);
    hidden.classList.add('finishingAssignmentField');
    assignFinishingForm.appendChild(hidden);
  });

  (async function init() {
    await fetchFinishingUsers();
    await fetchUnassignedData();
  })();
</script>

<%- include('partials/footer') %>
