<%#
  Lot-aware indent wrapper. Drop into any stage dashboard.
  Locals: user (req.session.user), stage (optional display name).
  Self-contained CSS (.iw-*) + JS. All JS selectors preserved.
%>
<% const __iw_role = (user && user.role) || ''; %>
<% const __iw_isStitching = __iw_role === 'stitching_master'; %>
<% const __iw_stage = (typeof stage !== 'undefined' && stage) ? stage : ''; %>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">

<style>
  /* ── tokens ─────────────────────────────────────────────────── */
  .iw-wrap {
    --ink: #1c1917;
    --ink-2: #44403c;
    --dim: #78716c;
    --faint: #a8a29e;
    --rule: #e7e5e4;
    --rule-hard: #d6d3d1;
    --bg: #fafaf9;
    --card: #ffffff;
    --tint: #fef7f0;
    --accent: #c2410c;
    --accent-deep: #9a3412;
    --accent-soft: #fed7aa;
    --ok: #15803d;
    --ok-soft: #dcfce7;
    --warn: #b45309;
    --warn-soft: #fef3c7;
    --info: #0e7490;
    --info-soft: #cffafe;
    --serif: 'Instrument Serif', 'Iowan Old Style', Georgia, serif;
    --mono: 'JetBrains Mono', ui-monospace, 'SFMono-Regular', Menlo, monospace;
    --sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;

    font-family: var(--sans);
    color: var(--ink);
    -webkit-font-smoothing: antialiased;
    background: var(--bg);
    padding: 4px;
  }

  /* ── card / section frame ──────────────────────────────────── */
  .iw-card {
    background: var(--card);
    border: 1px solid var(--rule);
    margin-bottom: 14px;
    position: relative;
  }
  .iw-card + .iw-card { margin-top: 14px; }

  .iw-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 20px 14px;
    border-bottom: 1px solid var(--rule);
  }
  .iw-head__title {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .iw-eyebrow {
    font-family: var(--mono);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--dim);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .iw-eyebrow::before {
    content: '';
    width: 14px;
    height: 1px;
    background: var(--accent);
    display: inline-block;
  }
  .iw-h {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 28px;
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--ink);
  }
  .iw-h i { font-size: 0.7em; color: var(--accent); margin-right: 6px; }
  .iw-h__num {
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 0.1em;
    margin-right: 10px;
    vertical-align: middle;
  }
  .iw-head__aside { flex-shrink: 0; display: flex; align-items: center; gap: 10px; }

  .iw-body { padding: 18px 20px 20px; }

  /* ── form atoms ────────────────────────────────────────────── */
  .iw-label {
    display: block;
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 500;
    color: var(--dim);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    margin-bottom: 6px;
  }
  .iw-input, .iw-select {
    width: 100%;
    padding: 9px 12px;
    font-family: var(--sans);
    font-size: 14px;
    color: var(--ink);
    background: var(--card);
    border: 1px solid var(--rule-hard);
    border-radius: 2px;
    transition: border-color 120ms ease, background 120ms ease;
  }
  .iw-input:hover, .iw-select:hover { border-color: var(--ink-2); }
  .iw-input:focus, .iw-select:focus {
    outline: none;
    border-color: var(--accent);
    background: #fffbf7;
  }
  .iw-input[readonly] {
    background: var(--bg);
    color: var(--ink-2);
    cursor: default;
  }
  .iw-input.iw-qty { font-family: var(--mono); font-weight: 500; font-size: 15px; }

  .iw-helper {
    font-size: 12px;
    color: var(--dim);
    margin-top: 8px;
    line-height: 1.5;
  }

  /* ── buttons ───────────────────────────────────────────────── */
  .iw-btn {
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.01em;
    padding: 9px 16px;
    border: 1px solid transparent;
    border-radius: 2px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    transition: all 120ms ease;
    white-space: nowrap;
  }
  .iw-btn-primary {
    background: var(--ink);
    color: var(--card);
    border-color: var(--ink);
  }
  .iw-btn-primary:hover { background: var(--accent-deep); border-color: var(--accent-deep); }
  .iw-btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
  .iw-btn-primary i { color: var(--accent-soft); }

  .iw-btn-ghost {
    background: transparent;
    color: var(--ink);
    border-color: var(--rule-hard);
  }
  .iw-btn-ghost:hover {
    border-color: var(--ink);
    background: var(--bg);
  }
  .iw-btn-ghost i { color: var(--accent); }

  .iw-btn-x {
    background: transparent;
    border: 0;
    color: var(--faint);
    cursor: pointer;
    width: 24px;
    height: 24px;
    border-radius: 2px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    line-height: 1;
    transition: color 120ms ease, background 120ms ease;
  }
  .iw-btn-x:hover { color: var(--accent); background: var(--tint); }

  /* ── lot type filter (stitching) ──────────────────────────── */
  .iw-tabfilter {
    display: inline-flex;
    border: 1px solid var(--rule-hard);
    border-radius: 2px;
    overflow: hidden;
    background: var(--card);
  }
  .iw-tabfilter select {
    border: 0;
    background: transparent;
    padding: 8px 28px 8px 12px;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink);
    appearance: none;
    cursor: pointer;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='10' height='10' viewBox='0 0 10 10'><path d='M2 4l3 3 3-3' stroke='%23c2410c' stroke-width='1.4' fill='none'/></svg>");
    background-repeat: no-repeat;
    background-position: right 10px center;
  }
  .iw-tabfilter select:focus { outline: none; background-color: var(--tint); }

  /* ── lot picker ───────────────────────────────────────────── */
  .iw-picker-frame {
    border: 1px solid var(--rule-hard);
    border-radius: 2px;
    background: var(--card);
    padding: 14px 14px 6px;
    transition: border-color 120ms ease;
  }
  .iw-picker-frame:focus-within { border-color: var(--accent); }

  /* spec strip for lot stats */
  .iw-summary {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    margin-top: 16px;
    border: 1px solid var(--rule);
    border-radius: 2px;
    background: var(--card);
    overflow: hidden;
  }
  .iw-stat {
    padding: 14px 16px;
    border-right: 1px solid var(--rule);
    background: var(--card);
    position: relative;
  }
  .iw-stat:last-child { border-right: 0; }
  .iw-stat::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 2px;
    background: var(--rule);
  }
  .iw-stat:first-child::before { background: var(--accent); }
  .iw-stat-num {
    font-family: var(--serif);
    font-size: 30px;
    font-weight: 400;
    line-height: 1;
    color: var(--ink);
    letter-spacing: -0.02em;
  }
  .iw-stat-lbl {
    margin-top: 6px;
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--dim);
  }

  /* ── line items table ─────────────────────────────────────── */
  .iw-rows-frame {
    border: 1px solid var(--rule);
    border-radius: 2px;
    overflow: hidden;
    background: var(--card);
  }
  .iw-row {
    display: grid;
    grid-template-columns: minmax(0, 1.8fr) minmax(0, 1fr) 110px 90px;
    gap: 0;
    align-items: stretch;
    border-bottom: 1px solid var(--rule);
    position: relative;
    background: var(--card);
  }
  .iw-row:last-child { border-bottom: 0; }
  .iw-row > * {
    padding: 14px 16px;
    border-right: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    gap: 6px;
    justify-content: center;
  }
  .iw-row > *:last-child { border-right: 0; }

  /* AUTO rows: warm tinted background + thick left edge */
  .iw-row.auto {
    background: var(--tint);
    border-left: 3px solid var(--accent);
  }
  .iw-row.auto > * { border-right-color: #f3e6d4; }
  .iw-row.auto .iw-input { background: var(--card); }
  .iw-row.auto .iw-input[readonly] { background: transparent; border-color: transparent; padding-left: 0; font-family: var(--mono); font-size: 13px; }

  /* CUSTOM rows: clean white, no accent edge, slightly dimmer */
  .iw-row.custom {
    background: var(--card);
    border-left: 3px solid transparent;
  }
  .iw-row.custom:hover { background: #fafaf9; }

  .iw-row__main { min-width: 0; }
  .iw-row__title {
    font-family: var(--serif);
    font-size: 19px;
    font-weight: 400;
    line-height: 1.15;
    color: var(--ink);
    letter-spacing: -0.005em;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .iw-row__title .iw-helper { font-family: var(--sans); }

  /* pills — typographic, not loud */
  .iw-pill {
    font-family: var(--mono);
    font-size: 9.5px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 3px 7px;
    border-radius: 2px;
    background: var(--accent);
    color: var(--card);
    display: inline-block;
    line-height: 1.2;
  }
  .iw-pill.gray { background: var(--ink-2); }
  .iw-pill.amber {
    background: transparent;
    color: var(--dim);
    border: 1px solid var(--rule-hard);
  }

  /* ── empty state ─────────────────────────────────────────── */
  .iw-empty {
    padding: 36px 24px;
    text-align: center;
    background: var(--card);
    color: var(--dim);
  }
  .iw-empty i {
    display: block;
    font-size: 28px;
    color: var(--faint);
    margin-bottom: 10px;
  }
  .iw-empty-h {
    font-family: var(--serif);
    font-size: 20px;
    font-style: italic;
    color: var(--ink-2);
    margin-bottom: 4px;
  }
  .iw-empty-sub {
    font-size: 13px;
    color: var(--dim);
    line-height: 1.5;
    max-width: 360px;
    margin: 0 auto;
  }

  /* ── submit bar ──────────────────────────────────────────── */
  .iw-actionbar {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px dashed var(--rule-hard);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .iw-actionbar__note {
    font-family: var(--mono);
    font-size: 10.5px;
    color: var(--dim);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  /* ── recent activity log ─────────────────────────────────── */
  .iw-log { background: var(--card); }
  .iw-req-item {
    display: grid;
    grid-template-columns: 78px 1fr auto;
    gap: 16px;
    align-items: baseline;
    padding: 14px 20px;
    border-bottom: 1px solid var(--rule);
  }
  .iw-req-item:last-child { border-bottom: 0; }
  .iw-req-item:hover { background: var(--bg); }
  .iw-req-time {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--dim);
    letter-spacing: 0.04em;
  }
  .iw-req-body { min-width: 0; }
  .iw-req-desc {
    font-family: var(--serif);
    font-size: 18px;
    font-weight: 400;
    color: var(--ink);
    line-height: 1.25;
    letter-spacing: -0.005em;
  }
  .iw-req-meta {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--dim);
    margin-top: 4px;
    letter-spacing: 0.02em;
  }
  .iw-req-lot {
    font-family: var(--mono);
    font-size: 10.5px;
    font-weight: 600;
    color: var(--accent);
    background: transparent;
    padding: 0;
    border-radius: 0;
    letter-spacing: 0.06em;
  }
  .iw-req-lot::before { content: '['; opacity: 0.6; margin-right: 1px; }
  .iw-req-lot::after { content: ']'; opacity: 0.6; margin-left: 1px; }

  .iw-status {
    font-family: var(--mono);
    font-size: 9.5px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 4px 9px;
    border-radius: 2px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    line-height: 1.2;
  }
  .iw-status::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    display: inline-block;
  }
  .iw-status.open { color: var(--warn); background: var(--warn-soft); }
  .iw-status.open::before { background: var(--warn); }
  .iw-status.proceeding { color: var(--info); background: var(--info-soft); }
  .iw-status.proceeding::before { background: var(--info); }
  .iw-status.arrived { color: var(--ok); background: var(--ok-soft); }
  .iw-status.arrived::before { background: var(--ok); }

  /* ── Select2 overrides ──────────────────────────────────── */
  .iw-wrap .select2-container { font-size: 14px; font-family: var(--sans); }
  .iw-wrap .select2-container .select2-selection--multiple,
  .iw-wrap .select2-container .select2-selection--single {
    min-height: 40px;
    border: 1px solid var(--rule-hard) !important;
    border-radius: 2px !important;
    background: var(--card);
  }
  .iw-wrap .select2-container--focus .select2-selection { border-color: var(--accent) !important; }
  .iw-wrap .select2-container--default .select2-selection--multiple .select2-selection__choice {
    background: var(--ink);
    color: var(--card);
    border: 0;
    border-radius: 2px;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 8px 4px 24px;
    margin: 4px 4px 0 0;
    position: relative;
  }
  .iw-wrap .select2-container--default .select2-selection--multiple .select2-selection__choice__remove {
    color: var(--accent-soft) !important;
    border-right: 0 !important;
    margin-right: 6px;
    padding: 0 !important;
    font-size: 13px;
  }
  .iw-wrap .select2-container--default .select2-results__option--highlighted {
    background: var(--ink) !important;
    color: var(--card) !important;
  }

  /* ── responsive ─────────────────────────────────────────── */
  @media (max-width: 900px) {
    .iw-row { grid-template-columns: 1fr 1fr; }
    .iw-row__main { grid-column: 1 / -1; border-right: 0; border-bottom: 1px solid var(--rule); }
    .iw-row.auto .iw-row__main { border-bottom-color: #f3e6d4; }
    .iw-row > *:nth-child(2) { border-right: 1px solid var(--rule); }
    .iw-summary { grid-template-columns: repeat(2, 1fr); }
    .iw-stat:nth-child(2) { border-right: 0; }
    .iw-stat:nth-child(-n+2) { border-bottom: 1px solid var(--rule); }
  }
  @media (max-width: 520px) {
    .iw-head { flex-direction: column; align-items: flex-start; }
    .iw-h { font-size: 24px; }
    .iw-row { grid-template-columns: 1fr; }
    .iw-row > * { border-right: 0; border-bottom: 1px solid var(--rule); padding: 12px 14px; }
    .iw-row > *:last-child { border-bottom: 0; }
    .iw-row.auto > * { border-bottom-color: #f3e6d4; }
    .iw-req-item { grid-template-columns: 1fr; gap: 6px; }
    .iw-req-time { order: -1; }
  }
</style>

<div class="iw-wrap" id="iwWrap"
     data-role="<%= __iw_role %>"
     data-stage="<%= __iw_stage %>"
     data-stitching="<%= __iw_isStitching ? '1' : '0' %>">

  <% if (__iw_isStitching) { %>
  <!-- ============== STITCHING: lot picker ============== -->
  <section class="iw-card">
    <header class="iw-head">
      <div class="iw-head__title">
        <span class="iw-eyebrow">Step 01 · Selection</span>
        <h2 class="iw-h"><span class="iw-h__num">01</span>Pick the lots</h2>
      </div>
      <div class="iw-head__aside">
        <span class="iw-label" style="margin:0;">Filter</span>
        <span class="iw-tabfilter">
          <select id="iwLotTypeFilter">
            <option value="denim">Denim</option>
            <option value="hosiery">Hosiery</option>
            <option value="">All approved</option>
          </select>
        </span>
      </div>
    </header>
    <div class="iw-body">
      <label class="iw-label" for="iwLotPicker">Search by lot number or SKU</label>
      <div class="iw-picker-frame">
        <select id="iwLotPicker" multiple style="width:100%"></select>
      </div>
      <p class="iw-helper">Quantities for zipper &amp; button auto-fill from the total approved pieces of every lot you pick here.</p>

      <div id="iwLotSummary" class="iw-summary" style="display:none;"></div>
    </div>
  </section>
  <% } %>

  <!-- ============== Items ============== -->
  <section class="iw-card">
    <header class="iw-head">
      <div class="iw-head__title">
        <span class="iw-eyebrow"><%= __iw_isStitching ? 'Step 02 · Requirements' : 'Requisition' %></span>
        <h2 class="iw-h">
          <% if (__iw_isStitching) { %><span class="iw-h__num">02</span><% } %>
          <%= __iw_isStitching ? 'Material requirement' : 'Raise material requirement' %>
        </h2>
      </div>
      <div class="iw-head__aside">
        <button type="button" class="iw-btn iw-btn-ghost" id="iwAddCustom">
          <i class="bi bi-plus-lg"></i> Add line
        </button>
      </div>
    </header>
    <div class="iw-body">
      <% if (!__iw_isStitching) { %>
        <label class="iw-label" for="iwSingleLot">Lot</label>
        <select id="iwSingleLot" class="iw-select" style="margin-bottom:18px;">
          <option value="">— No lot · general request —</option>
        </select>
      <% } %>

      <div id="iwRows" class="iw-rows-frame"></div>

      <div class="iw-actionbar">
        <span class="iw-actionbar__note">Lines marked AUTO are derived from selected lots. CUSTOM lines are added by you.</span>
        <button type="button" class="iw-btn iw-btn-primary" id="iwSubmit">
          <i class="bi bi-arrow-right-short"></i> <span>Submit indent</span>
        </button>
      </div>
    </div>
  </section>

  <!-- ============== Recent ============== -->
  <section class="iw-card iw-log">
    <header class="iw-head">
      <div class="iw-head__title">
        <span class="iw-eyebrow">Ledger</span>
        <h2 class="iw-h">Recent requests</h2>
      </div>
    </header>
    <div id="iwRecent">
      <div class="iw-empty">
        <i class="bi bi-hourglass-split"></i>
        <div class="iw-empty-h">Loading…</div>
      </div>
    </div>
  </section>
</div>

<script>
(function(){
  // Self-load jQuery + Select2 if the host page doesn't already provide them.
  function loadScript(src) {
    return new Promise(function(resolve, reject){
      var s = document.createElement('script');
      s.src = src; s.async = false;
      s.onload = resolve; s.onerror = reject;
      document.head.appendChild(s);
    });
  }
  function ensureDeps() {
    var p = Promise.resolve();
    if (!window.jQuery) {
      p = p.then(function(){ return loadScript('https://code.jquery.com/jquery-3.6.0.min.js'); });
    }
    p = p.then(function(){
      if (!window.jQuery.fn.select2) {
        return loadScript('https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js');
      }
    });
    return p;
  }
  function ready(fn) {
    ensureDeps().then(function(){
      if (window.jQuery && window.jQuery.fn && window.jQuery.fn.select2) return fn();
      setTimeout(function(){ ready(fn); }, 80);
    }).catch(function(err){
      console.error('IndentWrapper failed to load deps', err);
    });
  }
  ready(init);

  function init() {
    var $ = window.jQuery;
    var wrap = document.getElementById('iwWrap');
    if (!wrap) return;
    var isStitching = wrap.dataset.stitching === '1';

    var state = {
      lots: [],
      bom: [],
      customCount: 0,
      categories: [],
      submitting: false
    };

    function toast(msg, type) {
      if (window.showToast) return window.showToast(msg, type || 'info');
      alert(msg);
    }
    function esc(s) {
      if (s == null) return '';
      return String(s).replace(/[&<>"']/g, function(c){ return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]); });
    }
    function fmtDate(iso) {
      try {
        var d = new Date(iso);
        var dd = String(d.getDate()).padStart(2, '0');
        var mo = d.toLocaleString('en-US', { month: 'short' }).toUpperCase();
        return dd + ' ' + mo;
      } catch(e) { return ''; }
    }

    // ---- Load categories once
    fetch('/indent/api/categories').then(r=>r.json()).then(function(d){
      state.categories = d.categories || [];
    }).catch(function(){});

    // ---- Stitching: lot picker
    if (isStitching) {
      function loadLotsForPicker() {
        var type = document.getElementById('iwLotTypeFilter').value;
        return fetch('/indent/api/my-approved-lots' + (type ? '?lot_type=' + encodeURIComponent(type) : ''))
          .then(r => r.json())
          .then(function(d) { return d.lots || []; });
      }
      var $picker = $('#iwLotPicker');
      $picker.select2({
        placeholder: 'Type lot number or SKU…',
        width: '100%',
        data: []
      });
      function refreshPicker() {
        loadLotsForPicker().then(function(lots){
          var options = lots.map(function(l){
            var manualBit = l.manual_lot_number ? String(l.manual_lot_number).toUpperCase() + ' / ' : '';
            return { id: l.lot_no, text: manualBit + (l.lot_no || '').toUpperCase() + ' · ' + (l.sku || '') + ' · ' + (l.total_pieces || 0) + ' pcs (' + (l.lot_type || '-') + ')', _row: l };
          });
          $picker.empty().select2({ placeholder: 'Type lot number or SKU…', width: '100%', data: options, multiple: true });
        });
      }
      refreshPicker();
      document.getElementById('iwLotTypeFilter').addEventListener('change', refreshPicker);

      $picker.on('change', function(){
        var selected = $picker.select2('data') || [];
        state.lots = selected.map(function(opt){ return opt._row || { lot_no: opt.id }; });
        renderLotSummary();
        loadBomSuggestions();
      });
    } else {
      fetch('/indent/recent-lots').then(r=>r.json()).then(function(d){
        var sel = document.getElementById('iwSingleLot');
        if (!sel) return;
        (d.lots || []).forEach(function(l){
          // recent-lots now returns { lot_no, manual_lot_number } objects;
          // tolerate the legacy plain-string shape too.
          var lotNo = (l && typeof l === 'object') ? l.lot_no : l;
          var manual = (l && typeof l === 'object') ? l.manual_lot_number : null;
          var o = document.createElement('option');
          o.value = lotNo;
          o.textContent = (manual ? String(manual).toUpperCase() + ' / ' : '') + String(lotNo).toUpperCase();
          sel.appendChild(o);
        });
        // Make the lot picker type-to-search (by manual lot or system lot).
        if (window.jQuery && jQuery.fn.select2) {
          jQuery(sel).select2({ width: '100%', placeholder: 'Type manual or system lot…' });
        }
      });
      addCustomRow();
    }

    function renderLotSummary() {
      var box = document.getElementById('iwLotSummary');
      if (!box) return;
      if (state.lots.length === 0) { box.style.display = 'none'; box.innerHTML = ''; return; }
      var totalPcs = state.lots.reduce(function(s,l){ return s + (Number(l.total_pieces)||0); }, 0);
      var denim = state.lots.filter(function(l){ return l.lot_type === 'denim'; }).length;
      var hosiery = state.lots.filter(function(l){ return l.lot_type === 'hosiery'; }).length;
      box.style.display = '';
      box.innerHTML =
        '<div class="iw-stat"><div class="iw-stat-num">' + state.lots.length + '</div><div class="iw-stat-lbl">Lots picked</div></div>' +
        '<div class="iw-stat"><div class="iw-stat-num">' + totalPcs.toLocaleString('en-IN') + '</div><div class="iw-stat-lbl">Total pieces</div></div>' +
        '<div class="iw-stat"><div class="iw-stat-num">' + denim + '</div><div class="iw-stat-lbl">Denim</div></div>' +
        '<div class="iw-stat"><div class="iw-stat-num">' + hosiery + '</div><div class="iw-stat-lbl">Hosiery</div></div>';
    }

    function loadBomSuggestions() {
      if (state.lots.length === 0) {
        state.bom = [];
        renderRows();
        return;
      }
      var lotNos = state.lots.map(function(l){ return l.lot_no; }).join(',');
      fetch('/indent/api/bom-suggest?lot_nos=' + encodeURIComponent(lotNos))
        .then(r => r.json())
        .then(function(d) {
          if (!d.success) return;
          state.bom = (d.suggestions || []).map(function(s, idx){
            return Object.assign({}, s, {
              key: 'auto_' + idx,
              qty: s.default_qty || 0,
              variant_input: s.variant_number || ''
            });
          });
          renderRows();
        });
    }

    function renderRows() {
      var host = document.getElementById('iwRows');
      host.innerHTML = '';
      state.bom.forEach(function(b){ host.appendChild(buildAutoRow(b)); });
      state._customs = state._customs || [];
      state._customs.forEach(function(c){ host.appendChild(buildCustomRow(c)); });

      if (state.bom.length === 0 && state._customs.length === 0) {
        var empty = document.createElement('div');
        empty.className = 'iw-empty';
        empty.innerHTML =
          '<i class="bi bi-stack"></i>' +
          '<div class="iw-empty-h">' + (isStitching ? 'No lines yet' : 'Add your first line') + '</div>' +
          '<div class="iw-empty-sub">' +
            (isStitching
              ? 'Pick one or more lots above. Zipper, button, and dhaga lines will appear here, with quantities derived from your approved pieces.'
              : 'Use the “Add line” button to search the catalogue and start your indent.') +
          '</div>';
        host.appendChild(empty);
      }
    }

    function buildAutoRow(b) {
      var div = document.createElement('div');
      div.className = 'iw-row auto';
      div.dataset.kind = 'auto';
      div.dataset.category = b.category;
      div.dataset.variant = b.variant_number || '';
      var variantPicker = b.editable_variant
        ? '<div><label class="iw-label">Variant</label><input class="iw-input iw-variant" placeholder="e.g. #16, 8 in" value="' + esc(b.variant_input || '') + '"></div>'
        : '<div><label class="iw-label">Variant</label><input class="iw-input" readonly value="' + esc(b.variant_number || '—') + '"></div>';
      div.innerHTML =
        '<div class="iw-row__main">' +
          '<div class="iw-row__title">' +
            '<span class="iw-pill">Auto</span> ' + esc(b.label) +
          '</div>' +
          '<div class="iw-helper">' + esc(b.category) + (b.auto && b.default_qty ? ' · qty derived from total approved pieces' : ' · enter quantity manually') + '</div>' +
        '</div>' +
        variantPicker +
        '<div><label class="iw-label">Quantity</label>' +
          '<input type="number" class="iw-input iw-qty" min="0" step="1" value="' + (b.qty || 0) + '"></div>' +
        '<div><label class="iw-label">Unit</label>' +
          '<input class="iw-input" readonly value="' + esc(b.unit || '') + '"></div>';
      return div;
    }

    function buildCustomRow(c) {
      var div = document.createElement('div');
      div.className = 'iw-row custom';
      div.dataset.kind = 'custom';
      div.dataset.customKey = c.key;
      div.innerHTML =
        '<div class="iw-row__main">' +
          '<div class="iw-row__title">' +
            '<span class="iw-pill amber">Custom</span>' +
            '<span style="flex:1;"></span>' +
            '<button type="button" class="iw-btn-x" data-remove="' + c.key + '" title="Remove line" aria-label="Remove">&times;</button>' +
          '</div>' +
          '<label class="iw-label" style="margin-top:8px;">Search catalogue</label>' +
          '<select class="iw-goods" style="width:100%;"></select>' +
        '</div>' +
        '<div><label class="iw-label">Variant</label>' +
          '<input class="iw-input iw-variant" placeholder="optional"></div>' +
        '<div><label class="iw-label">Quantity</label>' +
          '<input type="number" class="iw-input iw-qty" min="0" step="0.01"></div>' +
        '<div><label class="iw-label">Unit</label>' +
          '<input class="iw-input iw-unit" readonly></div>';
      setTimeout(function(){
        var $sel = $(div).find('.iw-goods');
        $sel.select2({
          placeholder: 'Search any item…',
          allowClear: true,
          width: '100%',
          minimumInputLength: 1,
          ajax: {
            url: '/indent/api/items',
            dataType: 'json', delay: 250,
            data: function(p){ return { q: p.term }; },
            processResults: function(d){ return { results: d }; }
          }
        });
        $sel.on('select2:select', function(e){
          var d = e.params.data || {};
          $(div).find('.iw-unit').val(d.unit || '');
          if (d.variant_number) $(div).find('.iw-variant').val(d.variant_number);
          div.dataset.goodsId = d.id;
          div.dataset.categoryId = d.category_id || '';
          div.dataset.categoryName = d.category_name || '';
        });
      }, 0);
      div.querySelector('[data-remove]').addEventListener('click', function(){
        state._customs = state._customs.filter(function(x){ return x.key !== c.key; });
        renderRows();
      });
      return div;
    }

    function addCustomRow() {
      state._customs = state._customs || [];
      state._customs.push({ key: 'c_' + (++state.customCount) });
      renderRows();
    }
    document.getElementById('iwAddCustom').addEventListener('click', addCustomRow);

    // ---- Recent requests
    function loadRecent() {
      fetch('/indent/my-requests?limit=20').then(r=>r.json()).then(function(d){
        var host = document.getElementById('iwRecent');
        if (!d.success || !d.requests || d.requests.length === 0) {
          host.innerHTML =
            '<div class="iw-empty">' +
              '<i class="bi bi-journal"></i>' +
              '<div class="iw-empty-h">Nothing here yet</div>' +
              '<div class="iw-empty-sub">Submitted indents will appear in this ledger.</div>' +
            '</div>';
          return;
        }
        host.innerHTML = '';
        d.requests.forEach(function(r){
          var item = document.createElement('div');
          item.className = 'iw-req-item';
          var lotBit = r.lot_no ? '<span class="iw-req-lot">' + esc(String(r.lot_no).toUpperCase()) + '</span> · ' : '';
          var skuBit = r.lot_sku ? esc(r.lot_sku) + ' · ' : '';
          item.innerHTML =
            '<div class="iw-req-time">' + esc(fmtDate(r.created_at)) + '</div>' +
            '<div class="iw-req-body">' +
              '<div class="iw-req-desc">' + esc(r.goods_description) + '</div>' +
              '<div class="iw-req-meta">' + lotBit + skuBit + 'qty ' + esc(r.quantity_requested) + '</div>' +
            '</div>' +
            '<span class="iw-status ' + esc(r.status) + '">' + esc(r.status) + '</span>';
          host.appendChild(item);
        });
      }).catch(function(){
        document.getElementById('iwRecent').innerHTML =
          '<div class="iw-empty"><i class="bi bi-exclamation-circle"></i><div class="iw-empty-h">Failed to load</div></div>';
      });
    }
    loadRecent();

    // ---- Submit
    document.getElementById('iwSubmit').addEventListener('click', function(){
      if (state.submitting) return;
      var items = [];

      Array.from(document.querySelectorAll('.iw-row.auto')).forEach(function(r){
        var qty = parseFloat(r.querySelector('.iw-qty').value) || 0;
        if (qty <= 0) return;
        var variantInput = r.querySelector('.iw-variant');
        var variant = variantInput ? variantInput.value.trim() : (r.dataset.variant || '');
        items.push({
          goods_id: null,
          goods_description: r.querySelector('.iw-row__title').textContent.trim().replace(/^Auto\s*/, '') + (variant ? ' ' + variant : ''),
          quantity: qty,
          category_id: null,
          category_name: r.dataset.category,
          variant_number: variant || null,
          lot_nos: isStitching ? state.lots.map(function(l){return l.lot_no;}) : [document.getElementById('iwSingleLot') ? document.getElementById('iwSingleLot').value || null : null],
          split_evenly: false
        });
      });

      Array.from(document.querySelectorAll('.iw-row.custom')).forEach(function(r){
        var $sel = $(r).find('.iw-goods');
        var goodsId = $sel.val();
        var qty = parseFloat(r.querySelector('.iw-qty').value) || 0;
        if (qty <= 0) return;
        var variant = r.querySelector('.iw-variant').value.trim();
        items.push({
          goods_id: goodsId || null,
          goods_description: $sel.find(':selected').text() || null,
          quantity: qty,
          category_id: r.dataset.categoryId || null,
          variant_number: variant || null,
          lot_nos: isStitching ? state.lots.map(function(l){return l.lot_no;}) : [document.getElementById('iwSingleLot') ? document.getElementById('iwSingleLot').value || null : null]
        });
      });

      if (items.length === 0) { toast('Enter at least one quantity', 'warning'); return; }
      if (isStitching && state.lots.length === 0) { toast('Pick at least one lot first', 'warning'); return; }

      state.submitting = true;
      var btn = document.getElementById('iwSubmit');
      btn.disabled = true;
      var prevHtml = btn.innerHTML;
      btn.innerHTML = '<i class="bi bi-arrow-clockwise"></i> Submitting…';

      fetch('/indent/stage-create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: items })
      })
      .then(r => r.json().then(function(d){ return { status: r.status, body: d }; }))
      .then(function(res){
        var d = res.body;
        if (d.success) {
          var msg = 'Submitted ' + d.count + ' indent line(s)';
          if (d.duplicates && d.duplicates.length) msg += ' · skipped ' + d.duplicates.length + ' duplicate(s)';
          toast(msg, 'success');
          state._customs = [];
          state.bom.forEach(function(b){ b.qty = b.default_qty || 0; });
          renderRows();
          loadRecent();
        } else if (res.status === 409) {
          toast('All lines are duplicates of existing pending indents.', 'warning');
        } else {
          toast(d.error || 'Failed to submit', 'error');
        }
      })
      .catch(function(err){ toast('Error: ' + err.message, 'error'); })
      .finally(function(){
        state.submitting = false; btn.disabled = false; btn.innerHTML = prevHtml;
      });
    });
  }
})();
</script>
