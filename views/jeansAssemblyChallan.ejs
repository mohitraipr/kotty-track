<%- include('partials/header', { pageTitle: 'Jeans Assembly Challan #' + entry.id }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/jeansassemblydashboard' }) %>

<!-- Main Content -->
<main class="main-content" style="margin-left: 0;">
  <div class="container" style="max-width: 900px; margin: 0 auto;">

    <!-- Page Header with Back Button -->
    <div class="page-header">
      <div class="breadcrumbs">
        <a href="/jeansassemblydashboard">Jeans Assembly Dashboard</a>
        <span class="separator">/</span>
        <span>Challan #<%= entry.id %></span>
      </div>
      <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <h1 class="page-title">Jeans Assembly To Washing Challan</h1>
        <div class="d-flex gap-2">
          <button onclick="window.print()" class="btn btn-secondary">
            <i class="bi bi-printer"></i>
            Print / Save as PDF
          </button>
          <a href="/jeansassemblydashboard" class="btn btn-outline">
            <i class="bi bi-arrow-left"></i>
            Back
          </a>
        </div>
      </div>
    </div>

    <!-- Challan Container (for print) -->
    <div class="challan-container">

      <!-- Company Header -->
      <div class="company-header">
        <h2 class="company-name">Kotty Lifestyle Private Limited</h2>
        <p class="company-address">GB-65, Bharat Vihar, Lakkarpur, Faridabad, 121009</p>
        <p class="company-contact">Mobile: 8920374028</p>
      </div>

      <div class="challan-title-box">
        <span class="challan-title">Jeans Assembly To Washing Challan</span>
      </div>

      <!-- Basic Info Card -->
      <div class="card mb-4">
        <div class="card-header">
          <h3 class="card-title">Challan Details</h3>
          <span class="badge badge-primary">
            <i class="bi bi-file-earmark-text me-1"></i>
            Challan #<%= entry.id %>
          </span>
        </div>
        <div class="card-body">
          <div class="row g-4">
            <div class="col-md-4">
              <div class="detail-item">
                <span class="detail-label">Challan No</span>
                <span class="detail-value"><%= entry.id %></span>
              </div>
            </div>
            <div class="col-md-4">
              <div class="detail-item">
                <span class="detail-label">Challan Date</span>
                <span class="detail-value">
                  <% if (washingAssignments && washingAssignments.length > 0) { %>
                    <%= washingAssignments[0].assigned_on %>
                  <% } else { %>
                    ---
                  <% } %>
                </span>
              </div>
            </div>
            <div class="col-md-4">
              <div class="detail-item">
                <span class="detail-label">Lot No</span>
                <span class="detail-value"><%= entry.lot_no %></span>
              </div>
            </div>
            <div class="col-md-4">
              <div class="detail-item">
                <span class="detail-label">SKU Number</span>
                <span class="detail-value"><%= entry.sku %></span>
              </div>
            </div>
            <div class="col-md-4">
              <div class="detail-item">
                <span class="detail-label">Assigned To</span>
                <span class="detail-value">
                  <% if (washingAssignments && washingAssignments.length > 0) { %>
                    <%= washingAssignments[0].assignedUserName %>
                  <% } else { %>
                    ---
                  <% } %>
                </span>
              </div>
            </div>
            <div class="col-md-4">
              <div class="detail-item">
                <span class="detail-label">GSTIN</span>
                <span class="detail-value">06AAGCK0951K1ZH</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Size Details Card -->
      <div class="card mb-4">
        <div class="card-header">
          <h3 class="card-title">Size Details</h3>
          <span class="badge badge-neutral"><%= sizes.length %> size<%= sizes.length !== 1 ? 's' : '' %></span>
        </div>
        <div class="table-container" style="border: none; border-radius: 0;">
          <table class="table">
            <thead>
              <tr>
                <th>Size Label</th>
                <th class="text-end">Pieces</th>
              </tr>
            </thead>
            <tbody>
              <% sizes.forEach(sz => { %>
                <tr>
                  <td><span class="fw-medium"><%= sz.size_label %></span></td>
                  <td class="text-end"><%= sz.pieces %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <div class="card-footer">
          <div class="d-flex justify-content-end align-items-center gap-4">
            <span class="text-secondary" style="font-size: var(--text-sm);">Total Pieces</span>
            <span class="total-amount"><%= entry.total_pieces %></span>
          </div>
        </div>
      </div>

      <!-- Washing Assignments Card -->
      <div class="card mb-4">
        <div class="card-header">
          <h3 class="card-title">Washing Assignments</h3>
          <span class="badge badge-<%= washingAssignments && washingAssignments.length > 0 ? 'success' : 'neutral' %>">
            <%= washingAssignments && washingAssignments.length || 0 %> assignment<%= (washingAssignments && washingAssignments.length !== 1) ? 's' : '' %>
          </span>
        </div>
        <div class="card-body">
          <% if (washingAssignments && washingAssignments.length > 0) { %>
            <% washingAssignments.forEach((wa, index) => { %>
              <div class="assignment-block">
                <div class="row g-3">
                  <div class="col-md-4">
                    <div class="detail-item">
                      <span class="detail-label">Assigned To</span>
                      <span class="detail-value"><%= wa.assignedUserName %></span>
                    </div>
                  </div>
                  <div class="col-md-4">
                    <div class="detail-item">
                      <span class="detail-label">Assigned By</span>
                      <span class="detail-value"><%= wa.masterUserName %></span>
                    </div>
                  </div>
                  <div class="col-md-4">
                    <div class="detail-item">
                      <span class="detail-label">Status</span>
                      <span class="detail-value">
                        <% if (wa.is_approved === null) { %>
                          <span class="badge badge-warning">Pending</span>
                        <% } else if (wa.is_approved === 1) { %>
                          <span class="badge badge-success">Approved</span>
                        <% } else { %>
                          <span class="badge badge-danger">Denied</span>
                        <% } %>
                      </span>
                    </div>
                  </div>
                  <div class="col-md-4">
                    <div class="detail-item">
                      <span class="detail-label">Assigned On</span>
                      <span class="detail-value"><%= wa.assigned_on %></span>
                    </div>
                  </div>
                  <div class="col-md-4">
                    <div class="detail-item">
                      <span class="detail-label">Target Day</span>
                      <span class="detail-value"><%= wa.target_day || 'N/A' %></span>
                    </div>
                  </div>
                </div>
              </div>
              <% if (index < washingAssignments.length - 1) { %>
                <hr class="assignment-divider">
              <% } %>
            <% }) %>
          <% } else { %>
            <div class="empty-state">
              <i class="bi bi-inbox"></i>
              <p>No washing assignments found.</p>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Update Logs Card -->
      <div class="card mb-4">
        <div class="card-header">
          <h3 class="card-title">Update Logs</h3>
          <span class="badge badge-neutral"><%= updates && updates.length || 0 %> update<%= (updates && updates.length !== 1) ? 's' : '' %></span>
        </div>
        <div class="card-body">
          <% if (updates && updates.length) { %>
            <div class="updates-list">
              <% updates.forEach(u => { %>
                <div class="update-item">
                  <span class="update-size"><%= u.size_label %></span>
                  <span class="update-pieces">+<%= u.pieces %></span>
                  <span class="update-date"><%= u.updated_at %></span>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <div class="empty-state">
              <i class="bi bi-clock-history"></i>
              <p>No updates found.</p>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Signature Section -->
      <div class="signature-section">
        <div class="signature-box">
          <div class="signature-line"></div>
          <p class="signature-label">Receiver's Signature</p>
        </div>
        <div class="signature-box">
          <div class="signature-line"></div>
          <p class="signature-label">Authorized Signatory</p>
        </div>
      </div>

    </div> <!-- .challan-container -->

  </div>
</main>

<style>
  /* Company Header Styling */
  .company-header {
    text-align: center;
    padding: var(--space-6) 0;
    border-bottom: 2px solid var(--charcoal);
    margin-bottom: var(--space-6);
  }

  .company-name {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    color: var(--charcoal);
    margin: 0 0 var(--space-2) 0;
    text-transform: uppercase;
  }

  .company-address,
  .company-contact {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin: var(--space-1) 0;
  }

  /* Challan Title */
  .challan-title-box {
    text-align: center;
    margin-bottom: var(--space-6);
  }

  .challan-title {
    display: inline-block;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--terracotta);
    text-transform: uppercase;
    padding: var(--space-2) var(--space-4);
    border: 2px solid var(--terracotta);
    border-radius: var(--radius-md);
  }

  /* Detail Item Styling */
  .detail-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .detail-label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
  }

  .detail-value {
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--text-primary);
  }

  /* Total Amount */
  .total-amount {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    color: var(--terracotta);
    font-weight: 400;
  }

  /* Assignment Block */
  .assignment-block {
    padding: var(--space-4) 0;
  }

  .assignment-divider {
    border: none;
    border-top: 1px dashed var(--border-default);
    margin: var(--space-4) 0;
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: var(--space-8) var(--space-4);
    color: var(--text-secondary);
  }

  .empty-state i {
    font-size: 2rem;
    margin-bottom: var(--space-3);
    opacity: 0.5;
  }

  .empty-state p {
    margin: 0;
    font-size: var(--text-sm);
  }

  /* Updates List */
  .updates-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .update-item {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-3);
    background: var(--surface-secondary);
    border-radius: var(--radius-md);
  }

  .update-size {
    font-weight: 600;
    color: var(--text-primary);
    min-width: 60px;
  }

  .update-pieces {
    color: var(--success-text);
    font-weight: 500;
  }

  .update-date {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    margin-left: auto;
  }

  /* Signature Section */
  .signature-section {
    display: flex;
    justify-content: space-between;
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    gap: var(--space-8);
  }

  .signature-box {
    flex: 1;
    max-width: 250px;
    text-align: center;
  }

  .signature-line {
    border-top: 1px solid var(--charcoal);
    margin-bottom: var(--space-2);
    padding-top: 60px;
  }

  .signature-label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-secondary);
    margin: 0;
  }

  /* Table Enhancements */
  .fw-medium {
    font-weight: 500;
  }

  /* Print Styles */
  @page {
    size: A4;
    margin: 10mm;
  }

  @media print {
    .kotty-navbar,
    .breadcrumbs,
    .btn,
    .page-header .d-flex.gap-2,
    .sidebar-overlay {
      display: none !important;
    }

    body {
      background: #fff !important;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .main-content {
      margin-top: 0 !important;
      padding: 0 !important;
    }

    .container {
      max-width: 100% !important;
      padding: 0 !important;
    }

    .card {
      box-shadow: none !important;
      border: 1px solid #333 !important;
      break-inside: avoid;
    }

    .challan-container {
      page-break-inside: avoid;
    }

    .page-title {
      display: none;
    }

    .company-header {
      border-bottom-color: #333;
    }

    .challan-title-box {
      margin-top: 0;
    }

    .challan-title {
      border-color: #333;
      color: #333;
    }

    .signature-line {
      border-top-color: #333;
    }

    .badge {
      border: 1px solid #333 !important;
      background: transparent !important;
      color: #333 !important;
    }
  }
</style>

<%- include('partials/footer') %>
