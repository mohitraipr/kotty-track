<%- include('partials/header', { pageTitle: 'Approve Finishing' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/finishingdashboard' }) %>

<style>
  /* Page Layout - No Sidebar */
  .page-wrapper {
    margin-top: var(--navbar-height);
    padding: 28px;
    min-height: calc(100vh - var(--navbar-height));
    background: var(--bg-page);
  }

  @media (max-width: 768px) {
    .page-wrapper {
      padding: 16px;
    }
  }

  /* Sticky Search Bar */
  .sticky-search {
    position: sticky;
    top: var(--navbar-height);
    z-index: 100;
    background: var(--bg-page);
    padding: 16px 0;
    margin: -16px 0 16px 0;
  }

  /* Search Input */
  .search-input-wrapper {
    position: relative;
    max-width: 400px;
  }

  .search-input-wrapper i {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
  }

  .search-input {
    width: 100%;
    padding: 12px 14px 12px 42px;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--text-primary);
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }

  .search-input:focus {
    outline: none;
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px var(--terracotta-bg);
  }

  .search-input::placeholder {
    color: var(--text-muted);
  }

  /* Assignment Card */
  .assignment-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    margin-bottom: 16px;
    transition: all var(--transition-fast);
  }

  .assignment-card:hover {
    box-shadow: var(--shadow-sm);
    border-color: var(--border-medium);
  }

  .assignment-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 18px 20px;
    border-bottom: 1px solid var(--border-light);
    gap: 16px;
    flex-wrap: wrap;
  }

  .assignment-id {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--text-primary);
  }

  .assignment-id span {
    color: var(--terracotta);
  }

  .assignment-meta {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .meta-item i {
    color: var(--terracotta);
    font-size: 14px;
  }

  .assignment-body {
    padding: 18px 20px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
  }

  .detail-group {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .detail-label {
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-muted);
  }

  .detail-value {
    font-size: var(--text-sm);
    color: var(--text-primary);
    font-weight: 500;
  }

  .sizes-list {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .size-badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    background: var(--gray-100);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--text-primary);
  }

  .assignment-actions {
    padding: 16px 20px;
    background: var(--gray-50);
    border-top: 1px solid var(--border-light);
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
  }

  .action-form {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .remark-input {
    flex: 1;
    min-width: 200px;
    padding: 10px 14px;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--text-primary);
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }

  .remark-input:focus {
    outline: none;
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px var(--terracotta-bg);
  }

  .remark-input::placeholder {
    color: var(--text-muted);
  }

  /* Action Buttons */
  .btn-approve {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 10px 20px;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    border-radius: var(--radius-md);
    border: none;
    cursor: pointer;
    transition: all var(--transition-fast);
    background: var(--success);
    color: white;
  }

  .btn-approve:hover:not(:disabled) {
    background: #247a50;
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  .btn-approve:disabled {
    opacity: 0.65;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  .btn-deny {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 10px 20px;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    border-radius: var(--radius-md);
    border: 1px solid var(--danger);
    cursor: pointer;
    transition: all var(--transition-fast);
    background: transparent;
    color: var(--danger);
  }

  .btn-deny:hover:not(:disabled) {
    background: var(--danger);
    color: white;
  }

  .btn-deny:disabled {
    opacity: 0.65;
    cursor: not-allowed;
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: 64px 24px;
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
  }

  .empty-state-icon {
    width: 80px;
    height: 80px;
    margin: 0 auto 20px;
    background: var(--success-light);
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .empty-state-icon i {
    font-size: 36px;
    color: var(--success);
  }

  .empty-state-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--text-primary);
    margin-bottom: 8px;
  }

  .empty-state-text {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    max-width: 320px;
    margin: 0 auto;
  }

  /* Responsive */
  @media (max-width: 576px) {
    .assignment-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .assignment-body {
      grid-template-columns: 1fr;
    }

    .action-form {
      flex-direction: column;
      align-items: stretch;
    }

    .remark-input {
      min-width: 100%;
    }

    .btn-approve,
    .btn-deny {
      width: 100%;
      justify-content: center;
    }

    /* Hide deny form on very small screens */
    .deny-form {
      display: none;
    }
  }
</style>

<div class="page-wrapper">
  <div class="container-fluid" style="max-width: 1200px; margin: 0 auto;">
    <!-- Flash Messages -->
    <% if (error && error.length) { %>
      <div class="alert alert-danger">
        <i class="bi bi-exclamation-circle me-2"></i>
        <%= error.join(' | ') %>
      </div>
    <% } %>
    <% if (success && success.length) { %>
      <div class="alert alert-success">
        <i class="bi bi-check-circle me-2"></i>
        <%= success.join(' | ') %>
      </div>
    <% } %>

    <!-- Page Header -->
    <div class="page-header">
      <nav class="breadcrumbs">
        <a href="/finishingdashboard">Dashboard</a>
        <span class="separator"><i class="bi bi-chevron-right"></i></span>
        <span>Pending Approvals</span>
      </nav>
      <h1 class="page-title">Pending Finishing Assignments</h1>
      <p class="page-subtitle">Review and approve finishing assignments</p>
    </div>

    <!-- Sticky Search -->
    <div class="sticky-search">
      <div class="search-input-wrapper">
        <i class="bi bi-search"></i>
        <input type="text" id="liveSearch" class="search-input" placeholder="Search by lot, SKU, department..." />
      </div>
    </div>

    <!-- Assignments List -->
    <div id="assignmentsList">
      <% if (!pending || !pending.length) { %>
        <div class="empty-state">
          <div class="empty-state-icon">
            <i class="bi bi-check-circle"></i>
          </div>
          <h3 class="empty-state-title">All Caught Up</h3>
          <p class="empty-state-text">There are no pending finishing assignments to approve at the moment.</p>
        </div>
      <% } else { %>
        <% pending.forEach(p => { %>
          <div class="assignment-card" data-searchable>
            <div class="assignment-header">
              <div class="assignment-id">
                Assignment <span>#<%= p.id %></span>
              </div>
              <div class="assignment-meta">
                <div class="meta-item">
                  <i class="bi bi-building"></i>
                  <span><%= p.department %></span>
                </div>
                <div class="meta-item">
                  <i class="bi bi-calendar3"></i>
                  <span><%= p.assigned_on %></span>
                </div>
              </div>
            </div>

            <div class="assignment-body">
              <div class="detail-group">
                <span class="detail-label">Lot Number</span>
                <span class="detail-value"><%= p.lot_no %></span>
              </div>

              <div class="detail-group">
                <span class="detail-label">Total Pieces</span>
                <span class="detail-value"><%= p.total_pieces %></span>
              </div>

              <div class="detail-group">
                <span class="detail-label">Cutting SKU</span>
                <span class="detail-value"><%= p.cutting_sku || 'N/A' %></span>
              </div>

              <div class="detail-group">
                <span class="detail-label">Cutting Remark</span>
                <span class="detail-value"><%= p.cutting_remark || 'N/A' %></span>
              </div>

              <div class="detail-group" style="grid-column: 1 / -1;">
                <span class="detail-label">Sizes</span>
                <div class="sizes-list">
                  <% if (p.sizes && p.sizes.length) { %>
                    <% p.sizes.forEach(s => { %>
                      <span class="size-badge"><%= s.size_label %>: <%= s.pieces %></span>
                    <% }) %>
                  <% } else { %>
                    <span class="detail-value">N/A</span>
                  <% } %>
                </div>
              </div>
            </div>

            <div class="assignment-actions">
              <!-- Approve Form -->
              <form action="/finishingdashboard/approve/<%= p.id %>" method="POST" class="action-form" onsubmit="disableAllButtons(this); return false;">
                <input type="text" name="assignment_remark" class="remark-input" placeholder="Add an optional remark..." />
                <button type="submit" class="btn-approve">
                  <i class="bi bi-check-lg"></i>
                  Approve
                </button>
              </form>

              <!-- Deny Form (hidden on very small screens) -->
              <form action="/finishingdashboard/deny/<%= p.id %>" method="POST" class="action-form deny-form" style="margin-top: 12px;" onsubmit="disableAllButtons(this); return false;">
                <input type="text" name="assignment_remark" class="remark-input" placeholder="Reason for denial..." />
                <button type="submit" class="btn-deny" disabled>
                  <i class="bi bi-x-lg"></i>
                  Deny
                </button>
              </form>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</div>

<script>
  // Disable all buttons on form submission to prevent duplicate submissions
  function disableAllButtons(form) {
    const buttons = document.querySelectorAll('button');
    buttons.forEach(btn => btn.disabled = true);
    form.submit();
  }

  // Live Search functionality
  document.getElementById('liveSearch').addEventListener('input', function() {
    var searchValue = this.value.toLowerCase();
    var cards = document.querySelectorAll('[data-searchable]');

    cards.forEach(function(card) {
      var cardText = card.textContent.toLowerCase();
      if (cardText.indexOf(searchValue) > -1) {
        card.style.display = '';
      } else {
        card.style.display = 'none';
      }
    });
  });
</script>

<%- include('partials/footer') %>
