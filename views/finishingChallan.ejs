<% const pageTitle = 'Finishing Challan - ' + entry.lot_no; %>
<%- include('partials/header') %>

<!-- Print-specific styles -->
<style>
  @page { size: A4; margin: 10mm; }
  @media print {
    html, body { height: 100%; overflow: hidden; }
    .kotty-navbar, .no-print, .sidebar-overlay { display: none !important; }
    body { padding-top: 0 !important; background: #fff !important; }
    .challan-wrap {
      box-shadow: none !important;
      margin: 0 !important;
      max-width: 100% !important;
    }
  }

  /* Challan Container */
  .challan-wrap {
    max-width: 800px;
    margin: 0 auto;
    background: var(--bg-card);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
    padding: 32px;
  }

  /* Header Section */
  .challan-header {
    text-align: center;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 2px solid var(--terracotta);
  }

  .challan-header h1 {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    color: var(--charcoal);
    margin-bottom: 4px;
    letter-spacing: 0.5px;
  }

  .challan-header h2 {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--terracotta);
    font-weight: 500;
    margin: 0;
  }

  /* Meta Table */
  .meta-table {
    width: 100%;
    margin: 20px 0;
    border-collapse: collapse;
  }

  .meta-table td {
    padding: 8px 12px;
    font-size: var(--text-sm);
    color: var(--text-secondary);
    vertical-align: top;
  }

  .meta-table td:nth-child(odd) {
    font-weight: 600;
    color: var(--text-primary);
    width: 15%;
  }

  .meta-table td:nth-child(even) {
    width: 35%;
  }

  .meta-table tr {
    border-bottom: 1px solid var(--border-light);
  }

  .meta-table tr:last-child {
    border-bottom: none;
  }

  /* Section Title */
  .section-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--charcoal);
    margin: 28px 0 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border-medium);
  }

  /* Data Tables */
  .data-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 16px;
  }

  .data-table th,
  .data-table td {
    border: 1px solid var(--border-medium);
    padding: 10px 12px;
    text-align: center;
    font-size: var(--text-sm);
  }

  .data-table th {
    background: var(--cream-dark);
    font-weight: 600;
    color: var(--text-primary);
    font-family: var(--font-body);
  }

  .data-table td {
    color: var(--text-secondary);
  }

  .data-table .total-row td {
    font-weight: 600;
    background: var(--terracotta-bg);
    color: var(--terracotta-dark);
  }

  /* Image Section */
  .challan-image {
    margin: 20px 0;
    text-align: center;
  }

  .challan-image img {
    max-width: 100%;
    max-height: 250px;
    border: 1px solid var(--border-medium);
    border-radius: var(--radius-lg);
  }

  /* Signatures */
  .signatures {
    display: flex;
    justify-content: space-between;
    margin-top: 48px;
    padding-top: 16px;
  }

  .sig-box {
    width: 30%;
    text-align: center;
    padding-top: 8px;
    border-top: 1px solid var(--charcoal);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    font-weight: 500;
  }

  /* Print Button */
  .btn-print {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    font-size: var(--text-sm);
    font-weight: 500;
    font-family: var(--font-body);
    border: none;
    border-radius: var(--radius-md);
    background: var(--terracotta);
    color: white;
    cursor: pointer;
    transition: background var(--transition-fast);
    margin-bottom: 20px;
  }

  .btn-print:hover {
    background: var(--terracotta-dark);
  }

  /* Page Layout */
  .page-content {
    padding: 24px;
    padding-top: calc(var(--navbar-height) + 24px);
    min-height: 100vh;
    background: var(--bg-page);
  }

  /* Dispatch Info */
  .dispatch-info {
    margin-top: 8px;
    padding: 8px 12px;
    background: var(--cream-dark);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
  }

  .dispatch-info strong {
    color: var(--terracotta);
  }
</style>

<% const dashboardUrl = '/finishingdashboard'; %>
<%- include('partials/navbar', { dashboardUrl: dashboardUrl }) %>

<div class="page-content">
  <div class="challan-wrap">
    <% const pad = n => (n < 10 ? '0' : '') + n; %>

    <!-- Print Button -->
    <button class="btn-print no-print" onclick="window.print()">
      <i class="bi bi-printer"></i> Print Challan
    </button>

    <!-- Header -->
    <div class="challan-header">
      <h1>KOTTY LIFESTYLE</h1>
      <h2>Finishing Challan</h2>
    </div>

    <!-- Meta Information -->
    <table class="meta-table">
      <tr>
        <td>Challan ID:</td>
        <td>#<%= entry.id %></td>
        <td>Date:</td>
        <td>
          <% const d = new Date(entry.created_at); %>
          <%= pad(d.getDate()) %>-<%= pad(d.getMonth() + 1) %>-<%= d.getFullYear() %>
        </td>
      </tr>
      <tr>
        <td>Lot No:</td>
        <td><%= entry.lot_no %></td>
        <td>SKU:</td>
        <td><%= entry.sku %></td>
      </tr>
      <tr>
        <td>Total Pieces:</td>
        <td><%= entry.total_pieces %></td>
        <td>Created By:</td>
        <td><%= user.username %></td>
      </tr>
      <tr>
        <td>Remark:</td>
        <td colspan="3">
          <%= entry.cutting_remark || '—' %>
          <% if (dispatches && dispatches.length) { %>
            <div class="dispatch-info">
              <strong>Dispatched:</strong><br>
              <% dispatches.forEach((disp, idx) => {
                const dt = new Date(disp.sent_at);
              %>
                - <%= disp.destination %> (<%= pad(dt.getDate()) %>-<%= pad(dt.getMonth() + 1) %>-<%= dt.getFullYear() %>)<br>
              <% }) %>
            </div>
          <% } %>
        </td>
      </tr>
    </table>

    <!-- Image (Optional) -->
    <% if (entry.image_url) { %>
      <div class="challan-image">
        <img src="<%= entry.image_url %>" alt="Attached Image">
      </div>
    <% } %>

    <!-- Size Breakdown -->
    <h3 class="section-title">Size Breakdown</h3>
    <table class="data-table">
      <thead>
        <tr>
          <th>Sl No.</th>
          <th>Size Label</th>
          <th>Pieces</th>
        </tr>
      </thead>
      <tbody>
        <% let grandTot = 0; %>
        <% sizes.forEach((sz, i) => { grandTot += sz.pieces; %>
          <tr>
            <td><%= i + 1 %></td>
            <td><%= sz.size_label %></td>
            <td><%= sz.pieces %></td>
          </tr>
        <% }); %>
        <tr class="total-row">
          <td colspan="2">Total</td>
          <td><%= grandTot %></td>
        </tr>
      </tbody>
    </table>

    <!-- Update Log -->
    <% if (updates.length) { %>
      <h3 class="section-title">Updates (Log)</h3>
      <table class="data-table">
        <thead>
          <tr>
            <th>Sl No.</th>
            <th>Date &amp; Time</th>
            <th>Size</th>
            <th>Pieces Added</th>
          </tr>
        </thead>
        <tbody>
          <% updates.forEach((u, i) => { %>
            <tr>
              <td><%= i + 1 %></td>
              <td>
                <% const up = new Date(u.updated_at); %>
                <%= pad(up.getDate()) %>-<%= pad(up.getMonth() + 1) %>-<%= up.getFullYear() %>
                <%= pad(up.getHours()) %>:<%= pad(up.getMinutes()) %>
              </td>
              <td><%= u.size_label %></td>
              <td><%= u.pieces %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>

    <!-- Signatures -->
    <div class="signatures">
      <div class="sig-box">Issued By</div>
      <div class="sig-box">Checked By</div>
      <div class="sig-box">Received By</div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
