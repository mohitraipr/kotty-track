<%- include('partials/header', { pageTitle: 'SKU Details - ' + sku }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/dashboard' }) %>

<style>
  .page-container {
    padding-top: calc(var(--navbar-height) + 24px);
    padding-bottom: 48px;
    min-height: 100vh;
  }
  .page-header {
    margin-bottom: 24px;
  }
  .page-title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    color: var(--text-primary);
    margin-bottom: 8px;
  }
  .page-subtitle {
    color: var(--text-secondary);
    font-size: var(--text-base);
  }
  .breadcrumb-nav {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
    font-size: var(--text-sm);
  }
  .breadcrumb-nav a {
    color: var(--terracotta);
    text-decoration: none;
    transition: var(--transition-fast);
  }
  .breadcrumb-nav a:hover {
    color: var(--terracotta-dark);
  }
  .breadcrumb-nav span {
    color: var(--text-muted);
  }
  .sku-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--terracotta-bg);
    color: var(--terracotta);
    padding: 8px 16px;
    border-radius: var(--radius-full);
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    font-weight: 500;
    margin-bottom: 16px;
  }
  .sku-badge i {
    font-size: 1.25rem;
  }
  .kotty-card {
    background: var(--bg-card);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--border-light);
    overflow: hidden;
    margin-bottom: 24px;
  }
  .kotty-card-header {
    padding: 20px 24px;
    border-bottom: 1px solid var(--border-light);
    background: var(--gray-50);
  }
  .kotty-card-header h2, .kotty-card-header h3 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0;
  }
  .kotty-card-header i {
    color: var(--terracotta);
  }
  .kotty-card-body {
    padding: 24px;
  }
  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
  }
  .info-item {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .info-label {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .info-label i {
    color: var(--terracotta);
    font-size: 0.875rem;
  }
  .info-value {
    font-size: var(--text-lg);
    color: var(--text-primary);
    font-weight: 500;
  }
  .placeholder-message {
    text-align: center;
    padding: 48px 24px;
    color: var(--text-secondary);
  }
  .placeholder-message i {
    font-size: 3rem;
    color: var(--terracotta);
    margin-bottom: 16px;
    display: block;
  }
  .placeholder-message h4 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--text-primary);
    margin-bottom: 8px;
  }
  .placeholder-message p {
    color: var(--text-muted);
    max-width: 400px;
    margin: 0 auto;
  }
  .kotty-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 10px 20px;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--text-sm);
    border-radius: var(--radius-md);
    border: none;
    cursor: pointer;
    transition: var(--transition-fast);
    text-decoration: none;
  }
  .kotty-btn-primary {
    background: var(--terracotta);
    color: white;
  }
  .kotty-btn-primary:hover {
    background: var(--terracotta-dark);
    color: white;
  }
  .kotty-btn-outline {
    background: transparent;
    color: var(--text-primary);
    border: 1px solid var(--border-medium);
  }
  .kotty-btn-outline:hover {
    background: var(--gray-100);
    border-color: var(--border-dark);
    color: var(--text-primary);
  }
  .action-buttons {
    display: flex;
    gap: 12px;
    margin-top: 24px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .page-title {
      font-size: var(--text-2xl);
    }
    .info-grid {
      grid-template-columns: 1fr;
    }
    .action-buttons {
      flex-direction: column;
    }
    .kotty-btn {
      width: 100%;
    }
  }
</style>

<div class="page-container">
  <div class="container" style="max-width: var(--content-max-width);">
    <!-- Breadcrumb Navigation -->
    <nav class="breadcrumb-nav">
      <a href="/dashboard"><i class="bi bi-house-door"></i> Dashboard</a>
      <span>/</span>
      <span>SKU Details</span>
    </nav>

    <!-- Page Header -->
    <div class="page-header">
      <h1 class="page-title">SKU Details</h1>
      <div class="sku-badge">
        <i class="bi bi-upc-scan"></i>
        <%= sku %>
      </div>
    </div>

    <!-- SKU Information Card -->
    <div class="kotty-card">
      <div class="kotty-card-header">
        <h2><i class="bi bi-box-seam"></i> Product Information</h2>
      </div>
      <div class="kotty-card-body">
        <div class="placeholder-message">
          <i class="bi bi-boxes"></i>
          <h4>SKU Information</h4>
          <p>This page can be extended to show detailed inventory, history, and tracking information for SKU: <strong><%= sku %></strong></p>
        </div>

        <div class="action-buttons" style="justify-content: center;">
          <a href="/dashboard" class="kotty-btn kotty-btn-outline">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
          </a>
          <a href="/inventory" class="kotty-btn kotty-btn-primary">
            <i class="bi bi-archive"></i> View Inventory
          </a>
        </div>
      </div>
    </div>

    <!-- Additional sections can be added here -->
    <!-- Example: Inventory History Card -->
