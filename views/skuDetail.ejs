    <div class="kotty-card">
      <div class="kotty-card-header">
        <h3><i class="bi bi-clock-history"></i> Inventory History</h3>
      </div>
      <div class="kotty-card-body">
        <div class="info-grid">
          <div class="info-item">
            <span class="info-label"><i class="bi bi-box"></i> Current Stock</span>
            <span class="info-value">0 units</span>
          </div>
          <div class="info-item">
            <span class="info-label"><i class="bi bi-graph-up"></i> Sold This Month</span>
            <span class="info-value">0 units</span>
          </div>
          <div class="info-item">
            <span class="info-label"><i class="bi bi-calendar-event"></i> Last Updated</span>
            <span class="info-value">-</span>
          </div>
        </div>
      </div>
    </div>
    -->

  </div>
</div>

<%- include('partials/footer') %>
