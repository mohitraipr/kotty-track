<%- include('partials/header', { pageTitle: 'Accounts DC Challan List' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/accounts-challan' }) %>

<% const isSapna = user && user.username && user.username.toLowerCase() === 'sapna'; %>

<!-- Main Content -->
<main class="main-content" style="margin-left: 0;">
  <div class="container-fluid" style="max-width: 1400px; margin: 0 auto;">

    <!-- Page Header -->
    <div class="page-header">
      <div class="breadcrumbs">
        <a href="/accounts-challan">Dashboard</a>
        <span class="separator">/</span>
        <span>Challan List</span>
      </div>
      <h1 class="page-title">DC Challan List</h1>
      <p class="page-subtitle">Track every challan and open detailed views</p>
    </div>

    <!-- Alerts -->
    <% if (error && error.length) { %>
      <div class="alert alert-danger">
        <i class="bi bi-exclamation-circle"></i>
        <div>
          <% error.forEach(msg => { %><p class="mb-0"><%= msg %></p><% }); %>
        </div>
      </div>
    <% } %>
    <% if (success && success.length) { %>
      <div class="alert alert-success">
        <i class="bi bi-check-circle"></i>
        <div>
          <% success.forEach(msg => { %><p class="mb-0"><%= msg %></p><% }); %>
        </div>
      </div>
    <% } %>

    <!-- Tab Navigation -->
    <div class="card mb-4">
      <div class="card-body" style="padding: 12px 20px;">
        <nav class="d-flex flex-wrap gap-2">
          <% if (isSapna) { %>
            <a href="/purchase" class="btn btn-secondary">
              <i class="bi bi-cart-fill"></i> Purchase
            </a>
          <% } %>
          <a href="/accounts-challan" class="btn btn-secondary">
            <i class="bi bi-file-earmark-text"></i> DC Challan
          </a>
          <a href="/accounts-challan/list" class="btn btn-primary">
            <i class="bi bi-list-ul"></i> Challan List
          </a>
          <% if (isSapna) { %>
            <a href="/accounts-challan/gst" class="btn btn-secondary">
              <i class="bi bi-receipt"></i> GST Master
            </a>
          <% } %>
        </nav>
      </div>
    </div>

    <!-- Search Card -->
    <div class="card mb-4">
      <div class="card-body">
        <form method="GET" action="/accounts-challan/list" class="d-flex flex-wrap gap-3 align-items-end">
          <div class="flex-grow-1" style="min-width: 250px; max-width: 500px;">
            <label class="form-label">Search Challans</label>
            <div class="position-relative">
              <input
                type="text"
                name="search"
                value="<%= search %>"
                class="form-input"
                placeholder="Search by challan number or lot number..."
                style="padding-left: 40px;"
                data-bs-toggle="tooltip"
                title="Type challan number or lot number to search"
              >
              <i class="bi bi-search position-absolute" style="left: 14px; top: 50%; transform: translateY(-50%); color: var(--text-muted);"></i>
            </div>
          </div>
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-search"></i> Search
          </button>
          <% if (search) { %>
            <a href="/accounts-challan/list" class="btn btn-secondary">
              <i class="bi bi-x-lg"></i> Clear
            </a>
          <% } %>
        </form>
      </div>
    </div>

    <!-- Challans Table -->
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">
          <i class="bi bi-file-earmark-text me-2" style="color: var(--terracotta);"></i>
          Recent Challans
        </h2>
        <% if (challans && challans.length) { %>
          <span class="badge badge-primary"><%= challans.length %> records</span>
        <% } %>
      </div>

      <div class="table-container" style="border: none; border-radius: 0;">
        <div class="table-responsive">
          <table class="table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Challan No</th>
                <th>Date</th>
                <th>Consignee</th>
                <th>Amount</th>
                <th style="text-align: center;">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (challans && challans.length) { %>
                <% challans.forEach(ch => { %>
                  <tr>
                    <td>
                      <span class="badge badge-neutral">#<%= ch.id %></span>
                    </td>
                    <td>
                      <span style="font-weight: 500; color: var(--text-primary);"><%= ch.challan_no %></span>
                    </td>
                    <td>
                      <% if (ch.challan_date) { %>
                        <div class="d-flex align-items-center gap-2">
                          <i class="bi bi-calendar3" style="color: var(--text-muted); font-size: 0.875rem;"></i>
                          <%= ch.challan_date.toLocaleDateString('en-IN') %>
                        </div>
                      <% } else { %>
                        <span class="text-muted">--</span>
                      <% } %>
                    </td>
                    <td><%= ch.consignee_name %></td>
                    <td>
                      <span style="font-weight: 500; color: var(--terracotta);">
                        <%= ch.total_amount ? '\u20B9' + Number(ch.total_amount).toLocaleString('en-IN') : '--' %>
                      </span>
                    </td>
                    <td style="text-align: center;">
                      <a href="/accounts-challan/view/<%= ch.id %>" class="btn btn-sm btn-primary" data-bs-toggle="tooltip" title="View challan details and PDF">
                        <i class="bi bi-eye"></i> View
                      </a>
                    </td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td colspan="6">
                    <div class="empty-state">
                      <div class="empty-state-icon">
                        <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                      </div>
                      <h3 class="empty-state-title">No Challans Found</h3>
                      <p class="empty-state-text">
                        <% if (search) { %>
                          No challans match your search criteria. Try adjusting your search terms.
                        <% } else { %>
                          There are no challans to display at the moment.
                        <% } %>
                      </p>
                      <% if (search) { %>
                        <a href="/accounts-challan/list" class="btn btn-secondary mt-3">
                          <i class="bi bi-arrow-left"></i> Back to All Challans
                        </a>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

  </div>
</main>

<style>
  /* Page-specific styles */
  .main-content {
    margin-left: 0 !important;
  }

  .table-responsive {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  @media (max-width: 768px) {
    .page-header {
      margin-bottom: 20px;
    }

    .card-header {
      flex-direction: column;
      align-items: flex-start !important;
      gap: 8px;
    }

    .table th,
    .table td {
      padding: 10px 12px;
      white-space: nowrap;
    }

    .btn-sm {
      padding: 6px 10px;
      font-size: 0.75rem;
    }
  }
</style>

<%- include('partials/footer') %>
