<%- include('partials/header', { pageTitle: 'Mail Manager' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/mail-manager' }) %>

<style>
  /* Mail Manager - Page Specific Styles */
  .mail-manager-page {
    padding-top: calc(var(--navbar-height) + 1.5rem);
    min-height: 100vh;
  }

  /* Email List Styles */
  .email-row {
    cursor: pointer;
    transition: all var(--transition-fast);
    border-left: 3px solid transparent;
  }
  .email-row:hover {
    background-color: var(--cream-dark);
    border-left-color: var(--terracotta-light);
  }
  .email-row.selected {
    background-color: var(--terracotta-bg);
    border-left-color: var(--terracotta);
  }

  /* Classification Badges */
  .classification-badge {
    font-size: var(--text-xs);
    font-weight: 500;
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius-full);
  }
  .badge-initial { background-color: var(--info); color: white; }
  .badge-closed { background-color: var(--success); color: white; }
  .badge-proceeding { background-color: var(--warning); color: white; }
  .badge-replied { background-color: #20c997; color: white; }
  .badge-error { background-color: var(--danger); color: white; }
  .badge-unknown { background-color: var(--gray-400); color: white; }

  /* Checkbox Styling */
  .email-checkbox {
    width: 18px;
    height: 18px;
    cursor: pointer;
    accent-color: var(--terracotta);
  }

  /* Bulk Actions */
  .bulk-actions { display: none; }
  .bulk-actions.show { display: flex; }

  /* Email Preview */
  .email-preview {
    max-height: 400px;
    overflow-y: auto;
  }

  /* Video Card */
  .video-card {
    border-left: 4px solid var(--success);
    background: var(--bg-card);
    border-radius: var(--radius-md);
  }

  /* Upload Zone */
  .upload-zone {
    border: 2px dashed var(--border-medium);
    border-radius: var(--radius-lg);
    padding: 2rem;
    text-align: center;
    transition: all var(--transition-base);
    cursor: pointer;
    background: var(--cream);
  }
  .upload-zone:hover {
    border-color: var(--terracotta-light);
    background: var(--terracotta-bg);
  }
  .upload-zone.drag-over {
    border-color: var(--terracotta);
    background-color: var(--terracotta-bg);
  }

  /* Mapping Info Banner */
  .mapping-info {
    background: linear-gradient(135deg, var(--terracotta) 0%, var(--terracotta-dark) 100%);
  }

  /* Card Enhancements */
  .kotty-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }
  .kotty-card .card-header {
    background: transparent;
    border-bottom: 1px solid var(--border-light);
    font-weight: 500;
    color: var(--text-primary);
    padding: 1rem 1.25rem;
  }
  .kotty-card .card-header i {
    color: var(--terracotta);
  }
  .kotty-card .card-body {
    padding: 1.25rem;
  }

  /* Status Badge */
  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: 500;
  }
  .status-badge.connected {
    background: var(--success-light);
    color: var(--success);
  }
  .status-badge.warning {
    background: var(--warning-light);
    color: var(--warning);
  }
  .status-badge.error {
    background: var(--danger-light);
    color: var(--danger);
  }

  /* Button Styles */
  .btn-kotty-primary {
    background: var(--terracotta);
    color: white;
    border: none;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-md);
    font-weight: 500;
    transition: all var(--transition-fast);
  }
  .btn-kotty-primary:hover {
    background: var(--terracotta-dark);
    color: white;
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }
  .btn-kotty-primary:disabled {
    background: var(--gray-300);
    transform: none;
    box-shadow: none;
  }

  .btn-kotty-outline {
    background: transparent;
    color: var(--terracotta);
    border: 1px solid var(--terracotta);
    padding: 0.5rem 1rem;
    border-radius: var(--radius-md);
    font-weight: 500;
    transition: all var(--transition-fast);
  }
  .btn-kotty-outline:hover {
    background: var(--terracotta-bg);
    color: var(--terracotta-dark);
  }

  /* Form Controls */
  .form-control-kotty {
    border: 1px solid var(--border-medium);
    border-radius: var(--radius-md);
    padding: 0.5rem 0.75rem;
    font-size: var(--text-sm);
    transition: all var(--transition-fast);
    background: var(--bg-card);
  }
  .form-control-kotty:focus {
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px var(--terracotta-bg);
    outline: none;
  }

  /* Section Header */
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--text-primary);
    margin: 0;
  }

  /* Quick Action Buttons */
  .quick-action-btn {
    padding: 0.375rem 0.75rem;
    font-size: var(--text-xs);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-medium);
    background: var(--bg-card);
    color: var(--text-secondary);
    transition: all var(--transition-fast);
  }
  .quick-action-btn:hover {
    background: var(--cream-dark);
    color: var(--text-primary);
    border-color: var(--border-dark);
  }
  .quick-action-btn.btn-date {
    border-color: var(--info);
    color: var(--info);
  }
  .quick-action-btn.btn-date:hover {
    background: var(--info-light);
  }
  .quick-action-btn.btn-sync {
    border-color: var(--warning);
    color: var(--warning);
  }
  .quick-action-btn.btn-sync:hover {
    background: var(--warning-light);
  }

  /* Email Counter Badge */
  .email-counter {
    background: var(--terracotta-bg);
    color: var(--terracotta);
    padding: 0.25rem 0.625rem;
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: 500;
  }

  /* Stat Box */
  .stat-box {
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    padding: 0.75rem;
    text-align: center;
    background: var(--cream);
  }
  .stat-box .stat-value {
    font-size: var(--text-lg);
    font-weight: 600;
  }
  .stat-box .stat-label {
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.025em;
  }
  .stat-box.success .stat-value { color: var(--success); }
  .stat-box.info .stat-value { color: var(--info); }
  .stat-box.primary .stat-value { color: var(--terracotta); }
  .stat-box.warning .stat-value { color: var(--warning); }
  .stat-box.danger .stat-value { color: var(--danger); }
  .stat-box.muted .stat-value { color: var(--text-secondary); }

  /* Alert Styles */
  .alert-kotty {
    border-radius: var(--radius-md);
    border: none;
    padding: 0.75rem 1rem;
    font-size: var(--text-sm);
  }
  .alert-kotty.alert-success {
    background: var(--success-light);
    color: var(--success);
  }
  .alert-kotty.alert-warning {
    background: var(--warning-light);
    color: var(--warning);
  }
  .alert-kotty.alert-danger {
    background: var(--danger-light);
    color: var(--danger);
  }

  /* Progress Bar */
  .progress-kotty {
    height: 8px;
    border-radius: var(--radius-full);
    background: var(--cream-dark);
    overflow: hidden;
  }
  .progress-kotty .progress-bar {
    background: var(--terracotta);
  }

  /* Reply Log */
  .reply-log {
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    padding: 0.75rem;
    max-height: 200px;
    overflow-y: auto;
    font-size: var(--text-sm);
    background: var(--cream);
  }

  /* Responsive Adjustments */
  @media (max-width: 992px) {
    .mail-manager-page {
      padding-top: calc(var(--navbar-height) + 1rem);
    }
  }
</style>

<main class="mail-manager-page">
  <div class="container-fluid px-4">
    <div class="row g-4">
      <!-- Left Column: Mapping & Search -->
      <div class="col-lg-4">
        <!-- Zoho Status -->
        <div class="kotty-card mb-3">
          <div class="card-body py-3">
            <div class="d-flex justify-content-between align-items-center">
              <span class="fw-semibold">Zoho Mail Status</span>
              <% if (zohoStatus.connected) { %>
                <span class="status-badge connected"><i class="bi bi-check-circle"></i>Connected</span>
              <% } else if (zohoStatus.configured) { %>
                <span class="status-badge warning"><i class="bi bi-exclamation-triangle"></i>Not Connected</span>
              <% } else { %>
                <span class="status-badge error"><i class="bi bi-x-circle"></i>Not Configured</span>
              <% } %>
            </div>
            <% if (!zohoStatus.configured) { %>
              <small class="text-muted d-block mt-2">Set ZOHO_CLIENT_ID, ZOHO_CLIENT_SECRET, ZOHO_REFRESH_TOKEN env vars</small>
            <% } %>
          </div>
        </div>

        <!-- Auto-reply cron status + needs-attention -->
        <style>
          .ar-card .ar-row { display:flex; align-items:center; justify-content:space-between; gap:.5rem; }
          .ar-card .ar-row + .ar-row { margin-top:.5rem; }
          .ar-stat { display:inline-flex; align-items:center; gap:.35rem; font-size:.875rem; }
          .ar-pill { padding:.125rem .5rem; border-radius:9999px; font-weight:600; font-size:.75rem; font-variant-numeric:tabular-nums; }
          .ar-pill.ok { background:#dcfce7; color:#15803d; }
          .ar-pill.warn { background:#fef3c7; color:#92400e; }
          .ar-pill.err { background:#fee2e2; color:#b91c1c; }
          .ar-pill.muted { background:#f1f5f9; color:#475569; }
          .ar-reason-list { list-style:none; padding:0; margin:.5rem 0 0; }
          .ar-reason-list li { display:flex; justify-content:space-between; padding:.25rem 0; font-size:.8125rem; border-top:1px dashed #e5e7eb; }
          .ar-reason-list li:first-child { border-top:none; }
          .ar-reason-list .lbl { color:#475569; }
          .ar-reason-list .lbl a { color:inherit; text-decoration:underline dotted; cursor:pointer; }
          .ar-reason-list .val { font-weight:700; font-variant-numeric:tabular-nums; color:#0f172a; }
          .ar-empty { font-size:.8125rem; color:#64748b; padding:.5rem 0; }

          .ar-modal { position:fixed; inset:0; background:rgba(15,23,42,.5); backdrop-filter:blur(4px); z-index:1080; display:none; align-items:flex-start; justify-content:center; padding:3rem 1rem; }
          .ar-modal.show { display:flex; }
          .ar-modal-card { background:#fff; border-radius:14px; max-width:760px; width:100%; max-height:85vh; display:flex; flex-direction:column; box-shadow:0 24px 48px rgba(0,0,0,.18); overflow:hidden; }
          .ar-modal-head { padding:.875rem 1.125rem; border-bottom:1px solid #e5e7eb; display:flex; align-items:center; justify-content:space-between; gap:.5rem; }
          .ar-modal-title { font-weight:700; }
          .ar-modal-body { padding:.5rem 1.125rem 1.125rem; overflow-y:auto; }
          .ar-modal-close { background:transparent; border:none; font-size:1.5rem; line-height:1; cursor:pointer; color:#64748b; }
          .ar-row-table { width:100%; font-size:.8125rem; border-collapse:collapse; }
          .ar-row-table th, .ar-row-table td { border-bottom:1px solid #f1f5f9; padding:.5rem .375rem; text-align:left; vertical-align:top; }
          .ar-row-table th { font-size:.6875rem; text-transform:uppercase; letter-spacing:.04em; color:#64748b; font-weight:700; }
          .ar-row-table td.subject { max-width:280px; word-break:break-word; }
          .ar-row-table .from { color:#475569; font-size:.75rem; }
        </style>

        <div class="kotty-card mb-3 ar-card" id="autoReplyCard"
             data-migration-pending="<%= autoReply && autoReply.migrationPending ? '1' : '' %>">
          <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-robot me-2"></i>Auto-reply</span>
            <button class="btn btn-sm btn-kotty-primary" id="arRunBtn">
              <i class="bi bi-play-fill"></i> Run now
            </button>
          </div>
          <div class="card-body py-3">
            <% if (autoReply && autoReply.migrationPending) { %>
              <div class="ar-empty">
                Run <code>sql/mail_reply_visibility.sql</code> to enable visibility.
              </div>
            <% } else if (autoReply && autoReply.lastRun) { %>
              <% const r = autoReply.lastRun; %>
              <div class="ar-row">
                <span class="ar-stat">
                  <i class="bi bi-clock-history" style="color:var(--terracotta,#c2410c);"></i>
                  Last run:
                  <strong id="arLastRun" data-iso="<%= r.started_at %>"><%= new Date(r.started_at).toLocaleString() %></strong>
                </span>
                <span class="ar-pill <%= r.error_message ? 'err' : (r.replied > 0 ? 'ok' : 'muted') %>" id="arVerdict">
                  <% if (r.error_message) { %>FAILED<% } else if (r.replied > 0) { %>✓ <%= r.replied %> replied<% } else { %>nothing to reply<% } %>
                </span>
              </div>
              <div class="ar-row" style="flex-wrap:wrap;">
                <span class="ar-stat" title="Fetched from Zoho inbox">
                  <span class="ar-pill muted">Fetched <span id="arFetched"><%= r.fetched %></span></span>
                </span>
                <span class="ar-stat" title="Replied this run">
                  <span class="ar-pill ok">Replied <span id="arReplied"><%= r.replied %></span></span>
                </span>
                <span class="ar-stat" title="Skipped (any reason)">
                  <span class="ar-pill warn">Skipped <span id="arSkipped"><%= (Number(r.skipped_own||0)+Number(r.skipped_already_replied||0)+Number(r.skipped_no_order_id||0)+Number(r.skipped_no_awb||0)+Number(r.skipped_no_video||0)) %></span></span>
                </span>
                <% if (Number(r.errors||0) > 0) { %>
                <span class="ar-stat" title="Errors this run">
                  <span class="ar-pill err">Errors <span id="arErrors"><%= r.errors %></span></span>
                </span>
                <% } %>
              </div>
              <% if (r.error_message) { %>
                <div class="ar-empty" style="color:#b91c1c;">⚠ <%= r.error_message %></div>
              <% } %>
            <% } else { %>
              <div class="ar-empty">No cron runs recorded yet. Next scheduled run: 9:00 AM / 9:00 PM IST.</div>
            <% } %>

            <div style="margin-top:.875rem;">
              <div style="display:flex; justify-content:space-between; align-items:center;">
                <span style="font-size:.75rem; font-weight:700; text-transform:uppercase; letter-spacing:.05em; color:#475569;">
                  Needs attention (7 days)
                </span>
                <span class="ar-pill warn" id="arNeedsTotal"><%= autoReply && autoReply.totalNeedsAttention || 0 %></span>
              </div>
              <% const reasons = (autoReply && autoReply.needsAttention) || []; %>
              <% if (reasons.length === 0) { %>
                <div class="ar-empty">Nothing waiting on you. ✓</div>
              <% } else { %>
                <ul class="ar-reason-list" id="arReasonList">
                  <% reasons.forEach(function(row) {
                       const label = {
                         no_order_id: 'No customer order # in email',
                         no_awb: 'Order ID found but no AWB uploaded',
                         no_video: 'AWB known but no video in S3',
                         already_replied: 'Already replied (dup)',
                         not_target_class: 'Not a CCTV/AJIO target',
                         our_own: 'Our own outbound',
                         error: 'Errored',
                       }[row.skip_reason] || row.skip_reason; %>
                    <li>
                      <span class="lbl">
                        <a data-reason="<%= row.skip_reason %>" onclick="arOpenList('<%= row.skip_reason %>')">
                          <%= label %>
                        </a>
                      </span>
                      <span class="val"><%= row.n %></span>
                    </li>
                  <% }) %>
                </ul>
              <% } %>
            </div>
          </div>
        </div>

        <div class="ar-modal" id="arModal" onclick="if(event.target.id==='arModal')arCloseList()">
          <div class="ar-modal-card">
            <div class="ar-modal-head">
              <span class="ar-modal-title" id="arModalTitle">Emails</span>
              <button class="ar-modal-close" onclick="arCloseList()" aria-label="Close">&times;</button>
            </div>
            <div class="ar-modal-body" id="arModalBody">Loading…</div>
          </div>
        </div>

        <script>
          (function() {
            const card = document.getElementById('autoReplyCard');
            if (!card) return;
            const runBtn = document.getElementById('arRunBtn');
            const fmtNum = (n) => Number(n || 0).toLocaleString();
            const escapeHtml = (s) => String(s == null ? '' : s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":"&#39;"}[c]));

            async function refresh() {
              try {
                const r = await fetch('/mail-manager/auto-reply/summary', { credentials: 'include' });
                if (!r.ok) return;
                const data = await r.json();
                if (data.lastRun) {
                  const lr = data.lastRun;
                  const lrEl = document.getElementById('arLastRun');
                  if (lrEl) lrEl.textContent = new Date(lr.started_at).toLocaleString();
                  const set = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = fmtNum(v); };
                  set('arFetched', lr.fetched);
                  set('arReplied', lr.replied);
                  set('arSkipped', (lr.skipped_own || 0) + (lr.skipped_already_replied || 0) +
                                    (lr.skipped_no_order_id || 0) + (lr.skipped_no_awb || 0) + (lr.skipped_no_video || 0));
                  const verdict = document.getElementById('arVerdict');
                  if (verdict) {
                    verdict.className = 'ar-pill ' + (lr.error_message ? 'err' : (lr.replied > 0 ? 'ok' : 'muted'));
                    verdict.textContent = lr.error_message ? 'FAILED' : (lr.replied > 0 ? '✓ ' + lr.replied + ' replied' : 'nothing to reply');
                  }
                }
                const tot = document.getElementById('arNeedsTotal');
                if (tot) tot.textContent = data.totalNeedsAttention || 0;
              } catch (_) {}
            }

            runBtn.addEventListener('click', async () => {
              const orig = runBtn.innerHTML;
              runBtn.disabled = true;
              runBtn.innerHTML = '<i class="bi bi-arrow-repeat"></i> Running…';
              try {
                const r = await fetch('/mail-manager/auto-reply/run', { method: 'POST', credentials: 'include' });
                const data = await r.json();
                if (!r.ok || !data.ok) throw new Error(data.error || 'Run failed');
                // Brief flash then refresh card with new data
                runBtn.innerHTML = '<i class="bi bi-check2"></i> Done — ' + (data.replied || 0) + ' replied';
                await refresh();
              } catch (err) {
                runBtn.innerHTML = '<i class="bi bi-x-circle"></i> ' + (err.message || 'Failed');
              } finally {
                setTimeout(() => { runBtn.disabled = false; runBtn.innerHTML = orig; }, 2500);
              }
            });

            // Modal: show the actual emails behind a skip_reason
            const titleMap = {
              no_order_id: 'Emails missing a customer order number',
              no_awb: 'Order ID found but no AWB uploaded',
              no_video: 'AWB known but no video in S3',
              already_replied: 'Already replied (duplicate threads)',
              error: 'Errored during processing',
            };
            window.arOpenList = async function(reason) {
              const modal = document.getElementById('arModal');
              const body = document.getElementById('arModalBody');
              const title = document.getElementById('arModalTitle');
              title.textContent = titleMap[reason] || ('Emails: ' + reason);
              body.textContent = 'Loading…';
              modal.classList.add('show');
              try {
                const r = await fetch('/mail-manager/auto-reply/needs-attention?reason=' + encodeURIComponent(reason) + '&limit=200', { credentials: 'include' });
                const data = await r.json();
                if (!r.ok || !data.ok) throw new Error(data.error || 'Failed');
                if (!data.items || !data.items.length) {
                  body.innerHTML = '<div class="ar-empty">No emails in this bucket. ✓</div>';
                  return;
                }
                let html = '<table class="ar-row-table"><thead><tr>'
                         + '<th>Received</th><th>Subject / From</th><th>Order ID</th><th></th>'
                         + '</tr></thead><tbody>';
                for (const it of data.items) {
                  const when = it.created_at ? new Date(it.created_at).toLocaleString() : '';
                  html += '<tr>'
                       +   '<td>' + escapeHtml(when) + '</td>'
                       +   '<td class="subject">'
                       +     '<div>' + escapeHtml(it.subject || '(no subject)') + '</div>'
                       +     '<div class="from">' + escapeHtml(it.from_address || '') + '</div>'
                       +   '</td>'
                       +   '<td>' + escapeHtml(it.order_id || '—') + '</td>'
                       +   '<td><button class="btn btn-sm btn-outline-secondary" onclick="window.openEmailInPanel && window.openEmailInPanel(\'' + escapeHtml(it.message_id) + '\')">Open</button></td>'
                       + '</tr>';
                }
                html += '</tbody></table>';
                body.innerHTML = html;
              } catch (err) {
                body.innerHTML = '<div class="ar-empty" style="color:#b91c1c;">Failed to load: ' + escapeHtml(err.message) + '</div>';
              }
            };
            window.arCloseList = function() {
              document.getElementById('arModal').classList.remove('show');
            };
          })();
        </script>

        <!-- Excel Mapping Upload -->
        <div class="kotty-card mb-3">
          <div class="card-header">
            <i class="bi bi-file-earmark-spreadsheet me-2"></i>Order-to-AWB Mapping
          </div>
          <div class="card-body">
            <div id="uploadZone" class="upload-zone mb-3">
              <i class="bi bi-cloud-upload fs-2" style="color: var(--terracotta);"></i>
              <p class="mb-1 mt-2" style="color: var(--text-primary);">Drop Excel file here or click to browse</p>
              <small class="text-muted">Columns needed: Order ID, AWB</small>
              <input type="file" id="mappingFile" accept=".xlsx,.xls,.csv" class="d-none">
            </div>
            <div id="mappingStatus" class="<%= mappingCount > 0 ? '' : 'd-none' %>">
              <div class="mapping-info text-white p-3 rounded mb-2">
                <div class="d-flex justify-content-between align-items-center">
                  <span><i class="bi bi-database me-2"></i><span id="mappingCountDisplay"><%= mappingCount %></span> mappings loaded</span>
                  <button class="btn btn-sm btn-light" onclick="clearMapping()">Clear</button>
                </div>
              </div>
            </div>
            <div id="uploadProgress" class="d-none">
              <div class="progress-kotty">
                <div class="progress-bar progress-bar-striped progress-bar-animated" style="width: 100%"></div>
              </div>
