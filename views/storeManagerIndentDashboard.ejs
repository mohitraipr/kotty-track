<%- include('partials/header', { pageTitle: 'Indent Control' }) %>
<!-- Select2 CSS -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<%- include('partials/navbar', { dashboardUrl: '/dashboard' }) %>

<!-- Main Content Area (No Sidebar) -->
<main class="main-content" style="margin-left: 0;">
  <div class="container-fluid" style="max-width: 1400px; margin: 0 auto;">

    <!-- Page Header -->
    <div class="page-header">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div>
          <h1 class="page-title">Indent Control Room</h1>
          <p class="page-subtitle">Manage inventory requests and track arrivals</p>
        </div>
        <div class="d-flex flex-wrap align-items-center gap-3">
          <!-- Settings Toggle: Allow Free-Text Indent -->
          <form action="/indent/manage/settings" method="POST" class="d-flex align-items-center gap-2" style="margin: 0;">
            <label class="toggle-label" for="allowFreetextToggle" style="font-size: var(--text-sm); color: var(--text-secondary); white-space: nowrap;">
              Free-Text Indent
            </label>
            <label class="toggle-switch">
              <input type="hidden" name="allowFreetext" value="false">
              <input type="checkbox" name="allowFreetext" value="true" id="allowFreetextToggle" <%= allowFreetext ? 'checked' : '' %> onchange="this.form.submit()">
              <span class="toggle-slider"></span>
            </label>
          </form>

          <div class="header-divider"></div>

          <!-- Action Buttons -->
          <a href="/indent/manage/analytics" class="btn btn-secondary btn-sm">
            <i class="bi bi-bar-chart-line me-1"></i> Stock Analytics
          </a>
          <button class="btn btn-primary btn-sm" onclick="document.getElementById('createItemPanel').classList.toggle('active')">
            <i class="bi bi-plus-lg me-1"></i> Create Item Type
          </button>
          <button class="btn btn-secondary btn-sm" onclick="document.getElementById('addStockPanel').classList.toggle('active')">
            <i class="bi bi-box-arrow-in-down me-1"></i> Add Stock
          </button>
          <button class="btn btn-secondary btn-sm" onclick="document.getElementById('dispatchPanel').classList.toggle('active')">
            <i class="bi bi-truck me-1"></i> Dispatch
          </button>

          <span class="badge badge-neutral" style="font-size: var(--text-sm); padding: 8px 14px;">
            <i class="bi bi-person-fill me-1"></i>
            <%= user.username %> &middot; Store Manager
          </span>
        </div>
      </div>
    </div>

    <!-- Create Item Type Panel (Collapsible) -->
    <div id="createItemPanel" class="create-item-panel">
      <div class="card" style="border: 2px solid var(--terracotta); margin-bottom: 24px;">
        <div class="card-header" style="background: var(--terracotta-light, rgba(188,108,37,0.08));">
          <h2 class="card-title" style="margin: 0; font-size: var(--text-base);">
            <i class="bi bi-plus-circle me-2" style="color: var(--terracotta);"></i>Create New Item Type
          </h2>
          <button class="btn btn-secondary btn-sm" onclick="document.getElementById('createItemPanel').classList.remove('active')" style="padding: 4px 10px;">
            <i class="bi bi-x-lg"></i>
          </button>
        </div>
        <div class="card-body">
          <form action="/indent/manage/items/create" method="POST">
            <div class="row g-3 align-items-end">
              <div class="col-md-3 col-sm-6">
                <label class="form-label">Name <span style="color: var(--danger);">*</span></label>
                <input type="text" name="name" class="form-input" placeholder="e.g. Button, Zipper, Thread" required>
              </div>
              <div class="col-md-2 col-sm-6">
                <label class="form-label">Shade</label>
                <input type="text" name="shade" class="form-input" placeholder="e.g. Red, Navy Blue">
              </div>
              <div class="col-md-2 col-sm-6">
                <label class="form-label">Unit <span style="color: var(--danger);">*</span></label>
                <select name="unit" class="form-select item-unit-select" required>
                  <option value="">Select unit</option>
                  <option value="PCS">PCS</option>
                  <option value="ROLL">ROLL</option>
                  <option value="CONE">CONE</option>
                  <option value="GROSS">GROSS</option>
                </select>
              </div>
              <div class="col-md-2 col-sm-6">
                <label class="form-label">Size</label>
                <input type="text" name="size" class="form-input" placeholder="e.g. 10mm, Large">
              </div>
              <div class="col-md-3 col-sm-12">
                <button type="submit" class="btn btn-primary" style="width: 100%;">
                  <i class="bi bi-check-lg me-1"></i> Create Item
                </button>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- Add Stock Panel -->
    <div id="addStockPanel" class="create-item-panel">
      <div class="card" style="border: 2px solid var(--success, #2d8a5f); margin-bottom: 24px;">
        <div class="card-header" style="background: rgba(45,138,95,0.08);">
          <h2 class="card-title" style="margin: 0; font-size: var(--text-base);">
            <i class="bi bi-box-arrow-in-down me-2" style="color: var(--success, #2d8a5f);"></i>Add Stock
          </h2>
          <button class="btn btn-secondary btn-sm" onclick="document.getElementById('addStockPanel').classList.remove('active')" style="padding: 4px 10px;">
            <i class="bi bi-x-lg"></i>
          </button>
        </div>
        <div class="card-body">
          <form action="/indent/manage/stock/add" method="POST">
            <div class="row g-3">
              <div class="col-md-4">
                <label class="form-label">Select Item <span class="text-danger">*</span></label>
                <select id="addStockItem" name="goods_id" class="form-select" required>
                  <option value="">-- Select item --</option>
                  <% goods.forEach(g => { %>
                    <option value="<%= g.id %>"><%= g.description_of_goods %><%= g.shade ? ' - ' + g.shade : '' %><%= g.size ? ' (' + g.size + ')' : '' %> [<%= g.unit %>] (Qty: <%= g.qty %>)</option>
                  <% }) %>
                </select>
              </div>
              <div class="col-md-2">
                <label class="form-label">Quantity <span class="text-danger">*</span></label>
                <input type="number" name="quantity" class="form-control" required min="1" placeholder="Qty">
              </div>
              <div class="col-md-2">
                <label class="form-label">Invoice No.</label>
                <input type="text" name="invoice_number" class="form-control" placeholder="INV-001">
              </div>
              <div class="col-md-2">
                <label class="form-label">Vendor</label>
                <input type="text" name="vendor_name" class="form-control" placeholder="Vendor name">
              </div>
              <div class="col-md-2">
                <label class="form-label">Date</label>
                <input type="date" name="entry_date" class="form-control">
              </div>
              <div class="col-12">
                <button type="submit" class="btn btn-primary">
                  <i class="bi bi-plus-lg me-1"></i> Add Stock
                </button>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- Dispatch Panel -->
    <div id="dispatchPanel" class="create-item-panel">
      <div class="card" style="border: 2px solid var(--info, #3a7bc4); margin-bottom: 24px;">
        <div class="card-header" style="background: rgba(58,123,196,0.08);">
          <h2 class="card-title" style="margin: 0; font-size: var(--text-base);">
            <i class="bi bi-truck me-2" style="color: var(--info, #3a7bc4);"></i>Dispatch Goods
          </h2>
          <button class="btn btn-secondary btn-sm" onclick="document.getElementById('dispatchPanel').classList.remove('active')" style="padding: 4px 10px;">
            <i class="bi bi-x-lg"></i>
          </button>
        </div>
        <div class="card-body">
          <form action="/indent/manage/stock/dispatch" method="POST">
            <div class="row g-3">
              <div class="col-md-4">
                <label class="form-label">Select Item <span class="text-danger">*</span></label>
                <select id="dispatchStockItem" name="goods_id" class="form-select" required>
                  <option value="">-- Select item --</option>
                  <% goods.forEach(g => { %>
                    <option value="<%= g.id %>"><%= g.description_of_goods %><%= g.shade ? ' - ' + g.shade : '' %><%= g.size ? ' (' + g.size + ')' : '' %> [<%= g.unit %>] (Qty: <%= g.qty %>)</option>
                  <% }) %>
                </select>
              </div>
              <div class="col-md-3">
                <label class="form-label">Quantity <span class="text-danger">*</span></label>
                <input type="number" name="quantity" class="form-control" required min="1" placeholder="Qty">
              </div>
              <div class="col-md-3">
                <label class="form-label">Remark</label>
                <input type="text" name="remark" class="form-control" placeholder="Optional remark">
              </div>
              <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">
                  <i class="bi bi-truck me-1"></i> Dispatch
                </button>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- Flash Messages -->
    <%- include('partials/flashMessages') %>

    <!-- Stats Cards -->
    <div class="row g-3 mb-4">
      <div class="col-md-4 col-sm-6">
        <div class="stat-card">
          <div class="stat-icon" style="width: 44px; height: 44px; border-radius: var(--radius-md); background: var(--warning-light); display: flex; align-items: center; justify-content: center; margin-bottom: 14px;">
            <i class="bi bi-clock-history" style="font-size: 20px; color: var(--warning);"></i>
          </div>
          <div class="stat-label">Open Requests</div>
          <div class="stat-value"><%= stats.open || 0 %></div>
        </div>
      </div>
      <div class="col-md-4 col-sm-6">
        <div class="stat-card">
          <div class="stat-icon" style="width: 44px; height: 44px; border-radius: var(--radius-md); background: var(--info-light); display: flex; align-items: center; justify-content: center; margin-bottom: 14px;">
            <i class="bi bi-truck" style="font-size: 20px; color: var(--info);"></i>
          </div>
          <div class="stat-label">Proceeding</div>
          <div class="stat-value" style="color: var(--info);"><%= stats.proceeding || 0 %></div>
        </div>
      </div>
      <div class="col-md-4 col-sm-6">
        <div class="stat-card">
          <div class="stat-icon" style="width: 44px; height: 44px; border-radius: var(--radius-md); background: var(--success-light); display: flex; align-items: center; justify-content: center; margin-bottom: 14px;">
            <i class="bi bi-check-circle" style="font-size: 20px; color: var(--success);"></i>
          </div>
          <div class="stat-label">Arrived</div>
          <div class="stat-value" style="color: var(--success);"><%= stats.arrived || 0 %></div>
        </div>
      </div>
    </div>

    <!-- Requests Table Card -->
    <div class="card">
      <div class="card-header" style="flex-wrap: wrap; gap: 16px;">
        <div>
          <h2 class="card-title" style="margin-bottom: 4px;">Latest Indent Requests</h2>
          <p class="text-secondary" style="font-size: var(--text-sm); margin: 0;">Keep the flow smooth by acknowledging requests promptly.</p>
        </div>
        <div class="d-flex flex-wrap gap-2 align-items-center">
          <select id="exportStatus" class="form-select" style="width: auto; min-width: 120px;">
            <option value="">All Status</option>
            <option value="open">Open</option>
            <option value="proceeding">Proceeding</option>
            <option value="arrived">Arrived</option>
          </select>
          <input type="date" id="exportStartDate" class="form-input" style="width: auto;" placeholder="Start Date">
          <input type="date" id="exportEndDate" class="form-input" style="width: auto;" placeholder="End Date">
          <button onclick="exportToExcel()" class="btn btn-primary">
            <i class="bi bi-file-earmark-excel"></i>
            Download Excel
          </button>
        </div>
      </div>
      <div class="card-body p-0">
        <div class="table-container" style="border: none; border-radius: 0;">
          <div style="overflow-x: auto;">
            <table class="table" style="margin: 0;">
              <thead>
                <tr>
                  <th>Goods & Description</th>
                  <th>Shade</th>
                  <th>Quantity</th>
                  <th>Indent Filler</th>
                  <th>Dates</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% if (!requests || !requests.length) { %>
                <tr>
                  <td colspan="7" style="text-align: center; padding: 48px;">
                    <div class="empty-state" style="padding: 0;">
                      <div class="empty-state-icon">
                        <i class="bi bi-inbox" style="font-size: 48px;"></i>
                      </div>
                      <div class="empty-state-title">No requests yet</div>
                      <div class="empty-state-text">New indent requests will appear here.</div>
                    </div>
                  </td>
                </tr>
                <% } else { %>
                <% requests.forEach(row => { %>
                <tr>
                  <td data-label="Goods">
                    <div style="font-weight: 500; color: var(--text-primary);"><%= row.goods_description %></div>
                    <div style="color: var(--text-muted); font-size: var(--text-xs); margin-top: 4px;">
                      Used last month: <strong><%= row.used_last_month || 0 %></strong> &middot;
                      last 7 days: <strong><%= row.used_last_seven_days || 0 %></strong>
                    </div>
                  </td>
                  <td data-label="Shade">
                    <% if (row.shade) { %>
                      <span class="badge badge-neutral" style="font-size: var(--text-xs);"><%= row.shade %></span>
                    <% } else { %>
                      <span style="color: var(--text-muted);">--</span>
                    <% } %>
                  </td>
                  <td data-label="Quantity">
                    <span style="font-weight: 600; font-size: var(--text-lg);"><%= row.quantity_requested %></span>
                  </td>
                  <td data-label="Filler">
                    <% if (row.filler_name) { %>
                      <span style="font-weight: 500;"><%= row.filler_name %></span>
                    <% } else { %>
                      <span style="color: var(--text-muted);">--</span>
                    <% } %>
                  </td>
                  <td data-label="Dates">
                    <div style="font-size: var(--text-xs); line-height: 1.8;">
                      <div><span style="color: var(--text-muted);">Requested:</span> <%= row.request_date ? new Date(row.request_date).toLocaleDateString('en-IN') : '-' %></div>
                      <div><span style="color: var(--text-muted);">Proceed:</span> <%= row.proceed_date ? new Date(row.proceed_date).toLocaleDateString('en-IN') : '-' %></div>
                      <div><span style="color: var(--text-muted);">Arrived:</span> <%= row.arrival_date ? new Date(row.arrival_date).toLocaleDateString('en-IN') : '-' %></div>
                    </div>
                  </td>
                  <td data-label="Status">
                    <% if (row.status === 'open') { %>
                      <span class="badge badge-warning"><%= row.status %></span>
                    <% } else if (row.status === 'proceeding') { %>
                      <span class="badge badge-info"><%= row.status %></span>
                    <% } else if (row.status === 'arrived') { %>
                      <span class="badge badge-success"><%= row.status %></span>
                    <% } else { %>
                      <span class="badge badge-neutral"><%= row.status %></span>
                    <% } %>
                    <% if (row.final_quantity) { %>
                    <div style="font-size: var(--text-xs); color: var(--text-secondary); margin-top: 4px;">Final qty: <%= row.final_quantity %></div>
                    <% } %>
                    <% if (row.remark) { %>
                    <div style="font-size: var(--text-xs); color: var(--text-muted); margin-top: 2px;"><%= row.remark %></div>
                    <% } %>
                  </td>
                  <td data-label="Actions">
                    <% if (row.status === 'arrived') { %>
                    <span class="badge badge-success" style="font-size: var(--text-xs);">
                      <i class="bi bi-check-lg me-1"></i> Completed
                    </span>

                    <% } else if (row.status === 'open') { %>
                    <!-- Open: Only allow Mark Proceeding -->
                    <div class="d-flex flex-wrap gap-2 align-items-center">
                      <form action="/indent/requests/<%= row.id %>/proceed" method="POST" style="margin: 0;">
                        <button class="btn btn-primary btn-sm" type="submit">
                          <i class="bi bi-send me-1"></i> Mark Proceeding
                        </button>
                      </form>
                    </div>

                    <% } else if (row.status === 'proceeding') { %>
                    <!-- Proceeding: Only allow Mark Arrived -->
                    <div class="d-flex flex-wrap gap-2 align-items-center">
                      <button class="btn btn-secondary btn-sm arrival-toggle" data-id="<%= row.id %>">
                        <i class="bi bi-box-seam me-1"></i> Mark Arrived
                      </button>
                    </div>
                    <!-- Arrival Form -->
                    <div class="arrival-form" id="arrival-form-<%= row.id %>">
                      <% if (row.goods_id && row.current_stock != null) { %>
                      <div style="margin-bottom: 10px;">
                        <span class="badge badge-info" style="font-size: var(--text-xs); padding: 5px 10px;">
                          <i class="bi bi-box me-1"></i> Current Stock: <strong><%= row.current_stock %></strong>
                        </span>
                      </div>
                      <% } %>
                      <form action="/indent/requests/<%= row.id %>/arrive" method="POST">
                        <div class="row g-2">
                          <div class="col-sm-6 col-md-4">
                            <label class="form-label">Arrival Date</label>
                            <input type="date" name="arrivalDate" class="form-input" required>
                          </div>
                          <div class="col-sm-6 col-md-4">
                            <label class="form-label">Quantity Received</label>
                            <input type="number" step="0.01" name="finalQuantity" class="form-input" placeholder="Optional">
                          </div>
                          <div class="col-sm-12 col-md-4">
                            <label class="form-label">Remark</label>
                            <textarea name="remark" class="form-input" rows="1" placeholder="Optional" style="resize: vertical;"></textarea>
                          </div>
                          <div class="col-12">
                            <button class="btn btn-success btn-sm" type="submit">
                              <i class="bi bi-check-lg me-1"></i> Confirm Arrival
                            </button>
                          </div>
                        </div>
                      </form>
                    </div>
                    <% } %>
                  </td>
                </tr>
                <% }) %>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

  </div>
</main>

<!-- Additional Page Styles -->
<style>
  /* Toggle Switch */
  .toggle-switch {
    position: relative;
    display: inline-block;
    width: 44px;
    height: 24px;
    flex-shrink: 0;
  }

  .toggle-switch input {
    opacity: 0;
    width: 0;
    height: 0;
  }

  .toggle-slider {
    position: absolute;
    cursor: pointer;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: var(--border-medium, #ccc);
    transition: 0.25s;
    border-radius: 24px;
  }

  .toggle-slider::before {
    position: absolute;
    content: "";
    height: 18px;
    width: 18px;
    left: 3px;
    bottom: 3px;
    background-color: white;
    transition: 0.25s;
    border-radius: 50%;
  }

  .toggle-switch input:checked + .toggle-slider {
    background-color: var(--terracotta, #BC6C25);
  }

  .toggle-switch input:checked + .toggle-slider::before {
    transform: translateX(20px);
  }

  .toggle-label {
    cursor: pointer;
    user-select: none;
  }

  /* Header divider */
  .header-divider {
    width: 1px;
    height: 28px;
    background: var(--border-light, #e0e0e0);
    flex-shrink: 0;
  }

  /* Create Item Panel */
  .create-item-panel {
    display: none;
    animation: slideDown 0.2s ease-out;
  }

  .create-item-panel.active {
    display: block;
  }

  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Arrival Form - Hidden by default */
  .arrival-form {
    display: none;
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px dashed var(--border-light);
  }

  .arrival-form.active {
    display: block;
  }

  /* Select2 styling to match design system */
  .select2-container--default .select2-selection--single {
    height: 38px;
    border: 1px solid var(--border-medium, #d0d5dd);
    border-radius: var(--radius-md, 8px);
    padding: 4px 8px;
  }

  .select2-container--default .select2-selection--single .select2-selection__rendered {
    line-height: 28px;
    color: var(--text-primary);
  }

  .select2-container--default .select2-selection--single .select2-selection__arrow {
    height: 36px;
  }

  /* Mobile responsive table */
  @media (max-width: 960px) {
    .card-header {
      flex-direction: column;
      align-items: flex-start !important;
    }

    .table thead {
      display: none;
    }

    .table tbody tr {
      display: block;
      border: 1px solid var(--border-light);
      margin-bottom: 12px;
      border-radius: var(--radius-lg);
      padding: 16px;
      background: var(--bg-card);
    }

    .table tbody td {
      display: block;
      border: none;
      padding: 8px 0;
      text-align: left;
    }

    .table tbody td::before {
      content: attr(data-label);
      display: block;
      font-weight: 600;
      color: var(--text-secondary);
      font-size: var(--text-xs);
      text-transform: uppercase;
      letter-spacing: 0.04em;
      margin-bottom: 4px;
    }

    .table tbody td[colspan] {
      padding: 32px 16px;
    }

    .table tbody td[colspan]::before {
      display: none;
    }
  }

  /* Badge text transform */
  .badge {
    text-transform: capitalize;
  }
</style>

<!-- Page Scripts -->
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script>
  // Toggle arrival form visibility
  document.querySelectorAll('.arrival-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const form = document.getElementById(`arrival-form-${btn.dataset.id}`);
      if (form) {
        form.classList.toggle('active');
      }
    });
  });

  // Close button functionality for alerts
  document.querySelectorAll('.btn-close').forEach(btn => {
    btn.addEventListener('click', () => btn.parentElement && btn.parentElement.remove());
  });

  // Initialize Select2 on item unit dropdown
  if (typeof $ !== 'undefined' && $.fn.select2) {
    $('.item-unit-select').select2({
      placeholder: 'Select unit',
      minimumResultsForSearch: Infinity
    });
  }

  // Export to Excel functionality
  function exportToExcel() {
    const status = document.getElementById('exportStatus').value;
    const startDate = document.getElementById('exportStartDate').value;
    const endDate = document.getElementById('exportEndDate').value;

    let url = '/indent/manage/export?';
    const params = [];
    if (status) params.push('status=' + encodeURIComponent(status));
    if (startDate) params.push('startDate=' + encodeURIComponent(startDate));
    if (endDate) params.push('endDate=' + encodeURIComponent(endDate));

    window.location.href = url + params.join('&');
  }
</script>

<%- include('partials/footer') %>
