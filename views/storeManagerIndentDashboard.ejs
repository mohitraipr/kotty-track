<%- include('partials/header', { pageTitle: 'Indent Control' }) %>
<%- include('partials/navbar', { dashboardUrl: '/dashboard' }) %>

<!-- Main Content Area (No Sidebar) -->
<main class="main-content" style="margin-left: 0;">
  <div class="container-fluid" style="max-width: 1400px; margin: 0 auto;">

    <!-- Page Header -->
    <div class="page-header">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div>
          <h1 class="page-title">Indent Control Room</h1>
          <p class="page-subtitle">Manage inventory requests and track arrivals</p>
        </div>
        <div class="d-flex align-items-center gap-2">
          <span class="badge badge-neutral" style="font-size: var(--text-sm); padding: 8px 14px;">
            <i class="bi bi-person-fill me-1"></i>
            <%= user.username %> &middot; Store Manager
          </span>
        </div>
      </div>
    </div>

    <!-- Flash Messages -->
    <%- include('partials/flashMessages') %>

    <!-- Stats Cards -->
    <div class="row g-3 mb-4">
      <div class="col-md-4 col-sm-6">
        <div class="stat-card">
          <div class="stat-icon" style="width: 44px; height: 44px; border-radius: var(--radius-md); background: var(--warning-light); display: flex; align-items: center; justify-content: center; margin-bottom: 14px;">
            <i class="bi bi-clock-history" style="font-size: 20px; color: var(--warning);"></i>
          </div>
          <div class="stat-label">Open Requests</div>
          <div class="stat-value"><%= stats.open || 0 %></div>
        </div>
      </div>
      <div class="col-md-4 col-sm-6">
        <div class="stat-card">
          <div class="stat-icon" style="width: 44px; height: 44px; border-radius: var(--radius-md); background: var(--info-light); display: flex; align-items: center; justify-content: center; margin-bottom: 14px;">
            <i class="bi bi-truck" style="font-size: 20px; color: var(--info);"></i>
          </div>
          <div class="stat-label">Proceeding</div>
          <div class="stat-value" style="color: var(--info);"><%= stats.proceeding || 0 %></div>
        </div>
      </div>
      <div class="col-md-4 col-sm-6">
        <div class="stat-card">
          <div class="stat-icon" style="width: 44px; height: 44px; border-radius: var(--radius-md); background: var(--success-light); display: flex; align-items: center; justify-content: center; margin-bottom: 14px;">
            <i class="bi bi-check-circle" style="font-size: 20px; color: var(--success);"></i>
          </div>
          <div class="stat-label">Arrived</div>
          <div class="stat-value" style="color: var(--success);"><%= stats.arrived || 0 %></div>
        </div>
      </div>
    </div>

    <!-- Requests Table Card -->
    <div class="card">
      <div class="card-header" style="flex-wrap: wrap; gap: 16px;">
        <div>
          <h2 class="card-title" style="margin-bottom: 4px;">Latest Indent Requests</h2>
          <p class="text-secondary" style="font-size: var(--text-sm); margin: 0;">Keep the flow smooth by acknowledging requests promptly.</p>
        </div>
        <div class="d-flex flex-wrap gap-2 align-items-center">
          <select id="exportStatus" class="form-select" style="width: auto; min-width: 120px;">
            <option value="">All Status</option>
            <option value="open">Open</option>
            <option value="proceeding">Proceeding</option>
            <option value="arrived">Arrived</option>
          </select>
          <input type="date" id="exportStartDate" class="form-input" style="width: auto;" placeholder="Start Date">
          <input type="date" id="exportEndDate" class="form-input" style="width: auto;" placeholder="End Date">
          <button onclick="exportToExcel()" class="btn btn-primary">
            <i class="bi bi-file-earmark-excel"></i>
            Download Excel
          </button>
        </div>
      </div>
      <div class="card-body p-0">
        <div class="table-container" style="border: none; border-radius: 0;">
          <div style="overflow-x: auto;">
            <table class="table" style="margin: 0;">
              <thead>
                <tr>
                  <th>Goods & Description</th>
                  <th>Quantity</th>
                  <th>Indent Filler</th>
                  <th>Dates</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% if (!requests || !requests.length) { %>
                <tr>
                  <td colspan="6" style="text-align: center; padding: 48px;">
                    <div class="empty-state" style="padding: 0;">
                      <div class="empty-state-icon">
                        <i class="bi bi-inbox" style="font-size: 48px;"></i>
                      </div>
                      <div class="empty-state-title">No requests yet</div>
                      <div class="empty-state-text">New indent requests will appear here.</div>
                    </div>
                  </td>
                </tr>
                <% } else { %>
                <% requests.forEach(row => { %>
                <tr>
                  <td data-label="Goods">
                    <div style="font-weight: 500; color: var(--text-primary);"><%= row.goods_description %></div>
                    <div style="color: var(--text-muted); font-size: var(--text-xs); margin-top: 4px;">
                      Used last month: <strong><%= row.used_last_month || 0 %></strong> &middot;
                      last 7 days: <strong><%= row.used_last_seven_days || 0 %></strong>
                    </div>
                  </td>
                  <td data-label="Quantity">
                    <span style="font-weight: 600; font-size: var(--text-lg);"><%= row.quantity_requested %></span>
                  </td>
                  <td data-label="Filler">
                    <% if (row.filler_name) { %>
                      <span style="font-weight: 500;"><%= row.filler_name %></span>
                    <% } else { %>
                      <span style="color: var(--text-muted);">--</span>
                    <% } %>
                  </td>
                  <td data-label="Dates">
                    <div style="font-size: var(--text-xs); line-height: 1.8;">
                      <div><span style="color: var(--text-muted);">Requested:</span> <%= row.request_date ? new Date(row.request_date).toLocaleDateString('en-IN') : '-' %></div>
                      <div><span style="color: var(--text-muted);">Proceed:</span> <%= row.proceed_date ? new Date(row.proceed_date).toLocaleDateString('en-IN') : '-' %></div>
                      <div><span style="color: var(--text-muted);">Arrived:</span> <%= row.arrival_date ? new Date(row.arrival_date).toLocaleDateString('en-IN') : '-' %></div>
                    </div>
                  </td>
                  <td data-label="Status">
                    <% if (row.status === 'open') { %>
                      <span class="badge badge-warning"><%= row.status %></span>
                    <% } else if (row.status === 'proceeding') { %>
                      <span class="badge badge-info"><%= row.status %></span>
                    <% } else if (row.status === 'arrived') { %>
                      <span class="badge badge-success"><%= row.status %></span>
                    <% } else { %>
                      <span class="badge badge-neutral"><%= row.status %></span>
                    <% } %>
                    <% if (row.final_quantity) { %>
                    <div style="font-size: var(--text-xs); color: var(--text-secondary); margin-top: 4px;">Final qty: <%= row.final_quantity %></div>
                    <% } %>
                    <% if (row.remark) { %>
                    <div style="font-size: var(--text-xs); color: var(--text-muted); margin-top: 2px;"><%= row.remark %></div>
                    <% } %>
                  </td>
                  <td data-label="Actions">
                    <% if (row.status === 'arrived') { %>
                    <span class="badge badge-success" style="font-size: var(--text-xs);">
                      <i class="bi bi-check-lg me-1"></i> Completed
                    </span>
                    <% } else { %>
                    <div class="d-flex flex-wrap gap-2 align-items-center">
                      <% if (row.status === 'open') { %>
                      <form action="/indent/requests/<%= row.id %>/proceed" method="POST" style="margin: 0;">
                        <button class="btn btn-primary btn-sm" type="submit">
                          <i class="bi bi-send me-1"></i> Proceed
                        </button>
                      </form>
                      <% } %>
                      <button class="btn btn-secondary btn-sm arrival-toggle" data-id="<%= row.id %>">
                        <i class="bi bi-box-seam me-1"></i> Mark Arrived
                      </button>
                    </div>
                    <!-- Arrival Form -->
                    <div class="arrival-form" id="arrival-form-<%= row.id %>">
                      <form action="/indent/requests/<%= row.id %>/arrive" method="POST">
                        <div class="row g-2">
                          <div class="col-sm-6 col-md-4">
                            <label class="form-label">Arrival Date</label>
                            <input type="date" name="arrivalDate" class="form-input" required>
                          </div>
                          <div class="col-sm-6 col-md-4">
                            <label class="form-label">Quantity Received</label>
                            <input type="number" step="0.01" name="finalQuantity" class="form-input" placeholder="Optional">
                          </div>
                          <div class="col-sm-12 col-md-4">
                            <label class="form-label">Remark</label>
                            <textarea name="remark" class="form-input" rows="1" placeholder="Optional" style="resize: vertical;"></textarea>
                          </div>
                          <div class="col-12">
                            <button class="btn btn-success btn-sm" type="submit">
                              <i class="bi bi-check-lg me-1"></i> Confirm Arrival
                            </button>
                          </div>
                        </div>
                      </form>
                    </div>
                    <% } %>
                  </td>
                </tr>
                <% }) %>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

  </div>
</main>

<!-- Additional Page Styles -->
<style>
  /* Arrival Form - Hidden by default */
  .arrival-form {
    display: none;
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px dashed var(--border-light);
  }

  .arrival-form.active {
    display: block;
  }

  /* Mobile responsive table */
  @media (max-width: 960px) {
    .card-header {
      flex-direction: column;
      align-items: flex-start !important;
    }

    .table thead {
      display: none;
    }

    .table tbody tr {
      display: block;
      border: 1px solid var(--border-light);
      margin-bottom: 12px;
      border-radius: var(--radius-lg);
      padding: 16px;
      background: var(--bg-card);
    }

    .table tbody td {
      display: block;
      border: none;
      padding: 8px 0;
      text-align: left;
    }

    .table tbody td::before {
      content: attr(data-label);
      display: block;
      font-weight: 600;
      color: var(--text-secondary);
      font-size: var(--text-xs);
      text-transform: uppercase;
      letter-spacing: 0.04em;
      margin-bottom: 4px;
    }

    .table tbody td[colspan] {
      padding: 32px 16px;
    }

    .table tbody td[colspan]::before {
      display: none;
    }
  }

  /* Badge text transform */
  .badge {
    text-transform: capitalize;
  }
</style>

<!-- Page Scripts -->
<script>
  // Toggle arrival form visibility
  document.querySelectorAll('.arrival-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const form = document.getElementById(`arrival-form-${btn.dataset.id}`);
      if (form) {
        form.classList.toggle('active');
      }
    });
  });

  // Close button functionality for alerts
  document.querySelectorAll('.btn-close').forEach(btn => {
    btn.addEventListener('click', () => btn.parentElement && btn.parentElement.remove());
  });

  // Export to Excel functionality
  function exportToExcel() {
    const status = document.getElementById('exportStatus').value;
    const startDate = document.getElementById('exportStartDate').value;
    const endDate = document.getElementById('exportEndDate').value;

    let url = '/indent/manage/export?';
    const params = [];
    if (status) params.push('status=' + encodeURIComponent(status));
    if (startDate) params.push('startDate=' + encodeURIComponent(startDate));
    if (endDate) params.push('endDate=' + encodeURIComponent(endDate));

    window.location.href = url + params.join('&');
  }
</script>

<%- include('partials/footer') %>
