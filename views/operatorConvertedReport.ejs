<%- include('partials/header', { pageTitle: 'Converted Report' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/operator/dashboard' }) %>

<!-- Main Content -->
<main class="main-content" style="margin-left: 0;">
  <div class="container-fluid" style="max-width: var(--content-max-width); margin: 0 auto;">
    <!-- Breadcrumbs -->
    <div class="breadcrumbs">
      <a href="/operator/dashboard">Dashboard</a>
      <span class="separator"><i class="bi bi-chevron-right"></i></span>
      <span>Converted Report</span>
    </div>

    <!-- Page Header -->
    <div class="page-header">
      <h1 class="page-title">Converted Report</h1>
      <p class="page-subtitle">Track lot conversion across production stages</p>
    </div>

    <!-- Filter Card -->
    <div class="card mb-4">
      <div class="card-header">
        <h5 class="card-title"><i class="bi bi-funnel me-2"></i>Filter Options</h5>
      </div>
      <div class="card-body">
        <form method="GET" action="/operator/dashboard/converted-report">
          <div class="row g-3">
            <div class="col-md-3">
              <label for="lotType" class="form-label">Lot Type</label>
              <select name="lotType" id="lotType" class="form-select form-input">
                <option value="all" <%= filters.lotType === "all" ? "selected" : "" %>>All</option>
                <option value="akshay" <%= filters.lotType === "akshay" ? "selected" : "" %>>Akshay</option>
                <option value="non-akshay" <%= filters.lotType === "non-akshay" ? "selected" : "" %>>Non-Akshay</option>
              </select>
            </div>
            <div class="col-md-3">
              <label for="filterStage" class="form-label">Filter Stage</label>
              <select name="filterStage" id="filterStage" class="form-select form-input">
                <option value="cutting" <%= filters.filterStage === "cutting" ? "selected" : "" %>>Cutting</option>
                <option value="stitching" <%= filters.filterStage === "stitching" ? "selected" : "" %>>Stitching</option>
                <option value="finishing" <%= filters.filterStage === "finishing" ? "selected" : "" %>>Finishing</option>
                <option value="jeans" <%= filters.filterStage === "jeans" ? "selected" : "" %>>Jeans Assembly</option>
                <option value="washing" <%= filters.filterStage === "washing" ? "selected" : "" %>>Washing</option>
              </select>
            </div>
            <div class="col-md-3">
              <label for="startDate" class="form-label">Start Date (of selected stage)</label>
              <input type="date" name="startDate" id="startDate" class="form-control form-input" value="<%= filters.startDate %>">
            </div>
            <div class="col-md-3">
              <label for="endDate" class="form-label">End Date (of selected stage)</label>
              <input type="date" name="endDate" id="endDate" class="form-control form-input" value="<%= filters.endDate %>">
            </div>
          </div>
          <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-search"></i> Search
            </button>
            <a href="/operator/dashboard/converted-report/download?<%= new URLSearchParams(filters).toString() %>" class="btn btn-success">
              <i class="bi bi-file-earmark-excel"></i> Download Excel
            </a>
          </div>
        </form>
      </div>
    </div>

    <!-- Results Card -->
    <div class="card">
      <div class="card-header">
        <h5 class="card-title">
          <i class="bi bi-table me-2"></i>Report Results
        </h5>
        <span class="badge badge-neutral"><%= reportData.length %> records</span>
      </div>
      <div class="table-responsive">
        <table class="table">
          <thead>
            <tr>
              <th>Lot No</th>
              <th>Remark</th>
              <th>SKU</th>
              <th>Total Pieces</th>
              <th>Created At (<%= filters.filterStage.charAt(0).toUpperCase() + filters.filterStage.slice(1) %>)</th>
              <th>Stitching Qty</th>
              <th>Stitching User</th>
              <th>Stitching Date</th>
              <th>Cutting-Stitching Qty</th>
              <th>Finishing Qty</th>
              <th>Finishing User</th>
              <th>Finishing Date</th>
              <% if(filters.lotType === "akshay" || filters.lotType === "all") { %>
                <th>Jeans Assembly Qty</th>
                <th>Jeans Assembly User</th>
                <th>Jeans Assembly Date</th>
                <th>Jeans-Stitching Qty</th>
                <th>Washing Qty</th>
                <th>Washing User</th>
                <th>Washing Date</th>
              <% } %>
            </tr>
          </thead>
          <tbody>
            <% if(reportData.length === 0) { %>
              <tr>
                <td colspan="19" class="text-center py-5">
                  <div class="text-muted">
                    <i class="bi bi-inbox" style="font-size: 2.5rem; display: block; margin-bottom: 1rem; opacity: 0.5;"></i>
                    <p class="mb-0">No records found matching your criteria.</p>
                  </div>
                </td>
              </tr>
            <% } else { %>
              <% reportData.forEach(function(item) { %>
                <tr>
                  <td><strong><%= item.lot_no %></strong></td>
                  <td><%= item.remark %></td>
                  <td><code class="text-muted"><%= item.sku %></code></td>
                  <td><span class="badge badge-primary"><%= item.total_pieces %></span></td>
                  <td><%= item.created_at.toLocaleString() %></td>
                  <td><%= item.stitchingQuantity %></td>
                  <td><%= item.stitchingUsername %></td>
                  <td><%= item.stitchingDate ? item.stitchingDate.toLocaleString() : '<span class="text-muted">N/A</span>' %></td>
                  <td><%= item.cuttingStitchingQty %></td>
                  <td><%= item.finishingQuantity %></td>
                  <td><%= item.finishingUsername %></td>
                  <td><%= item.finishingDate ? item.finishingDate.toLocaleString() : '<span class="text-muted">N/A</span>' %></td>
                  <% if(filters.lotType === "akshay" || filters.lotType === "all") { %>
                    <% if(item.isAkshay) { %>
                      <td><%= item.jeansAssemblyQuantity %></td>
                      <td><%= item.jeansAssemblyUser %></td>
                      <td><%= item.jeansAssemblyDate ? item.jeansAssemblyDate.toLocaleString() : '<span class="text-muted">N/A</span>' %></td>
                      <td><%= item.jeansStitchingQty %></td>
                      <td><%= item.washingQuantity %></td>
                      <td><%= item.washingUsername %></td>
                      <td><%= item.washingDate ? item.washingDate.toLocaleString() : '<span class="text-muted">N/A</span>' %></td>
                    <% } else { %>
                      <td colspan="7" class="text-center text-muted">N/A (Non-Akshay Lot)</td>
                    <% } %>
                  <% } %>
                </tr>
              <% }); %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</main>

<style>
  /* Page-specific styles */
  code {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    background: var(--gray-100);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
  }

  .table td code {
    color: var(--text-secondary);
  }

  .table th {
    white-space: nowrap;
  }

  /* Responsive table scroll indicator */
  .table-responsive {
    position: relative;
  }

  .table-responsive::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 30px;
    height: 100%;
    background: linear-gradient(to left, rgba(255,255,255,0.9), transparent);
    pointer-events: none;
    opacity: 0;
    transition: opacity var(--transition-fast);
  }

  @media (max-width: 1200px) {
    .table-responsive::after {
      opacity: 1;
    }
  }

  /* Form input overrides for date inputs */
  input[type="date"].form-input {
    padding: 10px 14px;
  }
</style>

<%- include('partials/footer') %>
