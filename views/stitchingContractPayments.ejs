<%- include('partials/header', { pageTitle: 'Stitching Contract Payments' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/stitchingdashboard' }) %>

<main class="main-content">
  <div class="container-fluid" style="max-width: var(--content-max-width);">
    <!-- Page Header -->
    <div class="page-header">
      <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
          <div class="breadcrumbs">
            <a href="/stitchingdashboard">Stitching</a>
            <span class="separator">/</span>
            <span>Contract Payments</span>
          </div>
          <h1 class="page-title">Contract Payments</h1>
          <p class="page-subtitle">Select lots to process contract payments</p>
        </div>
        <div class="d-flex gap-2">
          <a href="/stitchingdashboard/payments/contract/history" class="btn btn-secondary">
            <i class="bi bi-clock-history"></i>
            History
          </a>
          <a href="/stitchingdashboard" class="btn btn-outline">
            <i class="bi bi-arrow-left"></i>
            Back
          </a>
        </div>
      </div>
    </div>

    <!-- Main Card -->
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">
          <i class="bi bi-list-check me-2" style="color: var(--terracotta);"></i>
          Pending Contract Lots
        </h2>
        <span class="badge badge-primary"><%= lots.length %> Lots</span>
      </div>
      <div class="card-body">
        <form id="payForm">
          <!-- Search Input -->
          <div class="mb-4">
            <div class="position-relative">
              <i class="bi bi-search position-absolute" style="left: 14px; top: 50%; transform: translateY(-50%); color: var(--text-muted);"></i>
              <input type="text" id="searchTable" class="form-control" placeholder="Search by lot number or SKU..." style="padding-left: 40px;">
            </div>
          </div>

          <!-- Table -->
          <div class="table-container">
            <table class="table" id="paymentsTable">
              <thead>
                <tr>
                  <th style="width: 50px;">
                    <input type="checkbox" id="selectAll" class="form-check-input" style="cursor: pointer;">
                  </th>
                  <th>Lot No</th>
                  <th>SKU</th>
                  <th>Cutting Remark</th>
                  <th class="text-end">Qty</th>
                  <th class="text-end">Rate</th>
                  <th class="text-end">Amount</th>
                </tr>
              </thead>
              <tbody>
                <% if (lots.length === 0) { %>
                <tr>
                  <td colspan="7" class="text-center py-5">
                    <div class="text-muted">
                      <i class="bi bi-inbox" style="font-size: 2rem; display: block; margin-bottom: 8px;"></i>
                      No pending contract payments
                    </div>
                  </td>
                </tr>
                <% } else { %>
                <% lots.forEach(function(l){ %>
                <tr>
                  <td>
                    <input type="checkbox" name="lotIds" value="<%= l.id %>" class="form-check-input" style="cursor: pointer;">
                  </td>
                  <td>
                    <span class="fw-medium" style="color: var(--text-primary);"><%= l.lot_no %></span>
                  </td>
                  <td><%= l.sku %></td>
                  <td>
                    <% if (l.cutting_remark) { %>
                      <span class="badge badge-neutral"><%= l.cutting_remark %></span>
                    <% } else { %>
                      <span class="text-muted">-</span>
                    <% } %>
                  </td>
                  <td class="text-end"><%= l.total_pieces %></td>
                  <td class="text-end"><%= l.rate %></td>
                  <td class="text-end fw-medium" style="color: var(--terracotta);"><%= l.amount %></td>
                </tr>
                <% }) %>
                <% } %>
              </tbody>
            </table>
          </div>

          <!-- Action Footer -->
          <% if (lots.length > 0) { %>
          <div class="d-flex align-items-center justify-content-between mt-4 pt-3" style="border-top: 1px solid var(--border-light);">
            <div class="text-muted" style="font-size: var(--text-sm);">
              <span id="selectedCount">0</span> lot(s) selected
            </div>
            <button type="button" id="payBtn" class="btn btn-primary btn-lg">
              <i class="bi bi-cash-stack"></i>
              Process Payment
            </button>
          </div>
          <% } %>
        </form>
      </div>
    </div>
  </div>
</main>

<!-- Summary Modal -->
<div class="modal fade" id="summaryModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="border-radius: var(--radius-xl); border: none; box-shadow: var(--shadow-xl);">
      <div class="modal-header" style="border-bottom: 1px solid var(--border-light);">
        <h5 class="modal-title" style="font-family: var(--font-display);">
          <i class="bi bi-receipt me-2" style="color: var(--terracotta);"></i>
          Payment Summary
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" style="padding: 24px;">
        <div id="summaryContent">
          <div class="d-flex justify-content-between align-items-center mb-3 pb-3" style="border-bottom: 1px solid var(--border-light);">
            <span class="text-muted">Selected Lots</span>
            <span id="summaryLots" class="fw-medium" style="font-size: var(--text-lg);">0</span>
          </div>
          <div class="d-flex justify-content-between align-items-center">
            <span class="text-muted">Total Amount</span>
            <span id="summaryAmount" class="fw-medium" style="font-size: var(--text-xl); color: var(--terracotta);">0.00</span>
          </div>
        </div>
      </div>
      <div class="modal-footer" style="border-top: 1px solid var(--border-light); background: var(--gray-50);">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" id="confirmPay" class="btn btn-success">
          <i class="bi bi-check-lg"></i>
          Confirm Payment
        </button>
      </div>
    </div>
  </div>
</div>

<script>
// Search functionality
const searchInput = document.getElementById('searchTable');
const rows = Array.from(document.querySelectorAll('#paymentsTable tbody tr'));
searchInput.addEventListener('input', () => {
  const term = searchInput.value.toLowerCase();
  rows.forEach(r => {
    const text = r.innerText.toLowerCase();
    r.style.display = text.includes(term) ? '' : 'none';
  });
});

// Select all functionality
const selectAllCheckbox = document.getElementById('selectAll');
const lotCheckboxes = document.querySelectorAll('input[name="lotIds"]');
const selectedCountEl = document.getElementById('selectedCount');

if (selectAllCheckbox) {
  selectAllCheckbox.addEventListener('change', () => {
    const visibleCheckboxes = Array.from(lotCheckboxes).filter(cb => {
      return cb.closest('tr').style.display !== 'none';
    });
    visibleCheckboxes.forEach(cb => {
      cb.checked = selectAllCheckbox.checked;
    });
    updateSelectedCount();
  });
}

lotCheckboxes.forEach(cb => {
  cb.addEventListener('change', updateSelectedCount);
});

function updateSelectedCount() {
  const checkedCount = document.querySelectorAll('input[name="lotIds"]:checked').length;
  if (selectedCountEl) {
    selectedCountEl.textContent = checkedCount;
  }
}

// Modal functionality
const modalEl = new bootstrap.Modal(document.getElementById('summaryModal'));
document.getElementById('payBtn').addEventListener('click', () => {
  const checks = Array.from(document.querySelectorAll('input[name="lotIds"]:checked'));
  if (!checks.length) {
    if (window.KottyTrack) {
      KottyTrack.showToast('Please select at least one lot', 'warning');
    } else {
      alert('Please select at least one lot');
    }
    return;
  }
  let total = 0;
  checks.forEach(c => {
    const row = c.closest('tr');
    total += parseFloat(row.children[6].innerText) || 0;
  });
  document.getElementById('summaryLots').innerText = checks.length;
  document.getElementById('summaryAmount').innerText = total.toFixed(2);
  modalEl.show();
});

document.getElementById('confirmPay').addEventListener('click', () => {
  const ids = Array.from(document.querySelectorAll('input[name="lotIds"]:checked')).map(c => c.value);
  if (!ids.length) return;
  window.location.href = `/stitchingdashboard/payments/contract/summary?ids=${ids.join(',')}`;
});
</script>

<%- include('partials/footer') %>
