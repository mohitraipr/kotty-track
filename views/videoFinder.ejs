<%- include('partials/header', { pageTitle: 'Video Finder' }) %>
<%- include('partials/navbar', { user: user }) %>

<style>
  /* Page-specific styles for Video Finder */
  .video-finder-content {
    margin-top: var(--navbar-height);
    padding: 28px;
    min-height: calc(100vh - var(--navbar-height));
  }

  .found-row {
    background-color: var(--success-light) !important;
  }

  .not-found-row {
    background-color: var(--danger-light) !important;
  }

  .video-link {
    font-weight: 500;
    text-decoration: none;
    color: var(--terracotta);
    transition: color var(--transition-fast);
  }

  .video-link:hover {
    color: var(--terracotta-dark);
    text-decoration: underline;
  }

  .awb-input {
    min-height: 120px;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  .search-mode-btn {
    flex: 1;
    padding: 10px 12px;
    border: 1px solid var(--border-medium);
    background: var(--bg-card);
    color: var(--text-secondary);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    transition: all var(--transition-fast);
    cursor: pointer;
  }

  .search-mode-btn:first-child {
    border-radius: var(--radius-md) 0 0 var(--radius-md);
  }

  .search-mode-btn:last-child {
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .search-mode-btn:not(:last-child) {
    border-right: none;
  }

  .search-mode-btn:hover {
    background: var(--gray-100);
    color: var(--text-primary);
  }

  .search-mode-btn.active {
    background: var(--terracotta);
    color: white;
    border-color: var(--terracotta);
  }

  .progress-container {
    display: none;
  }

  .progress-container.active {
    display: block;
  }

  .live-stats {
    font-size: var(--text-sm);
  }

  .live-stats .stat-item {
    display: inline-block;
    margin-right: 16px;
  }

  .results-table-wrapper {
    max-height: 70vh;
    overflow-y: auto;
  }

  .bucket-info {
    background: var(--gray-100);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    padding: 12px 16px;
    text-align: center;
  }

  .bucket-info code {
    background: var(--gray-200);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  .empty-state-icon {
    font-size: 3rem;
    color: var(--text-muted);
  }

  .search-panel .card-header {
    background: var(--charcoal);
    color: white;
  }

  .search-panel .card-header h5 {
    color: white;
    margin: 0;
  }

  @media (max-width: 768px) {
    .video-finder-content {
      padding: 16px;
    }

    .results-table-wrapper {
      max-height: 50vh;
    }
  }
</style>

<div class="video-finder-content">
  <!-- Page Header -->
  <div class="page-header">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
      <div>
        <h1 class="page-title">Video Finder</h1>
        <p class="page-subtitle">Search and manage video files by AWB, date, or keyword</p>
      </div>
      <% if (isMohitOperator) { %>
        <a href="/mail-manager" class="btn btn-secondary">
          <i class="bi bi-envelope"></i> Mail Manager
        </a>
      <% } %>
    </div>
  </div>

  <div class="row g-4">
    <!-- Search Panel -->
    <div class="col-lg-4">
      <div class="card search-panel">
        <div class="card-header">
          <h5><i class="bi bi-search me-2"></i>Search Videos</h5>
        </div>
        <div class="card-body">
          <!-- Search Mode Toggle -->
          <div class="d-flex mb-4" role="group">
            <button type="button" class="search-mode-btn active" data-mode="awb">
              <i class="bi bi-upc-scan me-1"></i> AWB
            </button>
            <button type="button" class="search-mode-btn" data-mode="date">
              <i class="bi bi-calendar me-1"></i> Date
            </button>
            <button type="button" class="search-mode-btn" data-mode="keyword">
              <i class="bi bi-search me-1"></i> Keyword
            </button>
          </div>

          <!-- AWB Search -->
          <div id="awbSearchPanel">
            <div class="form-group">
              <label for="awbList" class="form-label">AWB / Tracking Numbers</label>
              <textarea
                class="form-control form-textarea awb-input"
                id="awbList"
                placeholder="Enter AWB numbers (one per line, or comma/space separated)"
              ></textarea>
              <small class="text-muted">Paste multiple AWBs to search in bulk</small>
            </div>
            <button type="button" class="btn btn-primary w-100" id="searchAwbBtn">
              <i class="bi bi-search me-1"></i> Search AWBs
            </button>
          </div>

          <!-- Date Search -->
          <div id="dateSearchPanel" class="d-none">
            <div class="form-group">
              <label for="searchDate" class="form-label">Select Date</label>
              <input type="date" class="form-control form-input" id="searchDate" value="<%= new Date().toISOString().split('T')[0] %>">
              <small class="text-muted">View all videos uploaded on this date</small>
            </div>
            <button type="button" class="btn btn-primary w-100" id="searchDateBtn">
              <i class="bi bi-calendar-check me-1"></i> Browse Date
            </button>
          </div>

          <!-- Keyword Search -->
          <div id="keywordSearchPanel" class="d-none">
            <div class="form-group">
              <label for="keywordInput" class="form-label">Search Keyword</label>
              <input type="text" class="form-control form-input" id="keywordInput" placeholder="e.g., 2026, SF123, etc.">
              <small class="text-muted">Search for any text in video filenames</small>
            </div>
            <div class="form-group">
              <label for="keywordDate" class="form-label">Date (optional)</label>
              <input type="date" class="form-control form-input" id="keywordDate">
              <small class="text-muted">Limit search to specific date</small>
            </div>
            <button type="button" class="btn btn-primary w-100" id="searchKeywordBtn">
              <i class="bi bi-search me-1"></i> Search Keyword
            </button>
          </div>

          <hr class="my-4" style="border-color: var(--border-light);">

          <div class="form-group mb-3">
            <label class="form-label">Bulk Upload (Excel/CSV)</label>
            <input type="file" class="form-control form-input" id="bulkFile" accept=".xlsx,.xls,.csv">
            <small class="text-muted">Upload file with AWB column</small>
          </div>
          <button type="button" class="btn btn-secondary w-100" id="bulkSearchBtn" disabled>
            <i class="bi bi-file-earmark-spreadsheet me-1"></i> Bulk Search
          </button>
        </div>
      </div>

      <% if (bucketName) { %>
      <div class="bucket-info mt-3">
        <small class="text-muted">
          <i class="bi bi-cloud me-1"></i> S3 Bucket: <code><%= bucketName %></code>
        </small>
      </div>
      <% } %>
    </div>

    <!-- Results Panel -->
    <div class="col-lg-8">
      <div id="alertContainer"></div>

      <!-- Progress Bar for Large Searches -->
      <div class="card mb-3 progress-container" id="progressContainer">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="fw-bold">
              <i class="bi bi-hourglass-split me-2 text-terracotta"></i>Processing Large Search...
            </span>
            <button class="btn btn-sm btn-outline btn-danger" id="cancelSearchBtn">
              <i class="bi bi-x-circle me-1"></i> Cancel
            </button>
          </div>
          <div class="progress mb-3" style="height: 24px; background: var(--gray-200); border-radius: var(--radius-full);">
            <div class="progress-bar" id="searchProgress"
                 role="progressbar" style="width: 0%; background: var(--terracotta); border-radius: var(--radius-full);"
                 aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
              <span id="progressText" style="font-size: var(--text-sm); font-weight: 500;">0%</span>
            </div>
          </div>
          <div class="live-stats text-secondary">
            <span class="stat-item">
              <i class="bi bi-list-check me-1"></i> Processed: <strong id="processedCount">0</strong> / <span id="totalCount">0</span>
            </span>
            <span class="stat-item text-success">
              <i class="bi bi-check-circle me-1"></i> Found: <strong id="foundLiveCount">0</strong>
            </span>
            <span class="stat-item">
              <i class="bi bi-layers me-1"></i> Chunk: <span id="chunkInfo">0/0</span>
            </span>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <h5 class="card-title"><i class="bi bi-list-ul me-2"></i>Search Results</h5>
          <div class="d-flex gap-2 align-items-center">
            <span class="badge badge-success" id="foundBadge" style="display:none;">Found: 0</span>
            <span class="badge badge-danger" id="notFoundBadge" style="display:none;">Not Found: 0</span>
            <span class="badge badge-neutral" id="resultCount">0 result(s)</span>
          </div>
        </div>
        <div class="card-body p-0">
          <div class="results-table-wrapper">
            <table class="table mb-0" id="resultsTable">
              <thead>
                <tr>
                  <th>AWB / Filename</th>
                  <th>Status</th>
                  <th>Video</th>
                  <th>Size</th>
                  <% if (isMohitOperator) { %><th>Actions</th><% } %>
                </tr>
              </thead>
              <tbody id="resultsBody">
                <tr>
                  <td colspan="<%= isMohitOperator ? 5 : 4 %>" class="text-center py-5">
                    <div class="empty-state">
                      <i class="bi bi-search empty-state-icon d-block mb-3"></i>
                      <p class="empty-state-text">Search for videos using AWB, date, or keyword</p>
                    </div>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const isMohitOperator = <%= isMohitOperator %>;

// Search mode toggle
document.querySelectorAll('.search-mode-btn').forEach(btn => {
  btn.addEventListener('click', function() {
    document.querySelectorAll('.search-mode-btn').forEach(b => b.classList.remove('active'));
    this.classList.add('active');

    const mode = this.dataset.mode;
    document.getElementById('awbSearchPanel').classList.toggle('d-none', mode !== 'awb');
    document.getElementById('dateSearchPanel').classList.toggle('d-none', mode !== 'date');
    document.getElementById('keywordSearchPanel').classList.toggle('d-none', mode !== 'keyword');
  });
});

// Show alert - uses escapeHtml for user content
function showAlert(message, type = 'info') {
  const container = document.getElementById('alertContainer');
  const iconMap = {
    'success': 'check-circle',
    'danger': 'exclamation-triangle',
    'warning': 'exclamation-circle',
    'info': 'info-circle'
  };
  const alertDiv = document.createElement('div');
  alertDiv.className = `alert alert-${type} d-flex align-items-center justify-content-between`;
  alertDiv.setAttribute('role', 'alert');

  const contentDiv = document.createElement('div');
  const icon = document.createElement('i');
  icon.className = `bi bi-${iconMap[type] || 'info-circle'} me-2`;
  contentDiv.appendChild(icon);
  contentDiv.appendChild(document.createTextNode(' ' + message));

  const closeBtn = document.createElement('button');
  closeBtn.type = 'button';
  closeBtn.className = 'btn-close';
  closeBtn.style.fontSize = '0.75rem';
  closeBtn.onclick = function() { alertDiv.remove(); };

  alertDiv.appendChild(contentDiv);
  alertDiv.appendChild(closeBtn);

  container.textContent = '';
  container.appendChild(alertDiv);
}

// Escape HTML to prevent XSS
function escapeHtml(text) {
  const div = document.createElement('div');
  div.textContent = text || '';
  return div.textContent;
}

// Create table row safely using DOM methods
function createResultRow(r) {
  const found = r.found !== false;
  const displayName = r.awb || r.filename || (r.key ? r.key.split('/').pop() : null) || 'Unknown';

  const tr = document.createElement('tr');
  tr.className = found ? 'found-row' : 'not-found-row';

  // AWB/Filename cell
  const tdName = document.createElement('td');
  const strong = document.createElement('strong');
  strong.textContent = displayName;
  tdName.appendChild(strong);
  tr.appendChild(tdName);

  // Status cell
  const tdStatus = document.createElement('td');
  const badge = document.createElement('span');
  badge.className = found ? 'badge badge-success' : 'badge badge-danger';
  const badgeIcon = document.createElement('i');
  badgeIcon.className = found ? 'bi bi-check-circle me-1' : 'bi bi-x-circle me-1';
  badge.appendChild(badgeIcon);
  badge.appendChild(document.createTextNode(found ? ' Found' : ' Not Found'));
  tdStatus.appendChild(badge);
  tr.appendChild(tdStatus);

  // Video cell
  const tdVideo = document.createElement('td');
  if (found && r.url) {
    const link = document.createElement('a');
    link.href = r.url;
    link.target = '_blank';
    link.className = 'video-link';
    const linkIcon = document.createElement('i');
    linkIcon.className = 'bi bi-play-circle me-1';
    link.appendChild(linkIcon);
    link.appendChild(document.createTextNode(' ' + (r.filename || 'Download')));
    tdVideo.appendChild(link);
  } else {
    const span = document.createElement('span');
    span.className = 'text-muted';
    span.textContent = '-';
    tdVideo.appendChild(span);
  }
  tr.appendChild(tdVideo);

  // Size cell
  const tdSize = document.createElement('td');
  tdSize.textContent = (found && r.sizeFormatted) ? r.sizeFormatted : '-';
  tr.appendChild(tdSize);

  // Actions cell (if operator)
  if (isMohitOperator) {
    const tdActions = document.createElement('td');
    if (found && r.key) {
      const deleteBtn = document.createElement('button');
      deleteBtn.className = 'btn btn-sm btn-danger delete-btn';
      deleteBtn.dataset.key = r.key;
      deleteBtn.dataset.name = displayName;
      const deleteIcon = document.createElement('i');
      deleteIcon.className = 'bi bi-trash';
      deleteBtn.appendChild(deleteIcon);
      tdActions.appendChild(deleteBtn);
    } else {
      tdActions.textContent = '-';
    }
    tr.appendChild(tdActions);
  }

  return tr;
}

// Render results using DOM methods
function renderResults(results, isDateSearch = false) {
  const tbody = document.getElementById('resultsBody');
  const count = document.getElementById('resultCount');

  count.textContent = results.length + ' result(s)';
  tbody.textContent = '';

  if (!results.length) {
    const tr = document.createElement('tr');
    const td = document.createElement('td');
    td.colSpan = isMohitOperator ? 5 : 4;
    td.className = 'text-center py-5';

    const emptyState = document.createElement('div');
    emptyState.className = 'empty-state';

    const icon = document.createElement('i');
    icon.className = 'bi bi-search empty-state-icon d-block mb-3';
    emptyState.appendChild(icon);

    const text = document.createElement('p');
    text.className = 'empty-state-text';
    text.textContent = 'No videos found';
    emptyState.appendChild(text);

    td.appendChild(emptyState);
    tr.appendChild(td);
    tbody.appendChild(tr);
    return;
  }

  results.forEach(r => {
    tbody.appendChild(createResultRow(r));
  });
}

// Constants
const MAX_SINGLE_REQUEST = 500;
let currentEventSource = null;
let streamedResults = [];

// Progress UI helpers
function showProgress() {
  document.getElementById('progressContainer').classList.add('active');
}

function hideProgress() {
  document.getElementById('progressContainer').classList.remove('active');
}

function updateProgress(processed, total, found, chunk, totalChunks) {
  const percent = Math.round((processed / total) * 100);
  const bar = document.getElementById('searchProgress');
  bar.style.width = percent + '%';
  bar.setAttribute('aria-valuenow', percent);
  document.getElementById('progressText').textContent = percent + '%';
  document.getElementById('processedCount').textContent = processed.toLocaleString();
  document.getElementById('totalCount').textContent = total.toLocaleString();
  document.getElementById('foundLiveCount').textContent = found.toLocaleString();
  document.getElementById('chunkInfo').textContent = `${chunk}/${totalChunks}`;
}

function updateResultBadges(found, notFound) {
  const foundBadge = document.getElementById('foundBadge');
  const notFoundBadge = document.getElementById('notFoundBadge');
  if (found > 0) {
    foundBadge.textContent = 'Found: ' + found.toLocaleString();
    foundBadge.style.display = 'inline-block';
  }
  if (notFound > 0) {
    notFoundBadge.textContent = 'Not Found: ' + notFound.toLocaleString();
    notFoundBadge.style.display = 'inline-block';
  }
}

// Append results to table (for streaming)
function appendResults(items) {
  const tbody = document.getElementById('resultsBody');
  const countEl = document.getElementById('resultCount');

  // Clear placeholder if first results
  if (streamedResults.length === 0) {
    tbody.textContent = '';
  }

  items.forEach(r => {
    streamedResults.push(r);
    tbody.appendChild(createResultRow(r));
  });

  countEl.textContent = streamedResults.length + ' result(s)';
}

// Streaming search using SSE
function streamSearch(awbList) {
  return new Promise((resolve, reject) => {
    streamedResults = [];
    document.getElementById('foundBadge').style.display = 'none';
    document.getElementById('notFoundBadge').style.display = 'none';
    document.getElementById('resultsBody').textContent = '';

    const encoded = encodeURIComponent(awbList);
    currentEventSource = new EventSource(`/video-finder/api/search-stream?awbList=${encoded}`);

    let totalAwbs = 0;
    let foundCount = 0;

    currentEventSource.addEventListener('start', (e) => {
      const data = JSON.parse(e.data);
      totalAwbs = data.total;
      showProgress();
      updateProgress(0, totalAwbs, 0, 0, Math.ceil(totalAwbs / data.chunkSize));
    });

    currentEventSource.addEventListener('progress', (e) => {
      const data = JSON.parse(e.data);
      foundCount = data.found;
      updateProgress(data.processed, data.total, data.found, data.chunk, data.totalChunks);
    });

    currentEventSource.addEventListener('found', (e) => {
      const data = JSON.parse(e.data);
      appendResults(data.items);
    });

    currentEventSource.addEventListener('complete', (e) => {
      const data = JSON.parse(e.data);
      currentEventSource.close();
      currentEventSource = null;
      hideProgress();
      updateResultBadges(data.found, data.notFound);
      resolve(data);
    });

    currentEventSource.addEventListener('error', (e) => {
      if (e.data) {
        const data = JSON.parse(e.data);
        reject(new Error(data.message));
      } else {
        reject(new Error('Connection lost'));
      }
      currentEventSource.close();
      currentEventSource = null;
      hideProgress();
    });

    currentEventSource.onerror = () => {
      if (currentEventSource) {
        currentEventSource.close();
        currentEventSource = null;
      }
      hideProgress();
      reject(new Error('Connection lost'));
    };
  });
}

// Cancel button
document.getElementById('cancelSearchBtn').addEventListener('click', function() {
  if (currentEventSource) {
    currentEventSource.close();
    currentEventSource = null;
  }
  hideProgress();
  showAlert('Search cancelled', 'warning');
  document.getElementById('searchAwbBtn').disabled = false;
  document.getElementById('searchAwbBtn').textContent = '';
  const icon = document.createElement('i');
  icon.className = 'bi bi-search me-1';
  document.getElementById('searchAwbBtn').appendChild(icon);
  document.getElementById('searchAwbBtn').appendChild(document.createTextNode(' Search AWBs'));
});

// Helper to set button loading state
function setButtonLoading(btn, isLoading, icon, text) {
  btn.disabled = isLoading;
  btn.textContent = '';
  if (isLoading) {
    const spinner = document.createElement('span');
    spinner.className = 'spinner-border spinner-border-sm me-1';
    btn.appendChild(spinner);
    btn.appendChild(document.createTextNode(' ' + text));
  } else {
    const iconEl = document.createElement('i');
    iconEl.className = icon + ' me-1';
    btn.appendChild(iconEl);
    btn.appendChild(document.createTextNode(' ' + text));
  }
}

// AWB Search (AJAX or Streaming based on count)
document.getElementById('searchAwbBtn').addEventListener('click', async function() {
  const awbList = document.getElementById('awbList').value.trim();
  if (!awbList) {
    showAlert('Please enter at least one AWB number', 'warning');
    return;
  }

  // Count AWBs
  const awbCount = awbList.split(/[\n,\s|]+/).filter(s => s.trim()).length;

  setButtonLoading(this, true, 'bi bi-search', 'Searching...');

  try {
    if (awbCount > MAX_SINGLE_REQUEST) {
      // Use streaming for large searches
      showAlert('Large search (' + awbCount.toLocaleString() + ' AWBs) - streaming results...', 'info');
      const result = await streamSearch(awbList);
      showAlert('Complete! Found ' + result.found.toLocaleString() + ' of ' + result.total.toLocaleString() + ' videos', 'success');
    } else {
      // Use regular AJAX for smaller searches
      const res = await fetch('/video-finder/api/search', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ awbList })
      });
      const data = await res.json();

      if (data.error) {
        showAlert(data.error, 'danger');
        return;
      }

      renderResults(data.results);
      updateResultBadges(data.found, data.total - data.found);
      showAlert('Found ' + data.found + ' of ' + data.total + ' videos', 'success');
    }
  } catch (err) {
    showAlert('Search failed: ' + err.message, 'danger');
  } finally {
    setButtonLoading(this, false, 'bi bi-search', 'Search AWBs');
  }
});

// Date Search (AJAX)
document.getElementById('searchDateBtn').addEventListener('click', async function() {
  const date = document.getElementById('searchDate').value;
  if (!date) {
    showAlert('Please select a date', 'warning');
    return;
  }

  setButtonLoading(this, true, 'bi bi-calendar-check', 'Loading...');

  try {
    const res = await fetch('/video-finder/date/' + date);
    const data = await res.json();

    if (data.error) {
      showAlert(data.error, 'danger');
      return;
    }

    // Transform videos to results format
    const results = (data.videos || []).map(v => ({
      found: true,
      filename: v.filename,
      key: v.key,
      url: v.url,
      size: v.size,
      sizeFormatted: v.sizeFormatted
    }));

    renderResults(results, true);
    showAlert('Found ' + data.count + ' videos for ' + date, 'success');
  } catch (err) {
    showAlert('Failed to load videos: ' + err.message, 'danger');
  } finally {
    setButtonLoading(this, false, 'bi bi-calendar-check', 'Browse Date');
  }
});

// Keyword Search (AJAX)
document.getElementById('searchKeywordBtn').addEventListener('click', async function() {
  const keyword = document.getElementById('keywordInput').value.trim();
  const date = document.getElementById('keywordDate').value;

  if (!keyword) {
    showAlert('Please enter a search keyword', 'warning');
    return;
  }

  setButtonLoading(this, true, 'bi bi-search', 'Searching...');

  try {
    const params = new URLSearchParams({ keyword });
    if (date) params.append('date', date);

    const res = await fetch('/video-finder/api/keyword?' + params);
    const data = await res.json();

    if (data.error) {
      showAlert(data.error, 'danger');
      return;
    }

    renderResults(data.results);
    showAlert('Found ' + data.count + ' videos matching "' + keyword + '"', 'success');
  } catch (err) {
    showAlert('Search failed: ' + err.message, 'danger');
  } finally {
    setButtonLoading(this, false, 'bi bi-search', 'Search Keyword');
  }
});

// Bulk file upload
const bulkFile = document.getElementById('bulkFile');
const bulkSearchBtn = document.getElementById('bulkSearchBtn');

bulkFile.addEventListener('change', function() {
  bulkSearchBtn.disabled = !this.files.length;
});

bulkSearchBtn.addEventListener('click', async function() {
  if (!bulkFile.files.length) return;

  setButtonLoading(this, true, 'bi bi-file-earmark-spreadsheet', 'Searching...');

  const formData = new FormData();
  formData.append('awbFile', bulkFile.files[0]);

  try {
    const res = await fetch('/video-finder/bulk-search', {
      method: 'POST',
      body: formData
    });
    const data = await res.json();

    if (data.error) {
      showAlert(data.error, 'danger');
      return;
    }

    renderResults(data.results);
    showAlert('Found ' + data.found + ' of ' + data.total + ' videos', 'success');
  } catch (err) {
    showAlert('Bulk search failed: ' + err.message, 'danger');
  } finally {
    setButtonLoading(this, false, 'bi bi-file-earmark-spreadsheet', 'Bulk Search');
  }
});

// Delete handler
document.addEventListener('click', async function(e) {
  const btn = e.target.closest('.delete-btn');
  if (!btn) return;

  const key = btn.dataset.key;
  const name = btn.dataset.name;

  if (!confirm('Delete video?\n\n' + name + '\n\nThis cannot be undone.')) {
    return;
  }

  btn.disabled = true;
  btn.textContent = '';
  const spinner = document.createElement('span');
  spinner.className = 'spinner-border spinner-border-sm';
  btn.appendChild(spinner);

  try {
    const res = await fetch('/video-finder/delete', {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ key })
    });
    const data = await res.json();

    if (data.success) {
      btn.closest('tr').remove();
      showAlert('Video deleted successfully', 'success');
    } else {
      showAlert('Delete failed: ' + (data.error || 'Unknown error'), 'danger');
      btn.disabled = false;
      btn.textContent = '';
      const icon = document.createElement('i');
      icon.className = 'bi bi-trash';
      btn.appendChild(icon);
    }
  } catch (err) {
    showAlert('Delete failed: ' + err.message, 'danger');
    btn.disabled = false;
    btn.textContent = '';
    const icon = document.createElement('i');
    icon.className = 'bi bi-trash';
    btn.appendChild(icon);
  }
});

// Enter key handlers
document.getElementById('awbList').addEventListener('keydown', function(e) {
  if (e.key === 'Enter' && e.ctrlKey) {
    document.getElementById('searchAwbBtn').click();
  }
});

document.getElementById('keywordInput').addEventListener('keypress', function(e) {
  if (e.key === 'Enter') {
    document.getElementById('searchKeywordBtn').click();
  }
});
</script>

