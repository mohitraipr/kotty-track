<%- include('../partials/header', { pageTitle: 'Vendor POs' }) %>
<%- include('../partials/navbar', { dashboardUrl: '/nowi-po/dashboard' }) %>

<!-- Main Content -->
<main class="main-content" style="margin-left: 0;">
  <div class="container-fluid" style="max-width: 1200px; margin: 0 auto;">

    <!-- Page Header -->
    <div class="page-header">
      <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
          <nav class="breadcrumbs">
            <a href="/nowi-po/dashboard">Dashboard</a>
            <span class="separator">/</span>
            <span>Vendor POs</span>
          </nav>
          <h1 class="page-title">Vendor Purchase Orders</h1>
          <p class="page-subtitle">Manage and track all vendor purchase orders</p>
        </div>
        <a href="/nowi-po/create" class="btn btn-primary">
          <i class="bi bi-plus-lg"></i>
          Create New PO
        </a>
      </div>
    </div>

    <!-- Flash Messages -->
    <%- include('../partials/flashMessages') %>

    <!-- PO List Card -->
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">
          <i class="bi bi-file-earmark-text me-2" style="color: var(--terracotta);"></i>
          All Purchase Orders
        </h2>
        <span class="badge badge-neutral"><%= poRows.length %> total</span>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table align-middle mb-0">
            <thead>
              <tr>
                <th>PO Number</th>
                <th>Vendor Name</th>
                <th>Created By</th>
                <th>Created At</th>
                <th class="text-center">Lines</th>
                <th class="text-center">Total Qty</th>
                <th class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (poRows.length === 0) { %>
                <tr>
                  <td colspan="7" class="text-center py-5">
                    <div style="color: var(--text-muted);">
                      <i class="bi bi-inbox" style="font-size: 2.5rem; display: block; margin-bottom: 12px;"></i>
                      <p class="mb-2">No vendor POs created yet</p>
                      <a href="/nowi-po/create" class="btn btn-primary btn-sm">
                        <i class="bi bi-plus-lg"></i> Create First PO
                      </a>
                    </div>
                  </td>
                </tr>
              <% } %>
              <% poRows.forEach(po => { %>
                <tr>
                  <td>
                    <span style="font-weight: 500; color: var(--terracotta);">
                      <%= po.po_number || ('NOWI-PO-' + po.id) %>
                    </span>
                  </td>
                  <td><%= po.vendor_name %></td>
                  <td>
                    <span class="badge badge-neutral"><%= po.username || 'N/A' %></span>
                  </td>
                  <td><%= new Date(po.created_at).toLocaleDateString('en-IN') %></td>
                  <td class="text-center">
                    <span class="badge badge-info"><%= po.line_count %></span>
                  </td>
                  <td class="text-center">
                    <span style="font-weight: 500;"><%= po.total_quantity %></span>
                  </td>
                  <td class="text-end">
                    <div class="d-flex gap-2 justify-content-end">
                      <a href="/nowi-po/po/<%= po.id %>" class="btn btn-secondary btn-sm">
                        <i class="bi bi-eye"></i> View
                      </a>
                      <button type="button" class="btn btn-danger btn-sm" data-bs-toggle="modal" data-bs-target="#deletePOModal<%= po.id %>">
                        <i class="bi bi-trash"></i>
                      </button>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</main>

<!-- Delete PO Modals -->
<% poRows.forEach(po => { %>
  <div class="modal fade" id="deletePOModal<%= po.id %>" tabindex="-1" aria-labelledby="deletePOModalLabel<%= po.id %>" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content" style="border: 1px solid var(--border-light); border-radius: var(--radius-lg);">
        <div class="modal-header" style="border-bottom: 1px solid var(--border-light); padding: 18px 22px;">
          <h5 class="modal-title" id="deletePOModalLabel<%= po.id %>" style="font-family: var(--font-display); color: var(--danger);">
            <i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body" style="padding: 22px;">
          <p style="margin-bottom: 12px;">
            Are you sure you want to delete <strong style="color: var(--terracotta);"><%= po.po_number || ('NOWI-PO-' + po.id) %></strong> for vendor <strong><%= po.vendor_name %></strong>?
          </p>
          <div class="alert alert-warning mb-0" style="padding: 12px 16px;">
            <i class="bi bi-info-circle me-2"></i>
            This will delete <strong><%= po.line_count %></strong> line items. This action cannot be undone.
          </div>
        </div>
        <div class="modal-footer" style="border-top: 1px solid var(--border-light); padding: 16px 22px; background: var(--gray-50);">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <form action="/nowi-po/po/<%= po.id %>/delete" method="POST" style="display:inline;">
            <button type="submit" class="btn btn-danger">
              <i class="bi bi-trash me-1"></i> Delete PO
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
<% }) %>

<%- include('../partials/footer') %>
