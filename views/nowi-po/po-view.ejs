<%- include('../partials/header', { pageTitle: header.po_number + ' - Vendor PO' }) %>
<%- include('../partials/navbar', { dashboardUrl: '/nowi-po/dashboard' }) %>

<main class="main-content" style="margin-left: 0;">
  <div class="container-fluid" style="max-width: 1400px; margin: 0 auto;">

    <!-- Breadcrumbs -->
    <div class="breadcrumbs">
      <a href="/nowi-po/dashboard">Dashboard</a>
      <span class="separator"><i class="bi bi-chevron-right"></i></span>
      <a href="/nowi-po/po">Purchase Orders</a>
      <span class="separator"><i class="bi bi-chevron-right"></i></span>
      <span><%= header.po_number %></span>
    </div>

    <!-- Page Header -->
    <div class="page-header">
      <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
        <div>
          <h1 class="page-title"><%= header.po_number %></h1>
          <p class="page-subtitle">
            Created by <%= header.username || 'N/A' %> on <%= new Date(header.created_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
          </p>
        </div>
        <div class="d-flex flex-wrap gap-2 align-items-center">
          <a href="/nowi-po/po/<%= header.id %>/download" class="btn btn-success">
            <i class="bi bi-download"></i> Download Excel
          </a>
          <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#deletePOModal">
            <i class="bi bi-trash"></i> Delete PO
          </button>
          <span class="badge badge-primary" style="padding: 8px 16px; font-size: 0.875rem;">
            <i class="bi bi-building me-1"></i> <%= header.vendor_name %>
          </span>
        </div>
      </div>
    </div>

    <!-- Line Items Table -->
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">
          <i class="bi bi-list-ul me-2" style="color: var(--terracotta);"></i>
          Line Items
        </h2>
        <span class="badge badge-neutral"><%= lines.length %> items</span>
      </div>
      <div class="card-body" style="padding: 0;">
        <div class="table-responsive">
          <table class="table align-middle mb-0">
            <thead>
              <tr>
                <th>Vendor</th>
                <th>Image</th>
                <th>Color</th>
                <th>SKU</th>
                <th>Product Code</th>
                <th>Size</th>
                <th>Qty</th>
                <th>Weight</th>
                <th>Link</th>
              </tr>
            </thead>
            <tbody>
              <% if (lines.length === 0) { %>
                <tr>
                  <td colspan="9">
                    <div class="empty-state">
                      <div class="empty-state-icon">
                        <i class="bi bi-inbox" style="font-size: 48px;"></i>
                      </div>
                      <h3 class="empty-state-title">No Line Items</h3>
                      <p class="empty-state-text">This purchase order doesn't have any line items yet.</p>
                    </div>
                  </td>
                </tr>
              <% } else { %>
                <% lines.forEach(line => { %>
                  <tr>
                    <td>
                      <span class="fw-medium"><%= line.vendor_name %></span>
                    </td>
                    <td>
                      <% if (line.image) { %>
                        <img
                          src="<%= line.image %>"
                          alt="SKU Image"
                          class="sku-image-preview"
                          style="width: 50px; height: 50px; object-fit: cover; border-radius: var(--radius-md); border: 1px solid var(--border-light); cursor: pointer;"
                          onclick="openImageModal('<%= line.image %>')"
                        >
                      <% } else { %>
                        <span class="text-muted">
                          <i class="bi bi-image"></i>
                        </span>
                      <% } %>
                    </td>
                    <td>
                      <% if (line.color) { %>
                        <span class="badge badge-neutral"><%= line.color %></span>
                      <% } else { %>
                        <span class="text-muted">-</span>
                      <% } %>
                    </td>
                    <td>
                      <code style="background: var(--gray-100); padding: 2px 6px; border-radius: var(--radius-sm); font-size: 0.8rem;">
                        <%= line.sku %>
                      </code>
                    </td>
                    <td><%= line.product_code %></td>
                    <td>
                      <span class="badge badge-info"><%= line.size %></span>
                    </td>
                    <td>
                      <strong style="color: var(--terracotta);"><%= line.quantity %></strong>
                    </td>
                    <td><%= line.weight ?? '-' %></td>
                    <td>
                      <% if (line.link) { %>
                        <a href="<%= line.link %>" target="_blank" rel="noopener" class="btn btn-sm btn-outline">
                          <i class="bi bi-box-arrow-up-right"></i> Open
                        </a>
                      <% } else { %>
                        <span class="text-muted">-</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
      <% if (lines.length > 0) { %>
        <div class="card-footer">
          <div class="d-flex justify-content-between align-items-center">
            <span class="text-secondary">
              Total: <strong><%= lines.reduce((sum, l) => sum + (l.quantity || 0), 0) %></strong> units
            </span>
            <a href="/nowi-po/po" class="btn btn-secondary">
              <i class="bi bi-arrow-left"></i> Back to POs
            </a>
          </div>
        </div>
      <% } %>
    </div>

  </div>
</main>

<!-- Delete PO Modal -->
<div class="modal fade" id="deletePOModal" tabindex="-1" aria-labelledby="deletePOModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="border-radius: var(--radius-xl); border: none; box-shadow: var(--shadow-xl);">
      <div class="modal-header" style="border-bottom: 1px solid var(--border-light);">
        <h5 class="modal-title" id="deletePOModalLabel" style="font-family: var(--font-display); color: var(--danger);">
          <i class="bi bi-exclamation-triangle me-2"></i> Confirm Delete
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" style="padding: 24px;">
        <p style="margin-bottom: 12px;">
          Are you sure you want to delete <strong style="color: var(--terracotta);"><%= header.po_number %></strong>?
        </p>
        <p class="text-muted" style="margin-bottom: 16px;">
          Vendor: <strong><%= header.vendor_name %></strong>
        </p>
        <div class="alert alert-warning" style="margin-bottom: 0;">
          <i class="bi bi-info-circle me-2"></i>
          This will delete <strong><%= lines.length %></strong> line items. This action cannot be undone.
        </div>
      </div>
      <div class="modal-footer" style="border-top: 1px solid var(--border-light); background: var(--gray-50); border-radius: 0 0 var(--radius-xl) var(--radius-xl);">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
          <i class="bi bi-x-lg"></i> Cancel
        </button>
        <form action="/nowi-po/po/<%= header.id %>/delete" method="POST" style="display:inline;">
          <button type="submit" class="btn btn-danger">
            <i class="bi bi-trash"></i> Delete PO
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Image Preview Modal -->
<div class="modal fade" id="imagePreviewModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content" style="border-radius: var(--radius-xl); border: none; background: transparent; box-shadow: none;">
      <div class="modal-body text-center" style="padding: 0;">
        <img id="previewImage" src="" alt="SKU Image" style="max-width: 100%; max-height: 80vh; border-radius: var(--radius-lg); box-shadow: var(--shadow-xl);">
        <button type="button" class="btn btn-secondary mt-3" data-bs-dismiss="modal">
          <i class="bi bi-x-lg"></i> Close
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  /* Page-specific styles */
  .sku-image-preview:hover {
    transform: scale(1.05);
    box-shadow: var(--shadow-md);
    transition: all var(--transition-fast);
  }

  .table th {
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .page-header .d-flex {
      flex-direction: column;
      align-items: flex-start !important;
    }

    .page-header .badge {
      margin-top: 8px;
    }
  }
</style>

<script>
  // Image preview modal
  function openImageModal(src) {
    const modal = new bootstrap.Modal(document.getElementById('imagePreviewModal'));
    document.getElementById('previewImage').src = src;
    modal.show();
  }
</script>

<%- include('../partials/footer') %>
