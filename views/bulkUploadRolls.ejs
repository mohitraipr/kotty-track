<!-- views/bulkUploadRolls.ejs -->
<%- include('partials/header', { pageTitle: 'Bulk Upload Rolls' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/fabric-manager/dashboard' }) %>

<style>
  .upload-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    font-family: 'DM Serif Display', serif;
    color: var(--charcoal);
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .page-header p {
    color: var(--charcoal-light);
    font-family: 'Outfit', sans-serif;
    font-size: 1rem;
    margin: 0;
  }

  .upload-card {
    background: #ffffff;
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    border: 1px solid rgba(0, 0, 0, 0.06);
    overflow: hidden;
  }

  .upload-card-header {
    background: linear-gradient(135deg, var(--charcoal) 0%, #2d2d2d 100%);
    color: #ffffff;
    padding: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .upload-card-header i {
    font-size: 1.5rem;
    color: var(--terracotta);
  }

  .upload-card-header h4 {
    font-family: 'DM Serif Display', serif;
    font-size: 1.25rem;
    margin: 0;
  }

  .upload-card-body {
    padding: 2rem;
  }

  .file-input-wrapper {
    position: relative;
    margin-bottom: 1.5rem;
  }

  .file-input-wrapper label {
    display: block;
    font-family: 'Outfit', sans-serif;
    font-weight: 500;
    color: var(--charcoal);
    margin-bottom: 0.5rem;
  }

  .file-input-wrapper label i {
    color: var(--terracotta);
    margin-right: 0.5rem;
  }

  .file-input-wrapper .form-control {
    border: 2px dashed rgba(196, 92, 58, 0.3);
    border-radius: 8px;
    padding: 1rem;
    font-family: 'Outfit', sans-serif;
    transition: all 0.3s ease;
  }

  .file-input-wrapper .form-control:hover,
  .file-input-wrapper .form-control:focus {
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px rgba(196, 92, 58, 0.1);
  }

  .file-input-wrapper .form-text {
    font-family: 'Outfit', sans-serif;
    color: var(--charcoal-light);
    font-size: 0.875rem;
    margin-top: 0.5rem;
  }

  .btn-group-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn-upload {
    background: var(--terracotta);
    color: #ffffff;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-family: 'Outfit', sans-serif;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s ease;
  }

  .btn-upload:hover {
    background: #a84d30;
    color: #ffffff;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(196, 92, 58, 0.3);
  }

  .btn-cancel {
    background: transparent;
    color: var(--charcoal);
    border: 2px solid rgba(26, 26, 26, 0.2);
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-family: 'Outfit', sans-serif;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s ease;
  }

  .btn-cancel:hover {
    border-color: var(--charcoal);
    background: rgba(26, 26, 26, 0.05);
    color: var(--charcoal);
  }

  .info-section {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  .info-section h5 {
    font-family: 'DM Serif Display', serif;
    color: var(--charcoal);
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .info-section h5 i {
    color: var(--terracotta);
    font-size: 1rem;
  }

  .info-section p {
    font-family: 'Outfit', sans-serif;
    color: var(--charcoal-light);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .info-section p strong {
    color: var(--charcoal);
  }

  .btn-template {
    background: transparent;
    color: var(--terracotta);
    border: 2px solid var(--terracotta);
    padding: 0.625rem 1.25rem;
    border-radius: 8px;
    font-family: 'Outfit', sans-serif;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s ease;
  }

  .btn-template:hover {
    background: var(--terracotta);
    color: #ffffff;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(196, 92, 58, 0.3);
  }

  .info-card {
    background: rgba(196, 92, 58, 0.05);
    border: 1px solid rgba(196, 92, 58, 0.15);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    margin-bottom: 1rem;
  }

  .info-card p {
    margin-bottom: 0;
    font-size: 0.9rem;
  }

  @media (max-width: 576px) {
    .upload-container {
      padding: 1rem 0.75rem;
    }

    .upload-card-body {
      padding: 1.25rem;
    }

    .btn-group-actions {
      flex-direction: column;
    }

    .btn-group-actions .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<!-- Main Container -->
<div class="upload-container">
  <!-- Page Header -->
  <div class="page-header">
    <h1><i class="bi bi-upload me-2" style="color: var(--terracotta);"></i>Bulk Upload Rolls</h1>
    <p>Upload fabric invoice roll data using an Excel file</p>
  </div>

  <!-- Include Flash Messages Partial -->
  <%- include('partials/flashMessages') %>

  <!-- Upload Form Card -->
  <div class="upload-card">
    <div class="upload-card-header">
      <i class="bi bi-file-earmark-spreadsheet"></i>
      <h4>Upload for <%= tableName %></h4>
    </div>

    <div class="upload-card-body">
      <form action="/fabric-manager/bulk-upload/rolls" method="POST" enctype="multipart/form-data">
        <div class="file-input-wrapper">
          <label for="excelFile">
            <i class="bi bi-file-earmark-excel"></i> Excel File (.xlsx)
          </label>
          <input type="file" class="form-control" id="excelFile" name="excelFile" accept=".xlsx" required>
          <div class="form-text">
            <i class="bi bi-info-circle me-1"></i>
            Ensure the Excel file follows the required format. Download the template below if needed.
          </div>
        </div>

        <div class="btn-group-actions">
          <button type="submit" class="btn btn-upload">
            <i class="bi bi-cloud-upload"></i> Upload
          </button>
          <a href="/fabric-manager/dashboard" class="btn btn-cancel">
            <i class="bi bi-x-circle"></i> Cancel
          </a>
        </div>
      </form>

      <!-- Roll Number Uniqueness Information -->
      <div class="info-section">
        <h5><i class="bi bi-shield-check"></i> Roll Number Uniqueness</h5>
        <div class="info-card">
          <p>The system enforces that each <strong>roll_no</strong> is unique per vendor. If a <strong>roll_no</strong> already exists for a vendor, the upload will fail for that row.</p>
        </div>
      </div>

      <!-- Excel Template Information -->
      <div class="info-section">
        <h5><i class="bi bi-file-earmark-arrow-down"></i> Excel Template</h5>
        <p>Download the Excel template to ensure correct formatting and structure for your data:</p>
        <a href="/fabric-manager/bulk-upload/rolls/template" class="btn btn-template">
          <i class="bi bi-download"></i> Download Template
        </a>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
