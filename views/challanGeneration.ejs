<%- include('partials/header', { pageTitle: 'Generate Challan' }) %>
<%- include('partials/navbar') %>

<!-- Main Content -->
<main class="main-content" style="padding-top: calc(var(--navbar-height) + 24px); padding-bottom: 40px; min-height: 100vh;">
  <div class="container" style="max-width: 1200px;">

    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h1 style="font-family: var(--font-display); font-size: var(--text-3xl); color: var(--text-primary); margin-bottom: 4px;">
          Challan Generation
        </h1>
        <p style="color: var(--text-secondary); font-size: var(--text-sm);">
          Create delivery challan for washing job work
        </p>
      </div>
      <a href="/challandashboard" class="btn" style="background: var(--gray-200); color: var(--text-primary); border: none; padding: 10px 20px; border-radius: var(--radius-md); font-weight: 500; transition: var(--transition-fast);">
        <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
      </a>
    </div>

    <!-- Main Form Card -->
    <div class="kotty-card" style="background: var(--bg-card); border-radius: var(--radius-xl); box-shadow: var(--shadow-md); border: 1px solid var(--border-light); overflow: hidden;">
      <form action="/challandashboard/create" method="POST" id="challanForm">
        <!-- Hidden Data -->
        <input type="hidden" name="selectedRows" value="<%- JSON.stringify(selectedRows).replace(/\"/g,'&quot;') %>">

        <!-- Form Section: Basic Details -->
        <div style="padding: 24px; border-bottom: 1px solid var(--border-light);">
          <h3 style="font-family: var(--font-display); font-size: var(--text-xl); color: var(--text-primary); margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
            <span style="width: 28px; height: 28px; background: var(--terracotta-bg); color: var(--terracotta); border-radius: var(--radius-full); display: inline-flex; align-items: center; justify-content: center; font-family: var(--font-body); font-size: var(--text-sm); font-weight: 600;">1</span>
            Basic Information
          </h3>

          <div class="row g-4">
            <div class="col-md-4">
              <label class="form-label" style="font-weight: 500; color: var(--text-primary); margin-bottom: 6px;">
                Challan Date <span style="color: var(--danger);">*</span>
              </label>
              <input type="date" class="form-control" id="challanDate" name="challanDate"
                     value="<%= new Date().toLocaleDateString('en-CA') %>" required
                     style="padding: 12px 16px; border: 1px solid var(--border-medium); border-radius: var(--radius-md); font-family: var(--font-body); transition: var(--transition-fast);">
            </div>

            <div class="col-md-4">
              <label class="form-label" style="font-weight: 500; color: var(--text-primary); margin-bottom: 6px;">
                Select Washer (Consignee) <span style="color: var(--danger);">*</span>
              </label>
              <select class="form-select" id="washerId" name="washerId" required
                      style="padding: 12px 16px; border: 1px solid var(--border-medium); border-radius: var(--radius-md); font-family: var(--font-body); transition: var(--transition-fast);">
                <option value="">-- Select Washer --</option>
                <% washers.forEach(w=>{ %>
                  <option value="<%= w.id %>"><%= w.username %></option>
                <% }) %>
              </select>
            </div>

            <div class="col-md-4">
              <label class="form-label" style="font-weight: 500; color: var(--text-primary); margin-bottom: 6px;">
                Vehicle Number <span style="color: var(--danger);">*</span>
              </label>
              <input type="text" id="vehicleNumber" name="vehicleNumber" class="form-control"
                     placeholder="HR55-AB-1234" required
                     style="padding: 12px 16px; border: 1px solid var(--border-medium); border-radius: var(--radius-md); font-family: var(--font-body); transition: var(--transition-fast);">
            </div>
          </div>
        </div>

        <!-- Form Section: Consignee Details (Auto-filled) -->
        <div style="padding: 24px; border-bottom: 1px solid var(--border-light); background: var(--cream-dark);">
          <h3 style="font-family: var(--font-display); font-size: var(--text-xl); color: var(--text-primary); margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
            <span style="width: 28px; height: 28px; background: var(--terracotta-bg); color: var(--terracotta); border-radius: var(--radius-full); display: inline-flex; align-items: center; justify-content: center; font-family: var(--font-body); font-size: var(--text-sm); font-weight: 600;">2</span>
            Consignee Details
            <span style="font-size: var(--text-sm); font-weight: 400; color: var(--text-muted); font-family: var(--font-body);">(Auto-filled)</span>
          </h3>

          <div class="row g-4">
            <div class="col-md-3">
              <label class="form-label" style="font-weight: 500; color: var(--text-secondary); margin-bottom: 6px;">
                Consignee Name
              </label>
              <input type="text" id="consigneeName" class="form-control" disabled
                     style="padding: 12px 16px; border: 1px solid var(--border-light); border-radius: var(--radius-md); background: var(--bg-card); color: var(--text-secondary); font-family: var(--font-body);">
            </div>
            <div class="col-md-3">
              <label class="form-label" style="font-weight: 500; color: var(--text-secondary); margin-bottom: 6px;">
                Consignee GSTIN
              </label>
              <input type="text" id="consigneeGstin" class="form-control" disabled
                     style="padding: 12px 16px; border: 1px solid var(--border-light); border-radius: var(--radius-md); background: var(--bg-card); color: var(--text-secondary); font-family: var(--font-body);">
            </div>
            <div class="col-md-4">
              <label class="form-label" style="font-weight: 500; color: var(--text-secondary); margin-bottom: 6px;">
                Consignee Address
              </label>
              <input type="text" id="consigneeAddress" class="form-control" disabled
                     style="padding: 12px 16px; border: 1px solid var(--border-light); border-radius: var(--radius-md); background: var(--bg-card); color: var(--text-secondary); font-family: var(--font-body);">
            </div>
            <div class="col-md-2">
              <label class="form-label" style="font-weight: 500; color: var(--text-secondary); margin-bottom: 6px;">
                Place of Supply
              </label>
              <input type="text" id="placeOfSupply" class="form-control" disabled
                     style="padding: 12px 16px; border: 1px solid var(--border-light); border-radius: var(--radius-md); background: var(--bg-card); color: var(--text-secondary); font-family: var(--font-body);">
            </div>
          </div>
        </div>

        <!-- Form Section: Purpose & Price -->
        <div style="padding: 24px; border-bottom: 1px solid var(--border-light);">
          <h3 style="font-family: var(--font-display); font-size: var(--text-xl); color: var(--text-primary); margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
            <span style="width: 28px; height: 28px; background: var(--terracotta-bg); color: var(--terracotta); border-radius: var(--radius-full); display: inline-flex; align-items: center; justify-content: center; font-family: var(--font-body); font-size: var(--text-sm); font-weight: 600;">3</span>
            Purpose & Pricing
          </h3>

          <div class="row g-4">
            <div class="col-md-6">
              <label class="form-label" style="font-weight: 500; color: var(--text-primary); margin-bottom: 6px;">
                Purpose
              </label>
              <input type="text" id="purpose" name="purpose" class="form-control"
                     placeholder="e.g. Washing Job Work"
                     style="padding: 12px 16px; border: 1px solid var(--border-medium); border-radius: var(--radius-md); font-family: var(--font-body); transition: var(--transition-fast);">
            </div>
            <div class="col-md-3">
              <label class="form-label" style="font-weight: 500; color: var(--text-primary); margin-bottom: 6px;">
                Purpose Price (Rs.)
              </label>
              <div class="input-group">
                <span class="input-group-text" style="background: var(--cream-dark); border: 1px solid var(--border-medium); border-right: none; color: var(--text-secondary);">Rs.</span>
                <input type="number" id="purposePrice" name="purposePrice" class="form-control"
                       step="0.01" min="0" placeholder="0.00"
                       style="padding: 12px 16px; border: 1px solid var(--border-medium); border-radius: 0 var(--radius-md) var(--radius-md) 0; font-family: var(--font-body); transition: var(--transition-fast);">
              </div>
            </div>
          </div>
        </div>

        <!-- Form Section: Selected Lots Summary -->
        <div style="padding: 24px;">
          <h3 style="font-family: var(--font-display); font-size: var(--text-xl); color: var(--text-primary); margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
            <span style="width: 28px; height: 28px; background: var(--terracotta-bg); color: var(--terracotta); border-radius: var(--radius-full); display: inline-flex; align-items: center; justify-content: center; font-family: var(--font-body); font-size: var(--text-sm); font-weight: 600;">4</span>
            Selected Lots Summary
            <span style="background: var(--terracotta); color: white; font-size: var(--text-xs); padding: 4px 10px; border-radius: var(--radius-full); font-family: var(--font-body); font-weight: 500;">
              <%= selectedRows.length %> lot<%= selectedRows.length !== 1 ? 's' : '' %>
            </span>
          </h3>

          <div class="table-responsive" style="border: 1px solid var(--border-light); border-radius: var(--radius-lg); overflow: hidden;">
            <table class="table mb-0" style="margin: 0;">
              <thead style="background: var(--charcoal); color: var(--text-inverse);">
                <tr>
                  <th style="padding: 14px 16px; font-weight: 500; font-size: var(--text-sm); border: none;">Lot No</th>
                  <th style="padding: 14px 16px; font-weight: 500; font-size: var(--text-sm); border: none;">SKU</th>
                  <th style="padding: 14px 16px; font-weight: 500; font-size: var(--text-sm); border: none; text-align: center;">Total Pieces</th>
                  <th style="padding: 14px 16px; font-weight: 500; font-size: var(--text-sm); border: none;">Cutting Remark</th>
                </tr>
              </thead>
              <tbody>
                <% let totalPieces = 0; %>
                <% selectedRows.forEach((r, index) => { %>
                  <% totalPieces += parseInt(r.total_pieces) || 0; %>
                  <tr style="background: <%= index % 2 === 0 ? 'var(--bg-card)' : 'var(--cream)' %>; transition: var(--transition-fast);">
                    <td style="padding: 14px 16px; border-bottom: 1px solid var(--border-light); font-weight: 500; color: var(--terracotta);"><%= r.lot_no %></td>
                    <td style="padding: 14px 16px; border-bottom: 1px solid var(--border-light); color: var(--text-primary);"><%= r.sku %></td>
                    <td style="padding: 14px 16px; border-bottom: 1px solid var(--border-light); text-align: center; font-weight: 600;"><%= r.total_pieces %></td>
                    <td style="padding: 14px 16px; border-bottom: 1px solid var(--border-light); color: var(--text-secondary);"><%= r.cutting_remark || '-' %></td>
                  </tr>
                <% }) %>
              </tbody>
              <tfoot style="background: var(--cream-dark);">
                <tr>
                  <td colspan="2" style="padding: 14px 16px; font-weight: 600; border: none;">Total</td>
                  <td style="padding: 14px 16px; text-align: center; font-weight: 700; color: var(--terracotta); font-size: var(--text-lg); border: none;"><%= totalPieces %></td>
                  <td style="border: none;"></td>
                </tr>
              </tfoot>
            </table>
          </div>

          <!-- Submit Button -->
          <div class="d-flex justify-content-end mt-4 pt-3" style="border-top: 1px solid var(--border-light);">
            <button type="submit" class="btn" style="background: var(--terracotta); color: white; border: none; padding: 14px 28px; border-radius: var(--radius-md); font-weight: 500; font-size: var(--text-base); transition: var(--transition-fast); display: flex; align-items: center; gap: 8px;">
              <i class="bi bi-file-earmark-text"></i>
              Confirm & Generate Challan
            </button>
          </div>
        </div>
      </form>
    </div>

  </div>
</main>

<!-- Scripts -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
