};

$('#washerId').on('change', function () {
  const d = consigneeMapping[this.value] || {};
  $('#consigneeName').val(d.name||'');
  $('#consigneeGstin').val(d.gstin||'');
  $('#consigneeAddress').val(d.address||'');
  $('#placeOfSupply').val(d.placeOfSupply||'');
});

// Form input focus styles
document.querySelectorAll('.form-control, .form-select').forEach(input => {
  input.addEventListener('focus', function() {
    this.style.borderColor = 'var(--terracotta)';
    this.style.boxShadow = '0 0 0 3px var(--terracotta-bg)';
    this.style.outline = 'none';
  });
  input.addEventListener('blur', function() {
    this.style.borderColor = 'var(--border-medium)';
    this.style.boxShadow = 'none';
  });
});

// Submit button hover effect
const submitBtn = document.querySelector('button[type="submit"]');
if (submitBtn) {
  submitBtn.addEventListener('mouseenter', function() {
    this.style.background = 'var(--terracotta-dark)';
    this.style.transform = 'translateY(-1px)';
  });
  submitBtn.addEventListener('mouseleave', function() {
    this.style.background = 'var(--terracotta)';
    this.style.transform = 'translateY(0)';
  });
}
</script>

<%- include('partials/footer') %>
