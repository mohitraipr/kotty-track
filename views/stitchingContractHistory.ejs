<%- include('partials/header', { pageTitle: 'Contract History' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/stitchingdashboard' }) %>

<main class="kotty-main">
  <div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="page-header mb-4">
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
          <h1 class="page-title">Contract Payment History</h1>
          <p class="page-subtitle">View all payment sessions and receipts</p>
        </div>
        <a href="/stitchingdashboard/payments/contract" class="btn btn-outline-secondary">
          <i class="bi bi-arrow-left me-2"></i>Back to Payments
        </a>
      </div>
    </div>

    <!-- Payment Sessions -->
    <% if (sessions && sessions.length > 0) { %>
      <% sessions.forEach(function(s){ %>
        <div class="kotty-card mb-4">
          <div class="card-header d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-3">
              <div class="session-icon">
                <i class="bi bi-clock-history"></i>
              </div>
              <div>
                <h6 class="mb-0 fw-semibold"><%= new Date(s.time).toLocaleString('en-CA', {hour12: false}) %></h6>
                <small class="text-muted"><%= s.payments.length %> payment<%= s.payments.length !== 1 ? 's' : '' %></small>
              </div>
            </div>
            <a href="/stitchingdashboard/payments/contract/receipt/<%= new Date(s.time).getTime() %>" class="btn btn-kotty-outline btn-sm">
              <i class="bi bi-printer me-1"></i>Print Receipt
            </a>
          </div>
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table kotty-table mb-0">
                <thead>
                  <tr>
                    <th>Lot No.</th>
                    <th>SKU</th>
                    <th class="text-end">Qty</th>
                    <th class="text-end">Rate</th>
                    <th class="text-end">Amount</th>
                  </tr>
                </thead>
                <tbody>
                  <% s.payments.forEach(function(p){ %>
                    <tr>
                      <td>
                        <span class="badge bg-charcoal-subtle text-dark"><%= p.lot_no %></span>
                      </td>
                      <td><%= p.sku %></td>
                      <td class="text-end"><%= p.qty %></td>
                      <td class="text-end"><%= p.rate %></td>
                      <td class="text-end fw-semibold"><%= p.amount %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
          <div class="card-footer text-end">
            <span class="session-total">
              <span class="text-muted me-2">Session Total:</span>
              <span class="total-amount"><%= s.total.toFixed(2) %></span>
            </span>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="kotty-card">
        <div class="card-body text-center py-5">
          <div class="empty-state">
            <i class="bi bi-inbox display-4 text-muted mb-3"></i>
            <h5 class="text-muted">No Payment History</h5>
            <p class="text-muted mb-0">There are no payment sessions recorded yet.</p>
          </div>
        </div>
      </div>
    <% } %>
  </div>
</main>

<style>
  .kotty-main {
    padding-top: var(--navbar-height, 60px);
    min-height: 100vh;
    background: var(--bg-page, #faf8f5);
  }

  .page-header {
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-light, #e8e6e1);
  }

  .page-title {
    font-family: var(--font-display, 'DM Serif Display', Georgia, serif);
    font-size: var(--text-2xl, 1.5rem);
    color: var(--text-primary, #1a1a1a);
    margin-bottom: 0.25rem;
  }

  .page-subtitle {
    font-size: var(--text-sm, 0.875rem);
    color: var(--text-secondary, #5a5650);
    margin-bottom: 0;
  }

  .kotty-card {
    background: var(--bg-card, #ffffff);
    border: 1px solid var(--border-light, #e8e6e1);
    border-radius: var(--radius-lg, 8px);
    box-shadow: var(--shadow-sm, 0 2px 4px rgba(26, 26, 26, 0.06));
    overflow: hidden;
  }

  .kotty-card .card-header {
    background: var(--cream, #faf8f5);
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--border-light, #e8e6e1);
  }

  .kotty-card .card-body {
    padding: 1.5rem;
  }

  .kotty-card .card-footer {
    background: var(--gray-50, #fafaf9);
    padding: 1rem 1.5rem;
    border-top: 1px solid var(--border-light, #e8e6e1);
  }

  .session-icon {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md, 6px);
    background: var(--terracotta-bg, rgba(196, 92, 58, 0.08));
    color: var(--terracotta, #c45c3a);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
  }

  .kotty-table {
    font-family: var(--font-body, 'Outfit', sans-serif);
  }

  .kotty-table thead th {
    background: var(--gray-100, #f5f5f3);
    font-weight: 600;
    font-size: var(--text-sm, 0.875rem);
    color: var(--text-secondary, #5a5650);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    padding: 0.875rem 1rem;
    border: none;
    border-bottom: 1px solid var(--border-light, #e8e6e1);
  }

  .kotty-table tbody td {
    padding: 0.875rem 1rem;
    vertical-align: middle;
    border-color: var(--border-light, #e8e6e1);
    color: var(--text-primary, #1a1a1a);
  }

  .kotty-table tbody tr:hover {
    background: var(--cream, #faf8f5);
  }

  .bg-charcoal-subtle {
    background: var(--gray-200, #e8e6e1);
    font-weight: 500;
  }

  .btn-kotty-outline {
    border: 1px solid var(--terracotta, #c45c3a);
    color: var(--terracotta, #c45c3a);
    background: transparent;
    font-weight: 500;
    padding: 0.375rem 0.875rem;
    border-radius: var(--radius-md, 6px);
    transition: all var(--transition-fast, 150ms);
  }

  .btn-kotty-outline:hover {
    background: var(--terracotta, #c45c3a);
    color: white;
    border-color: var(--terracotta, #c45c3a);
  }

  .session-total {
    font-size: var(--text-lg, 1.125rem);
  }

  .total-amount {
    font-family: var(--font-display, 'DM Serif Display', Georgia, serif);
    font-size: var(--text-xl, 1.25rem);
    color: var(--terracotta, #c45c3a);
    font-weight: 500;
  }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .empty-state i {
    opacity: 0.5;
  }

  @media (max-width: 768px) {
    .page-header .d-flex {
      flex-direction: column;
      align-items: flex-start !important;
    }

    .kotty-card .card-header {
      flex-direction: column;
      align-items: flex-start !important;
      gap: 1rem;
    }

    .kotty-card .card-header .btn {
      width: 100%;
    }

    .kotty-table thead th,
    .kotty-table tbody td {
      padding: 0.625rem 0.5rem;
      font-size: var(--text-sm, 0.875rem);
    }
  }
</style>

<%- include('partials/footer') %>
