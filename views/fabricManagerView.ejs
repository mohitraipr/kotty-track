<%- include('partials/header', { pageTitle: 'Fabric Manager View' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/fabric-manager/dashboard' }) %>

<style>
  /* Page-specific styles */
  .table-scroll {
    max-height: 500px;
    overflow-y: auto;
  }

  @media print {
    .no-print {
      display: none !important;
    }
    .main-content {
      margin-left: 0 !important;
      margin-top: 0 !important;
      padding: 0 !important;
    }
    .kotty-navbar {
      display: none !important;
    }
  }

  .search-form {
    display: flex;
    gap: 8px;
  }

  .search-form .form-input {
    min-width: 200px;
  }

  .action-btn {
    padding: 6px 10px;
    border-radius: var(--radius-md);
    border: none;
    cursor: pointer;
    transition: all var(--transition-fast);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .action-btn-view {
    background: var(--info-light);
    color: var(--info);
  }

  .action-btn-view:hover {
    background: var(--info);
    color: white;
  }

  .action-btn-download {
    background: var(--gray-200);
    color: var(--text-secondary);
  }

  .action-btn-download:hover {
    background: var(--gray-300);
    color: var(--text-primary);
  }

  .header-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: center;
  }

  .bottom-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: flex-end;
  }

  @media (max-width: 768px) {
    .page-header-flex {
      flex-direction: column;
      align-items: flex-start !important;
      gap: 16px;
    }

    .search-form {
      width: 100%;
    }

    .search-form .form-input {
      flex: 1;
    }

    .header-actions {
      width: 100%;
      justify-content: flex-start;
    }

    .bottom-actions {
      justify-content: stretch;
    }

    .bottom-actions .btn {
      flex: 1;
      justify-content: center;
    }
  }
</style>

<main class="main-content" style="margin-left: 0;">
  <div class="container" style="max-width: var(--content-max-width); margin: 0 auto; padding: 28px;">

    <!-- Flash Messages -->
    <%- include('partials/flashMessages') %>

    <!-- Page Header -->
    <div class="page-header">
      <div class="breadcrumbs">
        <a href="/fabric-manager/dashboard">Dashboard</a>
        <span class="separator"><i class="bi bi-chevron-right"></i></span>
        <span>View Fabric Invoices</span>
      </div>

      <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 page-header-flex no-print">
        <div class="d-flex align-items-center gap-3 flex-wrap">
          <h1 class="page-title" style="margin-bottom: 0;">
            <i class="bi bi-table me-2"></i>Data in <%= tableName %>
          </h1>

          <!-- Search Form -->
          <form class="search-form" method="GET" action="/fabric-manager/view">
            <input type="hidden" name="table" value="<%= tableName %>" />
            <input
              type="text"
              name="search"
              class="form-input"
              placeholder="Search invoices..."
              value="<%= searchTerm %>"
            />
            <button type="submit" class="btn btn-primary btn-sm">
              <i class="bi bi-search"></i> Search
            </button>
          </form>
        </div>

        <!-- Header Actions -->
        <div class="header-actions">
          <a
            href="/fabric-manager/download-excel?search=<%= encodeURIComponent(searchTerm) %>"
            class="btn btn-success btn-sm"
          >
            <i class="bi bi-download"></i> Download Excel
          </a>
          <button class="btn btn-secondary btn-sm" onclick="window.print()">
            <i class="bi bi-printer"></i> Print
          </button>
        </div>
      </div>
    </div>

    <!-- Data Table Card -->
    <div class="card" style="margin-bottom: 24px;">
      <div class="table-container">
        <div class="table-scroll">
          <table class="table">
            <thead>
              <tr>
                <th><i class="bi bi-hash"></i> ID</th>
                <th><i class="bi bi-file-earmark-text"></i> Invoice No</th>
                <th><i class="bi bi-truck"></i> Vendor Name</th>
                <th><i class="bi bi-calendar3"></i> Date Invoice</th>
                <th><i class="bi bi-calendar-check"></i> Date Received</th>
                <th><i class="bi bi-boxes"></i> Total Rolls</th>
                <th><i class="bi bi-palette"></i> Fabric Type</th>
                <th><i class="bi bi-speedometer2"></i> Invoice Weight</th>
                <th><i class="bi bi-dash-circle"></i> Short Weight</th>
                <th><i class="bi bi-check-circle"></i> Received Weight</th>
                <th><i class="bi bi-person"></i> Created By</th>
                <th><i class="bi bi-gear"></i> Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (rows.length === 0) { %>
                <tr>
                  <td colspan="12" style="text-align: center; padding: 40px; color: var(--text-muted);">
                    <i class="bi bi-inbox" style="font-size: 32px; display: block; margin-bottom: 12px;"></i>
                    No Fabric Invoices Found.
                  </td>
                </tr>
              <% } else { %>
                <% rows.forEach(invoice => { %>
                  <tr>
                    <td><span class="badge badge-neutral"><%= invoice.id %></span></td>
                    <td style="font-weight: 500;"><%= invoice.invoice_no %></td>
                    <td><%= invoice.vendor_name %></td>
                    <td><%= invoice.date_invoice.toLocaleDateString('en-CA') %></td>
                    <td><%= invoice.date_received.toLocaleDateString('en-CA') %></td>
                    <td><span class="badge badge-info"><%= invoice.total_roll_quantity %></span></td>
                    <td><%= invoice.fabric_type || 'N/A' %></td>
                    <td><%= invoice.invoice_weight || 'N/A' %></td>
                    <td><%= invoice.short_weight || 'N/A' %></td>
                    <td><%= invoice.received_weight || 'N/A' %></td>
                    <td><%= invoice.created_by %></td>
                    <td>
                      <div class="d-flex gap-2">
                        <a href="/fabric-manager/invoice/<%= invoice.id %>/rolls" class="action-btn action-btn-view" title="View Rolls" data-bs-toggle="tooltip">
                          <i class="bi bi-eye"></i>
                        </a>
                        <a href="/fabric-manager/invoice/<%= invoice.id %>/download-rolls" class="action-btn action-btn-download" title="Download Rolls" data-bs-toggle="tooltip">
                          <i class="bi bi-download"></i>
                        </a>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Pagination -->
    <% if (totalPages && totalPages > 1) { %>
      <nav class="no-print" style="margin-bottom: 24px;">
        <ul class="pagination justify-content-center" style="display: flex; gap: 8px; list-style: none; padding: 0; margin: 0;">
          <li>
            <a
              class="btn btn-secondary btn-sm <%= (currentPage <= 1) ? 'disabled' : '' %>"
              href="/fabric-manager/view?table=<%= tableName %>&search=<%= encodeURIComponent(searchTerm) %>&page=<%= currentPage - 1 %>"
              style="<%= (currentPage <= 1) ? 'pointer-events: none; opacity: 0.5;' : '' %>"
            >
              <i class="bi bi-chevron-left"></i> Previous
            </a>
          </li>
          <li>
            <span class="btn btn-ghost btn-sm" style="cursor: default;">
              Page <%= currentPage %> of <%= totalPages %>
            </span>
          </li>
          <li>
            <a
              class="btn btn-secondary btn-sm <%= (currentPage >= totalPages) ? 'disabled' : '' %>"
              href="/fabric-manager/view?table=<%= tableName %>&search=<%= encodeURIComponent(searchTerm) %>&page=<%= currentPage + 1 %>"
              style="<%= (currentPage >= totalPages) ? 'pointer-events: none; opacity: 0.5;' : '' %>"
            >
              Next <i class="bi bi-chevron-right"></i>
            </a>
          </li>
        </ul>
      </nav>
    <% } %>

    <!-- Bottom Actions -->
    <div class="bottom-actions no-print">
      <a href="/fabric-manager/bulk-upload" class="btn btn-outline">
        <i class="bi bi-upload"></i> Bulk Upload Fabric Invoices
      </a>
      <a href="/fabric-manager/bulk-upload/rolls" class="btn btn-secondary">
        <i class="bi bi-upload"></i> Bulk Upload Fabric Invoice Rolls
      </a>
      <a href="/fabric-manager/dashboard" class="btn btn-primary">
        <i class="bi bi-arrow-left"></i> Back to Dashboard
      </a>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
