<%- include('partials/header', { pageTitle: 'PO Operator Dashboard' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/po-creator/operator/dashboard' }) %>

<style>
  /* ═══════════════════════════════════════════════════════════════════════════
     PO OPERATOR DASHBOARD - Kotty Track Design System
     Industrial Textile Elegance
   ═══════════════════════════════════════════════════════════════════════════ */

  :root {
    --charcoal: #1a1a1a;
    --charcoal-light: #2d2d2d;
    --cream: #faf8f5;
    --cream-dark: #f0ebe3;
    --terracotta: #c45c3a;
    --terracotta-light: #d4826a;
    --terracotta-dark: #a84a2d;
    --terracotta-bg: rgba(196, 92, 58, 0.08);
    --success: #2d8a5f;
    --success-light: #e8f5ef;
    --warning: #c4873a;
    --warning-light: #fef3e2;
    --danger: #c23b22;
    --danger-light: #fdeaea;
    --info: #3a7bc4;
    --info-light: #e8f1fb;
    --text-primary: #1a1a1a;
    --text-secondary: #5a5a5a;
    --text-muted: #8a8a8a;
    --border: #e5e0d8;
    --border-light: #f0ebe3;
    --shadow-sm: 0 1px 3px rgba(26, 26, 26, 0.06);
    --shadow-md: 0 4px 12px rgba(26, 26, 26, 0.08);
    --shadow-lg: 0 8px 24px rgba(26, 26, 26, 0.12);
    --radius-sm: 6px;
    --radius-md: 10px;
    --radius-lg: 16px;
  }

  body {
    background: var(--cream);
    min-height: 100vh;
  }

  /* Main Layout */
  .dashboard-container {
    max-width: 1800px;
    margin: 0 auto;
    padding: 32px 24px;
  }

  /* Page Header */
  .page-header {
    margin-bottom: 32px;
    animation: fadeInUp 0.5s ease-out;
  }

  .page-title {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 2.25rem;
    font-weight: 400;
    color: var(--charcoal);
    margin-bottom: 6px;
    letter-spacing: -0.02em;
  }

  .page-subtitle {
    font-family: 'Outfit', sans-serif;
    font-size: 0.95rem;
    color: var(--text-secondary);
    font-weight: 400;
  }

  /* Tab Navigation */
  .nav-tabs-kotty {
    display: flex;
    gap: 4px;
    padding: 6px;
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    margin-bottom: 24px;
    animation: fadeInUp 0.5s ease-out 0.1s backwards;
    overflow-x: auto;
  }

  .nav-tabs-kotty .nav-link {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    font-family: 'Outfit', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    background: transparent;
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .nav-tabs-kotty .nav-link:hover {
    color: var(--charcoal);
    background: var(--cream);
  }

  .nav-tabs-kotty .nav-link.active {
    color: white;
    background: var(--terracotta);
    box-shadow: var(--shadow-sm);
  }

  .nav-tabs-kotty .nav-link i {
    font-size: 1rem;
  }

  /* Stats Grid */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 28px;
    animation: fadeInUp 0.5s ease-out 0.15s backwards;
  }

  .stat-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 24px;
    position: relative;
    transition: all 0.25s ease;
    overflow: hidden;
  }

  .stat-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: var(--terracotta);
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .stat-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .stat-card:hover::before {
    opacity: 1;
  }

  .stat-card:nth-child(1)::before { background: var(--terracotta); }
  .stat-card:nth-child(2)::before { background: var(--info); }
  .stat-card:nth-child(3)::before { background: var(--success); }
  .stat-card:nth-child(4)::before { background: var(--warning); }

  .stat-label {
    font-family: 'Outfit', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 10px;
  }

  .stat-value {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 2.25rem;
    font-weight: 400;
    color: var(--charcoal);
    line-height: 1;
  }

  .stat-card:nth-child(1) .stat-value { color: var(--terracotta); }
  .stat-card:nth-child(2) .stat-value { color: var(--info); }
  .stat-card:nth-child(3) .stat-value { color: var(--success); }
  .stat-card:nth-child(4) .stat-value { color: var(--warning); }

  /* Content Cards */
  .content-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    animation: fadeInUp 0.5s ease-out 0.2s backwards;
  }

  .content-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 24px;
    border-bottom: 1px solid var(--border-light);
    background: linear-gradient(to right, var(--cream), white);
  }

  .content-card-title {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 1.25rem;
    color: var(--charcoal);
    margin: 0;
  }

  .content-card-body {
    padding: 0;
  }

  /* Iframe Container */
  .iframe-container {
    width: 100%;
    height: 800px;
    border: none;
  }

  .iframe-container-md {
    height: 600px;
  }

  /* Tab Content */
  .tab-content {
    animation: fadeIn 0.3s ease-out;
  }

  .tab-pane {
    display: none;
  }

  .tab-pane.active {
    display: block;
  }

  /* Button Styles */
  .btn-kotty {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    font-family: 'Outfit', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .btn-kotty-primary {
    background: var(--terracotta);
    color: white;
  }

  .btn-kotty-primary:hover {
    background: var(--terracotta-dark);
    color: white;
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  .btn-kotty-success {
    background: var(--success);
    color: white;
  }

  .btn-kotty-success:hover {
    background: #246b4a;
    color: white;
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  .btn-kotty-secondary {
    background: white;
    color: var(--text-primary);
    border: 1px solid var(--border);
  }

  .btn-kotty-secondary:hover {
    background: var(--cream);
    border-color: var(--charcoal-light);
  }

  /* Settings Grid */
  .settings-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  /* Animations */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* Responsive */
  @media (max-width: 1200px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 992px) {
    .settings-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .dashboard-container {
      padding: 20px 16px;
    }

    .page-title {
      font-size: 1.75rem;
    }

    .stats-grid {
      grid-template-columns: 1fr;
    }

    .stat-card {
      padding: 18px;
    }

    .stat-value {
      font-size: 1.75rem;
    }

    .nav-tabs-kotty {
      flex-wrap: nowrap;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .nav-tabs-kotty .nav-link {
      padding: 10px 16px;
      font-size: 0.8rem;
    }

    .iframe-container {
      height: 500px;
    }

    .iframe-container-md {
      height: 400px;
    }

    .content-card-header {
      flex-direction: column;
      gap: 12px;
      align-items: flex-start;
    }
  }
</style>

<div class="dashboard-container">
  <!-- Page Header -->
  <div class="page-header">
    <h1 class="page-title">PO Operator Dashboard</h1>
    <p class="page-subtitle">Manage purchase orders, inward data, panels, and SKU analysis</p>
  </div>

  <!-- Tab Navigation -->
  <div class="nav-tabs-kotty" id="poTabs" role="tablist">
    <button class="nav-link active" id="overview-tab" data-tab="overview" type="button">
      <i class="bi bi-grid-1x2"></i> Overview
    </button>
    <button class="nav-link" id="inward-tab" data-tab="inward" type="button">
      <i class="bi bi-box-arrow-in-down"></i> Inward Data
    </button>
    <button class="nav-link" id="outward-tab" data-tab="outward" type="button">
      <i class="bi bi-box-arrow-up"></i> Outward/Panels
    </button>
    <button class="nav-link" id="sku-tab" data-tab="sku" type="button">
      <i class="bi bi-grid-3x3"></i> SKU Analysis
    </button>
    <button class="nav-link" id="lot-tab" data-tab="lot" type="button">
      <i class="bi bi-tags"></i> Lot Entries
    </button>
    <button class="nav-link" id="settings-tab" data-tab="settings" type="button">
      <i class="bi bi-gear"></i> Settings
    </button>
  </div>

  <!-- Tab Content -->
  <div class="tab-content" id="poTabContent">
    <!-- Overview Tab -->
    <div class="tab-pane active" id="overview" role="tabpanel">
      <!-- Stats Grid -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-label">Total Cartons</div>
          <div class="stat-value" id="totalCartons">-</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Total SKUs</div>
          <div class="stat-value" id="totalSKUs">-</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Total Quantity</div>
          <div class="stat-value" id="totalQty">-</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">PO Creators</div>
          <div class="stat-value" id="totalCreators">-</div>
        </div>
      </div>

      <div class="content-card">
        <div class="content-card-header">
          <h2 class="content-card-title">All PO Data</h2>
        </div>
        <div class="content-card-body">
          <iframe src="/po-creator/operator/view-all" class="iframe-container" id="overviewFrame"></iframe>
        </div>
      </div>
    </div>

    <!-- Inward Data Tab -->
    <div class="tab-pane" id="inward" role="tabpanel">
      <div class="content-card">
        <div class="content-card-header">
          <h2 class="content-card-title">All Inward Data</h2>
          <a href="/po-creator/operator/download-all-excel" class="btn-kotty btn-kotty-success">
            <i class="bi bi-download"></i> Download Excel
          </a>
        </div>
        <div class="content-card-body">
          <iframe src="/po-creator/operator/view-all" class="iframe-container"></iframe>
        </div>
      </div>
    </div>

    <!-- Outward/Panels Tab -->
    <div class="tab-pane" id="outward" role="tabpanel">
      <div class="content-card">
        <div class="content-card-header">
          <h2 class="content-card-title">Panel-wise Outward Data</h2>
        </div>
        <div class="content-card-body">
          <iframe src="/po-creator/operator/view-panel-wise" class="iframe-container"></iframe>
        </div>
      </div>
    </div>

    <!-- SKU Analysis Tab -->
    <div class="tab-pane" id="sku" role="tabpanel">
      <div class="content-card">
        <div class="content-card-header">
          <h2 class="content-card-title">SKU-wise Analysis</h2>
        </div>
        <div class="content-card-body">
          <iframe src="/po-creator/operator/view-sku-wise" class="iframe-container"></iframe>
        </div>
      </div>
    </div>

    <!-- Lot Entries Tab -->
    <div class="tab-pane" id="lot" role="tabpanel">
      <div class="content-card">
        <div class="content-card-header">
          <h2 class="content-card-title">Lot Entries by Date</h2>
        </div>
        <div class="content-card-body">
          <iframe src="/po-creator/operator/lot-entries" class="iframe-container"></iframe>
        </div>
      </div>
    </div>

    <!-- Settings Tab -->
    <div class="tab-pane" id="settings" role="tabpanel">
      <div class="settings-grid">
        <div class="content-card">
          <div class="content-card-header">
            <h2 class="content-card-title">Manage Brand Codes</h2>
          </div>
          <div class="content-card-body">
            <iframe src="/po-creator/operator/manage-brands" class="iframe-container iframe-container-md"></iframe>
          </div>
        </div>
        <div class="content-card">
          <div class="content-card-header">
            <h2 class="content-card-title">Manage Categories</h2>
          </div>
          <div class="content-card-body">
            <iframe src="/po-creator/operator/manage-categories" class="iframe-container iframe-container-md"></iframe>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<script>
  // Tab Navigation
  document.addEventListener('DOMContentLoaded', function() {
    const tabs = document.querySelectorAll('#poTabs .nav-link');
    const tabPanes = document.querySelectorAll('.tab-pane');

    tabs.forEach(tab => {
      tab.addEventListener('click', function() {
        const targetTab = this.getAttribute('data-tab');

        // Remove active class from all tabs and panes
        tabs.forEach(t => t.classList.remove('active'));
        tabPanes.forEach(p => p.classList.remove('active'));

        // Add active class to clicked tab and corresponding pane
        this.classList.add('active');
        document.getElementById(targetTab).classList.add('active');
      });
    });

    // Load stats
    loadStats();
  });

  // Load stats
  async function loadStats() {
    try {
      const response = await fetch('/po-creator/operator/api/stats');
      if (response.ok) {
        const stats = await response.json();
        document.getElementById('totalCartons').textContent = stats.totalCartons || 0;
        document.getElementById('totalSKUs').textContent = stats.totalSKUs || 0;
        document.getElementById('totalQty').textContent = stats.totalQty || 0;
        document.getElementById('totalCreators').textContent = stats.totalCreators || 0;
      }
    } catch (error) {
      console.error('Error loading stats:', error);
    }
  }
</script>
