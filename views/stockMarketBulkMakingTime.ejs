<%- include('partials/header', { pageTitle: 'Bulk Making Time' }) %>
<%- include('partials/navbar') %>

<!-- Main Content -->
<main class="main-content" style="margin-left: 0;">
  <div class="container" style="max-width: 800px;">
    <!-- Page Header -->
    <div class="page-header">
      <div class="breadcrumbs">
        <a href="/dashboard">Dashboard</a>
        <span class="separator">/</span>
        <a href="/easyecom/stock-market">Out of Stock</a>
        <span class="separator">/</span>
        <span>Bulk Making Time</span>
      </div>
      <div class="d-flex align-items-center justify-content-between">
        <h1 class="page-title">Bulk Making Time</h1>
        <a href="/easyecom/stock-market" class="btn btn-secondary">
          <i class="bi bi-arrow-left"></i>
          Back to Out of Stock
        </a>
      </div>
      <p class="page-subtitle">Update making time for multiple SKUs in bulk using comma-separated values</p>
    </div>

    <!-- Main Card -->
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">
          <i class="bi bi-clock-history me-2" style="color: var(--terracotta);"></i>
          Bulk Update
        </h2>
      </div>
      <div class="card-body">
        <!-- Format Info -->
        <div class="alert alert-info alert-permanent">
          <i class="bi bi-info-circle"></i>
          <div>
            <strong>Format:</strong>
            <span class="badge badge-primary ms-2">SKU, Warehouse (optional), Making Time (days)</span>
            <br>
            <small class="mt-2 d-block">
              <strong>Example:</strong>
              <code style="background: var(--cream-dark); padding: 2px 6px; border-radius: 4px;">SKU123, WH1, 5</code> or
              <code style="background: var(--cream-dark); padding: 2px 6px; border-radius: 4px;">SKU123,,7</code> for default warehouse
            </small>
          </div>
        </div>

        <!-- Error Messages -->
        <% if (result && result.errors && result.errors.length) { %>
          <div class="alert alert-danger alert-permanent">
            <i class="bi bi-exclamation-triangle"></i>
            <div>
              <strong>Some rows failed:</strong>
              <ul class="mb-0 mt-2" style="padding-left: 1.25rem;">
                <% result.errors.forEach(err => { %>
                  <li><%= err %></li>
                <% }); %>
              </ul>
            </div>
          </div>
        <% } %>

        <!-- Success Message -->
        <% if (result && result.success && result.success.length) { %>
          <div class="alert alert-success alert-permanent">
            <i class="bi bi-check-circle"></i>
            <div>
              Successfully updated <strong><%= result.success.length %></strong> row(s).
            </div>
          </div>
        <% } %>

        <!-- Form -->
        <form method="post" action="/easyecom/stock-market/making-time">
          <div class="form-group">
            <label for="bulkInput" class="form-label">Bulk Input</label>
            <textarea
              class="form-control form-textarea"
              id="bulkInput"
              name="bulkInput"
              rows="10"
              placeholder="SKU123, WH1, 5&#10;SKU456,,7&#10;SKU789, WH2, 14"
              required
              style="font-family: var(--font-mono); font-size: 0.9rem; line-height: 1.6;"
            ><%= bulkInput || '' %></textarea>
            <small class="text-muted mt-2 d-block">
              Enter one entry per line. Empty warehouse field uses the default warehouse.
            </small>
          </div>

          <div class="d-flex justify-content-end gap-3">
            <a href="/easyecom/stock-market" class="btn btn-secondary">
              Cancel
            </a>
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-check2-circle"></i>
              Update Making Time
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Help Section -->
    <div class="card mt-4">
      <div class="card-body">
        <h3 style="font-family: var(--font-display); font-size: var(--text-lg); margin-bottom: 1rem;">
          <i class="bi bi-question-circle me-2" style="color: var(--terracotta);"></i>
          How to Use
        </h3>
        <div class="row g-4">
          <div class="col-md-4">
            <div class="d-flex gap-3">
              <div style="width: 32px; height: 32px; background: var(--terracotta-bg); color: var(--terracotta); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; font-weight: 600; flex-shrink: 0;">1</div>
              <div>
                <strong>Prepare Data</strong>
                <p class="text-muted mb-0" style="font-size: var(--text-sm);">Format your data as comma-separated values with SKU, warehouse, and days.</p>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="d-flex gap-3">
              <div style="width: 32px; height: 32px; background: var(--terracotta-bg); color: var(--terracotta); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; font-weight: 600; flex-shrink: 0;">2</div>
              <div>
                <strong>Paste Data</strong>
                <p class="text-muted mb-0" style="font-size: var(--text-sm);">Paste the data into the text area with one entry per line.</p>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="d-flex gap-3">
              <div style="width: 32px; height: 32px; background: var(--terracotta-bg); color: var(--terracotta); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; font-weight: 600; flex-shrink: 0;">3</div>
              <div>
                <strong>Submit</strong>
                <p class="text-muted mb-0" style="font-size: var(--text-sm);">Click Update to process all entries at once.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
