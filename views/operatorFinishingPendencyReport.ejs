<%- include('partials/header', { pageTitle: 'Finishing Pendency Report' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/operator/dashboard' }) %>

<!-- Main Content -->
<main class="main-content" style="margin-left: 0;">
  <div class="container-fluid" style="max-width: 1400px; margin: 0 auto;">

    <!-- Page Header -->
    <div class="page-header">
      <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
        <div>
          <nav class="breadcrumbs">
            <a href="/operator/dashboard">Dashboard</a>
            <span class="separator">/</span>
            <span>Finishing Pendency</span>
          </nav>
          <h1 class="page-title">Finishing Pendency Report</h1>
          <p class="page-subtitle">Overview of pending and completed finishing for all operators</p>
        </div>
        <a href="/operator/dashboard" class="btn btn-secondary">
          <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
      </div>
    </div>

    <!-- Summary Table Card -->
    <div class="card mb-4">
      <div class="card-header">
        <h2 class="card-title">
          <i class="bi bi-bar-chart-line me-2" style="color: var(--terracotta);"></i>
          All Finishing Operators Summary
        </h2>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table mb-0">
            <thead>
              <tr>
                <th>User</th>
                <th>Total Assignments</th>
                <th>Completed</th>
                <th>Pending</th>
                <th style="min-width: 180px;">Completion Rate</th>
              </tr>
            </thead>
            <tbody>
              <% usersSummary.forEach(function(user) {
                   const rate = user.total_assignments > 0
                                ? ((user.completed_assignments / user.total_assignments) * 100).toFixed(0)
                                : 0;
              %>
              <tr>
                <td>
                  <div class="d-flex align-items-center gap-2">
                    <div class="user-avatar" style="width: 32px; height: 32px; font-size: 0.75rem;">
                      <%= user.username ? user.username.charAt(0).toUpperCase() : 'U' %>
                    </div>
                    <span style="font-weight: 500;"><%= user.username %></span>
                  </div>
                </td>
                <td>
                  <span class="badge badge-neutral"><%= user.total_assignments %></span>
                </td>
                <td>
                  <span class="badge badge-success"><%= user.completed_assignments %></span>
                </td>
                <td>
                  <span class="badge badge-warning"><%= user.pending_assignments %></span>
                </td>
                <td>
                  <div class="d-flex align-items-center gap-2">
                    <div class="progress flex-grow-1" style="height: 8px;">
                      <div class="progress-bar success" role="progressbar" style="width: <%= rate %>%;"></div>
                    </div>
                    <span style="font-size: var(--text-sm); font-weight: 500; min-width: 40px;"><%= rate %>%</span>
                  </div>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Detailed View Card -->
    <div class="card">
      <div class="card-header">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 w-100">
          <h2 class="card-title mb-0">
            <i class="bi bi-person-lines-fill me-2" style="color: var(--terracotta);"></i>
            Detailed Finishing Report
          </h2>
          <!-- User Selection Form -->
          <form method="GET" action="/operator/pendency-report/finishing" class="d-flex align-items-center gap-2">
            <select name="user_id" class="form-select form-input" style="min-width: 200px; padding: 8px 36px 8px 12px;">
              <option value="">-- Select User --</option>
              <% usersSummary.forEach(function(user) { %>
                <option value="<%= user.user_id %>" <%= (query.user_id == user.user_id ? 'selected' : '') %>><%= user.username %></option>
              <% }); %>
            </select>
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-search"></i> View
            </button>
          </form>
        </div>
      </div>
      <div class="card-body">
        <% if (selectedUserId) { %>
          <!-- User Summary Stats -->
          <div class="row g-3 mb-4">
            <div class="col-md-4">
              <div class="stat-card">
                <div class="stat-label">Total Assigned Pieces</div>
                <div class="stat-value"><%= detailedSummary.totalAssigned %></div>
              </div>
            </div>
            <div class="col-md-4">
              <div class="stat-card">
                <div class="stat-label">Total Pending Pieces</div>
                <div class="stat-value" style="color: var(--warning);"><%= detailedSummary.totalPending %></div>
              </div>
            </div>
            <div class="col-md-4 d-flex align-items-end">
              <a href="/operator/pendency-report/finishing/download?user_id=<%= selectedUserId %>" class="btn btn-success w-100">
                <i class="bi bi-file-earmark-excel"></i> Download Excel
              </a>
            </div>
          </div>

          <% if (detailedAssignments.length > 0) { %>
            <div class="table-container">
              <div class="table-responsive">
                <table class="table mb-0">
                  <thead>
                    <tr>
                      <th>Lot No</th>
                      <th>Total Pieces</th>
                      <th>Finished</th>
                      <th>Pending</th>
                      <th>Assigned On</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% detailedAssignments.forEach(function(asg) { %>
                      <tr>
                        <td>
                          <span style="font-weight: 500; color: var(--terracotta);"><%= asg.lot_no %></span>
                        </td>
                        <td><%= asg.total_pieces %></td>
                        <td>
                          <span class="badge badge-success"><%= asg.finished %></span>
                        </td>
                        <td>
                          <span class="badge badge-warning"><%= asg.pending %></span>
                        </td>
                        <td style="font-size: var(--text-sm); color: var(--text-secondary);">
                          <%= new Date(asg.assigned_on).toLocaleString() %>
                        </td>
                      </tr>
                    <% }); %>
                  </tbody>
                </table>
              </div>
            </div>
          <% } else { %>
            <div class="empty-state">
              <div class="empty-state-icon">
                <i class="bi bi-inbox" style="font-size: 48px;"></i>
              </div>
              <h3 class="empty-state-title">No Assignments Found</h3>
              <p class="empty-state-text">No detailed finishing assignments found for the selected user.</p>
            </div>
          <% } %>
        <% } else { %>
          <div class="empty-state">
            <div class="empty-state-icon">
              <i class="bi bi-person-badge" style="font-size: 48px;"></i>
            </div>
            <h3 class="empty-state-title">Select a User</h3>
            <p class="empty-state-text">Select a user from the dropdown above to view detailed finishing data.</p>
          </div>
        <% } %>
      </div>
    </div>

  </div>
</main>

<%- include('partials/footer') %>
