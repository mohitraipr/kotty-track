<%- include('partials/header', { pageTitle: 'Contract Summary' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/stitchingdashboard' }) %>

<main class="main-content" style="margin-left: 0;">
  <div class="container" style="max-width: 900px; margin: 0 auto;">
    <!-- Page Header -->
    <div class="page-header">
      <div class="breadcrumbs">
        <a href="/stitchingdashboard">Stitching</a>
        <span class="separator">/</span>
        <a href="/stitchingdashboard/payments/contract">Contract Payments</a>
        <span class="separator">/</span>
        <span>Confirm Payment</span>
      </div>
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
          <h1 class="page-title">Confirm Contract Payment</h1>
          <p class="page-subtitle">Review and confirm the payment details below</p>
        </div>
        <a href="/stitchingdashboard/payments/contract" class="btn btn-secondary">
          <i class="bi bi-arrow-left"></i>
          Back
        </a>
      </div>
    </div>

    <!-- Payment Summary Card -->
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">
          <i class="bi bi-receipt me-2" style="color: var(--terracotta);"></i>
          Payment Summary
        </h2>
        <span class="badge badge-primary">
          <%= lots.length %> Lot<%= lots.length !== 1 ? 's' : '' %>
        </span>
      </div>
      <div class="card-body p-0">
        <form method="POST" action="/stitchingdashboard/payments/contract/pay" id="paymentForm">
          <div class="table-container" style="border: none; border-radius: 0;">
            <table class="table">
              <thead>
                <tr>
                  <th>Lot No.</th>
                  <th>SKU</th>
                  <th class="text-center">Quantity</th>
                  <th class="text-end">Rate</th>
                  <th class="text-end">Amount</th>
                </tr>
              </thead>
              <tbody>
                <% lots.forEach(function(l){ %>
                  <tr>
                    <td>
                      <span class="font-display" style="font-size: var(--text-base); color: var(--text-primary);">
                        <%= l.lot_no %>
                      </span>
                    </td>
                    <td>
                      <span class="badge badge-neutral"><%= l.sku %></span>
                    </td>
                    <td class="text-center">
                      <strong><%= l.total_pieces %></strong>
                    </td>
                    <td class="text-end" style="color: var(--text-secondary);">
                      ₹<%= parseFloat(l.rate).toFixed(2) %>
                    </td>
                    <td class="text-end">
                      <strong style="color: var(--terracotta);">₹<%= parseFloat(l.amount).toFixed(2) %></strong>
                    </td>
                  </tr>
                  <input type="hidden" name="lotIds" value="<%= l.id %>">
                <% }) %>
              </tbody>
            </table>
          </div>

          <!-- Total Amount Section -->
          <div class="card-footer" style="background: var(--cream-dark);">
            <div class="d-flex justify-content-between align-items-center">
              <span class="text-secondary" style="font-size: var(--text-sm); text-transform: uppercase; letter-spacing: 0.05em;">
                Total Amount
              </span>
              <span class="font-display" style="font-size: var(--text-2xl); color: var(--terracotta);">
                ₹<%= parseFloat(totalAmount).toFixed(2) %>
              </span>
            </div>
          </div>

          <!-- Action Buttons -->
          <div class="p-4" style="background: var(--gray-50); border-top: 1px solid var(--border-light);">
            <div class="d-flex justify-content-end gap-3">
              <button type="button" onclick="window.print()" class="btn btn-secondary">
                <i class="bi bi-printer"></i>
                Print
              </button>
              <button type="submit" class="btn btn-success">
                <i class="bi bi-check-circle"></i>
                Confirm Payment
              </button>
            </div>
          </div>
        </form>
      </div>
    </div>

    <!-- Info Note -->
    <div class="alert alert-info mt-4" style="display: flex; align-items: flex-start; gap: 12px;">
      <i class="bi bi-info-circle" style="font-size: 1.25rem; flex-shrink: 0;"></i>
      <div>
        <strong>Note:</strong> Once confirmed, this payment will be recorded and cannot be undone.
        Please verify all details before proceeding.
      </div>
    </div>
  </div>
</main>

<!-- Print Styles -->
<style>
  @media print {
    .kotty-navbar,
    .breadcrumbs,
    .btn,
    .alert,
    .page-subtitle {
      display: none !important;
    }

    .main-content {
      margin: 0 !important;
      padding: 20px !important;
    }

    .card {
      box-shadow: none !important;
      border: 1px solid #ddd !important;
    }

    .page-title {
      font-size: 24px !important;
      margin-bottom: 20px !important;
    }

    .table th,
    .table td {
      padding: 10px 12px !important;
    }

    body {
      background: white !important;
    }
  }
</style>

<%- include('partials/footer') %>
