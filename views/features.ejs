<%- include('partials/header', { pageTitle: 'Features' }) %>
<%- include('partials/navbar') %>

<style>
  /* Features Page Specific Styles */
  .features-page {
    padding-top: calc(var(--navbar-height) + 2rem);
    padding-bottom: 4rem;
    min-height: 100vh;
  }

  /* Hero Section */
  .features-hero {
    background: var(--terracotta);
    color: var(--text-inverse);
    border-radius: var(--radius-2xl);
    padding: 3rem;
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    margin-bottom: 2.5rem;
  }

  .features-hero::before {
    content: '';
    position: absolute;
    width: 20rem;
    height: 20rem;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 50%;
    top: -8rem;
    right: -8rem;
  }

  .features-hero::after {
    content: '';
    position: absolute;
    width: 12rem;
    height: 12rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 50%;
    bottom: -4rem;
    left: -4rem;
  }

  .features-hero h1 {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    margin-bottom: 1rem;
    position: relative;
    z-index: 1;
  }

  .features-hero p {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    max-width: 40rem;
    opacity: 0.95;
    line-height: 1.7;
    position: relative;
    z-index: 1;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(255, 255, 255, 0.2);
    color: var(--text-inverse);
    padding: 0.4rem 1rem;
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    font-weight: 500;
    font-family: var(--font-body);
    transition: color var(--transition-fast);
    position: relative;
    z-index: 1;
  }

  .back-link:hover {
    color: #fff;
  }

  /* Table of Contents Card */
  .toc-card {
    background: var(--bg-card);
    border-radius: var(--radius-xl);
    border: 1px solid var(--border-light);
    box-shadow: var(--shadow-md);
    position: sticky;
    top: calc(var(--navbar-height) + 1.5rem);
  }

  .toc-card .card-body {
    padding: 1.5rem;
  }

  .toc-card h2 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--terracotta);
    margin-bottom: 1rem;
  }

  .toc-card .list-group {
    border: none;
  }

  .toc-card .list-group-item {
    border: none;
    padding: 0.85rem 1rem;
    color: var(--text-secondary);
    font-family: var(--font-body);
    font-weight: 500;
    background: transparent;
    border-radius: var(--radius-md);
    margin-bottom: 0.25rem;
    transition: all var(--transition-fast);
  }

  .toc-card .list-group-item:hover,
  .toc-card .list-group-item:focus {
    background: var(--terracotta-bg);
    color: var(--terracotta);
  }

  .toc-count {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--terracotta);
    opacity: 0.8;
  }

  /* Feature Cards */
  .feature-card {
    background: var(--bg-card);
    border-radius: var(--radius-xl);
    border: 1px solid var(--border-light);
    padding: 2rem;
    box-shadow: var(--shadow-sm);
    margin-bottom: 1.5rem;
    transition: all var(--transition-base);
  }

  .feature-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--cream-darker);
  }

  .feature-card h2 {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    color: var(--charcoal);
    margin-bottom: 0.75rem;
  }

  .feature-card > p {
    font-family: var(--font-body);
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    line-height: 1.7;
  }

  /* Module Badges */
  .module-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .module-badge {
    background: var(--terracotta-bg);
    color: var(--terracotta);
    padding: 0.35rem 0.75rem;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-family: var(--font-body);
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  /* Feature List */
  .feature-card ul {
    margin-bottom: 0;
    padding-left: 1.25rem;
  }

  .feature-card li {
    margin-bottom: 0.5rem;
    line-height: 1.65;
    color: var(--text-secondary);
    font-family: var(--font-body);
  }

  .feature-card li::marker {
    color: var(--terracotta);
    font-weight: bold;
  }

  /* Responsive Adjustments */
  @media (max-width: 991px) {
    .features-hero {
      padding: 2rem;
    }

    .features-hero h1 {
      font-size: var(--text-3xl);
    }

    .toc-card {
      position: static;
      margin-bottom: 2rem;
    }
  }

  @media (max-width: 576px) {
    .features-hero {
      padding: 1.5rem;
    }

    .features-hero h1 {
      font-size: var(--text-2xl);
    }

    .feature-card {
      padding: 1.5rem;
    }
  }
</style>

<main class="features-page">
  <div class="container">
    <!-- Hero Section -->
    <section class="features-hero">
      <div class="d-flex justify-content-between align-items-start flex-column flex-lg-row gap-3">
        <div>
          <span class="hero-badge">Kotty Track</span>
          <h1>End-to-End Production Features</h1>
          <p>
            Explore how every module in Kotty Track fits together - from onboarding fabric to dispatching finished pieces,
            handling payroll, and syncing with partner platforms. Each section summarises the capabilities available to
            the teams who rely on the app every day.
          </p>
        </div>
        <div class="text-lg-end">
          <a class="back-link" href="<%= user ? '/' : '/login' %>">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
              <path fill-rule="evenodd" d="M11.854 4.146a.5.5 0 0 1 0 .708L9.207 7.5H14.5a.5.5 0 0 1 0 1H9.207l2.647 2.646a.5.5 0 0 1-.708.708l-3.5-3.5a.5.5 0 0 1 0-.708l3.5-3.5a.5.5 0 0 1 .708 0z"/>
              <path fill-rule="evenodd" d="M4.5 2.5A1.5 1.5 0 0 0 3 4v8a1.5 1.5 0 0 0 1.5 1.5h4a.5.5 0 0 1 0 1h-4A2.5 2.5 0 0 1 2 12V4a2.5 2.5 0 0 1 2.5-2.5h4a.5.5 0 0 1 0 1h-4z"/>
            </svg>
            <span><%= user ? 'Back to dashboard' : 'Back to login' %></span>
          </a>
        </div>
      </div>
    </section>

    <!-- Main Content -->
    <div class="row g-4">
      <!-- Table of Contents -->
      <div class="col-lg-4">
        <div class="card toc-card">
          <div class="card-body">
            <h2>Jump to a capability</h2>
            <div class="list-group list-group-flush">
              <% featureSections.forEach(section => { %>
                <a class="list-group-item list-group-item-action" href="#<%= section.id %>">
                  <div class="d-flex justify-content-between align-items-center">
                    <span><%= section.title %></span>
                    <% if (section.modules && section.modules.length) { %>
                      <span class="toc-count">
                        <%= section.modules.length %>
                        <%= section.modules.length === 1 ? 'file' : 'files' %>
                      </span>
                    <% } %>
                  </div>
                </a>
              <% }); %>
            </div>
          </div>
        </div>
      </div>

      <!-- Feature Cards -->
      <div class="col-lg-8">
        <% featureSections.forEach(section => { %>
          <article id="<%= section.id %>" class="feature-card">
            <h2><%= section.title %></h2>
            <p><%= section.description %></p>
            <% if (section.modules && section.modules.length) { %>
              <div class="module-badges" aria-label="Key modules">
                <% section.modules.forEach(module => { %>
                  <span class="module-badge"><%= module %></span>
                <% }); %>
              </div>
            <% } %>
            <ul>
              <% section.highlights.forEach(point => { %>
                <li><%= point %></li>
              <% }); %>
            </ul>
          </article>
        <% }); %>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
