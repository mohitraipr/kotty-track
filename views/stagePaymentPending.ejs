<%- include('partials/header', { pageTitle: 'Pending Payments' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/operator/dashboard' }) %>

<style>
  :root {
    --charcoal: #1a1a1a;
    --cream: #faf8f5;
    --cream-dark: #f0ebe3;
    --terracotta: #c45c3a;
    --success: #2d8a5f;
    --warning: #c4873a;
    --danger: #c23b22;
    --info: #3a7bc4;
    --border: #e5e0d8;
    --text-secondary: #5a5a5a;
    --radius-sm: 6px;
    --radius-md: 10px;
  }

  body { background: var(--cream); }

  .page-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 32px 24px;
    padding-top: calc(60px + 32px);
  }

  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
    flex-wrap: wrap;
    gap: 16px;
  }

  .page-title {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 1.75rem;
    color: var(--charcoal);
  }

  .btn-group { display: flex; gap: 8px; flex-wrap: wrap; }

  .btn-kotty {
    font-family: 'Outfit', sans-serif;
    font-weight: 500;
    padding: 8px 16px;
    border-radius: var(--radius-sm);
    font-size: 0.85rem;
    border: none;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .btn-primary { background: var(--terracotta); color: white; }
  .btn-outline { background: white; border: 1px solid var(--border); color: var(--charcoal); }
  .btn-success { background: var(--success); color: white; }
  .btn-danger { background: var(--danger); color: white; }
  .btn-warning { background: var(--warning); color: white; }
  .btn-sm { padding: 4px 10px; font-size: 0.75rem; }

  .alert {
    padding: 12px 16px;
    border-radius: var(--radius-sm);
    margin-bottom: 16px;
    font-family: 'Outfit', sans-serif;
  }
  .alert-success { background: #e8f5ef; color: var(--success); }
  .alert-error { background: #fdeaea; color: var(--danger); }

  .card {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    margin-bottom: 24px;
  }

  .card-header {
    padding: 16px 20px;
    border-bottom: 1px solid var(--border);
    background: linear-gradient(180deg, var(--cream) 0%, white 100%);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .card-title {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 1.1rem;
    color: var(--charcoal);
    margin: 0;
  }

  .card-body { padding: 20px; }

  .filter-row {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }

  .form-control, .form-select {
    font-family: 'Outfit', sans-serif;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 8px 12px;
    font-size: 0.875rem;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'Outfit', sans-serif;
    font-size: 0.85rem;
  }

  th {
    background: var(--cream);
    padding: 12px;
    text-align: left;
    font-weight: 600;
    font-size: 0.7rem;
    text-transform: uppercase;
    color: var(--text-secondary);
    border-bottom: 2px solid var(--border);
  }

  td {
    padding: 12px;
    border-bottom: 1px solid var(--border);
  }

  tr:hover { background: var(--cream); }

  .badge {
    padding: 4px 8px;
    border-radius: 12px;
    font-size: 0.7rem;
    font-weight: 600;
  }

  .badge-stitching { background: #e8f1fb; color: var(--info); }
  .badge-washing { background: #ede9fe; color: #7c3aed; }
  .badge-finishing { background: #e8f5ef; color: var(--success); }
  .badge-assembly { background: #fce7f3; color: #be185d; }
  .badge-cutting { background: #fef3e2; color: var(--warning); }

  .rate-warning {
    background: #fef3e2;
    color: var(--warning);
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 0.75rem;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .summary-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    margin-bottom: 24px;
  }

  .summary-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 16px;
  }

  .summary-label {
    font-family: 'Outfit', sans-serif;
    font-size: 0.75rem;
    color: var(--text-secondary);
    text-transform: uppercase;
  }

  .summary-value {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 1.5rem;
    color: var(--charcoal);
  }

  .modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.5);
    z-index: 1000;
    align-items: center;
    justify-content: center;
  }
  .modal.active { display: flex; }
  .modal-content {
    background: white;
    border-radius: var(--radius-md);
    padding: 24px;
    max-width: 400px;
    width: 90%;
  }
  .modal-title {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 1.25rem;
    margin-bottom: 16px;
  }
  .form-group { margin-bottom: 16px; }
  .form-label {
    font-family: 'Outfit', sans-serif;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-secondary);
    margin-bottom: 4px;
    display: block;
  }
</style>

<div class="page-container">
  <div class="page-header">
    <h1 class="page-title">Pending Payments</h1>
    <div class="btn-group">
      <a href="/operator/payments/rates" class="btn-kotty btn-primary">
        <i class="bi bi-gear"></i> Configure Rates
      </a>
      <a href="/operator/payments/debits" class="btn-kotty btn-outline">
        <i class="bi bi-dash-circle"></i> Debits
      </a>
      <a href="/operator/payments/history" class="btn-kotty btn-outline">
        <i class="bi bi-clock-history"></i> History
      </a>
    </div>
  </div>

  <% if (error && error.length) { %>
  <div class="alert alert-error"><%= error %></div>
  <% } %>
  <% if (success && success.length) { %>
  <div class="alert alert-success"><%= success %></div>
  <% } %>

  <!-- Summary by User -->
  <% const userArr = Object.values(userTotals); %>
  <% if (userArr.length > 0) { %>
  <div class="summary-cards">
    <% userArr.slice(0, 6).forEach(u => { %>
    <div class="summary-card">
      <div class="summary-label"><%= u.username %></div>
      <div class="summary-value"><%= u.total.toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></div>
      <div style="font-size: 0.8rem; color: var(--text-secondary);">
        <%= u.count %> entries
        <% if (u.debits > 0) { %>
        | <span style="color: var(--danger);">Debits: <%= u.debits.toLocaleString() %></span>
        <% } %>
      </div>
    </div>
    <% }); %>
  </div>
  <% } %>

  <!-- Filters -->
  <div class="card">
    <div class="card-body">
      <form method="GET" class="filter-row">
        <select name="stage" class="form-select">
          <option value="all" <%= currentStage === 'all' ? 'selected' : '' %>>All Stages</option>
          <% stages.forEach(s => { %>
          <option value="<%= s %>" <%= currentStage === s ? 'selected' : '' %>><%= s.charAt(0).toUpperCase() + s.slice(1) %></option>
          <% }); %>
        </select>
        <input type="text" name="search" class="form-control" placeholder="Search lot/sku/worker..." value="<%= search %>">
        <button type="submit" class="btn-kotty btn-primary">Filter</button>
        <% if (search || currentStage !== 'all') { %>
        <a href="/operator/payments/pending" class="btn-kotty btn-outline">Clear</a>
        <% } %>
      </form>
    </div>
  </div>

  <!-- Payments Table -->
  <div class="card">
    <div class="card-header">
      <h2 class="card-title"><i class="bi bi-hourglass-split"></i> Pending Payments</h2>
      <span style="font-size: 0.85rem; color: var(--text-secondary);"><%= payments.length %> pending</span>
    </div>
    <div class="card-body" style="padding: 0; overflow-x: auto;">
      <table>
        <thead>
          <tr>
            <th>Worker</th>
            <th>Lot No</th>
            <th>SKU</th>
            <th>Stage</th>
            <th>Qty</th>
            <th>Base Rate</th>
            <th>Extra</th>
            <th>Total</th>
            <th>Created</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (payments.length === 0) { %>
          <tr><td colspan="10" style="text-align: center; color: var(--text-secondary);">No pending payments</td></tr>
          <% } else { %>
          <% payments.forEach(p => { %>
          <tr>
            <td><strong><%= p.username %></strong></td>
            <td><%= p.lot_no %></td>
            <td><%= p.sku %></td>
            <td><span class="badge badge-<%= p.stage %>"><%= p.stage %></span></td>
            <td><%= p.qty.toLocaleString() %></td>
            <td>
              <% if (!p.rate_configured) { %>
              <span class="rate-warning"><i class="bi bi-exclamation-triangle"></i> Not set</span>
              <% } else { %>
              <%= parseFloat(p.base_rate).toFixed(2) %>
              <% } %>
            </td>
            <td><%= parseFloat(p.extra_amount || 0).toFixed(2) %></td>
            <td>
              <% if (!p.rate_configured) { %>
              <span class="rate-warning"><i class="bi bi-exclamation-triangle"></i> Set rate</span>
              <% } else { %>
              <strong><%= parseFloat(p.total_amount).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></strong>
              <% } %>
            </td>
            <td><%= new Date(p.created_at).toLocaleDateString('en-IN') %></td>
            <td>
              <% if (!p.rate_configured) { %>
              <button type="button" class="btn-kotty btn-sm btn-warning" onclick="openSetRateModal(<%= p.id %>, '<%= p.sku %>', '<%= p.stage %>')">
                <i class="bi bi-currency-rupee"></i> Set Rate
              </button>
              <% } else { %>
              <button type="button" class="btn-kotty btn-sm btn-outline" onclick="openEditModal(<%= p.id %>, <%= p.qty %>, <%= parseFloat(p.base_rate) %>)">
                <i class="bi bi-pencil"></i>
              </button>
              <% } %>
              <form method="POST" action="/operator/payments/cancel/<%= p.id %>" style="display: inline;" onsubmit="return confirm('Cancel this payment?')">
                <button type="submit" class="btn-kotty btn-sm btn-danger">
                  <i class="bi bi-x"></i>
                </button>
              </form>
            </td>
          </tr>
          <% }); %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Edit Payment Modal -->
<div id="editModal" class="modal">
  <div class="modal-content">
    <h3 class="modal-title">Edit Payment</h3>
    <form id="editForm" method="POST">
      <input type="hidden" name="payment_id" id="editPaymentId">
      <div class="form-group">
        <label class="form-label">Quantity</label>
        <input type="number" name="qty" id="editQty" class="form-control" required>
      </div>
      <div class="form-group">
        <label class="form-label">Base Rate</label>
        <input type="number" name="base_rate" id="editBaseRate" step="0.01" class="form-control" required>
      </div>
      <div style="display: flex; gap: 8px; justify-content: flex-end; margin-top: 16px;">
        <button type="button" class="btn-kotty btn-outline" onclick="closeEditModal()">Cancel</button>
        <button type="submit" class="btn-kotty btn-primary">Save</button>
      </div>
    </form>
  </div>
</div>

<!-- Set Rate Modal -->
<div id="setRateModal" class="modal">
  <div class="modal-content">
    <h3 class="modal-title">Set Rate for SKU</h3>
    <form id="setRateForm" method="POST" action="/operator/payments/rates">
      <input type="hidden" name="redirect" value="/operator/payments/pending">
      <div class="form-group">
        <label class="form-label">SKU</label>
        <input type="text" name="sku" id="setRateSku" class="form-control" readonly>
      </div>
      <div class="form-group">
        <label class="form-label">Stage</label>
        <input type="text" name="stage" id="setRateStage" class="form-control" readonly>
      </div>
      <div class="form-group">
        <label class="form-label">Rate *</label>
        <input type="number" name="rate" step="0.01" class="form-control" required>
      </div>
      <div style="display: flex; gap: 8px; justify-content: flex-end; margin-top: 16px;">
        <button type="button" class="btn-kotty btn-outline" onclick="closeSetRateModal()">Cancel</button>
        <button type="submit" class="btn-kotty btn-primary">Save Rate</button>
      </div>
    </form>
  </div>
</div>

<script>
function openEditModal(id, qty, rate) {
  document.getElementById('editPaymentId').value = id;
  document.getElementById('editQty').value = qty;
  document.getElementById('editBaseRate').value = rate;
  document.getElementById('editForm').action = '/operator/payments/edit/' + id;
  document.getElementById('editModal').classList.add('active');
}

function closeEditModal() {
  document.getElementById('editModal').classList.remove('active');
}

function openSetRateModal(paymentId, sku, stage) {
  document.getElementById('setRateSku').value = sku;
  document.getElementById('setRateStage').value = stage;
  document.getElementById('setRateModal').classList.add('active');
}

function closeSetRateModal() {
  document.getElementById('setRateModal').classList.remove('active');
}

document.querySelectorAll('.modal').forEach(modal => {
  modal.addEventListener('click', function(e) {
    if (e.target === this) {
      this.classList.remove('active');
    }
  });
});
</script>

<%- include('partials/footer') %>
