<%- include('partials/header', { pageTitle: 'Washing Invoice List' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/washingdashboard' }) %>

<!-- Main Content -->
<main class="main-content" style="margin-left: 0;">
  <div class="container-fluid" style="max-width: var(--content-max-width); margin: 0 auto;">

    <!-- Page Header -->
    <div class="page-header">
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
          <nav class="breadcrumbs">
            <a href="/washingdashboard">Dashboard</a>
            <span class="separator"><i class="bi bi-chevron-right"></i></span>
            <a href="/washingdashboard/payments">Payments</a>
            <span class="separator"><i class="bi bi-chevron-right"></i></span>
            <span>Invoice List</span>
          </nav>
          <h1 class="page-title">Washing Invoices</h1>
          <p class="page-subtitle">View and manage all washing invoices</p>
        </div>
        <div>
          <a href="/washingdashboard/payments" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i>
            Back to Payments
          </a>
        </div>
      </div>
    </div>

    <!-- Invoice List Card -->
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">
          <i class="bi bi-receipt me-2" style="color: var(--terracotta);"></i>
          All Invoices
        </h2>
        <span class="badge badge-neutral"><%= invoices.length %> invoices</span>
      </div>
      <div class="card-body p-0">
        <% if (invoices && invoices.length > 0) { %>
          <div class="table-container" style="border: none; border-radius: 0;">
            <div class="table-responsive">
              <table class="table mb-0">
                <thead>
                  <tr>
                    <th>Invoice ID</th>
                    <% if (invoices[0] && invoices[0].washer_name) { %>
                      <th>Washer</th>
                    <% } %>
                    <th>Total Amount</th>
                    <th>Date</th>
                    <th style="text-align: right;">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% invoices.forEach(function(inv){ %>
                    <tr>
                      <td>
                        <span class="badge badge-primary">#<%= inv.id %></span>
                      </td>
                      <% if (inv.washer_name) { %>
                        <td>
                          <div class="d-flex align-items-center gap-2">
                            <div class="user-avatar" style="width: 32px; height: 32px; font-size: 0.75rem; background: var(--charcoal);">
                              <%= inv.washer_name.charAt(0).toUpperCase() %>
                            </div>
                            <span style="font-weight: 500;"><%= inv.washer_name %></span>
                          </div>
                        </td>
                      <% } %>
                      <td>
                        <span style="font-family: var(--font-display); font-size: 1.1rem; color: var(--terracotta);">
                          Rs. <%= typeof inv.total_amount === 'number' ? inv.total_amount.toLocaleString('en-IN') : inv.total_amount %>
                        </span>
                      </td>
                      <td>
                        <div class="d-flex align-items-center gap-2">
                          <i class="bi bi-calendar3 text-muted"></i>
                          <span>
                            <%= inv.created_at.toISOString ? inv.created_at.toISOString().replace('T',' ').slice(0,19) : inv.created_at %>
                          </span>
                        </div>
                      </td>
                      <td style="text-align: right;">
                        <a class="btn btn-primary btn-sm" href="<%= baseUrl %><%= inv.id %>">
                          <i class="bi bi-eye"></i>
                          View Invoice
                        </a>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </div>
        <% } else { %>
          <!-- Empty State -->
          <div class="empty-state">
            <div class="empty-state-icon">
              <i class="bi bi-receipt" style="font-size: 48px;"></i>
            </div>
            <h3 class="empty-state-title">No Invoices Found</h3>
            <p class="empty-state-text">
              There are no washing invoices to display at this time.
            </p>
            <a href="/washingdashboard/payments" class="btn btn-primary mt-3">
              <i class="bi bi-arrow-left"></i>
              Back to Payments
            </a>
          </div>
        <% } %>
      </div>
    </div>

  </div>
</main>

<style>
  /* Page-specific styles */
  .table-responsive {
    overflow-x: auto;
  }

  .table tbody tr {
    transition: background-color var(--transition-fast);
  }

  .table tbody tr:hover {
    background-color: var(--gray-50);
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .page-header .d-flex {
      flex-direction: column;
      align-items: flex-start !important;
    }

    .page-header .btn {
      width: 100%;
      justify-content: center;
    }

    .table th, .table td {
      padding: 10px 12px;
      font-size: 0.8rem;
    }

    .btn-sm {
      padding: 4px 8px;
      font-size: 0.7rem;
    }
  }
</style>

<%- include('partials/footer') %>
