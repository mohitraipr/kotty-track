<%- include('partials/header', { pageTitle: 'Dashboard' }) %>
<%- include('partials/navbar', { user: user }) %>

<!-- Main Content -->
<main class="main-content" style="margin-left: 0;">
  <div class="container-fluid" style="max-width: var(--content-max-width); margin: 0 auto;">

    <!-- Flash Messages -->
    <% if (error && error.length > 0) { %>
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>

    <% if (success && success.length > 0) { %>
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>
        <%= success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>

    <% if (tableName) { %>
      <!-- Table View Section -->
      <div class="page-header">
        <div class="breadcrumbs">
          <a href="/dashboard">Dashboard</a>
          <span class="separator">/</span>
          <span><%= tableName %></span>
        </div>
        <h1 class="page-title">Data in <%= tableName %></h1>
      </div>

      <!-- Search & Actions Bar -->
      <div class="card mb-4 no-print">
        <div class="card-body py-3">
          <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
            <form class="d-flex align-items-center gap-2" method="GET" action="/dashboard/view">
              <input type="hidden" name="table" value="<%= tableName %>" />
              <div class="position-relative">
                <i class="bi bi-search position-absolute" style="left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-muted);"></i>
                <input
                  type="text"
                  name="search"
                  class="form-control"
                  placeholder="Search..."
                  value="<%= searchTerm %>"
                  style="padding-left: 36px; min-width: 240px;"
                />
              </div>
              <button type="submit" class="btn btn-primary">
                <i class="bi bi-search me-1"></i> Search
              </button>
            </form>
            <div class="d-flex gap-2">
              <a
                href="/dashboard/download-excel?table=<%= tableName %>&search=<%= searchTerm %>"
                class="btn btn-success"
              >
                <i class="bi bi-file-earmark-excel me-1"></i> Download Excel
              </a>
              <button class="btn btn-secondary" onclick="window.print()">
                <i class="bi bi-printer me-1"></i> Print
              </button>
              <a href="/dashboard" class="btn btn-outline">
                <i class="bi bi-arrow-left me-1"></i> Back
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Data Table -->
      <div class="card">
        <div class="table-container" style="max-height: 500px; overflow-y: auto;">
          <table class="table" id="dataTable">
            <thead style="position: sticky; top: 0; z-index: 10;">
              <% if (rows.length > 0) { %>
                <tr>
                  <% Object.keys(rows[0]).forEach((col) => { %>
                    <th><%= col %></th>
                  <% }) %>
                </tr>
              <% } else { %>
                <tr>
                  <% columns.forEach((c) => { %>
                    <th><%= c.Field %></th>
                  <% }) %>
                </tr>
              <% } %>
            </thead>
            <tbody>
              <% if (rows.length > 0) { %>
                <% rows.forEach((r) => { %>
                  <tr>
                    <% columns.forEach((c) => { %>
                      <td><%= (r[c.Field] !== undefined) ? r[c.Field] : '' %></td>
                    <% }) %>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="<%= columns.length %>" class="text-center py-5">
                    <div class="empty-state">
                      <i class="bi bi-inbox empty-state-icon" style="font-size: 48px;"></i>
                      <h5 class="empty-state-title mt-3">No data found</h5>
                      <p class="empty-state-text">There are no records to display in this table.</p>
                    </div>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Pagination -->
      <% if (totalPages && totalPages > 1) { %>
        <nav class="mt-4 no-print">
          <ul class="pagination justify-content-center">
            <li class="page-item <%= (currentPage <= 1) ? 'disabled' : '' %>">
              <a
                class="page-link"
                href="/dashboard/view?table=<%= tableName %>&search=<%= searchTerm %>&page=<%= currentPage - 1 %>"
                style="color: var(--terracotta); border-color: var(--border-light);"
              >
                <i class="bi bi-chevron-left"></i> Previous
              </a>
            </li>
            <li class="page-item disabled">
              <span class="page-link" style="background: var(--cream-dark); border-color: var(--border-light); color: var(--text-primary);">
                Page <%= currentPage %> of <%= totalPages %>
              </span>
            </li>
            <li class="page-item <%= (currentPage >= totalPages) ? 'disabled' : '' %>">
              <a
                class="page-link"
                href="/dashboard/view?table=<%= tableName %>&search=<%= searchTerm %>&page=<%= currentPage + 1 %>"
                style="color: var(--terracotta); border-color: var(--border-light);"
              >
                Next <i class="bi bi-chevron-right"></i>
              </a>
            </li>
          </ul>
        </nav>
      <% } %>

      <!-- Insert New Data Form -->
      <% if (canUpdate) { %>
        <div class="card mt-4">
          <div class="card-header">
            <h3 class="card-title">
              <i class="bi bi-plus-circle me-2" style="color: var(--terracotta);"></i>
              Insert New Data
            </h3>
          </div>
          <div class="card-body">
            <form method="POST" action="/dashboard/insert/<%= tableName %>">
              <div class="row">
                <% columns.forEach((col, index) => {
                     if (col.Key === 'PRI') { return; }
                     let inputType = 'text';
                     if (col.Type.includes('int') || col.Type.includes('decimal')) {
                       inputType = 'number';
                     } else if (col.Type.includes('date') || col.Type.includes('time')) {
                       inputType = 'date';
                     }
                %>
                  <div class="col-md-6 col-lg-4">
                    <div class="form-group">
                      <label class="form-label"><%= col.Field %></label>

                      <% if (col.Type.includes('enum(')) {
                           const match = col.Type.match(/\(([^)]+)\)/);
                           let enumVals = [];
                           if (match && match[1]) {
                             enumVals = match[1].split(',').map(v => v.replace(/'/g, '').trim());
                           }
                      %>
                        <select class="form-control form-select" name="<%= col.Field %>">
                          <% enumVals.forEach(ev => { %>
                            <option value="<%= ev %>"><%= ev %></option>
                          <% }) %>
                        </select>
                      <% } else { %>
                        <input
                          type="<%= inputType %>"
                          class="form-control"
                          name="<%= col.Field %>"
                          step="0.01"
                          placeholder="Enter <%= col.Field %>"
                        />
                      <% } %>
                    </div>
                  </div>
                <% }) %>
              </div>
              <div class="mt-3">
                <button type="submit" class="btn btn-primary">
                  <i class="bi bi-plus-lg me-1"></i> Insert Record
                </button>
              </div>
            </form>
          </div>
        </div>
      <% } %>

      <!-- Bulk Upload Section -->
      <% if (user.roleName === 'fabric_manager' && (tableName === 'fabric_invoices' || tableName === 'fabric_invoice_rolls')) { %>
        <div class="card mt-4">
          <div class="card-header">
            <h3 class="card-title">
              <i class="bi bi-cloud-upload me-2" style="color: var(--terracotta);"></i>
              Bulk Upload
            </h3>
          </div>
          <div class="card-body">
            <p class="text-secondary mb-3">You can download the Excel template and upload data in bulk.</p>
            <div class="d-flex gap-3">
              <a
                href="/dashboard/download-template?table=<%= tableName %>"
                class="btn btn-success"
              >
                <i class="bi bi-download me-1"></i> Download Excel Template
              </a>
              <a
                href="/dashboard/bulk-upload?table=<%= tableName %>"
                class="btn btn-outline"
              >
                <i class="bi bi-upload me-1"></i> Go to Bulk Upload Page
              </a>
            </div>
          </div>
        </div>
      <% } %>

    <% } else { %>
      <!-- Dashboard List View -->
      <div class="page-header">
        <h1 class="page-title">Available Dashboards</h1>
        <p class="page-subtitle">Select a dashboard to view its data</p>
      </div>

      <% if (dashboards && dashboards.length) { %>
        <div class="row g-4">
          <% dashboards.forEach((dashboard) => { %>
            <div class="col-md-6 col-lg-4">
              <a
                href="/dashboard/view?table=<%= dashboard.table_name %>"
                class="card kotty-card text-decoration-none d-block h-100"
                style="transition: all var(--transition-fast);"
              >
                <div class="card-body d-flex flex-column">
                  <div class="d-flex align-items-start justify-content-between mb-3">
                    <div class="p-2 rounded-lg" style="background: var(--terracotta-bg);">
                      <i class="bi bi-table" style="color: var(--terracotta); font-size: 24px;"></i>
                    </div>
                    <i class="bi bi-arrow-right" style="color: var(--text-muted);"></i>
                  </div>
                  <h5 class="card-title mb-2" style="color: var(--text-primary);"><%= dashboard.name %></h5>
                  <p class="text-muted mb-0" style="font-size: var(--text-sm);">
                    <i class="bi bi-database me-1"></i> <%= dashboard.table_name %>
                  </p>
                </div>
              </a>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="card">
          <div class="card-body">
            <div class="empty-state">
              <i class="bi bi-clipboard-x empty-state-icon" style="font-size: 64px;"></i>
              <h4 class="empty-state-title mt-3">No dashboards assigned</h4>
              <p class="empty-state-text">No dashboards are assigned to your role yet. Please contact an administrator.</p>
            </div>
          </div>
        </div>
      <% } %>
    <% } %>
  </div>
</main>

<style>
  /* Page-specific styles */
  .kotty-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--terracotta-light);
  }

  .pagination .page-link {
    background: var(--bg-card);
  }

  .pagination .page-item.disabled .page-link {
    background: var(--cream-dark);
    color: var(--text-muted);
  }

  .table-container .table thead {
    background: var(--cream-dark);
  }

  .table-container .table th {
    background: var(--cream-dark);
    color: var(--text-secondary);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: var(--text-xs);
  }

  .table-container .table td {
    vertical-align: middle;
  }

  .table-container .table tbody tr:hover {
    background: var(--cream-dark);
  }

  /* Print styles */
  @media print {
    .no-print {
      display: none !important;
    }

    .main-content {
      margin: 0 !important;
      padding: 0 !important;
    }

    .kotty-navbar {
      display: none !important;
    }

    .card {
      border: 1px solid #ddd;
      box-shadow: none;
    }
  }

  /* Form control overrides for Kotty theme */
  .form-control {
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    padding: 10px 14px;
    font-family: var(--font-body);
    transition: all var(--transition-fast);
  }

  .form-control:focus {
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px var(--terracotta-bg);
    outline: none;
  }

  .form-select {
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    padding: 10px 14px;
    font-family: var(--font-body);
    transition: all var(--transition-fast);
  }

  .form-select:focus {
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px var(--terracotta-bg);
    outline: none;
  }
</style>

<%- include('partials/footer') %>
