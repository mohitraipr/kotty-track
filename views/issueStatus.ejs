<%- include('partials/header', { pageTitle: 'Flipkart Issue Status' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/dashboard' }) %>

<style>
  /* Issue Status - Page Specific Styles */
  .issue-status-page {
    padding-top: calc(var(--navbar-height) + 1.5rem);
    padding-bottom: 2rem;
    min-height: 100vh;
  }

  /* Page Header */
  .page-header {
    margin-bottom: 1.5rem;
  }
  .page-header h1 {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }
  .page-header p {
    color: var(--text-secondary);
    font-size: var(--text-sm);
  }

  /* Card Styles */
  .kotty-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
  }
  .kotty-card .card-header {
    background: transparent;
    border-bottom: 1px solid var(--border-light);
    font-weight: 500;
    color: var(--text-primary);
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .kotty-card .card-header i {
    color: var(--terracotta);
  }
  .kotty-card .card-body {
    padding: 1.25rem;
  }

  /* Form Styles */
  .form-label {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }
  .form-control {
    border: 1px solid var(--border-medium);
    border-radius: var(--radius-md);
    padding: 0.75rem 1rem;
    font-family: var(--font-body);
    font-size: var(--text-base);
    transition: all var(--transition-fast);
    background: var(--bg-card);
    color: var(--text-primary);
  }
  .form-control:focus {
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px rgba(196, 92, 58, 0.12);
    outline: none;
  }
  .form-control::placeholder {
    color: var(--text-muted);
  }
  textarea.form-control {
    min-height: 140px;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.6;
  }
  .form-text {
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin-top: 0.375rem;
  }

  /* Button Styles */
  .btn-kotty-primary {
    background: var(--terracotta);
    color: white;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-md);
    font-weight: 500;
    font-family: var(--font-body);
    font-size: var(--text-base);
    transition: all var(--transition-fast);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .btn-kotty-primary:hover {
    background: var(--terracotta-dark);
    color: white;
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }
  .btn-kotty-primary:active {
    transform: translateY(0);
  }
  .btn-kotty-primary:disabled {
    background: var(--gray-300);
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  /* Alert Styles */
  .alert-kotty {
    border-radius: var(--radius-md);
    padding: 0.875rem 1rem;
    margin-bottom: 1.25rem;
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: var(--text-sm);
    border-left: 4px solid;
  }
  .alert-kotty i {
    font-size: var(--text-lg);
    margin-top: 0.125rem;
  }
  .alert-kotty-danger {
    background: var(--danger-light);
    color: var(--danger);
    border-left-color: var(--danger);
  }
  .alert-kotty-success {
    background: var(--success-light);
    color: var(--success);
    border-left-color: var(--success);
  }

  /* Results Section */
  .results-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .results-header h3 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--text-primary);
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .results-header h3 i {
    color: var(--terracotta);
  }
  .results-count {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    background: var(--cream-dark);
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full);
  }

  /* Table Styles */
  .table-container {
    overflow-x: auto;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-light);
  }
  .kotty-table {
    width: 100%;
    border-collapse: collapse;
    margin: 0;
    font-size: var(--text-sm);
  }
  .kotty-table thead {
    background: var(--charcoal);
    color: white;
  }
  .kotty-table thead th {
    padding: 0.875rem 1rem;
    font-weight: 500;
    text-align: left;
    white-space: nowrap;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .kotty-table tbody tr {
    border-bottom: 1px solid var(--border-light);
    transition: background var(--transition-fast);
  }
  .kotty-table tbody tr:last-child {
    border-bottom: none;
  }
  .kotty-table tbody tr:hover {
    background: var(--cream-dark);
  }
  .kotty-table tbody td {
    padding: 0.875rem 1rem;
    color: var(--text-primary);
    vertical-align: middle;
  }

  /* Status Badge Styles */
  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.25rem 0.625rem;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 500;
    white-space: nowrap;
  }
  .status-open {
    background: var(--warning-light);
    color: var(--warning);
  }
  .status-closed, .status-resolved {
    background: var(--success-light);
    color: var(--success);
  }
  .status-pending {
    background: var(--info-light);
    color: var(--info);
  }
  .status-error {
    background: var(--danger-light);
    color: var(--danger);
  }

  /* Error Cell */
  .error-text {
    color: var(--danger);
    font-size: var(--text-xs);
    max-width: 200px;
    word-break: break-word;
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: 3rem 2rem;
    color: var(--text-muted);
  }
  .empty-state i {
    font-size: 3rem;
    margin-bottom: 1rem;
    opacity: 0.5;
  }
  .empty-state p {
    margin: 0;
    font-size: var(--text-sm);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .issue-status-page {
      padding-top: calc(var(--navbar-height) + 1rem);
    }
    .page-header h1 {
      font-size: var(--text-2xl);
    }
    .kotty-table {
      font-size: var(--text-xs);
    }
    .kotty-table thead th,
    .kotty-table tbody td {
      padding: 0.625rem 0.75rem;
    }
  }
</style>

<div class="issue-status-page">
  <div class="container-fluid px-4">
    <!-- Page Header -->
    <div class="page-header">
      <h1>Flipkart Issue Status</h1>
      <p>Check the status of Flipkart support tickets in bulk</p>
    </div>

    <!-- Alerts -->
    <% if (error && error.length) { %>
      <div class="alert-kotty alert-kotty-danger">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span><%= error[0] %></span>
      </div>
    <% } %>
    <% if (success && success.length) { %>
      <div class="alert-kotty alert-kotty-success">
        <i class="bi bi-check-circle-fill"></i>
        <span><%= success[0] %></span>
      </div>
    <% } %>

    <div class="row g-4">
      <!-- Search Form -->
      <div class="col-lg-4">
        <div class="kotty-card">
          <div class="card-header">
            <i class="bi bi-search"></i>
            <span>Check Ticket Status</span>
          </div>
          <div class="card-body">
            <form method="POST" action="/flipkart/issue-status">
              <div class="mb-3">
                <label for="ticketIds" class="form-label">Ticket IDs</label>
                <textarea
                  class="form-control"
                  id="ticketIds"
                  name="ticketIds"
                  rows="8"
                  placeholder="Enter ticket IDs (one per line)&#10;Example:&#10;FKMP123456&#10;FKMP789012"
                  required><%= ticketIds %></textarea>
                <div class="form-text">
                  <i class="bi bi-info-circle"></i> Enter each ticket ID on a new line
                </div>
              </div>
              <button type="submit" class="btn-kotty-primary w-100">
                <i class="bi bi-search"></i>
                Check Status
              </button>
            </form>
          </div>
        </div>
      </div>

      <!-- Results -->
      <div class="col-lg-8">
        <% if (results.length) { %>
          <div class="results-header">
            <h3>
              <i class="bi bi-list-check"></i>
              Results
            </h3>
            <span class="results-count"><%= results.length %> ticket<%= results.length !== 1 ? 's' : '' %></span>
          </div>

          <div class="kotty-card">
            <div class="table-container">
              <table class="kotty-table">
                <thead>
                  <tr>
                    <th>Ticket ID</th>
                    <th>Issue ID</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th>Updated</th>
                    <th>Resolved</th>
                    <th>TAT</th>
                    <th>Repromise TAT</th>
                    <th>Error</th>
                  </tr>
                </thead>
                <tbody>
                  <% results.forEach(r => { %>
                    <tr>
                      <td><strong><%= r.ticketId %></strong></td>
                      <td><%= r.issueId || '-' %></td>
                      <td>
                        <% if (r.displayStatus) { %>
                          <span class="status-badge status-<%= r.displayStatus.toLowerCase().includes('closed') || r.displayStatus.toLowerCase().includes('resolved') ? 'closed' : r.displayStatus.toLowerCase().includes('open') ? 'open' : 'pending' %>">
                            <%= r.displayStatus %>
                          </span>
                        <% } else { %>
                          <span class="text-muted">-</span>
                        <% } %>
                      </td>
                      <td><%= r.createdDate || '-' %></td>
                      <td><%= r.lastUpdatedDate || '-' %></td>
                      <td><%= r.resolvedDate || '-' %></td>
                      <td><%= r.tat || '-' %></td>
                      <td><%= r.repromiseTat || '-' %></td>
                      <td>
                        <% if (r.error) { %>
                          <span class="error-text" title="<%= r.error %>">
                            <i class="bi bi-exclamation-circle"></i> <%= r.error %>
                          </span>
                        <% } else { %>
                          <span class="text-muted">-</span>
                        <% } %>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        <% } else { %>
          <div class="kotty-card">
            <div class="empty-state">
              <i class="bi bi-ticket-detailed"></i>
              <p>Enter ticket IDs in the form and click "Check Status" to see results</p>
            </div>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
