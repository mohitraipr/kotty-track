<%- include('partials/header', { pageTitle: 'Stitching Pendency Report' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/operator/dashboard' }) %>

<main class="main-content" style="margin-left: 0;">
  <div class="container" style="max-width: 1400px; margin: 0 auto;">
    <!-- Page Header -->
    <div class="page-header">
      <div class="breadcrumbs">
        <a href="/operator/dashboard">Dashboard</a>
        <span class="separator">/</span>
        <span>Pendency Reports</span>
        <span class="separator">/</span>
        <span>Stitching</span>
      </div>
      <h1 class="page-title">Stitching Pendency Dashboard</h1>
      <p class="page-subtitle">Overview of Pending and Completed Assignments for All Stitching Users</p>
    </div>

    <!-- All Stitching Users Summary Card -->
    <div class="card mb-4">
      <div class="card-header">
        <h2 class="card-title">
          <i class="bi bi-bar-chart-line me-2" style="color: var(--terracotta);"></i>
          All Stitching Users Summary
        </h2>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table mb-0">
            <thead>
              <tr>
                <th>User</th>
                <th>Total Assignments</th>
                <th>Completed</th>
                <th>Pending</th>
                <th style="min-width: 200px;">Completion Rate</th>
              </tr>
            </thead>
            <tbody>
              <% usersSummary.forEach(function(user) {
                   const rate = user.total_assignments > 0
                                ? ((user.completed_assignments / user.total_assignments) * 100).toFixed(0)
                                : 0;
              %>
              <tr>
                <td>
                  <div class="d-flex align-items-center gap-2">
                    <div class="user-avatar" style="width: 32px; height: 32px; font-size: 0.75rem;">
                      <%= user.username ? user.username.charAt(0).toUpperCase() : 'U' %>
                    </div>
                    <span class="fw-medium"><%= user.username %></span>
                  </div>
                </td>
                <td><span class="badge badge-neutral"><%= user.total_assignments %></span></td>
                <td><span class="badge badge-success"><%= user.completed_assignments %></span></td>
                <td><span class="badge badge-warning"><%= user.pending_assignments %></span></td>
                <td>
                  <div class="d-flex align-items-center gap-2">
                    <div class="progress flex-grow-1" style="height: 10px;">
                      <div class="progress-bar success" role="progressbar"
                        style="width: <%= rate %>%;" aria-valuenow="<%= rate %>"
                        aria-valuemin="0" aria-valuemax="100">
                      </div>
                    </div>
                    <span class="text-secondary" style="min-width: 40px; font-size: var(--text-sm);"><%= rate %>%</span>
                  </div>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Detailed Report Card -->
    <div class="card">
      <div class="card-header">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 w-100">
          <h2 class="card-title">
            <i class="bi bi-person-lines-fill me-2" style="color: var(--terracotta);"></i>
            Detailed Report
          </h2>
          <!-- User Selection Form -->
          <form method="GET" action="/operator/pendency-report/stitching" class="d-flex align-items-center gap-2">
            <select name="user_id" class="form-select" style="min-width: 200px;">
              <option value="">-- Select User --</option>
              <% usersSummary.forEach(function(user) { %>
                <option value="<%= user.user_id %>" <%= (query.user_id == user.user_id ? 'selected' : '') %>>
                  <%= user.username %>
                </option>
              <% }); %>
            </select>
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-search"></i>
              <span class="d-none d-sm-inline">View</span>
            </button>
          </form>
        </div>
      </div>
      <div class="card-body">
        <% if (selectedUserId) { %>
          <!-- Summary Stats for Selected User -->
          <div class="row g-4 mb-4">
            <div class="col-md-4">
              <div class="stat-card">
                <div class="stat-label">Total Assigned Pieces</div>
                <div class="stat-value"><%= detailedSummary.totalAssigned %></div>
              </div>
            </div>
            <div class="col-md-4">
              <div class="stat-card">
                <div class="stat-label">Total Pending Pieces</div>
                <div class="stat-value text-warning"><%= detailedSummary.totalPending %></div>
              </div>
            </div>
            <div class="col-md-4">
              <div class="d-flex align-items-center justify-content-center h-100">
                <a href="/operator/pendency-report/stitching/download?user_id=<%= selectedUserId %>" class="btn btn-success btn-lg">
                  <i class="bi bi-file-earmark-excel"></i> Download Excel
                </a>
              </div>
            </div>
          </div>

          <% if (detailedAssignments.length > 0) { %>
            <div class="table-container">
              <div class="table-responsive">
                <table class="table mb-0">
                  <thead>
                    <tr>
                      <th>Lot No</th>
                      <th>Total Pieces</th>
                      <th>Stitched</th>
                      <th>Pending</th>
                      <th>Assigned On</th>
                      <th>Size Breakdown</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% detailedAssignments.forEach(function(asg) { %>
                      <tr>
                        <td>
                          <span class="fw-medium" style="color: var(--terracotta);"><%= asg.lot_no %></span>
                        </td>
                        <td><%= asg.total_pieces %></td>
                        <td><span class="badge badge-success"><%= asg.stitched %></span></td>
                        <td><span class="badge badge-warning"><%= asg.pending %></span></td>
                        <td>
                          <span style="font-size: var(--text-sm); color: var(--text-secondary);">
                            <%= new Date(asg.assigned_on).toLocaleString() %>
                          </span>
                        </td>
                        <td>
                          <% if (asg.sizes && asg.sizes.length) { %>
                            <div class="size-breakdown">
                              <% asg.sizes.forEach(function(sz) { %>
                                <div class="d-flex align-items-center gap-2 mb-1" style="font-size: var(--text-sm);">
                                  <span class="badge badge-primary"><%= sz.size_label %></span>
                                  <span><%= sz.stitched %>/<%= sz.total %> stitched</span>
                                  <span class="text-muted">(<%= sz.pending %> pending)</span>
                                </div>
                              <% }); %>
                            </div>
                          <% } else { %>
                            <span class="text-muted">N/A</span>
                          <% } %>
                        </td>
                      </tr>
                    <% }); %>
                  </tbody>
                </table>
              </div>
            </div>
          <% } else { %>
            <div class="empty-state">
              <div class="empty-state-icon">
                <i class="bi bi-inbox" style="font-size: 48px;"></i>
              </div>
              <h3 class="empty-state-title">No Assignments Found</h3>
              <p class="empty-state-text">No detailed assignments found for the selected user.</p>
            </div>
          <% } %>
        <% } else { %>
          <div class="empty-state">
            <div class="empty-state-icon">
              <i class="bi bi-person-check" style="font-size: 48px;"></i>
            </div>
            <h3 class="empty-state-title">Select a User</h3>
            <p class="empty-state-text">Select a user from the dropdown above to view detailed assignment data.</p>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</main>

<style>
  /* Page-specific styles */
  .size-breakdown {
    max-width: 300px;
  }

  .text-warning {
    color: var(--warning) !important;
  }

  /* Ensure proper spacing without sidebar */
  .main-content {
    margin-left: 0 !important;
  }
</style>

<%- include('partials/footer') %>
