<%- include('partials/header', { pageTitle: 'Stitching TAT Detail' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/operator/dashboard' }) %>

<main class="main-content" style="margin-left: 0;">
  <div class="container" style="max-width: 1400px; margin: 0 auto;">
    <!-- Page Header -->
    <div class="page-header">
      <div class="breadcrumbs">
        <a href="/operator/dashboard">Dashboard</a>
        <span class="separator">/</span>
        <a href="/stitching-tat">Stitching TAT Summary</a>
        <span class="separator">/</span>
        <span><%= masterUser.username %></span>
      </div>
      <h1 class="page-title">Stitching TAT Detail: <%= masterUser.username %></h1>
      <p class="page-subtitle">As of <%= currentDate %></p>
    </div>

    <!-- Action Buttons -->
    <div class="d-flex flex-wrap gap-2 mb-4">
      <a href="/stitching-tat" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Summary
      </a>
      <a href="/operator/stitching-tat/<%= masterUser.id %>?download=1" class="btn btn-success">
        <i class="bi bi-file-earmark-excel me-1"></i>Download Excel
      </a>
    </div>

    <!-- TAT Detail Table Card -->
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">
          <i class="bi bi-clock-history me-2" style="color: var(--terracotta);"></i>
          TAT Details
        </h2>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table mb-0">
            <thead>
              <tr>
                <th>Lot No</th>
                <th>SKU</th>
                <th>Status</th>
                <th>Total Pieces</th>
                <th>Cutting Remark</th>
                <th>Assigned On</th>
                <th>Next Dept On</th>
                <th>TAT (Days)</th>
              </tr>
            </thead>
            <tbody>
              <% detailRows.forEach((row) => {
                 // If TAT > 3 => "red-row", else "green-row"
                 const isDelayed = row.tatDays > 3;
                 const rowClass = isDelayed ? "tat-crossed" : "tat-within";

                 // Extra label in the TAT cell => e.g. "4 (TAT Crossed)" or "2 (Within TAT)"
                 const tatLabel = isDelayed ? "TAT Crossed" : "Within TAT";
              %>
                <tr class="<%= rowClass %>">
                  <td>
                    <span class="fw-medium" style="color: var(--terracotta);"><%= row.lotNo %></span>
                  </td>
                  <td><%= row.sku %></td>
                  <td>
                    <span class="badge <%= isDelayed ? 'badge-warning' : 'badge-success' %>">
                      <%= row.status %>
                    </span>
                  </td>
                  <td><%= row.totalPieces %></td>
                  <td>
                    <span style="font-size: var(--text-sm); color: var(--text-secondary);">
                      <%= row.cuttingRemark || '-' %>
                    </span>
                  </td>
                  <td>
                    <span style="font-size: var(--text-sm);">
                      <%= row.assignedOnStr %>
                    </span>
                  </td>
                  <td>
                    <span style="font-size: var(--text-sm);">
                      <%= row.nextDeptAssignedOnStr || '-' %>
                    </span>
                  </td>
                  <td>
                    <div class="d-flex align-items-center gap-2">
                      <span class="badge <%= isDelayed ? 'badge-danger' : 'badge-success' %>">
                        <%= row.tatDays %> days
                      </span>
                      <span class="tat-label <%= isDelayed ? 'text-danger' : 'text-success' %>">
                        <%= tatLabel %>
                      </span>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>

        <% if (detailRows.length === 0) { %>
          <div class="empty-state">
            <div class="empty-state-icon">
              <i class="bi bi-inbox" style="font-size: 48px;"></i>
            </div>
            <h3 class="empty-state-title">No Data Available</h3>
            <p class="empty-state-text">No TAT detail records found for this user.</p>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</main>

<style>
  /* Page-specific styles */
  .tat-crossed {
    background-color: rgba(220, 53, 69, 0.08) !important;
  }

  .tat-within {
    background-color: rgba(25, 135, 84, 0.08) !important;
  }

  .tat-label {
    font-size: var(--text-xs);
    font-weight: 500;
    white-space: nowrap;
  }

  .text-danger {
    color: var(--danger) !important;
  }

  .text-success {
    color: var(--success) !important;
  }

  .badge-danger {
    background: linear-gradient(135deg, #dc3545, #c82333);
    color: white;
  }

  /* Ensure proper spacing without sidebar */
  .main-content {
    margin-left: 0 !important;
  }
</style>

<%- include('partials/footer') %>
