<%- include('partials/header', { pageTitle: 'Contract Receipt' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/stitchingdashboard' }) %>

<style>
  .receipt-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .receipt-card {
    background: #ffffff;
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    overflow: hidden;
  }

  .receipt-header {
    background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
    color: #faf8f5;
    padding: 1.5rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .receipt-header h1 {
    font-family: 'DM Serif Display', serif;
    font-size: 1.75rem;
    margin: 0;
    color: #faf8f5;
  }

  .receipt-date {
    background: rgba(196, 92, 58, 0.2);
    border: 1px solid #c45c3a;
    color: #faf8f5;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    font-family: 'Outfit', sans-serif;
    font-size: 0.9rem;
  }

  .receipt-date i {
    color: #c45c3a;
    margin-right: 0.5rem;
  }

  .receipt-body {
    padding: 2rem;
  }

  .receipt-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    margin-bottom: 1.5rem;
  }

  .receipt-table thead th {
    background: #faf8f5;
    color: #1a1a1a;
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 1rem;
    text-align: left;
    border-bottom: 2px solid #e8e4df;
  }

  .receipt-table thead th:first-child {
    border-radius: 8px 0 0 0;
  }

  .receipt-table thead th:last-child {
    border-radius: 0 8px 0 0;
    text-align: right;
  }

  .receipt-table tbody tr {
    transition: background-color 0.2s ease;
  }

  .receipt-table tbody tr:hover {
    background-color: #faf8f5;
  }

  .receipt-table tbody td {
    padding: 1rem;
    border-bottom: 1px solid #e8e4df;
    font-family: 'Outfit', sans-serif;
    color: #333;
  }

  .receipt-table tbody td:last-child {
    text-align: right;
    font-weight: 500;
  }

  .receipt-table tbody tr:last-child td {
    border-bottom: none;
  }

  .lot-badge {
    background: linear-gradient(135deg, #c45c3a 0%, #a84a2d 100%);
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 500;
    display: inline-block;
  }

  .sku-text {
    font-weight: 500;
    color: #1a1a1a;
  }

  .qty-badge {
    background: #e8e4df;
    color: #1a1a1a;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-weight: 500;
  }

  .rate-text {
    color: #666;
  }

  .amount-text {
    color: #1a1a1a;
    font-weight: 600;
  }

  .receipt-footer {
    background: #faf8f5;
    padding: 1.5rem 2rem;
    border-top: 2px solid #e8e4df;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .total-section {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .total-label {
    font-family: 'Outfit', sans-serif;
    font-size: 1rem;
    color: #666;
    font-weight: 500;
  }

  .total-amount {
    font-family: 'DM Serif Display', serif;
    font-size: 1.75rem;
    color: #c45c3a;
  }

  .action-buttons {
    display: flex;
    gap: 0.75rem;
  }

  .btn-back {
    background: #ffffff;
    color: #1a1a1a;
    border: 1px solid #e8e4df;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-family: 'Outfit', sans-serif;
    font-weight: 500;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.2s ease;
  }

  .btn-back:hover {
    background: #f5f5f5;
    color: #1a1a1a;
    border-color: #ccc;
  }

  .btn-print {
    background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
    color: #faf8f5;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-family: 'Outfit', sans-serif;
    font-weight: 500;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.2s ease;
  }

  .btn-print:hover {
    background: linear-gradient(135deg, #2d2d2d 0%, #3d3d3d 100%);
    transform: translateY(-1px);
  }

  /* Print Styles */
  @media print {
    body {
      background: white !important;
    }

    .kotty-navbar,
    .action-buttons,
    .btn-back,
    .btn-print,
    .sidebar-overlay {
      display: none !important;
    }

    .receipt-container {
      max-width: 100%;
      padding: 0;
      margin: 0;
    }

    .receipt-card {
      box-shadow: none;
      border: 1px solid #ddd;
    }

    .receipt-header {
      background: #1a1a1a !important;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .receipt-table thead th {
      background: #f5f5f5 !important;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .lot-badge {
      background: #c45c3a !important;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .receipt-footer {
      justify-content: flex-end;
    }
  }

  /* Responsive */
  @media (max-width: 768px) {
    .receipt-container {
      padding: 1rem 0.5rem;
    }

    .receipt-header {
      padding: 1rem;
      flex-direction: column;
      align-items: flex-start;
    }

    .receipt-header h1 {
      font-size: 1.5rem;
    }

    .receipt-body {
      padding: 1rem;
      overflow-x: auto;
    }

    .receipt-table {
      min-width: 500px;
    }

    .receipt-footer {
      padding: 1rem;
      flex-direction: column;
      align-items: stretch;
    }

    .total-section {
      justify-content: space-between;
    }

    .action-buttons {
      flex-direction: column;
    }

    .btn-back,
    .btn-print {
      justify-content: center;
    }
  }
</style>

<div class="receipt-container">
  <div class="receipt-card">
    <!-- Receipt Header -->
    <div class="receipt-header">
      <h1><i class="bi bi-receipt me-2"></i>Payment Receipt</h1>
      <div class="receipt-date">
        <i class="bi bi-calendar3"></i>
        Paid On: <%= paidAt %>
      </div>
    </div>

    <!-- Receipt Body -->
    <div class="receipt-body">
      <table class="receipt-table">
        <thead>
          <tr>
            <th>Lot</th>
            <th>SKU</th>
            <th>Qty</th>
            <th>Rate</th>
            <th>Amount</th>
          </tr>
        </thead>
        <tbody>
          <% payments.forEach(function(p){ %>
            <tr>
              <td><span class="lot-badge"><%= p.lot_no %></span></td>
              <td><span class="sku-text"><%= p.sku %></span></td>
              <td><span class="qty-badge"><%= p.qty %></span></td>
              <td><span class="rate-text"><%= p.rate %></span></td>
              <td><span class="amount-text"><%= p.amount %></span></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- Receipt Footer -->
    <div class="receipt-footer">
      <div class="total-section">
        <span class="total-label">Total Amount:</span>
        <span class="total-amount"><%= totalAmount %></span>
      </div>
      <div class="action-buttons">
        <a href="/stitchingdashboard/payments/contract/history" class="btn-back">
          <i class="bi bi-arrow-left"></i>
          Back
        </a>
        <button type="button" onclick="window.print()" class="btn-print">
          <i class="bi bi-printer"></i>
          Print
        </button>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
