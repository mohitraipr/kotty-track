<%- include('partials/header', { pageTitle: 'Assembly Pendency Report' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/operator/dashboard' }) %>

<main class="main-content" style="margin-left: 0;">
  <div class="container-fluid" style="max-width: 1400px; margin: 0 auto;">
    <!-- Page Header -->
    <div class="page-header">
      <div class="breadcrumbs">
        <a href="/operator/dashboard">Dashboard</a>
        <span class="separator">/</span>
        <span>Assembly Pendency Report</span>
      </div>
      <h1 class="page-title">Jeans Assembly Pendency Dashboard</h1>
      <p class="page-subtitle">Overview of Pending and Completed Assembly for All Users</p>
    </div>

    <!-- Summary Table Card -->
    <div class="card mb-4">
      <div class="card-header">
        <h2 class="card-title">
          <i class="bi bi-bar-chart-line me-2 text-terracotta"></i>
          All Assembly Users Summary
        </h2>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table mb-0">
            <thead>
              <tr>
                <th>User</th>
                <th>Total Assignments</th>
                <th>Completed</th>
                <th>Pending</th>
                <th style="min-width: 200px;">Completion Rate</th>
              </tr>
            </thead>
            <tbody>
              <% usersSummary.forEach(function(user) {
                   const rate = user.total_assignments > 0
                                ? ((user.completed_assignments / user.total_assignments) * 100).toFixed(0)
                                : 0;
              %>
              <tr>
                <td>
                  <div class="d-flex align-items-center gap-2">
                    <div class="user-avatar" style="width: 32px; height: 32px; font-size: 0.75rem; background: var(--terracotta); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white;">
                      <%= user.username ? user.username.charAt(0).toUpperCase() : 'U' %>
                    </div>
                    <span class="fw-medium"><%= user.username %></span>
                  </div>
                </td>
                <td>
                  <span class="badge badge-neutral"><%= user.total_assignments %></span>
                </td>
                <td>
                  <span class="badge badge-success"><%= user.completed_assignments %></span>
                </td>
                <td>
                  <span class="badge badge-warning"><%= user.pending_assignments %></span>
                </td>
                <td>
                  <div class="d-flex align-items-center gap-2">
                    <div class="progress flex-grow-1" style="height: 10px;">
                      <div class="progress-bar success" role="progressbar" style="width: <%= rate %>%;"></div>
                    </div>
                    <span class="text-secondary" style="min-width: 40px; font-size: 0.875rem; font-weight: 500;"><%= rate %>%</span>
                  </div>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Detailed View Card -->
    <div class="card">
      <div class="card-header flex-wrap gap-3">
        <h2 class="card-title">
          <i class="bi bi-person-lines-fill me-2 text-terracotta"></i>
          Detailed Assembly Report
        </h2>
        <!-- User Selection Form -->
        <form method="GET" action="/operator/pendency-report/assembly" class="d-flex align-items-center gap-2 flex-wrap">
          <select name="user_id" class="form-select" style="min-width: 200px; max-width: 250px;">
            <option value="">-- Select User --</option>
            <% usersSummary.forEach(function(user) { %>
              <option value="<%= user.user_id %>" <%= (query.user_id == user.user_id ? 'selected' : '') %>>
                <%= user.username %>
              </option>
            <% }); %>
          </select>
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-search"></i>
            <span class="d-none d-sm-inline">View</span>
          </button>
        </form>
      </div>
      <div class="card-body">
        <% if (selectedUserId) { %>
          <!-- Summary Stats for Selected User -->
          <div class="row g-3 mb-4">
            <div class="col-md-6">
              <div class="stat-card">
                <div class="stat-label">Total Assigned Pieces</div>
                <div class="stat-value"><%= detailedSummary.totalAssigned %></div>
              </div>
            </div>
            <div class="col-md-6">
              <div class="stat-card">
                <div class="stat-label">Total Pending Pieces</div>
                <div class="stat-value text-warning"><%= detailedSummary.totalPending %></div>
              </div>
            </div>
          </div>

          <!-- Download Button -->
          <div class="mb-4">
            <a href="/operator/pendency-report/assembly/download?user_id=<%= selectedUserId %>" class="btn btn-success">
              <i class="bi bi-file-earmark-excel"></i>
              Download Excel
            </a>
          </div>

          <!-- Detailed Assignments Table -->
          <% if (detailedAssignments.length > 0) { %>
            <div class="table-container">
              <div class="table-responsive">
                <table class="table mb-0">
                  <thead>
                    <tr>
                      <th>Lot No</th>
                      <th>Total Pieces</th>
                      <th>Assembled</th>
                      <th>Pending</th>
                      <th>Assigned On</th>
                      <th>Size Breakdown</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% detailedAssignments.forEach(function(asg) { %>
                      <tr>
                        <td>
                          <span class="fw-medium text-terracotta"><%= asg.lot_no %></span>
                        </td>
                        <td><%= asg.total_pieces %></td>
                        <td>
                          <span class="badge badge-success"><%= asg.assembled %></span>
                        </td>
                        <td>
                          <span class="badge badge-warning"><%= asg.pending %></span>
                        </td>
                        <td>
                          <span class="text-secondary" style="font-size: 0.875rem;">
                            <%= new Date(asg.assigned_on).toLocaleString('en-IN', {
                              day: '2-digit',
                              month: 'short',
                              year: 'numeric',
                              hour: '2-digit',
                              minute: '2-digit'
                            }) %>
                          </span>
                        </td>
                        <td>
                          <% if (asg.sizes && asg.sizes.length) { %>
                            <div class="size-breakdown">
                              <% asg.sizes.forEach(function(sz) { %>
                                <div class="size-item d-flex align-items-center gap-2 mb-1" style="font-size: 0.875rem;">
                                  <span class="badge badge-neutral" style="min-width: 45px;"><%= sz.size_label %></span>
                                  <span class="text-success"><%= sz.assembled %></span>
                                  <span class="text-muted">/</span>
                                  <span><%= sz.total %></span>
                                  <span class="text-muted">assembled,</span>
                                  <span class="text-warning"><%= sz.pending %></span>
                                  <span class="text-muted">pending</span>
                                </div>
                              <% }); %>
                            </div>
                          <% } else { %>
                            <span class="text-muted">N/A</span>
                          <% } %>
                        </td>
                      </tr>
                    <% }); %>
                  </tbody>
                </table>
              </div>
            </div>
          <% } else { %>
            <div class="empty-state">
              <div class="empty-state-icon">
                <i class="bi bi-inbox" style="font-size: 3rem;"></i>
              </div>
              <h3 class="empty-state-title">No Assignments Found</h3>
              <p class="empty-state-text">No detailed assembly assignments found for the selected user.</p>
            </div>
          <% } %>
        <% } else { %>
          <div class="empty-state">
            <div class="empty-state-icon">
              <i class="bi bi-person-badge" style="font-size: 3rem;"></i>
            </div>
            <h3 class="empty-state-title">Select a User</h3>
            <p class="empty-state-text">Select a user from the dropdown above to view detailed assembly data.</p>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</main>

<style>
  /* Page-specific styles */
  .size-breakdown {
    max-height: 150px;
    overflow-y: auto;
  }

  .size-item:last-child {
    margin-bottom: 0 !important;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .card-header {
      flex-direction: column;
      align-items: flex-start !important;
    }

    .card-header form {
      width: 100%;
    }

    .card-header form select {
      flex: 1;
    }
  }
</style>

<%- include('partials/footer') %>
