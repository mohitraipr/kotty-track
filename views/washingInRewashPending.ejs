<%- include('partials/header', { pageTitle: 'Pending Rewash' }) %>
<%- include('partials/navbar', { dashboardUrl: '/washingin' }) %>

<!-- Main Content -->
<div class="main-content" style="margin-left: 0;">
  <div class="container-fluid" style="max-width: 1200px; margin: 0 auto;">

    <!-- Page Header -->
    <div class="page-header">
      <div class="breadcrumbs">
        <a href="/washingin">Washing In</a>
        <span class="separator">/</span>
        <span>Pending Rewash</span>
      </div>
      <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
          <h1 class="page-title">Pending Rewash Requests</h1>
          <p class="page-subtitle">Review and complete rewash requests awaiting processing</p>
        </div>
        <div class="d-flex gap-2">
          <a href="/washingin/assign-rewash" class="btn btn-primary">
            <i class="bi bi-arrow-repeat"></i> New Rewash
          </a>
          <a href="/washingin" class="btn btn-secondary">
            <i class="bi bi-speedometer2"></i> Dashboard
          </a>
        </div>
      </div>
    </div>

    <!-- Main Card -->
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">
          <i class="bi bi-hourglass-split me-2 text-terracotta"></i>
          Awaiting Completion
        </h2>
        <span class="badge badge-primary" id="pendingCount">Loading...</span>
      </div>
      <div class="card-body p-0">
        <div class="table-container" style="border: none; border-radius: 0;">
          <div class="table-responsive">
            <table class="table mb-0">
              <thead>
                <tr>
                  <th style="width: 80px;">#</th>
                  <th>Lot No</th>
                  <th>Requested Qty</th>
                  <th>Requested On</th>
                  <th style="width: 150px; text-align: center;">Action</th>
                </tr>
              </thead>
              <tbody id="pendingBody">
                <!-- Loading state -->
                <tr id="loadingRow">
                  <td colspan="5" class="text-center py-5">
                    <div class="d-flex flex-column align-items-center gap-3">
                      <div class="spinner"></div>
                      <span class="text-secondary">Loading pending requests...</span>
                    </div>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
  async function loadPending() {
    try {
      const res = await fetch('/washingin/assign-rewash/pending/list');
      const { data } = await res.json();
      const body = document.getElementById('pendingBody');
      const countBadge = document.getElementById('pendingCount');
      body.innerHTML = '';

      if (!data.length) {
        countBadge.textContent = '0 pending';
        countBadge.className = 'badge badge-success';
        body.innerHTML = `
          <tr>
            <td colspan="5">
              <div class="empty-state">
                <div class="empty-state-icon">
                  <i class="bi bi-check-circle" style="font-size: 48px;"></i>
                </div>
                <h3 class="empty-state-title">All Clear</h3>
                <p class="empty-state-text">No pending rewash requests at the moment.</p>
                <a href="/washingin/assign-rewash" class="btn btn-primary mt-3">
                  <i class="bi bi-plus-lg"></i> Create New Rewash
                </a>
              </div>
            </td>
          </tr>`;
        return;
      }

      countBadge.textContent = data.length + ' pending';
      countBadge.className = 'badge badge-warning';

      data.forEach((r, index) => {
        const date = new Date(r.created_at).toLocaleString('en-IN', {
          day: '2-digit',
          month: 'short',
          year: 'numeric',
          hour: '2-digit',
          minute: '2-digit'
        });
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td>
            <span class="badge badge-neutral">${r.id}</span>
          </td>
          <td>
            <span class="fw-medium">${r.lot_no}</span>
          </td>
          <td>
            <span class="badge badge-info">${r.total_requested} pcs</span>
          </td>
          <td>
            <span class="text-secondary">${date}</span>
          </td>
          <td class="text-center">
            <form method="POST" action="/washingin/assign-rewash/pending/${r.id}/complete" style="display: inline;">
              <button type="submit" class="btn btn-success btn-sm">
                <i class="bi bi-check-lg"></i> Complete
              </button>
            </form>
          </td>
        `;
        body.appendChild(tr);
      });
    } catch (err) {
      console.error('Error loading pending requests:', err);
      const body = document.getElementById('pendingBody');
      const countBadge = document.getElementById('pendingCount');
      countBadge.textContent = 'Error';
      countBadge.className = 'badge badge-danger';
      body.innerHTML = `
        <tr>
          <td colspan="5">
            <div class="empty-state">
              <div class="empty-state-icon text-danger">
                <i class="bi bi-exclamation-triangle" style="font-size: 48px;"></i>
              </div>
              <h3 class="empty-state-title">Failed to Load</h3>
              <p class="empty-state-text">Unable to fetch pending rewash requests. Please try again.</p>
              <button onclick="loadPending()" class="btn btn-secondary mt-3">
                <i class="bi bi-arrow-clockwise"></i> Retry
              </button>
            </div>
          </td>
        </tr>`;
    }
  }

  document.addEventListener('DOMContentLoaded', loadPending);
</script>

<%- include('partials/footer') %>
