</main>

<div class="toast-area" id="toastArea"></div>

<script>
'use strict';

const BASE = '/stitchingdashboard';

let currentLot = null;
let currentState = null;
let infoTab = 'work';

// ─── helpers ────────────────────────────────
function el(id) { return document.getElementById(id); }
function fmt(n) { return Number(n || 0).toLocaleString(); }
function fmtMoney(n) { return '₹' + (Number(n || 0).toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 2 })); }
function escapeText(s) { return String(s).replace(/[&<>]/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c])); }

function toast(msg, kind) {
  const t = document.createElement('div');
  t.className = 'toast ' + (kind || '');
  t.textContent = msg;
  el('toastArea').appendChild(t);
  setTimeout(() => { t.style.opacity = '0'; t.style.transition = 'opacity 0.3s'; }, 3500);
  setTimeout(() => t.remove(), 3800);
}

function api(method, url, body) {
  const opts = { method, headers: { 'Content-Type': 'application/json' } };
  if (body) opts.body = JSON.stringify(body);
  return fetch(url, opts).then(async r => {
    const data = await r.json().catch(() => ({}));
    if (!r.ok) throw new Error(data.error || ('HTTP ' + r.status));
    return data;
  });
}

// ─── search ────────────────────────────────
async function runSearch() {
  const q = el('searchInput').value.trim();
  if (!q) return;
  el('searchBtn').disabled = true;
  el('searchBtn').textContent = '…';
  try {
    const data = await api('GET', BASE + '/event/search?q=' + encodeURIComponent(q));
    const wrap = el('searchResults');
    wrap.textContent = '';
    if (!data.lots.length) {
      wrap.innerHTML = '<div class="placeholder" style="padding: 1rem;"><p>No lots found for &ldquo;' + escapeText(q) + '&rdquo;</p></div>';
      wrap.classList.add('show'); return;
    }
    if (data.lots.length === 1) { wrap.classList.remove('show'); await selectLot(data.lots[0]); return; }
    data.lots.forEach(lot => {
      const row = document.createElement('div'); row.className = 'search-result-row';
      row.onclick = () => selectLot(lot);
      const num = document.createElement('span'); num.className = 'search-result-no'; num.textContent = (lot.lot_no || '').toUpperCase();
      row.appendChild(num);
      const meta = document.createElement('span'); meta.className = 'search-result-meta';
      meta.textContent = (lot.sku || '—') + ' · ' + Number(lot.total_pieces || 0) + ' pcs cut';
      row.appendChild(meta);
      const isDenim = (lot.flow_type || '').toLowerCase() === 'denim' ||
                      (lot.flow_type === null && lot.is_denim_cutter);
      const flow = document.createElement('span');
      flow.className = 'search-result-flow ' + (isDenim ? 'denim' : 'hosiery');
      flow.textContent = isDenim ? 'denim' : 'hosiery';
      row.appendChild(flow);
      wrap.appendChild(row);
    });
    wrap.classList.add('show');
  } catch (err) { toast('Search failed: ' + err.message, 'error'); }
  finally { el('searchBtn').disabled = false; el('searchBtn').textContent = 'Search'; }
}
el('searchBtn').addEventListener('click', runSearch);
el('searchInput').addEventListener('keydown', e => { if (e.key === 'Enter') runSearch(); });

// ─── select & state ─────────────────────────
async function selectLot(lot) {
  el('searchResults').classList.remove('show');
  currentLot = lot;
  await refreshState();
}

async function refreshState() {
  if (!currentLot) return;
  try {
    currentState = await api('GET', BASE + '/event/lot-state/' + currentLot.id);
    renderState();
  } catch (err) { toast('Could not load lot: ' + err.message, 'error'); }
}

function renderState() {
  if (!currentState) return;
  const { lot, stage_aggregates: agg, upstream_sizes, open_approvals: open } = currentState;

  el('lotNo').textContent = (lot.lot_no || '').toUpperCase();
  el('lotSku').textContent = lot.sku || '—';
  el('lotCutter').textContent = lot.cutting_master || '—';
  const isDenim = (lot.flow_type || '').toLowerCase() === 'denim' || (lot.flow_type === null && lot.is_denim_cutter);
  el('lotFlow').textContent = isDenim ? 'denim' : 'hosiery';

  const remarkNote = el('cuttingRemarkNote');
  if (lot.cutting_remark) {
    el('cuttingRemarkText').textContent = lot.cutting_remark;
    remarkNote.style.display = 'flex';
  } else { remarkNote.style.display = 'none'; }

  el('aggApproved').textContent = fmt(agg.approved);
  el('aggCompleted').textContent = fmt(agg.completed);
  el('aggRejected').textContent = fmt(agg.rejected);
  el('aggInline').textContent = fmt(agg.inline);

  const totalCut = upstream_sizes.reduce((a, s) => a + (Number(s.cut_qty || s.stitched_qty || s.assembled_qty || s.washed_qty || s.upstream_qty) || 0), 0);
  el('totalCut').textContent = fmt(totalCut);

  // size cards
  const grid = el('sizeGrid'); grid.textContent = '';
  upstream_sizes.forEach((s, i) => {
    const cut = s.cut_qty || s.stitched_qty || s.assembled_qty || s.washed_qty || s.upstream_qty || 0;
    const approved = s.approved || 0;
    const completed = s.completed || 0;
    const rejected = s.rejected || 0;
    const available = s.available || 0;
    const pctApproved = cut > 0 ? Math.min(100, (approved / cut) * 100) : 0;
    const pctCompleted = cut > 0 ? Math.min(100, (completed / cut) * 100) : 0;
    const card = document.createElement('div');
    card.className = 'size-card' + (available === 0 && completed === cut ? ' fully-done' : '');
    card.style.animationDelay = (i * 25) + 'ms';
    card.style.animation = 'revealDown 0.3s ease-out backwards';
    card.innerHTML = `
      <div class="size-card-head">
        <span class="size-card-label">${escapeText(s.size_label)}</span>
        <span class="size-card-cut">cut ${fmt(cut)}</span>
      </div>
      <div class="size-fill">
        <div class="size-fill-approved" style="width: ${pctApproved}%"></div>
        <div class="size-fill-completed" style="width: ${pctCompleted}%"></div>
      </div>
      <div class="size-card-stats">
        <div class="size-card-stat ${approved === 0 ? 'dim':''}"><span class="v">${fmt(approved)}</span><span class="l">approved</span></div>
        <div class="size-card-stat ${completed === 0 ? 'dim':''}"><span class="v">${fmt(completed)}</span><span class="l">done</span></div>
        <div class="size-card-stat ${rejected === 0 ? 'dim':''}"><span class="v" style="color: ${rejected > 0 ? '#b34d28':''};">${fmt(rejected)}</span><span class="l">rejected</span></div>
      </div>
    `;
    grid.appendChild(card);
  });

  el('lotCard').classList.add('show');
  el('actionsSection').classList.add('show');
  renderActions();
}

// ═══════════════════════════════════════════════════════════
// AUTO-ACTIONS — decides what cards to show based on state.
//
//   - "Take pieces into stitching" if there's anything still in cutting
//   - "Mark as done" if the worker has open approvals (one card per)
//   - "Nothing to do here" if both empty
// ═══════════════════════════════════════════════════════════
function renderActions() {
  const wrap = el('actionsContainer');
  wrap.innerHTML = '';
  const totalAvailable = currentState.upstream_total_available || 0;
  const open = currentState.open_approvals;

  let actionCount = 0;

  // Card 1 — Take pieces (only if cutting pool has any left)
  if (totalAvailable > 0) {
    actionCount++;
    wrap.appendChild(buildTakeCard());
  }

  // Card 2..N — Mark as done (one per worker's open approve)
  open.forEach(a => {
    actionCount++;
    wrap.appendChild(buildMarkDoneCard(a));
  });

  if (actionCount === 0) {
    const nothing = document.createElement('div');
    nothing.className = 'nothing-card';
    nothing.innerHTML = '<div class="mark">✓</div><p>This lot is fully processed at stitching.<br><small style="opacity: 0.7;">Nothing for you to do here.</small></p>';
    wrap.appendChild(nothing);
    el('actionsHeading').textContent = '— this lot —';
  } else {
    el('actionsHeading').textContent = actionCount === 1 ? 'What you can do on this lot' : 'What you can do on this lot · ' + actionCount + ' actions';
  }
}

function buildTakeCard() {
  const upstream = currentState.upstream_sizes;
  const totalAvailable = currentState.upstream_total_available || 0;
  const card = document.createElement('div');
  card.className = 'action-card';
  card.innerHTML = `
    <div class="action-card-head">
      <div class="action-card-icon">↘</div>
      <div class="action-card-text">
        <p class="action-card-title">Take <strong>${fmt(totalAvailable)}</strong> pieces into stitching</p>
        <p class="action-card-subtitle">— everything still in the cutting pool</p>
      </div>
    </div>
    <button class="action-card-confirm is-take" data-action="take-confirm">
      <span class="check">✓</span>
      <span>Yes, take all ${fmt(totalAvailable)} pieces</span>
    </button>
    <div class="action-card-adjust" data-action="take-toggle">
      <span class="arrow">⌄</span> Or adjust by size
    </div>
    <div class="action-card-form">
      <p class="form-helper">Pre-filled with everything available. Reduce a size by tapping − or typing.</p>
      <div class="size-input-list" id="takeSizeList"></div>
      <div class="form-row"><input type="text" id="takeRemark" placeholder="Note (optional)" /></div>
      <div class="form-totals">
        <span class="l">Total to take</span>
        <span class="v" id="takeTotal">0</span>
      </div>
      <button class="ledger-btn-primary" data-action="take-submit" style="width: 100%; margin-top: 0.875rem; padding: 1rem;">Take pieces</button>
    </div>
  `;
  // build size inputs (pre-filled to max)
  const list = card.querySelector('#takeSizeList');
  upstream.forEach(s => {
    const avail = s.available || 0;
    if (avail === 0) return;
    const row = document.createElement('div');
    row.className = 'size-input-row';
    row.innerHTML = `
      <span class="size-input-label">${escapeText(s.size_label)}</span>
      <span class="size-input-avail"><span class="n">${fmt(avail)}</span> available</span>
      <div class="stepper">
        <button type="button" data-step="-10">−10</button>
        <button type="button" data-step="-1">−</button>
        <input type="number" min="0" max="${avail}" value="${avail}" data-size="${escapeText(s.size_label)}" data-avail="${avail}" />
        <button type="button" data-step="1">+</button>
        <button type="button" data-step="10">+10</button>
      </div>
    `;
    const input = row.querySelector('input');
    row.querySelectorAll('button[data-step]').forEach(btn => {
      btn.addEventListener('click', () => {
        const cur = parseInt(input.value, 10) || 0;
        let next = cur + parseInt(btn.dataset.step, 10);
        if (next < 0) next = 0;
        if (next > avail) next = avail;
        input.value = next;
        recalcTakeTotal(card);
      });
    });
    input.addEventListener('input', () => recalcTakeTotal(card));
    list.appendChild(row);
  });

  // wire actions
  card.querySelector('[data-action="take-toggle"]').addEventListener('click', () => card.classList.toggle('expanded'));
  card.querySelector('[data-action="take-confirm"]').addEventListener('click', () => doTakeAll(card));
  card.querySelector('[data-action="take-submit"]').addEventListener('click', () => doTakeFromForm(card));

  recalcTakeTotal(card);
  return card;
}

function recalcTakeTotal(card) {
  const inputs = card.querySelectorAll('#takeSizeList input[data-size]');
  let total = 0;
  inputs.forEach(i => {
    let v = parseInt(i.value, 10);
    if (!Number.isFinite(v) || v < 0) v = 0;
    const max = Number(i.dataset.avail) || 0;
    if (v > max) { v = max; i.value = v; }
    total += v;
  });
  card.querySelector('#takeTotal').textContent = fmt(total);
}

async function doTakeAll(card) {
  const upstream = currentState.upstream_sizes;
  const sizes = upstream
    .filter(s => (s.available || 0) > 0)
    .map(s => ({ size_label: s.size_label, pieces: s.available }));
  if (!sizes.length) return;
  const total = sizes.reduce((a, s) => a + s.pieces, 0);
  if (!confirm('Take ' + fmt(total) + ' pieces of ' + (currentLot.lot_no || '').toUpperCase() + ' into stitching?')) return;
  await doTakeRequest(sizes, '');
}

async function doTakeFromForm(card) {
  const inputs = card.querySelectorAll('#takeSizeList input[data-size]');
  const sizes = [];
  inputs.forEach(i => {
    const p = parseInt(i.value, 10) || 0;
    if (p > 0) sizes.push({ size_label: i.dataset.size, pieces: p });
  });
  if (!sizes.length) { toast('No pieces selected', 'error'); return; }
  const remark = card.querySelector('#takeRemark').value.trim() || null;
  const total = sizes.reduce((a, s) => a + s.pieces, 0);
  if (!confirm('Take ' + fmt(total) + ' pieces of ' + (currentLot.lot_no || '').toUpperCase() + ' into stitching?')) return;
  await doTakeRequest(sizes, remark);
}

async function doTakeRequest(sizes, remark) {
  try {
    await api('POST', BASE + '/event/approve', { cutting_lot_id: currentLot.id, sizes, remark });
    toast('Taken into stitching ✓', 'success');
    await refreshState();
    if (infoTab === 'work') loadHistory();
  } catch (err) { toast('Could not take: ' + err.message, 'error'); }
}

function buildMarkDoneCard(approve) {
  const card = document.createElement('div');
  card.className = 'action-card';
  card.dataset.approveId = String(approve.event_id);

  const sizesText = Object.entries(approve.sizes).map(([k,v]) => '<strong>' + escapeText(k) + '</strong> ' + fmt(v)).join('  ·  ');
  const when = new Date(approve.approved_at).toLocaleDateString(undefined, { day: 'numeric', month: 'short' });

  card.innerHTML = `
    <div class="action-card-head is-complete">
      <div class="action-card-icon">✓</div>
      <div class="action-card-text">
        <p class="action-card-title">Mark <strong>${fmt(approve.inline)}</strong> pieces as done</p>
        <p class="action-card-subtitle">— from your batch of ${fmt(approve.approved)} taken on ${when}</p>
      </div>
    </div>
    <button class="action-card-confirm" data-action="done-confirm">
      <span class="check">✓</span>
      <span>Yes, all ${fmt(approve.inline)} pieces are done</span>
    </button>
    <div class="action-card-adjust" data-action="done-toggle">
      <span class="arrow">⌄</span> Or some pieces are still being worked / spoiled
    </div>
    <div class="action-card-form">
      <p class="form-helper">Pre-filled with the full inline amount per size. Reduce if some pieces aren't done yet.</p>
      <div class="size-input-list" id="doneSizeList-${approve.event_id}"></div>
      <div class="form-row"><input type="text" data-input="done-remark" placeholder="Completion note (optional)" /></div>
      <div class="form-totals">
        <span class="l">Marking as done</span>
        <span class="v" data-display="done-total">0</span>
      </div>

      <div class="reject-toggle" data-action="reject-toggle">+ Some pieces are spoiled / damaged</div>
      <div class="reject-section" data-section="reject">
        <p class="form-helper" style="margin-top: 0.5rem; color: #b34d28;">Pieces that cannot be sent forward — entered here will be permanently rejected.</p>
        <div class="size-input-list" data-list="reject-sizes"></div>
        <div class="form-row"><input type="text" data-input="reject-reason" placeholder="Reject reason (e.g. fabric defect)" /></div>
        <div class="form-totals" style="border-color: #b34d28;">
          <span class="l">Rejecting</span>
          <span class="v" data-display="reject-total" style="color: #b34d28;">0</span>
        </div>
      </div>

      <button class="ledger-btn-primary" data-action="done-submit" style="width: 100%; margin-top: 0.875rem; padding: 1rem;">Save</button>
    </div>
  `;

  // build size inputs for done (pre-filled with each size's INLINE amount)
  const list = card.querySelector('#doneSizeList-' + approve.event_id);
  // We have approve.sizes (the original approved per-size); inline per-size
  // isn't broken down in open_approvals, so in v1 we treat each size's
  // inline as its full approved amount minus child completes/rejects.
  // The open_approvals list only includes approves with positive inline,
  // so using approve.sizes as the cap is safe (the server will validate).
  Object.entries(approve.sizes).forEach(([label, full]) => {
    const row = document.createElement('div');
    row.className = 'size-input-row';
    row.innerHTML = `
      <span class="size-input-label">${escapeText(label)}</span>
      <span class="size-input-avail">up to <span class="n">${fmt(full)}</span></span>
      <div class="stepper">
        <button type="button" data-step="-10">−10</button>
        <button type="button" data-step="-1">−</button>
        <input type="number" min="0" max="${full}" value="${full}" data-size="${escapeText(label)}" data-max="${full}" data-kind="done" />
        <button type="button" data-step="1">+</button>
        <button type="button" data-step="10">+10</button>
      </div>
    `;
    bindStepper(row);
    list.appendChild(row);
  });

  // build size inputs for reject (default 0)
  const rList = card.querySelector('[data-list="reject-sizes"]');
  Object.entries(approve.sizes).forEach(([label, full]) => {
    const row = document.createElement('div');
    row.className = 'reject-row';
    row.innerHTML = `
      <span class="size-input-label">${escapeText(label)}</span>
      <span class="size-input-avail">up to <span class="n">${fmt(full)}</span></span>
      <div class="stepper">
        <button type="button" data-step="-1">−</button>
        <input type="number" min="0" max="${full}" value="0" data-size="${escapeText(label)}" data-max="${full}" data-kind="reject" />
        <button type="button" data-step="1">+</button>
      </div>
    `;
    bindStepper(row);
    rList.appendChild(row);
  });

  // also: when "done" qty changes, ensure done+reject for that size doesn't exceed the cap
  card.addEventListener('input', () => recalcDoneTotals(card, approve));

  // wire actions
  card.querySelector('[data-action="done-toggle"]').addEventListener('click', () => card.classList.toggle('expanded'));
  card.querySelector('[data-action="reject-toggle"]').addEventListener('click', () => {
    card.querySelector('[data-section="reject"]').classList.toggle('show');
  });
  card.querySelector('[data-action="done-confirm"]').addEventListener('click', () => doMarkDoneAll(card, approve));
  card.querySelector('[data-action="done-submit"]').addEventListener('click', () => doMarkDoneFromForm(card, approve));

  recalcDoneTotals(card, approve);
  return card;
}

function bindStepper(row) {
  const input = row.querySelector('input');
  const max = Number(input.dataset.max) || 0;
  row.querySelectorAll('button[data-step]').forEach(btn => {
    btn.addEventListener('click', () => {
      const cur = parseInt(input.value, 10) || 0;
      let next = cur + parseInt(btn.dataset.step, 10);
      if (next < 0) next = 0;
      if (next > max) next = max;
      input.value = next;
      input.dispatchEvent(new Event('input', { bubbles: true }));
    });
  });
}

function recalcDoneTotals(card, approve) {
  // per-size cap: done + reject must not exceed approve.sizes[label]
  let done = 0, rej = 0;
  const doneInputs = card.querySelectorAll('input[data-kind="done"]');
  const rejInputs = card.querySelectorAll('input[data-kind="reject"]');

  // build size -> approve cap
  const caps = approve.sizes;
  // index reject by size for quick lookup
  const rejBySize = {};
  rejInputs.forEach(i => { rejBySize[i.dataset.size] = i; });

  doneInputs.forEach(i => {
    let v = parseInt(i.value, 10);
    if (!Number.isFinite(v) || v < 0) v = 0;
    const cap = caps[i.dataset.size] || 0;
    const r = parseInt((rejBySize[i.dataset.size] || {}).value, 10) || 0;
    if (v + r > cap) { v = Math.max(0, cap - r); i.value = v; }
    done += v;
  });
  rejInputs.forEach(i => {
    let v = parseInt(i.value, 10);
    if (!Number.isFinite(v) || v < 0) v = 0;
    const cap = caps[i.dataset.size] || 0;
    const d = parseInt((card.querySelector('input[data-kind="done"][data-size="' + i.dataset.size + '"]') || {}).value, 10) || 0;
    if (v + d > cap) { v = Math.max(0, cap - d); i.value = v; }
    rej += v;
  });
  card.querySelector('[data-display="done-total"]').textContent = fmt(done);
  card.querySelector('[data-display="reject-total"]').textContent = fmt(rej);
}

async function doMarkDoneAll(card, approve) {
  // confirm path — assume entire inline gets marked done, no rejects
  const completed_sizes = Object.entries(approve.sizes).map(([size_label, pieces]) => ({ size_label, pieces }));
  const total = completed_sizes.reduce((a, s) => a + s.pieces, 0);
  if (!confirm('Mark ' + fmt(total) + ' pieces of ' + (currentLot.lot_no || '').toUpperCase() + ' as done?')) return;
  await doMarkDoneRequest(approve.event_id, completed_sizes, [], null, null);
}

async function doMarkDoneFromForm(card, approve) {
  const completed = {}, rejected = {};
  card.querySelectorAll('input[data-kind="done"]').forEach(i => {
    const v = parseInt(i.value, 10) || 0;
    if (v > 0) completed[i.dataset.size] = (completed[i.dataset.size] || 0) + v;
  });
  card.querySelectorAll('input[data-kind="reject"]').forEach(i => {
    const v = parseInt(i.value, 10) || 0;
    if (v > 0) rejected[i.dataset.size] = (rejected[i.dataset.size] || 0) + v;
  });
  const cs = Object.entries(completed).map(([size_label, pieces]) => ({ size_label, pieces }));
  const rs = Object.entries(rejected).map(([size_label, pieces]) => ({ size_label, pieces }));
  if (!cs.length && !rs.length) { toast('Nothing entered', 'error'); return; }

  const cTotal = cs.reduce((a, s) => a + s.pieces, 0);
  const rTotal = rs.reduce((a, s) => a + s.pieces, 0);
  let msg = '';
  if (cTotal) msg += 'Mark ' + fmt(cTotal) + ' done';
  if (rTotal) msg += (msg ? ', ' : '') + 'reject ' + fmt(rTotal);
  if (!confirm(msg + ' for ' + (currentLot.lot_no || '').toUpperCase() + '?')) return;

  const remark = card.querySelector('[data-input="done-remark"]').value.trim() || null;
  const reason = card.querySelector('[data-input="reject-reason"]').value.trim() || null;
  await doMarkDoneRequest(approve.event_id, cs, rs, remark, reason);
}

async function doMarkDoneRequest(parentId, completed_sizes, rejected_sizes, complete_remark, reject_reason) {
  try {
    await api('POST', BASE + '/event/complete', {
      parent_event_id: parentId,
      completed_sizes, rejected_sizes,
      complete_remark, reject_reason,
    });
    toast('Saved ✓', 'success');
    await refreshState();
    if (infoTab === 'work') loadHistory();
  } catch (err) { toast('Could not save: ' + err.message, 'error'); }
}

// ─── My Work / My Payments ─────────────────
function switchInfoTab(tab) {
  infoTab = tab;
  el('tabWork').classList.toggle('active', tab === 'work');
  el('tabPayments').classList.toggle('active', tab === 'payments');
  el('workTab').style.display = tab === 'work' ? 'block' : 'none';
  el('paymentsTab').style.display = tab === 'payments' ? 'block' : 'none';
  if (tab === 'work') loadHistory();
  else loadPayments();
}

async function loadHistory() {
  const days = el('historyDays').value;
  const type = el('historyType').value;
  const list = el('historyList');
  list.innerHTML = '<div class="placeholder"><div class="placeholder-mark">·</div><p>Loading…</p></div>';
  try {
    const data = await api('GET', BASE + '/event/history?days=' + encodeURIComponent(days) + '&type=' + encodeURIComponent(type));
    if (!data.events || !data.events.length) {
      list.innerHTML = '<div class="placeholder"><div class="placeholder-mark">·</div><p>No work in this range.</p></div>';
      return;
    }
    list.textContent = '';
    const labelFor = { approve: 'taken', complete: 'done', reject: 'rejected' };
    data.events.forEach(e => {
      const row = document.createElement('div');
      row.className = 'timeline-row is-' + e.event_type;
      row.onclick = () => row.classList.toggle('expanded');
      const sizesHtml = e.sizes && Object.keys(e.sizes).length
        ? Object.entries(e.sizes).map(([k,v]) => '<strong>' + escapeText(k) + '</strong> ' + fmt(v)).join('  ·  ')
        : '<em>no size detail</em>';
      row.innerHTML = `
        <div class="timeline-row-head">
          <span class="timeline-row-lot">${escapeText(e.lot_no || '—')}</span>
          <span class="timeline-row-pieces">${fmt(e.pieces)}</span>
        </div>
        <div class="timeline-row-meta">
          <span class="event-type-pill ${e.event_type}">${labelFor[e.event_type] || e.event_type}</span>
          <span>${new Date(e.created_at).toLocaleString()}</span>
          ${e.remark ? '<span style="opacity:0.7;">— ' + escapeText(String(e.remark).slice(0, 60)) + '</span>' : ''}
        </div>
        <div class="timeline-row-detail">${sizesHtml}</div>
      `;
      list.appendChild(row);
    });
  } catch (err) {
    list.innerHTML = '<div class="placeholder"><div class="placeholder-mark">!</div><p>Could not load: ' + escapeText(err.message) + '</p></div>';
  }
}

el('historyDays').addEventListener('change', loadHistory);
el('historyType').addEventListener('change', loadHistory);

function downloadHistoryExcel() {
  const days = el('historyDays').value;
  const type = el('historyType').value;
  window.location = BASE + '/event/export?days=' + encodeURIComponent(days) + '&type=' + encodeURIComponent(type);
}

async function loadPayments() {
  const days = el('payDays').value;
  const status = el('payStatus').value;
  const sumWrap = el('paySummary');
  const list = el('payList');
  sumWrap.innerHTML = '';
  list.innerHTML = '<div class="placeholder"><div class="placeholder-mark">·</div><p>Loading…</p></div>';
  try {
    const data = await api('GET', BASE + '/event/payments?days=' + encodeURIComponent(days) + '&status=' + encodeURIComponent(status));
    const s = data.summary;
    sumWrap.innerHTML = `
      <div class="pay-summary-cell is-pending">
        <div class="l">Pending</div>
        <div class="v">${fmtMoney(s.pending_amount)}</div>
        <div class="small">${fmt(s.pending_qty)} pieces</div>
      </div>
      <div class="pay-summary-cell">
        <div class="l">Paid</div>
        <div class="v">${fmtMoney(s.paid_amount)}</div>
        <div class="small">${fmt(s.paid_qty)} pieces</div>
      </div>
    `;

    if (!data.payments || !data.payments.length) {
      list.innerHTML = '<div class="placeholder"><div class="placeholder-mark">·</div><p>No payments in this range.</p></div>';
      return;
    }
    list.textContent = '';
    data.payments.forEach(p => {
      const row = document.createElement('div');
      row.className = 'pay-row';
      const when = new Date(p.created_at).toLocaleString(undefined, { day: 'numeric', month: 'short', year: '2-digit' });
      row.innerHTML = `
        <div class="pay-row-main">
          <div class="pay-row-lot">${escapeText(p.lot_no || '—')}</div>
          <div class="pay-row-meta">${escapeText(p.sku || '')} · ${fmt(p.qty)} pcs · ${when}${p.rate_configured ? '' : ' · <span style="color:#b34d28;">rate not set</span>'}</div>
        </div>
        <div class="pay-row-amount">${fmtMoney(p.total_amount)}</div>
        <span class="pay-row-status ${p.status}">${p.status}</span>
      `;
      list.appendChild(row);
    });
  } catch (err) {
    list.innerHTML = '<div class="placeholder"><div class="placeholder-mark">!</div><p>Could not load: ' + escapeText(err.message) + '</p></div>';
  }
}

el('payDays').addEventListener('change', loadPayments);
el('payStatus').addEventListener('change', loadPayments);

function downloadPaymentsExcel() {
  const days = el('payDays').value;
  const status = el('payStatus').value;
  window.location = BASE + '/event/payments/export?days=' + encodeURIComponent(days) + '&status=' + encodeURIComponent(status);
}

// initial: load my work tab
loadHistory();
</script>

