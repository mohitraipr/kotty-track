<%- include('partials/header', { pageTitle: 'Stitching' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/stitchingdashboard' }) %>

<style>
  /* ───────────────────────────────────────────────────────────────
     STITCHING DASHBOARD — Craftsman's ledger book aesthetic.
     Warm cream paper, oxblood accents, big numbers, hand-stamped
     status pills, dashed ledger separators. Single-column, generous
     whitespace, large touch targets — built for tablets on the floor.
     ─────────────────────────────────────────────────────────────── */

  body { background: var(--cream); }

  .ledger-page {
    max-width: 920px;
    margin: 0 auto;
    padding: calc(var(--navbar-height) + 1.75rem) 1rem 6rem;
    min-height: 100vh;
    position: relative;
  }

  /* subtle paper grain — sparse dots overlayed at low opacity */
  .ledger-page::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    background-image: radial-gradient(rgba(196,92,58,0.06) 1px, transparent 1px);
    background-size: 28px 28px;
    z-index: 0;
  }
  .ledger-page > * { position: relative; z-index: 1; }

  /* ─── Page header ─────────────────────────────────────────── */
  .ledger-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px dashed var(--border-medium);
  }
  .ledger-head h1 {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4vw, 3rem);
    font-weight: 400;
    color: var(--text-primary);
    margin: 0;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .ledger-head .subtitle {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--terracotta-dark);
    font-size: var(--text-base);
  }

  /* ─── Search ─────────────────────────────────────────────── */
  .ledger-search {
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    box-shadow: 0 1px 3px rgba(196,92,58,0.06), 0 0 0 1px var(--border-light);
    margin-bottom: 1.75rem;
  }
  .ledger-search-row { display: flex; gap: 0.625rem; }
  .ledger-search-input {
    flex: 1;
    padding: 0.875rem 1.125rem;
    border: 1.5px solid var(--border-medium);
    border-radius: var(--radius-md);
    background: var(--cream);
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--text-primary);
    transition: all 0.2s;
  }
  .ledger-search-input::placeholder { color: var(--text-muted); font-style: italic; }
  .ledger-search-input:focus {
    outline: none;
    border-color: var(--terracotta);
    background: var(--bg-card);
    box-shadow: 0 0 0 4px rgba(196,92,58,0.12);
  }
  .ledger-btn-primary {
    padding: 0.875rem 1.5rem;
    border: none;
    border-radius: var(--radius-md);
    background: var(--terracotta);
    color: white;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-base);
    cursor: pointer;
    transition: all 0.15s;
    letter-spacing: 0.02em;
  }
  .ledger-btn-primary:hover { background: var(--terracotta-dark); transform: translateY(-1px); box-shadow: 0 4px 12px rgba(196,92,58,0.25); }
  .ledger-btn-primary:active { transform: translateY(0); }
  .ledger-btn-primary:disabled { background: var(--text-muted); cursor: not-allowed; transform: none; box-shadow: none; }

  .search-results {
    margin-top: 1rem;
    border-top: 1px dashed var(--border-light);
    padding-top: 1rem;
    display: none;
  }
  .search-results.show { display: block; animation: revealDown 0.3s ease-out; }
  .search-result-row {
    display: flex; align-items: center; gap: 1rem;
    padding: 0.875rem 1rem;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: background 0.12s;
  }
  .search-result-row:hover { background: var(--cream-dark); }
  .search-result-row + .search-result-row { border-top: 1px dashed var(--border-light); }
  .search-result-no {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--text-primary);
    font-size: var(--text-base);
    min-width: 9ch;
  }
  .search-result-meta { flex: 1; color: var(--text-secondary); font-size: var(--text-sm); }
  .search-result-flow {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-sm);
    padding: 0.2rem 0.625rem;
    border-radius: var(--radius-full);
  }
  .search-result-flow.denim { background: var(--terracotta-bg); color: var(--terracotta-dark); }
  .search-result-flow.hosiery { background: var(--info-light); color: var(--info); }

  /* ─── Lot context card ────────────────────────────────────── */
  .lot-card {
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    box-shadow: 0 1px 3px rgba(196,92,58,0.06), 0 0 0 1px var(--border-light);
    margin-bottom: 1.5rem;
    display: none;
    position: relative;
  }
  .lot-card.show { display: block; animation: revealDown 0.4s ease-out; }

  /* "stamped" lot number in the corner */
  .lot-card-stamp {
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    transform: rotate(3deg);
    border: 2px solid var(--terracotta);
    color: var(--terracotta-dark);
    padding: 0.25rem 0.625rem;
    border-radius: 4px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-sm);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    opacity: 0.85;
  }
  .lot-no-display {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 2.5rem);
    color: var(--text-primary);
    margin: 0 0 0.25rem;
    letter-spacing: -0.02em;
    line-height: 1.05;
  }
  .lot-meta {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    margin-bottom: 1.25rem;
  }
  .lot-meta strong { color: var(--text-primary); font-weight: 500; }

  /* cutting remark — "From Cutting" memo style */
  .lot-card .cutting-remark-note { margin: 1rem 0 1.5rem; }

  /* ─── Aggregate strip ─────────────────────────────────────── */
  .agg-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.5rem;
    margin: 1.25rem 0 1.75rem;
    padding: 1rem 0;
    border-top: 1px dashed var(--border-light);
    border-bottom: 1px dashed var(--border-light);
  }
  .agg-cell { text-align: center; }
  .agg-cell .agg-label {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.375rem;
  }
  .agg-cell .agg-value {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    color: var(--text-primary);
    line-height: 1;
    transition: color 0.3s;
  }
  .agg-cell.pop .agg-value { animation: popNumber 0.4s ease-out; }
  .agg-cell.is-inline .agg-value { color: var(--terracotta-dark); }
  .agg-cell.is-completed .agg-value { color: #2d6a3e; }
  .agg-cell.is-rejected .agg-value { color: #b34d28; }
  .agg-cell + .agg-cell { border-left: 1px dashed var(--border-light); padding-left: 0.5rem; }

  /* ─── Per-size cards (the centerpiece) ────────────────────── */
  .size-section-title {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--text-secondary);
    font-size: var(--text-base);
    margin: 0 0 0.875rem;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }
  .size-section-title .total-cut {
    font-family: var(--font-mono);
    color: var(--text-muted);
    font-size: var(--text-xs);
    font-style: normal;
  }

  .size-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(168px, 1fr));
    gap: 0.875rem;
  }

  .size-card {
    background: var(--cream);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    padding: 1rem 1rem 0.875rem;
    transition: all 0.2s;
    position: relative;
    overflow: hidden;
  }
  .size-card.fully-done { background: rgba(45, 106, 62, 0.04); border-color: rgba(45, 106, 62, 0.15); }
  .size-card.fully-done::after {
    content: '✓';
    position: absolute;
    top: 0.5rem;
    right: 0.625rem;
    color: #2d6a3e;
    font-size: var(--text-lg);
    opacity: 0.55;
  }

  .size-card-head {
    display: flex; align-items: baseline; justify-content: space-between;
    margin-bottom: 0.625rem;
  }
  .size-card-label {
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: 0.02em;
  }
  .size-card-cut {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--text-muted);
    font-size: var(--text-xs);
  }

  /* The "beaker" fill bar — segments showing approved + completed visually */
  .size-fill {
    height: 7px;
    background: var(--cream-darker);
    border-radius: 999px;
    overflow: hidden;
    margin-bottom: 0.5rem;
    position: relative;
  }
  .size-fill-approved {
    position: absolute; top: 0; left: 0; bottom: 0;
    background: var(--terracotta-light);
    border-radius: 999px;
    transition: width 0.5s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .size-fill-completed {
    position: absolute; top: 0; left: 0; bottom: 0;
    background: linear-gradient(90deg, #2d6a3e, #4f8b5e);
    border-radius: 999px;
    transition: width 0.5s cubic-bezier(0.32, 0.72, 0, 1);
  }

  .size-card-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.25rem;
    font-size: var(--text-xs);
    color: var(--text-secondary);
    margin-top: 0.5rem;
  }
  .size-card-stat .v {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--text-primary);
    display: block;
    font-size: var(--text-sm);
  }
  .size-card-stat .l {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--text-muted);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .size-card-stat.dim .v { color: var(--text-muted); }
  .size-card-available {
    display: block;
    text-align: center;
    margin-top: 0.625rem;
    padding-top: 0.5rem;
    border-top: 1px dashed var(--border-light);
    font-family: var(--font-display);
    font-style: italic;
    color: var(--terracotta-dark);
    font-size: var(--text-xs);
  }
  .size-card-available .n {
    font-family: var(--font-display);
    font-style: normal;
    font-weight: 400;
    font-size: var(--text-xl);
    color: var(--text-primary);
    margin-right: 0.25rem;
  }
  .size-card.zero-avail .size-card-available { color: var(--text-muted); }

  /* ─── Action panel ───────────────────────────────────────── */
  .action-panel {
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    box-shadow: 0 1px 3px rgba(196,92,58,0.06), 0 0 0 1px var(--border-light);
    overflow: hidden;
    margin-bottom: 1.5rem;
    display: none;
  }
  .action-panel.show { display: block; animation: revealDown 0.4s ease-out 0.1s backwards; }

  .action-tabs {
    display: flex;
    background: var(--cream);
    border-bottom: 1px dashed var(--border-medium);
    padding: 0 0.5rem;
  }
  .action-tab {
    flex: 1;
    padding: 1rem 0.75rem;
    background: transparent;
    border: none;
    border-bottom: 3px solid transparent;
    cursor: pointer;
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-base);
    color: var(--text-secondary);
    transition: all 0.15s;
    margin-bottom: -1px;
  }
  .action-tab:hover { color: var(--text-primary); }
  .action-tab.active {
    color: var(--terracotta-dark);
    border-bottom-color: var(--terracotta);
    font-weight: 500;
  }
  .action-tab[disabled] { opacity: 0.3; cursor: not-allowed; }

  .action-body { padding: 1.5rem; }

  /* Approve panel */
  .approve-cta {
    display: flex; align-items: center; gap: 0.875rem;
    padding: 1rem 1.25rem;
    background: linear-gradient(135deg, var(--terracotta) 0%, var(--terracotta-dark) 100%);
    color: white;
    border: none;
    border-radius: var(--radius-md);
    width: 100%;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    margin-bottom: 1.25rem;
    transition: all 0.2s;
    box-shadow: 0 2px 8px rgba(196,92,58,0.2);
  }
  .approve-cta:hover { transform: translateY(-1px); box-shadow: 0 4px 14px rgba(196,92,58,0.3); }
  .approve-cta:active { transform: translateY(0); }
  .approve-cta:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
  .approve-cta-text { flex: 1; text-align: left; }
  .approve-cta-text small {
    display: block;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    opacity: 0.85;
    font-size: var(--text-xs);
    margin-top: 2px;
    letter-spacing: 0.04em;
  }
  .approve-cta-num {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 400;
    line-height: 1;
  }

  .approve-divider {
    text-align: center;
    color: var(--text-muted);
    font-family: var(--font-display);
    font-style: italic;
    margin: 1rem 0;
    position: relative;
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .approve-divider::before,
  .approve-divider::after {
    content: '';
    position: absolute;
    top: 50%; height: 0;
    width: calc(50% - 3rem);
    border-top: 1px dashed var(--border-medium);
  }
  .approve-divider::before { left: 0; }
  .approve-divider::after { right: 0; }

  /* per-size input rows for approve */
  .size-input-list { display: flex; flex-direction: column; gap: 0.625rem; margin-bottom: 1rem; }
  .size-input-row {
    display: flex; align-items: center; gap: 0.875rem;
    padding: 0.625rem 0.875rem;
    background: var(--cream);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
  }
  .size-input-row.disabled { opacity: 0.4; }
  .size-input-label {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: var(--text-base);
    width: 3rem;
    color: var(--text-primary);
  }
  .size-input-avail {
    flex: 1;
    font-family: var(--font-display);
    font-style: italic;
    color: var(--text-muted);
    font-size: var(--text-sm);
  }
  .size-input-avail .n { color: var(--text-secondary); font-style: normal; font-weight: 500; }
  .stepper { display: flex; align-items: center; gap: 0.25rem; }
  .stepper button {
    width: 2.25rem; height: 2.25rem;
    border: 1px solid var(--border-medium);
    background: var(--bg-card);
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-size: var(--text-lg);
    color: var(--text-primary);
    font-weight: 600;
    line-height: 1;
    transition: all 0.1s;
  }
  .stepper button:hover { background: var(--cream-dark); border-color: var(--terracotta-light); }
  .stepper button:active { transform: scale(0.95); }
  .stepper button:disabled { opacity: 0.35; cursor: not-allowed; transform: none; }
  .stepper input {
    width: 4.5rem;
    height: 2.25rem;
    text-align: center;
    border: 1px solid var(--border-medium);
    border-radius: var(--radius-sm);
    background: var(--bg-card);
    font-family: var(--font-mono);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--text-primary);
  }
  .stepper input:focus { outline: none; border-color: var(--terracotta); box-shadow: 0 0 0 3px var(--terracotta-bg); }

  .form-row {
    margin-bottom: 0.875rem;
  }
  .form-row input[type="text"], .form-row textarea {
    width: 100%;
    padding: 0.75rem 0.875rem;
    border: 1px solid var(--border-medium);
    border-radius: var(--radius-md);
    background: var(--cream);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--text-primary);
    box-sizing: border-box;
  }
  .form-row input[type="text"]:focus, .form-row textarea:focus {
    outline: none; border-color: var(--terracotta); background: var(--bg-card);
    box-shadow: 0 0 0 3px var(--terracotta-bg);
  }

  .total-bar {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 1.25rem;
    background: var(--cream);
    border: 1px dashed var(--terracotta);
    border-radius: var(--radius-md);
    margin-top: 1rem;
  }
  .total-bar-label {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--text-secondary);
    font-size: var(--text-sm);
  }
  .total-bar-value {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    color: var(--terracotta-dark);
    line-height: 1;
  }

  /* approve picker (own batches) */
  .approve-picker {
    display: flex; flex-direction: column; gap: 0.625rem;
    margin-bottom: 1.25rem;
  }
  .approve-pick {
    border: 1.5px solid var(--border-light);
    border-radius: var(--radius-md);
    padding: 0.875rem 1rem;
    cursor: pointer;
    background: var(--cream);
    transition: all 0.15s;
    position: relative;
  }
  .approve-pick:hover { border-color: var(--terracotta-light); transform: translateX(2px); }
  .approve-pick.selected { border-color: var(--terracotta); background: var(--terracotta-bg); }
  .approve-pick-head {
    display: flex; justify-content: space-between; align-items: baseline;
    margin-bottom: 0.25rem;
  }
  .approve-pick-num {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    color: var(--text-primary);
    line-height: 1;
  }
  .approve-pick-num em {
    font-style: italic;
    color: var(--terracotta-dark);
    font-weight: 400;
  }
  .approve-pick-when {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--text-muted);
    font-size: var(--text-xs);
  }
  .approve-pick-detail {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-secondary);
    word-spacing: 0.4em;
  }

  /* complete form: per-size complete + reject inputs */
  .complete-grid {
    display: flex; flex-direction: column;
    gap: 0.625rem;
    margin-bottom: 1rem;
  }
  .complete-row {
    display: grid;
    grid-template-columns: 3rem 1fr 1fr;
    gap: 0.625rem;
    align-items: center;
    padding: 0.625rem;
    background: var(--cream);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
  }
  .complete-row-label {
    font-family: var(--font-mono);
    font-weight: 700;
    color: var(--text-primary);
    text-align: center;
  }
  .complete-row-input { display: flex; flex-direction: column; gap: 0.125rem; }
  .complete-row-input label {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.625rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .complete-row-input.reject label { color: #b34d28; }
  .complete-row-input input {
    padding: 0.5rem 0.625rem;
    border: 1px solid var(--border-medium);
    border-radius: var(--radius-sm);
    background: var(--bg-card);
    font-family: var(--font-mono);
    font-weight: 600;
    text-align: right;
    font-size: var(--text-sm);
  }
  .complete-row-input input:focus { outline: none; border-color: var(--terracotta); box-shadow: 0 0 0 3px var(--terracotta-bg); }
  .complete-row-input.reject input:focus { border-color: #b34d28; box-shadow: 0 0 0 3px rgba(179,77,40,0.15); }

  /* ─── History panel ──────────────────────────────────────── */
  .history-controls {
    display: flex; flex-wrap: wrap; gap: 0.625rem;
    margin-bottom: 1rem; align-items: center;
  }
  .history-controls input[type="date"] {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border-medium);
    border-radius: var(--radius-sm);
    background: var(--cream);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--text-primary);
  }
  .history-controls .spacer { flex: 1; }
  .history-controls .btn-secondary {
    padding: 0.5rem 0.875rem;
    border: 1px solid var(--terracotta);
    background: transparent;
    color: var(--terracotta-dark);
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--text-sm);
    cursor: pointer;
    transition: all 0.15s;
  }
  .history-controls .btn-secondary:hover { background: var(--terracotta); color: white; }
  .history-controls select {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border-medium);
    border-radius: var(--radius-sm);
    background: var(--cream);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--text-primary);
  }

  /* timeline */
  .timeline { position: relative; padding-left: 1.25rem; }
  .timeline::before {
    content: '';
    position: absolute;
    left: 4px; top: 6px; bottom: 6px;
    width: 1.5px;
    background: linear-gradient(to bottom, var(--terracotta-bg) 0%, var(--cream-darker) 100%);
  }
  .timeline-row {
    position: relative;
    padding: 0.5rem 0 0.5rem 0.875rem;
    cursor: pointer;
    border-bottom: 1px dashed var(--cream-darker);
  }
  .timeline-row::before {
    content: '';
    position: absolute;
    left: -1.25rem; top: 0.875rem;
    width: 9px; height: 9px;
    border-radius: 50%;
    background: var(--terracotta);
    box-shadow: 0 0 0 3px var(--cream);
  }
  .timeline-row.is-complete::before { background: #2d6a3e; }
  .timeline-row.is-reject::before { background: #b34d28; }
  .timeline-row-head {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 0.5rem;
  }
  .timeline-row-lot {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--text-primary);
    font-size: var(--text-sm);
  }
  .timeline-row-pieces {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--text-primary);
  }
  .timeline-row-meta {
    display: flex; gap: 0.625rem; align-items: baseline;
    font-size: var(--text-xs);
    color: var(--text-muted);
    font-family: var(--font-display);
    font-style: italic;
    margin-top: 0.125rem;
  }
  .event-type-pill {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.6875rem;
    padding: 0.125rem 0.5rem;
    border-radius: var(--radius-full);
    letter-spacing: 0.04em;
    text-transform: lowercase;
  }
  .event-type-pill.approve { background: var(--terracotta-bg); color: var(--terracotta-dark); }
  .event-type-pill.complete { background: rgba(45,106,62,0.1); color: #2d6a3e; }
  .event-type-pill.reject { background: rgba(179,77,40,0.12); color: #b34d28; }

  .timeline-row-detail {
    display: none;
    margin-top: 0.5rem;
    padding: 0.5rem 0.75rem;
    background: var(--cream);
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-secondary);
    word-spacing: 0.5em;
  }
  .timeline-row.expanded .timeline-row-detail { display: block; animation: revealDown 0.2s; }

  /* ─── Empty / placeholder states ──────────────────────────── */
  .placeholder {
    text-align: center;
    padding: 2.5rem 1rem;
    color: var(--text-muted);
  }
  .placeholder-mark {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-2xl);
    color: var(--terracotta-light);
    margin-bottom: 0.5rem;
  }
  .placeholder p {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-base);
    margin: 0;
  }

  /* ─── Toasts ───────────────────────────────────────────── */
  .toast-area {
    position: fixed;
    bottom: 1.25rem;
    right: 1.25rem;
    display: flex; flex-direction: column; gap: 0.5rem;
    z-index: 100;
    max-width: 380px;
  }
  .toast {
    padding: 0.875rem 1.125rem;
    background: var(--bg-card);
    border-radius: var(--radius-md);
    box-shadow: 0 8px 24px rgba(26,26,26,0.16), 0 0 0 1px var(--border-light);
    border-left: 4px solid var(--terracotta);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--text-primary);
    animation: slideUp 0.3s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .toast.success { border-left-color: #2d6a3e; }
  .toast.error { border-left-color: #b34d28; }

  /* ─── Animations ──────────────────────────────────────── */
  @keyframes revealDown {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes slideUp {
    from { transform: translateY(20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
  @keyframes popNumber {
    0% { transform: scale(1); }
    50% { transform: scale(1.08); color: var(--terracotta); }
    100% { transform: scale(1); }
  }

  /* ─── Mobile / tablet polish ─────────────────────────── */
  @media (max-width: 640px) {
    .agg-strip { grid-template-columns: repeat(2, 1fr); gap: 0.75rem 0.25rem; }
    .agg-cell + .agg-cell { border-left: none; padding-left: 0; }
    .agg-cell:nth-child(odd) + .agg-cell { border-left: 1px dashed var(--border-light); padding-left: 0.5rem; }
    .lot-card { padding: 1.25rem; }
    .ledger-head { flex-direction: column; align-items: flex-start; gap: 0.25rem; }
    .complete-row { grid-template-columns: 2.5rem 1fr 1fr; }
  }
</style>

<main class="ledger-page">
  <header class="ledger-head">
    <h1>Stitching</h1>
    <span class="subtitle">— operator ledger</span>
  </header>

  <!-- ─── Search ─────────────────────────────────────── -->
  <section class="ledger-search">
    <div class="ledger-search-row">
      <input type="text" id="searchInput" class="ledger-search-input" placeholder="Lot number, SKU, or cutting remark…" autofocus />
      <button id="searchBtn" class="ledger-btn-primary">Search</button>
    </div>
    <div id="searchResults" class="search-results"></div>
  </section>

  <!-- ─── Lot context card ───────────────────────────── -->
  <section id="lotCard" class="lot-card">
    <span class="lot-card-stamp">Active Lot</span>
    <h2 class="lot-no-display" id="lotNo">—</h2>
    <div class="lot-meta">
      <strong id="lotSku">—</strong>
      &nbsp;·&nbsp; cut by <strong id="lotCutter">—</strong>
      &nbsp;·&nbsp; <span id="lotFlow" style="font-style: italic; color: var(--terracotta-dark);">denim</span>
    </div>

    <div class="cutting-remark-note" id="cuttingRemarkNote" style="display: none;">
      <span class="cutting-remark-note__label">From Cutting</span>
      <span class="cutting-remark-note__text" id="cuttingRemarkText"></span>
    </div>

    <div class="agg-strip">
      <div class="agg-cell" id="aggApprovedCell"><div class="agg-label">Approved</div><div class="agg-value" id="aggApproved">0</div></div>
      <div class="agg-cell is-completed" id="aggCompletedCell"><div class="agg-label">Completed</div><div class="agg-value" id="aggCompleted">0</div></div>
      <div class="agg-cell is-rejected" id="aggRejectedCell"><div class="agg-label">Rejected</div><div class="agg-value" id="aggRejected">0</div></div>
      <div class="agg-cell is-inline" id="aggInlineCell"><div class="agg-label">Inline</div><div class="agg-value" id="aggInline">0</div></div>
    </div>

    <h3 class="size-section-title">
      <span>Per size</span>
      <span class="total-cut">Cut total <span id="totalCut">0</span></span>
    </h3>
    <div class="size-grid" id="sizeGrid"></div>
  </section>

  <!-- ─── Action panel: Approve / Complete / History ─── -->
  <section id="actionPanel" class="action-panel">
    <div class="action-tabs">
      <button class="action-tab active" id="tabApprove" onclick="switchTab('approve')">Approve</button>
      <button class="action-tab" id="tabComplete" onclick="switchTab('complete')">Complete &amp; Reject</button>
      <button class="action-tab" id="tabHistory" onclick="switchTab('history')">My Recent Work</button>
    </div>

    <!-- APPROVE -->
    <div class="action-body" id="approvePanel">
      <button class="approve-cta" id="approveAllBtn" onclick="approveAll()">
        <div class="approve-cta-text">
          Approve all available<br>
          <small>take everything still in the cutting pool</small>
        </div>
        <span class="approve-cta-num" id="approveAllNum">0</span>
      </button>
      <div class="approve-divider">or pick by size</div>
      <div class="size-input-list" id="approveSizeList"></div>
      <div class="form-row">
        <input type="text" id="approveRemark" placeholder="Remark (optional)" />
      </div>
      <div class="total-bar">
        <span class="total-bar-label">Total to approve</span>
        <span class="total-bar-value" id="approveTotal">0</span>
      </div>
      <button class="ledger-btn-primary" id="approveBtn" onclick="submitApprove()" style="width:100%; margin-top: 0.875rem; padding: 1rem;" disabled>Record approval</button>
    </div>

    <!-- COMPLETE -->
    <div class="action-body" id="completePanel" style="display: none;">
      <p style="font-family: var(--font-display); font-style: italic; color: var(--text-secondary); font-size: var(--text-sm); margin: 0 0 1rem;">
        Pick one of <em>your own</em> open approvals, then enter what's done and (optionally) what's rejected per size.
      </p>
      <div id="approvePicker" class="approve-picker"></div>
      <div id="completeForm" style="display: none;">
        <div class="complete-grid" id="completeSizeList"></div>
        <div class="form-row"><input type="text" id="completeRemark" placeholder="Completion remark (optional)" /></div>
        <div class="form-row"><input type="text" id="rejectReason" placeholder="Reject reason (only if rejecting)" /></div>
        <div class="total-bar">
          <span class="total-bar-label">Done / Rejected</span>
          <span class="total-bar-value">
            <span id="completeTotal">0</span>
            <span style="color: var(--text-muted); font-weight: 400;"> / </span>
            <span id="rejectTotal" style="color: #b34d28;">0</span>
          </span>
        </div>
        <button class="ledger-btn-primary" id="completeBtn" onclick="submitComplete()" style="width:100%; margin-top: 0.875rem; padding: 1rem;" disabled>Record completion</button>
      </div>
    </div>

    <!-- HISTORY -->
    <div class="action-body" id="historyPanel" style="display: none;">
      <div class="history-controls">
        <select id="historyDays">
          <option value="1">Today</option>
          <option value="7" selected>Last 7 days</option>
          <option value="30">Last 30 days</option>
          <option value="90">Last 90 days</option>
        </select>
        <select id="historyType">
          <option value="all">All event types</option>
          <option value="approve">Approve only</option>
          <option value="complete">Complete only</option>
          <option value="reject">Reject only</option>
        </select>
        <span class="spacer"></span>
        <button class="btn-secondary" onclick="downloadExcel()" id="excelBtn">⬇ Excel</button>
      </div>
      <div id="historyList" class="timeline">
        <div class="placeholder"><div class="placeholder-mark">·</div><p>Loading your recent work…</p></div>
      </div>
    </div>
  </section>

  <!-- placeholder before any lot is selected -->
  <section id="welcomeBlock" class="placeholder" style="padding: 3rem 1rem;">
    <div class="placeholder-mark">⌕</div>
    <p>Search a lot above to begin.</p>
  </section>
</main>

<div class="toast-area" id="toastArea"></div>

<script>
'use strict';

const BASE = '/stitchingdashboard';

let currentLot = null;
let currentState = null;
let selectedApprovalId = null;
let currentTab = 'approve';

// ─── helpers ─────────────────────────────────────────────
function el(id) { return document.getElementById(id); }
function fmt(n) { return Number(n || 0).toLocaleString(); }
function escapeText(s) { return String(s).replace(/[&<>]/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c])); }

function toast(msg, kind) {
  const t = document.createElement('div');
  t.className = 'toast ' + (kind || '');
  t.textContent = msg;
  el('toastArea').appendChild(t);
  setTimeout(() => { t.style.opacity = '0'; t.style.transition = 'opacity 0.3s'; }, 3000);
  setTimeout(() => t.remove(), 3300);
}

function api(method, url, body) {
  const opts = { method, headers: { 'Content-Type': 'application/json' } };
  if (body) opts.body = JSON.stringify(body);
  return fetch(url, opts).then(async r => {
    const data = await r.json().catch(() => ({}));
    if (!r.ok) throw new Error(data.error || ('HTTP ' + r.status));
    return data;
  });
}

function popCell(cellId) {
  const c = el(cellId);
  if (!c) return;
  c.classList.remove('pop');
  void c.offsetWidth; // restart animation
  c.classList.add('pop');
}

// ─── Search ──────────────────────────────────────────────
async function runSearch() {
  const q = el('searchInput').value.trim();
  if (!q) return;
  el('searchBtn').disabled = true;
  el('searchBtn').textContent = '…';
  try {
    const data = await api('GET', BASE + '/event/search?q=' + encodeURIComponent(q));
    const wrap = el('searchResults');
    wrap.textContent = '';
    if (!data.lots.length) {
      wrap.innerHTML = '<div class="placeholder" style="padding: 1rem;"><p>No lots found for &ldquo;' + escapeText(q) + '&rdquo;</p></div>';
      wrap.classList.add('show'); return;
    }
    if (data.lots.length === 1) { wrap.classList.remove('show'); await selectLot(data.lots[0]); return; }
    data.lots.forEach(lot => {
      const row = document.createElement('div'); row.className = 'search-result-row';
      row.onclick = () => selectLot(lot);
      const num = document.createElement('span'); num.className = 'search-result-no'; num.textContent = (lot.lot_no || '').toUpperCase();
      row.appendChild(num);
      const meta = document.createElement('span'); meta.className = 'search-result-meta';
      meta.textContent = (lot.sku || '—') + ' · ' + Number(lot.total_pieces || 0) + ' pcs cut';
      row.appendChild(meta);
      const isDenim = (lot.flow_type || '').toLowerCase() === 'denim' ||
                      (lot.flow_type === null && lot.is_denim_cutter);
      const flow = document.createElement('span');
      flow.className = 'search-result-flow ' + (isDenim ? 'denim' : 'hosiery');
      flow.textContent = isDenim ? 'denim' : 'hosiery';
      row.appendChild(flow);
      wrap.appendChild(row);
    });
    wrap.classList.add('show');
  } catch (err) { toast('Search failed: ' + err.message, 'error'); }
  finally { el('searchBtn').disabled = false; el('searchBtn').textContent = 'Search'; }
}

el('searchBtn').addEventListener('click', runSearch);
el('searchInput').addEventListener('keydown', e => { if (e.key === 'Enter') runSearch(); });

// ─── Select & state load ────────────────────────────────
async function selectLot(lot) {
  el('searchResults').classList.remove('show');
  el('welcomeBlock').style.display = 'none';
  currentLot = lot;
  await refreshState();
}

async function refreshState() {
  if (!currentLot) return;
  try {
    currentState = await api('GET', BASE + '/event/lot-state/' + currentLot.id);
    renderState();
    if (currentTab === 'history') loadHistory();
  } catch (err) { toast('Could not load lot: ' + err.message, 'error'); }
}

function renderState() {
  if (!currentState) return;
  const { lot, stage_aggregates: agg, upstream_sizes, open_approvals: open } = currentState;

  el('lotNo').textContent = (lot.lot_no || '').toUpperCase();
  el('lotSku').textContent = lot.sku || '—';
  el('lotCutter').textContent = lot.cutting_master || '—';
  const isDenim = (lot.flow_type || '').toLowerCase() === 'denim' ||
                  (lot.flow_type === null && lot.is_denim_cutter);
  el('lotFlow').textContent = isDenim ? 'denim' : 'hosiery';

  const remarkNote = el('cuttingRemarkNote');
  if (lot.cutting_remark) {
    el('cuttingRemarkText').textContent = lot.cutting_remark;
    remarkNote.style.display = 'flex';
  } else { remarkNote.style.display = 'none'; }

  // pop the changed aggregates
  ['aggApproved','aggCompleted','aggRejected','aggInline'].forEach(id => {
    const cur = parseInt(el(id).textContent.replace(/,/g,''), 10) || 0;
    const next = agg[id.replace('agg','').toLowerCase()];
    el(id).textContent = fmt(next);
    if (cur !== next) popCell(id + 'Cell');
  });

  // total cut
  const totalCut = upstream_sizes.reduce((a, s) => a + (Number(s.cut_qty || s.stitched_qty || s.assembled_qty || s.washed_qty || s.upstream_qty) || 0), 0);
  el('totalCut').textContent = fmt(totalCut);

  // size cards
  const grid = el('sizeGrid'); grid.textContent = '';
  upstream_sizes.forEach((s, i) => {
    const cut = s.cut_qty || s.stitched_qty || s.assembled_qty || s.washed_qty || s.upstream_qty || 0;
    const approved = s.approved || 0;
    const completed = s.completed || 0;
    const rejected = s.rejected || 0;
    const inline = s.inline || 0;
    const available = s.available || 0;

    const pctApproved = cut > 0 ? Math.min(100, (approved / cut) * 100) : 0;
    const pctCompleted = cut > 0 ? Math.min(100, (completed / cut) * 100) : 0;

    const card = document.createElement('div');
    card.className = 'size-card' + (available === 0 && completed === cut ? ' fully-done' : '') + (available === 0 && approved < cut ? ' zero-avail' : '');
    card.style.animationDelay = (i * 30) + 'ms';
    card.style.animation = 'revealDown 0.3s ease-out backwards';

    card.innerHTML = `
      <div class="size-card-head">
        <span class="size-card-label">${escapeText(s.size_label)}</span>
        <span class="size-card-cut">cut ${fmt(cut)}</span>
      </div>
      <div class="size-fill">
        <div class="size-fill-approved" style="width: ${pctApproved}%"></div>
        <div class="size-fill-completed" style="width: ${pctCompleted}%"></div>
      </div>
      <div class="size-card-stats">
        <div class="size-card-stat ${approved === 0 ? 'dim':''}"><span class="v">${fmt(approved)}</span><span class="l">approved</span></div>
        <div class="size-card-stat ${completed === 0 ? 'dim':''}"><span class="v">${fmt(completed)}</span><span class="l">done</span></div>
        <div class="size-card-stat ${rejected === 0 ? 'dim':''}"><span class="v" style="color: ${rejected > 0 ? '#b34d28':''};">${fmt(rejected)}</span><span class="l">rejected</span></div>
      </div>
      <div class="size-card-available">
        <span class="n">${fmt(available)}</span>still available
      </div>
    `;
    grid.appendChild(card);
  });

  el('lotCard').classList.add('show');
  el('actionPanel').classList.add('show');

  const totalAvailable = currentState.upstream_total_available || 0;
  const canApprove = totalAvailable > 0;
  const canComplete = open.length > 0;

  el('tabApprove').disabled = !canApprove;
  el('tabComplete').disabled = !canComplete;

  if (currentTab === 'approve' && !canApprove && canComplete) switchTab('complete');
  else if (currentTab === 'complete' && !canComplete && canApprove) switchTab('approve');

  renderApproveForm();
  renderCompletePanel();
}

// ─── Tabs ─────────────────────────────────────────────
function switchTab(tab) {
  currentTab = tab;
  ['approve','complete','history'].forEach(t => {
    el('tab' + t.charAt(0).toUpperCase() + t.slice(1)).classList.toggle('active', t === tab);
    el(t + 'Panel').style.display = (t === tab ? 'block' : 'none');
  });
  if (tab === 'history') loadHistory();
}

// ─── Approve form ────────────────────────────────────
function renderApproveForm() {
  const list = el('approveSizeList'); list.textContent = '';
  const upstream = currentState.upstream_sizes;
  const totalAvailable = currentState.upstream_total_available || 0;

  el('approveAllNum').textContent = fmt(totalAvailable);
  el('approveAllBtn').disabled = totalAvailable <= 0;

  if (totalAvailable <= 0) {
    list.innerHTML = '<div class="placeholder" style="padding: 1.25rem;"><p>Nothing left in the cutting pool — all pieces have been approved at stitching.</p></div>';
    el('approveBtn').disabled = true;
    el('approveTotal').textContent = '0';
    return;
  }

  upstream.forEach(s => {
    const avail = s.available || 0;
    const row = document.createElement('div');
    row.className = 'size-input-row' + (avail === 0 ? ' disabled' : '');
    row.innerHTML = `
      <span class="size-input-label">${escapeText(s.size_label)}</span>
      <span class="size-input-avail"><span class="n">${fmt(avail)}</span> available</span>
      <div class="stepper">
        <button type="button" data-step="-10" ${avail === 0 ? 'disabled':''}>−10</button>
        <button type="button" data-step="-1"  ${avail === 0 ? 'disabled':''}>−</button>
        <input type="number" min="0" max="${avail}" value="0" data-size="${escapeText(s.size_label)}" data-avail="${avail}" ${avail === 0 ? 'disabled':''} />
        <button type="button" data-step="1"   ${avail === 0 ? 'disabled':''}>+</button>
        <button type="button" data-step="10"  ${avail === 0 ? 'disabled':''}>+10</button>
      </div>
    `;
    list.appendChild(row);

    const input = row.querySelector('input');
    row.querySelectorAll('button[data-step]').forEach(btn => {
      btn.addEventListener('click', () => {
        const cur = parseInt(input.value, 10) || 0;
        const step = parseInt(btn.dataset.step, 10);
        let next = cur + step;
        if (next < 0) next = 0;
        if (next > avail) next = avail;
        input.value = next;
        recalcApproveTotal();
      });
    });
    input.addEventListener('input', recalcApproveTotal);
  });

  recalcApproveTotal();
}

function recalcApproveTotal() {
  const inputs = el('approveSizeList').querySelectorAll('input[data-size]');
  let total = 0;
  inputs.forEach(i => {
    let v = parseInt(i.value, 10);
    if (!Number.isFinite(v) || v < 0) v = 0;
    const max = Number(i.dataset.avail) || 0;
    if (v > max) { v = max; i.value = v; }
    total += v;
  });
  el('approveTotal').textContent = fmt(total);
  el('approveBtn').disabled = total <= 0;
}

function approveAll() {
  // Fill each size input to its max in one click
  el('approveSizeList').querySelectorAll('input[data-size]').forEach(i => {
    i.value = Number(i.dataset.avail) || 0;
  });
  recalcApproveTotal();
  // Auto-submit if user clicked the big CTA
  setTimeout(submitApprove, 100);
}

async function submitApprove() {
  if (!currentLot) return;
  const inputs = el('approveSizeList').querySelectorAll('input[data-size]');
  const sizes = [];
  inputs.forEach(i => {
    const p = parseInt(i.value, 10) || 0;
    if (p > 0) sizes.push({ size_label: i.dataset.size, pieces: p });
  });
  if (!sizes.length) return;
  const total = sizes.reduce((a, s) => a + s.pieces, 0);

  if (!confirm('Approve ' + fmt(total) + ' pieces for ' + (currentLot.lot_no || '').toUpperCase() + '?')) return;
  el('approveBtn').disabled = true;
  el('approveAllBtn').disabled = true;
  try {
    await api('POST', BASE + '/event/approve', {
      cutting_lot_id: currentLot.id, sizes,
      remark: el('approveRemark').value.trim() || null,
    });
    toast('Approved ' + fmt(total) + ' pieces', 'success');
    el('approveRemark').value = '';
    await refreshState();
  } catch (err) {
    toast('Approve failed: ' + err.message, 'error');
    el('approveBtn').disabled = false;
    el('approveAllBtn').disabled = false;
  }
}

// ─── Complete panel ──────────────────────────────────
function renderCompletePanel() {
  const picker = el('approvePicker'); picker.textContent = '';
  selectedApprovalId = null; el('completeForm').style.display = 'none';
  const open = currentState.open_approvals;
  if (!open.length) {
    picker.innerHTML = '<div class="placeholder"><div class="placeholder-mark">·</div><p>No open approvals of yours on this lot.<br><small>Approve some pieces first.</small></p></div>';
    return;
  }
  open.forEach(a => {
    const card = document.createElement('div');
    card.className = 'approve-pick';
    card.dataset.id = String(a.event_id);
    card.onclick = () => selectApprove(a);
    card.innerHTML = `
      <div class="approve-pick-head">
        <span class="approve-pick-num">${fmt(a.approved)} <em>· ${fmt(a.inline)} inline</em></span>
        <span class="approve-pick-when">${new Date(a.approved_at).toLocaleString()}</span>
      </div>
      <div class="approve-pick-detail">${Object.entries(a.sizes).map(([k,v]) => '<strong>' + escapeText(k) + '</strong> ' + fmt(v)).join('  ·  ')}</div>
    `;
    picker.appendChild(card);
  });
}

function selectApprove(approve) {
  selectedApprovalId = approve.event_id;
  document.querySelectorAll('.approve-pick').forEach(c => c.classList.remove('selected'));
  document.querySelectorAll('.approve-pick').forEach(c => {
    if (Number(c.dataset.id) === approve.event_id) c.classList.add('selected');
  });

  const list = el('completeSizeList'); list.textContent = '';
  Object.entries(approve.sizes).forEach(([label, approvedPieces]) => {
    const row = document.createElement('div');
    row.className = 'complete-row';
    row.innerHTML = `
      <span class="complete-row-label">${escapeText(label)}</span>
      <div class="complete-row-input">
        <label>Done (≤ ${approvedPieces})</label>
        <input type="number" min="0" max="${approvedPieces}" value="0" data-size="${escapeText(label)}" data-kind="done" />
      </div>
      <div class="complete-row-input reject">
        <label>Reject (≤ ${approvedPieces})</label>
        <input type="number" min="0" max="${approvedPieces}" value="0" data-size="${escapeText(label)}" data-kind="reject" />
      </div>
    `;
    row.querySelectorAll('input').forEach(inp => inp.addEventListener('input', recalcCompleteTotals));
    list.appendChild(row);
  });
  el('completeForm').style.display = 'block';
  recalcCompleteTotals();
}

function recalcCompleteTotals() {
  let done = 0, rej = 0;
  el('completeSizeList').querySelectorAll('input').forEach(i => {
    let v = parseInt(i.value, 10);
    if (!Number.isFinite(v) || v < 0) v = 0;
    const max = Number(i.max) || 0;
    if (v > max) { v = max; i.value = v; }
    if (i.dataset.kind === 'done') done += v;
    else if (i.dataset.kind === 'reject') rej += v;
  });
  el('completeTotal').textContent = fmt(done);
  el('rejectTotal').textContent = fmt(rej);
  el('completeBtn').disabled = (done + rej) <= 0;
}

async function submitComplete() {
  if (!selectedApprovalId) return;
  const completed = {}, rejected = {};
  el('completeSizeList').querySelectorAll('input').forEach(i => {
    const v = parseInt(i.value, 10) || 0;
    if (v > 0) {
      const target = i.dataset.kind === 'done' ? completed : rejected;
      target[i.dataset.size] = (target[i.dataset.size] || 0) + v;
    }
  });
  const cs = Object.entries(completed).map(([size_label, pieces]) => ({ size_label, pieces }));
  const rs = Object.entries(rejected).map(([size_label, pieces]) => ({ size_label, pieces }));
  if (!cs.length && !rs.length) return;
  const cTotal = cs.reduce((a, s) => a + s.pieces, 0);
  const rTotal = rs.reduce((a, s) => a + s.pieces, 0);
  let msg = '';
  if (cTotal) msg += 'Complete ' + fmt(cTotal);
  if (rTotal) msg += (msg ? ', ' : '') + 'reject ' + fmt(rTotal);
  if (!confirm(msg + ' for ' + (currentLot.lot_no || '').toUpperCase() + '?')) return;
  el('completeBtn').disabled = true;
  try {
    await api('POST', BASE + '/event/complete', {
      parent_event_id: selectedApprovalId,
      completed_sizes: cs, rejected_sizes: rs,
      complete_remark: el('completeRemark').value.trim() || null,
      reject_reason: el('rejectReason').value.trim() || null,
    });
    toast('Recorded.', 'success');
    el('completeRemark').value = ''; el('rejectReason').value = '';
    await refreshState();
  } catch (err) { toast('Could not record: ' + err.message, 'error'); el('completeBtn').disabled = false; }
}

// ─── History ─────────────────────────────────────────
async function loadHistory() {
  const days = el('historyDays').value;
  const type = el('historyType').value;
  const list = el('historyList');
  list.innerHTML = '<div class="placeholder"><div class="placeholder-mark">·</div><p>Loading…</p></div>';
  try {
    const data = await api('GET', BASE + '/event/history?days=' + encodeURIComponent(days) + '&type=' + encodeURIComponent(type));
    if (!data.events || !data.events.length) {
      list.innerHTML = '<div class="placeholder"><div class="placeholder-mark">·</div><p>No events in this range.</p></div>';
      return;
    }
    list.textContent = '';
    data.events.forEach(e => {
      const row = document.createElement('div');
      row.className = 'timeline-row is-' + e.event_type;
      row.onclick = () => row.classList.toggle('expanded');
      const sizesHtml = e.sizes && Object.keys(e.sizes).length
        ? Object.entries(e.sizes).map(([k,v]) => '<strong>' + escapeText(k) + '</strong> ' + fmt(v)).join('  ·  ')
        : '<em>no size detail</em>';
      row.innerHTML = `
        <div class="timeline-row-head">
          <span class="timeline-row-lot">${escapeText(e.lot_no || '—')}</span>
          <span class="timeline-row-pieces">${fmt(e.pieces)}</span>
        </div>
        <div class="timeline-row-meta">
          <span class="event-type-pill ${e.event_type}">${e.event_type}</span>
          <span>${new Date(e.created_at).toLocaleString()}</span>
          ${e.remark ? '<span style="opacity:0.7;">— ' + escapeText(String(e.remark).slice(0, 60)) + '</span>' : ''}
        </div>
        <div class="timeline-row-detail">${sizesHtml}</div>
      `;
      list.appendChild(row);
    });
  } catch (err) {
    list.innerHTML = '<div class="placeholder"><div class="placeholder-mark">!</div><p>Could not load history: ' + escapeText(err.message) + '</p></div>';
  }
}

el('historyDays').addEventListener('change', loadHistory);
el('historyType').addEventListener('change', loadHistory);

function downloadExcel() {
  const days = el('historyDays').value;
  const type = el('historyType').value;
  window.location = BASE + '/event/export?days=' + encodeURIComponent(days) + '&type=' + encodeURIComponent(type);
}
</script>

