<%- include('partials/header', { pageTitle: 'Stitching' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/stitchingdashboard' }) %>

<style>
  /* ───────────────────────────────────────────────────────────────
     STITCHING DASHBOARD — Factory-floor friendly.
     Auto-decides what action the worker should take. Pre-fills
     quantities. Plain English. No "approve/complete" jargon.
     ─────────────────────────────────────────────────────────────── */

  body { background: var(--cream); }

  .ledger-page {
    max-width: 920px;
    margin: 0 auto;
    padding: calc(var(--navbar-height) + 1.5rem) 1rem 6rem;
    min-height: 100vh;
    position: relative;
  }
  .ledger-page::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    background-image: radial-gradient(rgba(196,92,58,0.06) 1px, transparent 1px);
    background-size: 28px 28px;
    z-index: 0;
  }
  .ledger-page > * { position: relative; z-index: 1; }

  /* ─── Header ────────────────────────────────────────────── */
  .ledger-head {
    display: flex; align-items: baseline; justify-content: space-between;
    margin-bottom: 1.75rem;
    padding-bottom: 1rem;
    border-bottom: 1px dashed var(--border-medium);
    flex-wrap: wrap; gap: 0.5rem;
  }
  .ledger-head h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 400;
    color: var(--text-primary);
    margin: 0;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .ledger-head .subtitle {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--terracotta-dark);
    font-size: var(--text-base);
  }

  /* ─── Search ────────────────────────────────────────────── */
  .ledger-search {
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    box-shadow: 0 1px 3px rgba(196,92,58,0.06), 0 0 0 1px var(--border-light);
    margin-bottom: 1.5rem;
  }
  .ledger-search-row { display: flex; gap: 0.625rem; }
  .ledger-search-input {
    flex: 1; min-width: 0;
    padding: 0.875rem 1.125rem;
    border: 1.5px solid var(--border-medium);
    border-radius: var(--radius-md);
    background: var(--cream);
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--text-primary);
    transition: all 0.2s;
  }
  .ledger-search-input::placeholder { color: var(--text-muted); font-style: italic; }
  .ledger-search-input:focus {
    outline: none;
    border-color: var(--terracotta);
    background: var(--bg-card);
    box-shadow: 0 0 0 4px rgba(196,92,58,0.12);
  }
  .ledger-btn-primary {
    padding: 0.875rem 1.5rem;
    border: none;
    border-radius: var(--radius-md);
    background: var(--terracotta);
    color: white;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-base);
    cursor: pointer;
    transition: all 0.15s;
  }
  .ledger-btn-primary:hover { background: var(--terracotta-dark); transform: translateY(-1px); box-shadow: 0 4px 12px rgba(196,92,58,0.25); }
  .ledger-btn-primary:disabled { background: var(--text-muted); cursor: not-allowed; transform: none; }

  .search-results {
    margin-top: 1rem;
    border-top: 1px dashed var(--border-light);
    padding-top: 1rem;
    display: none;
  }
  .search-results.show { display: block; animation: revealDown 0.3s; }
  .search-result-row {
    display: flex; align-items: center; gap: 1rem;
    padding: 0.875rem 1rem; border-radius: var(--radius-md); cursor: pointer;
    transition: background 0.12s;
  }
  .search-result-row:hover { background: var(--cream-dark); }
  .search-result-row + .search-result-row { border-top: 1px dashed var(--border-light); }
  .search-result-no { font-family: var(--font-mono); font-weight: 600; color: var(--text-primary); min-width: 9ch; }
  .search-result-meta { flex: 1; color: var(--text-secondary); font-size: var(--text-sm); }
  .search-result-flow {
    font-family: var(--font-display); font-style: italic; font-size: var(--text-sm);
    padding: 0.2rem 0.625rem; border-radius: var(--radius-full);
  }
  .search-result-flow.denim { background: var(--terracotta-bg); color: var(--terracotta-dark); }
  .search-result-flow.hosiery { background: var(--info-light); color: var(--info); }

  /* ─── Lot card ──────────────────────────────────────────── */
  .lot-card {
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    box-shadow: 0 1px 3px rgba(196,92,58,0.06), 0 0 0 1px var(--border-light);
    margin-bottom: 1.5rem;
    display: none;
    position: relative;
  }
  .lot-card.show { display: block; animation: revealDown 0.4s; }
  .lot-card-stamp {
    position: absolute; top: 0.875rem; right: 1rem;
    transform: rotate(3deg);
    border: 2px solid var(--terracotta);
    color: var(--terracotta-dark);
    padding: 0.2rem 0.5rem; border-radius: 4px;
    font-family: var(--font-display); font-style: italic;
    font-size: var(--text-xs); letter-spacing: 0.04em; text-transform: uppercase;
    opacity: 0.85;
  }
  .lot-no-display {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 5vw, 2.25rem);
    color: var(--text-primary); margin: 0 0 0.25rem;
    letter-spacing: -0.02em; line-height: 1.05;
  }
  .lot-meta { color: var(--text-secondary); font-size: var(--text-sm); margin-bottom: 1rem; }
  .lot-meta strong { color: var(--text-primary); font-weight: 500; }
  .lot-card .cutting-remark-note { margin: 1rem 0 1.25rem; }

  .agg-strip {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.5rem;
    margin: 1rem 0 1.25rem;
    padding: 0.875rem 0;
    border-top: 1px dashed var(--border-light);
    border-bottom: 1px dashed var(--border-light);
  }
  .agg-cell { text-align: center; }
  .agg-cell .agg-label {
    font-family: var(--font-display); font-style: italic;
    font-size: var(--text-xs); color: var(--text-muted);
    letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 0.375rem;
  }
  .agg-cell .agg-value {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2rem);
    color: var(--text-primary); line-height: 1; transition: color 0.3s;
  }
  .agg-cell.is-inline .agg-value { color: var(--terracotta-dark); }
  .agg-cell.is-completed .agg-value { color: #2d6a3e; }
  .agg-cell.is-rejected .agg-value { color: #b34d28; }
  .agg-cell + .agg-cell { border-left: 1px dashed var(--border-light); padding-left: 0.5rem; }

  .size-section-title {
    font-family: var(--font-display); font-style: italic;
    color: var(--text-secondary); font-size: var(--text-sm);
    margin: 0 0 0.625rem;
    display: flex; align-items: baseline; justify-content: space-between;
  }
  .size-section-title .total-cut { font-family: var(--font-mono); color: var(--text-muted); font-size: var(--text-xs); font-style: normal; }

  .size-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 0.625rem;
  }
  .size-card {
    background: var(--cream); border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    padding: 0.75rem 0.875rem; transition: all 0.2s; position: relative; overflow: hidden;
  }
  .size-card.fully-done { background: rgba(45, 106, 62, 0.04); border-color: rgba(45, 106, 62, 0.15); }
  .size-card.fully-done::after {
    content: '✓'; position: absolute; top: 0.375rem; right: 0.5rem;
    color: #2d6a3e; font-size: var(--text-base); opacity: 0.55;
  }
  .size-card-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 0.375rem; }
  .size-card-label { font-family: var(--font-mono); font-size: var(--text-lg); font-weight: 700; color: var(--text-primary); letter-spacing: 0.02em; }
  .size-card-cut { font-family: var(--font-display); font-style: italic; color: var(--text-muted); font-size: var(--text-xs); }
  .size-fill { height: 6px; background: var(--cream-darker); border-radius: 999px; overflow: hidden; margin-bottom: 0.375rem; position: relative; }
  .size-fill-approved { position: absolute; top: 0; left: 0; bottom: 0; background: var(--terracotta-light); border-radius: 999px; transition: width 0.5s cubic-bezier(0.32, 0.72, 0, 1); }
  .size-fill-completed { position: absolute; top: 0; left: 0; bottom: 0; background: linear-gradient(90deg, #2d6a3e, #4f8b5e); border-radius: 999px; transition: width 0.5s cubic-bezier(0.32, 0.72, 0, 1); }
  .size-card-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.25rem; font-size: 0.625rem; color: var(--text-secondary); }
  .size-card-stat .v { font-family: var(--font-mono); font-weight: 600; color: var(--text-primary); display: block; font-size: var(--text-xs); }
  .size-card-stat .l { font-family: var(--font-display); font-style: italic; color: var(--text-muted); font-size: 0.5625rem; text-transform: uppercase; letter-spacing: 0.04em; }
  .size-card-stat.dim .v { color: var(--text-muted); }

  /* ═══════════════════════════════════════════════════════════
     ACTION CARDS — these are the centerpiece. Big, obvious,
     pre-filled. Workers read the headline → tap the green tick.
     ═══════════════════════════════════════════════════════════ */

  .actions-section { display: none; }
  .actions-section.show { display: block; animation: revealDown 0.4s; }

  .actions-heading {
    font-family: var(--font-display); font-style: italic;
    color: var(--text-secondary);
    font-size: var(--text-base);
    margin: 0 0 0.875rem;
    letter-spacing: 0.02em;
  }

  .action-card {
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    padding: 0;
    box-shadow: 0 1px 3px rgba(196,92,58,0.06), 0 0 0 1px var(--border-light);
    margin-bottom: 1rem;
    overflow: hidden;
  }
  .action-card-head {
    display: flex; align-items: center; gap: 1rem;
    padding: 1.25rem 1.25rem 1.125rem;
    background: linear-gradient(135deg, var(--terracotta) 0%, var(--terracotta-dark) 100%);
    color: white;
  }
  .action-card-head.is-complete { background: linear-gradient(135deg, #2d6a3e 0%, #1f4a2c 100%); }
  .action-card-icon {
    flex: 0 0 auto; width: 56px; height: 56px;
    background: rgba(255,255,255,0.18);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display); font-size: 1.875rem; line-height: 1;
  }
  .action-card-text { flex: 1; min-width: 0; }
  .action-card-title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 3vw, 1.5rem); line-height: 1.15;
    margin: 0 0 0.25rem; color: white; letter-spacing: -0.01em;
  }
  .action-card-title em { font-style: italic; opacity: 0.92; }
  .action-card-subtitle {
    font-family: var(--font-display); font-style: italic;
    font-size: var(--text-sm); opacity: 0.85; margin: 0;
  }
  .action-card-confirm {
    width: 100%;
    padding: 1.25rem;
    background: var(--cream);
    border: none; border-top: 1px dashed var(--border-medium);
    color: var(--text-primary);
    font-family: var(--font-body); font-weight: 600; font-size: var(--text-base);
    cursor: pointer; transition: all 0.15s;
    display: flex; align-items: center; justify-content: center; gap: 0.625rem;
  }
  .action-card-confirm:hover { background: var(--cream-dark); }
  .action-card-confirm:active { transform: translateY(1px); }
  .action-card-confirm:disabled { opacity: 0.5; cursor: not-allowed; }
  .action-card-confirm .check {
    display: inline-flex; width: 28px; height: 28px;
    background: #2d6a3e; color: white;
    border-radius: 50%;
    align-items: center; justify-content: center;
    font-size: var(--text-base);
  }
  .action-card-confirm.is-take .check { background: var(--terracotta); }

  .action-card-adjust {
    text-align: center;
    padding: 0.625rem;
    background: var(--cream); border-top: 1px dashed var(--border-light);
    cursor: pointer;
    color: var(--text-secondary);
    font-family: var(--font-display); font-style: italic;
    font-size: var(--text-sm);
    transition: color 0.15s;
  }
  .action-card-adjust:hover { color: var(--terracotta-dark); }
  .action-card-adjust .arrow { transition: transform 0.2s; display: inline-block; }
  .action-card.expanded .action-card-adjust .arrow { transform: rotate(180deg); }

  .action-card-form {
    display: none;
    padding: 1rem 1.25rem 1.25rem;
    background: var(--cream);
    border-top: 1px dashed var(--border-medium);
  }
  .action-card.expanded .action-card-form { display: block; }

  .form-helper {
    font-family: var(--font-display); font-style: italic;
    color: var(--text-muted); font-size: var(--text-sm);
    margin: 0 0 0.625rem;
  }

  .size-input-list { display: flex; flex-direction: column; gap: 0.5rem; }
  .size-input-row {
    display: grid; grid-template-columns: 3rem 1fr auto; gap: 0.5rem;
    align-items: center;
    padding: 0.5rem 0.625rem;
    background: var(--bg-card);
    border: 1px solid var(--border-light); border-radius: var(--radius-md);
  }
  .size-input-row.disabled { opacity: 0.4; }
  .size-input-label { font-family: var(--font-mono); font-weight: 700; font-size: var(--text-base); color: var(--text-primary); text-align: center; }
  .size-input-avail { font-family: var(--font-display); font-style: italic; color: var(--text-muted); font-size: var(--text-xs); }
  .size-input-avail .n { color: var(--text-secondary); font-style: normal; font-weight: 500; font-size: var(--text-sm); }
  .stepper { display: flex; align-items: center; gap: 0.25rem; }
  .stepper button {
    width: 2.25rem; height: 2.25rem;
    border: 1px solid var(--border-medium); background: var(--bg-card);
    border-radius: var(--radius-sm); cursor: pointer;
    font-size: var(--text-base); color: var(--text-primary); font-weight: 600;
  }
  .stepper button:hover { background: var(--cream-dark); border-color: var(--terracotta-light); }
  .stepper button:disabled { opacity: 0.35; cursor: not-allowed; }
  .stepper input {
    width: 4rem; height: 2.25rem; text-align: center;
    border: 1px solid var(--border-medium); border-radius: var(--radius-sm);
    background: var(--bg-card); font-family: var(--font-mono);
    font-size: var(--text-base); font-weight: 600; color: var(--text-primary);
  }
  .stepper input:focus { outline: none; border-color: var(--terracotta); box-shadow: 0 0 0 3px var(--terracotta-bg); }

  .form-row { margin-top: 0.75rem; }
  .form-row input[type="text"] {
    width: 100%; padding: 0.625rem 0.75rem;
    border: 1px solid var(--border-medium); border-radius: var(--radius-md);
    background: var(--bg-card); font-family: var(--font-body);
    font-size: var(--text-sm); color: var(--text-primary);
    box-sizing: border-box;
  }
  .form-row input[type="text"]:focus { outline: none; border-color: var(--terracotta); box-shadow: 0 0 0 3px var(--terracotta-bg); }

  .form-totals {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.75rem 0.875rem;
    background: var(--bg-card);
    border: 1px dashed var(--terracotta);
    border-radius: var(--radius-md);
    margin-top: 0.875rem;
  }
  .form-totals .l { font-family: var(--font-display); font-style: italic; color: var(--text-secondary); font-size: var(--text-sm); }
  .form-totals .v { font-family: var(--font-display); font-size: var(--text-2xl); color: var(--terracotta-dark); line-height: 1; }

  /* "Mark done" multi-pick (for when worker has more than one open approval) */
  .mark-done-list { display: flex; flex-direction: column; gap: 0.625rem; margin-bottom: 0.875rem; }
  .mark-done-item {
    border: 1.5px solid var(--border-light); background: var(--cream);
    border-radius: var(--radius-md);
    padding: 0.875rem 1rem; cursor: pointer; transition: all 0.15s;
  }
  .mark-done-item:hover { border-color: var(--terracotta-light); }
  .mark-done-item.selected { border-color: var(--terracotta); background: var(--terracotta-bg); }
  .mark-done-head { display: flex; justify-content: space-between; align-items: baseline; }
  .mark-done-num { font-family: var(--font-display); font-size: var(--text-2xl); color: var(--text-primary); line-height: 1; }
  .mark-done-num em { font-style: italic; color: var(--terracotta-dark); font-weight: 400; }
  .mark-done-when { font-family: var(--font-display); font-style: italic; color: var(--text-muted); font-size: var(--text-xs); }
  .mark-done-detail { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-secondary); margin-top: 0.25rem; word-spacing: 0.4em; }

  /* "+ Some pieces are spoiled" toggle for reject path */
  .reject-toggle {
    margin-top: 0.875rem;
    padding: 0.625rem 0.875rem;
    background: rgba(179, 77, 40, 0.06);
    border: 1px dashed rgba(179, 77, 40, 0.4);
    border-radius: var(--radius-md);
    color: #b34d28;
    font-family: var(--font-display); font-style: italic;
    font-size: var(--text-sm);
    cursor: pointer; text-align: center;
    transition: all 0.15s;
  }
  .reject-toggle:hover { background: rgba(179, 77, 40, 0.1); }
  .reject-section { display: none; padding-top: 0.875rem; }
  .reject-section.show { display: block; animation: revealDown 0.2s; }
  .reject-section .form-row { margin-top: 0; }
  .reject-row {
    display: grid; grid-template-columns: 3rem 1fr auto; gap: 0.5rem;
    align-items: center;
    padding: 0.5rem 0.625rem;
    background: var(--bg-card);
    border: 1px solid rgba(179, 77, 40, 0.18); border-radius: var(--radius-md);
  }
  .reject-row .stepper input:focus { border-color: #b34d28; box-shadow: 0 0 0 3px rgba(179,77,40,0.15); }

  .nothing-card {
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    padding: 2.25rem 1.5rem;
    text-align: center;
    box-shadow: 0 1px 3px rgba(196,92,58,0.06), 0 0 0 1px var(--border-light);
    margin-bottom: 1rem;
  }
  .nothing-card .mark { font-family: var(--font-display); font-size: 2.5rem; color: var(--terracotta-light); line-height: 1; }
  .nothing-card p { font-family: var(--font-display); font-style: italic; color: var(--text-secondary); font-size: var(--text-base); margin: 0.5rem 0 0; }

  /* ─── Bottom info section: My Work + My Payments tabs ───── */
  .info-section {
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    box-shadow: 0 1px 3px rgba(196,92,58,0.06), 0 0 0 1px var(--border-light);
    margin-top: 1.5rem;
    overflow: hidden;
  }
  .info-tabs {
    display: flex; background: var(--cream); border-bottom: 1px dashed var(--border-medium);
  }
  .info-tab {
    flex: 1; padding: 0.875rem 0.5rem;
    background: transparent; border: none; border-bottom: 3px solid transparent;
    cursor: pointer;
    font-family: var(--font-display); font-style: italic; font-size: var(--text-base);
    color: var(--text-secondary); transition: all 0.15s; margin-bottom: -1px;
  }
  .info-tab:hover { color: var(--text-primary); }
  .info-tab.active { color: var(--terracotta-dark); border-bottom-color: var(--terracotta); font-weight: 500; }
  .info-body { padding: 1.25rem; }

  .info-controls {
    display: flex; flex-wrap: wrap; gap: 0.5rem;
    margin-bottom: 1rem; align-items: center;
  }
  .info-controls select, .info-controls input[type="date"] {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border-medium); border-radius: var(--radius-sm);
    background: var(--cream); font-family: var(--font-body); font-size: var(--text-sm);
    color: var(--text-primary);
  }
  .info-controls .spacer { flex: 1; }
  .btn-secondary {
    padding: 0.5rem 0.875rem;
    border: 1px solid var(--terracotta); background: transparent;
    color: var(--terracotta-dark); border-radius: var(--radius-sm);
    font-family: var(--font-body); font-weight: 500; font-size: var(--text-sm); cursor: pointer;
    transition: all 0.15s;
  }
  .btn-secondary:hover { background: var(--terracotta); color: white; }

  /* timeline */
  .timeline { position: relative; padding-left: 1.25rem; }
  .timeline::before {
    content: ''; position: absolute; left: 4px; top: 6px; bottom: 6px; width: 1.5px;
    background: linear-gradient(to bottom, var(--terracotta-bg) 0%, var(--cream-darker) 100%);
  }
  .timeline-row { position: relative; padding: 0.5rem 0 0.5rem 0.875rem; cursor: pointer; border-bottom: 1px dashed var(--cream-darker); }
  .timeline-row::before { content: ''; position: absolute; left: -1.25rem; top: 0.875rem; width: 9px; height: 9px; border-radius: 50%; background: var(--terracotta); box-shadow: 0 0 0 3px var(--cream); }
  .timeline-row.is-complete::before { background: #2d6a3e; }
  .timeline-row.is-reject::before { background: #b34d28; }
  .timeline-row-head { display: flex; align-items: baseline; justify-content: space-between; gap: 0.5rem; }
  .timeline-row-lot { font-family: var(--font-mono); font-weight: 600; color: var(--text-primary); font-size: var(--text-sm); }
  .timeline-row-pieces { font-family: var(--font-display); font-size: var(--text-lg); color: var(--text-primary); }
  .timeline-row-meta { display: flex; gap: 0.625rem; align-items: baseline; font-size: var(--text-xs); color: var(--text-muted); font-family: var(--font-display); font-style: italic; margin-top: 0.125rem; }
  .event-type-pill { font-family: var(--font-display); font-style: italic; font-size: 0.6875rem; padding: 0.125rem 0.5rem; border-radius: var(--radius-full); letter-spacing: 0.04em; text-transform: lowercase; }
  .event-type-pill.approve { background: var(--terracotta-bg); color: var(--terracotta-dark); }
  .event-type-pill.complete { background: rgba(45,106,62,0.1); color: #2d6a3e; }
  .event-type-pill.reject { background: rgba(179,77,40,0.12); color: #b34d28; }
  .timeline-row-detail { display: none; margin-top: 0.5rem; padding: 0.5rem 0.75rem; background: var(--cream); border-radius: var(--radius-sm); font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-secondary); word-spacing: 0.5em; }
  .timeline-row.expanded .timeline-row-detail { display: block; animation: revealDown 0.2s; }

  /* payments */
  .pay-summary {
    display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .pay-summary-cell {
    background: var(--cream); border-radius: var(--radius-md);
    padding: 0.875rem 1rem; border: 1px dashed var(--border-light);
  }
  .pay-summary-cell.is-pending { border-color: rgba(196,92,58,0.3); background: var(--terracotta-bg); }
  .pay-summary-cell .l { font-family: var(--font-display); font-style: italic; font-size: var(--text-xs); color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; }
  .pay-summary-cell .v { font-family: var(--font-display); font-size: clamp(1.5rem, 4vw, 2rem); color: var(--text-primary); margin-top: 0.25rem; line-height: 1; }
  .pay-summary-cell .small { font-family: var(--font-mono); color: var(--text-secondary); font-size: var(--text-xs); margin-top: 0.25rem; }
  .pay-summary-cell.is-pending .v { color: var(--terracotta-dark); }

  .pay-list { display: flex; flex-direction: column; }
  .pay-row {
    display: grid; grid-template-columns: 1fr auto auto; gap: 0.5rem; align-items: baseline;
    padding: 0.625rem 0.5rem;
    border-bottom: 1px dashed var(--cream-darker);
  }
  .pay-row-main { min-width: 0; }
  .pay-row-lot { font-family: var(--font-mono); font-weight: 600; color: var(--text-primary); font-size: var(--text-sm); }
  .pay-row-meta { font-family: var(--font-display); font-style: italic; font-size: var(--text-xs); color: var(--text-muted); margin-top: 0.125rem; }
  .pay-row-amount { font-family: var(--font-display); font-size: var(--text-lg); color: var(--text-primary); }
  .pay-row-status { font-family: var(--font-display); font-style: italic; font-size: var(--text-xs); padding: 0.15rem 0.5rem; border-radius: var(--radius-full); }
  .pay-row-status.pending { background: var(--terracotta-bg); color: var(--terracotta-dark); }
  .pay-row-status.paid { background: rgba(45,106,62,0.1); color: #2d6a3e; }
  .pay-row-status.cancelled { background: rgba(0,0,0,0.05); color: var(--text-muted); }

  /* ─── Empty / placeholder ──────────────────────── */
  .placeholder { text-align: center; padding: 2.25rem 1rem; color: var(--text-muted); }
  .placeholder-mark { font-family: var(--font-display); font-style: italic; font-size: var(--text-2xl); color: var(--terracotta-light); margin-bottom: 0.5rem; }
  .placeholder p { font-family: var(--font-display); font-style: italic; font-size: var(--text-base); margin: 0; }
  .placeholder p small { display: block; margin-top: 0.25rem; opacity: 0.7; }

  /* ─── Toasts ────────────────────────────────── */
  .toast-area { position: fixed; bottom: 1.25rem; right: 1.25rem; display: flex; flex-direction: column; gap: 0.5rem; z-index: 100; max-width: 380px; }
  .toast { padding: 0.875rem 1.125rem; background: var(--bg-card); border-radius: var(--radius-md); box-shadow: 0 8px 24px rgba(26,26,26,0.16), 0 0 0 1px var(--border-light); border-left: 4px solid var(--terracotta); font-family: var(--font-body); font-size: var(--text-sm); color: var(--text-primary); animation: slideUp 0.3s cubic-bezier(0.32, 0.72, 0, 1); }
  .toast.success { border-left-color: #2d6a3e; }
  .toast.error { border-left-color: #b34d28; }

  @keyframes revealDown { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes slideUp { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

  @media (max-width: 640px) {
    .agg-strip { grid-template-columns: repeat(2, 1fr); gap: 0.75rem 0.25rem; }
    .agg-cell + .agg-cell { border-left: none; padding-left: 0; }
    .agg-cell:nth-child(odd) + .agg-cell { border-left: 1px dashed var(--border-light); padding-left: 0.5rem; }
    .lot-card { padding: 1.25rem; }
    .ledger-head { flex-direction: column; align-items: flex-start; gap: 0.25rem; }
    .pay-summary { grid-template-columns: 1fr; }
    .pay-row { grid-template-columns: 1fr auto; }
    .pay-row-status { grid-column: 1 / -1; justify-self: start; }
  }
</style>

<main class="ledger-page">
  <header class="ledger-head">
    <h1>Stitching</h1>
    <span class="subtitle">— operator ledger</span>
  </header>

  <!-- ─── Search ────────────────────────────── -->
