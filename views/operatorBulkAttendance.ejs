<%- include('partials/header', { pageTitle: 'Bulk Attendance' }) %>

<%- include('partials/navbar', { user: user, dashboardUrl: '/operator/dashboard' }) %>

<!-- Main Content -->
<main class="main-content" style="padding-top: 80px;">
  <div class="container py-4">
    <!-- Page Header -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4">
      <div class="mb-3 mb-md-0">
        <h1 class="page-title mb-1" style="font-family: 'DM Serif Display', serif; color: #1a1a1a; font-size: 1.75rem;">
          Bulk Attendance
        </h1>
        <p class="page-subtitle text-muted mb-0" style="font-family: 'Outfit', sans-serif;">
          <%= supervisor.username %> - Manage attendance for all employees
        </p>
      </div>
      <a href="/operator/supervisors/<%= supervisor.id %>/employees" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-2"></i>Back to Employees
      </a>
    </div>

    <!-- Flash Messages -->
    <%- include('partials/flashMessages') %>

    <!-- Date Filter Card -->
    <div class="card mb-4" style="border: 1px solid rgba(26, 26, 26, 0.1); border-radius: 12px; background: #ffffff;">
      <div class="card-body p-4">
        <form method="GET" class="row g-3 align-items-end">
          <div class="col-12 col-sm-6 col-md-4 col-lg-3">
            <label class="form-label fw-medium" style="font-family: 'Outfit', sans-serif; color: #1a1a1a;">
              <i class="bi bi-calendar3 me-2" style="color: #c45c3a;"></i>Select Date
            </label>
            <input type="date" name="date" class="form-control" value="<%= date %>" required
              style="border-radius: 8px; border: 1px solid rgba(26, 26, 26, 0.2); padding: 0.625rem 1rem;">
          </div>
          <div class="col-auto">
            <button type="submit" class="btn" style="background-color: #1a1a1a; color: #faf8f5; border-radius: 8px; padding: 0.625rem 1.5rem;">
              <i class="bi bi-search me-2"></i>Load Attendance
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Attendance Form Card -->
    <div class="card" style="border: 1px solid rgba(26, 26, 26, 0.1); border-radius: 12px; background: #ffffff;">
      <div class="card-header py-3 px-4" style="background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%); border-radius: 12px 12px 0 0;">
        <div class="d-flex justify-content-between align-items-center">
          <h5 class="mb-0" style="font-family: 'DM Serif Display', serif; color: #faf8f5;">
            <i class="bi bi-people-fill me-2"></i>Employee Attendance
          </h5>
          <span class="badge" style="background-color: #c45c3a; color: #fff;">
            <%= employees.length %> Employees
          </span>
        </div>
      </div>
      <div class="card-body p-0">
        <form method="POST" id="bulkAttendanceForm">
          <input type="hidden" name="date" value="<%= date %>">

          <!-- Desktop Table View -->
          <div class="table-responsive d-none d-md-block">
            <table class="table table-hover mb-0" style="font-family: 'Outfit', sans-serif;">
              <thead style="background-color: rgba(26, 26, 26, 0.03);">
                <tr>
                  <th class="py-3 px-4" style="font-weight: 600; color: #1a1a1a; border-bottom: 2px solid rgba(26, 26, 26, 0.1);">
                    Punch ID
                  </th>
                  <th class="py-3 px-4" style="font-weight: 600; color: #1a1a1a; border-bottom: 2px solid rgba(26, 26, 26, 0.1);">
                    Employee Name
                  </th>
                  <th class="py-3 px-4" style="font-weight: 600; color: #1a1a1a; border-bottom: 2px solid rgba(26, 26, 26, 0.1);">
                    <i class="bi bi-box-arrow-in-right me-1" style="color: #28a745;"></i>Punch In
                  </th>
                  <th class="py-3 px-4" style="font-weight: 600; color: #1a1a1a; border-bottom: 2px solid rgba(26, 26, 26, 0.1);">
                    <i class="bi bi-box-arrow-right me-1" style="color: #dc3545;"></i>Punch Out
                  </th>
                </tr>
              </thead>
              <tbody>
                <% employees.forEach(function(emp, idx){ %>
                <tr style="border-bottom: 1px solid rgba(26, 26, 26, 0.05);">
                  <td class="py-3 px-4">
                    <span class="badge" style="background-color: rgba(196, 92, 58, 0.1); color: #c45c3a; font-weight: 500; padding: 0.5rem 0.75rem;">
                      <%= emp.punching_id %>
                    </span>
                  </td>
                  <td class="py-3 px-4" style="color: #1a1a1a; font-weight: 500;">
                    <%= emp.name %>
                  </td>
                  <td class="py-3 px-4">
                    <input type="time" name="punch_in[]" class="form-control" value="<%= emp.punch_in || '' %>"
                      style="border-radius: 8px; border: 1px solid rgba(26, 26, 26, 0.2); max-width: 150px;">
                  </td>
                  <td class="py-3 px-4">
                    <input type="time" name="punch_out[]" class="form-control" value="<%= emp.punch_out || '' %>"
                      style="border-radius: 8px; border: 1px solid rgba(26, 26, 26, 0.2); max-width: 150px;">
                  </td>
                  <input type="hidden" name="employee_id[]" value="<%= emp.id %>">
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <!-- Mobile Card View -->
          <div class="d-md-none p-3">
            <% employees.forEach(function(emp, idx){ %>
            <div class="card mb-3" style="border: 1px solid rgba(26, 26, 26, 0.1); border-radius: 10px;">
              <div class="card-body p-3">
                <div class="d-flex justify-content-between align-items-center mb-3">
                  <h6 class="mb-0" style="font-weight: 600; color: #1a1a1a;"><%= emp.name %></h6>
                  <span class="badge" style="background-color: rgba(196, 92, 58, 0.1); color: #c45c3a;">
                    <%= emp.punching_id %>
                  </span>
                </div>
                <div class="row g-2">
                  <div class="col-6">
                    <label class="form-label small text-muted mb-1">
                      <i class="bi bi-box-arrow-in-right me-1" style="color: #28a745;"></i>Punch In
                    </label>
                    <input type="time" name="punch_in[]" class="form-control" value="<%= emp.punch_in || '' %>"
                      style="border-radius: 8px; border: 1px solid rgba(26, 26, 26, 0.2);">
                  </div>
                  <div class="col-6">
                    <label class="form-label small text-muted mb-1">
                      <i class="bi bi-box-arrow-right me-1" style="color: #dc3545;"></i>Punch Out
                    </label>
                    <input type="time" name="punch_out[]" class="form-control" value="<%= emp.punch_out || '' %>"
                      style="border-radius: 8px; border: 1px solid rgba(26, 26, 26, 0.2);">
                  </div>
                </div>
                <input type="hidden" name="employee_id[]" value="<%= emp.id %>">
              </div>
            </div>
            <% }) %>
          </div>

          <!-- Empty State -->
          <% if (employees.length === 0) { %>
          <div class="text-center py-5">
            <i class="bi bi-person-x" style="font-size: 3rem; color: rgba(26, 26, 26, 0.3);"></i>
            <p class="mt-3 text-muted" style="font-family: 'Outfit', sans-serif;">No employees found for this supervisor</p>
          </div>
          <% } %>

          <!-- Submit Button -->
          <% if (employees.length > 0) { %>
          <div class="card-footer bg-transparent p-4" style="border-top: 1px solid rgba(26, 26, 26, 0.1);">
            <div class="d-flex flex-column flex-sm-row gap-3 justify-content-between align-items-center">
              <div class="text-muted small" style="font-family: 'Outfit', sans-serif;">
                <i class="bi bi-info-circle me-1"></i>
                Updating attendance for <strong><%= date %></strong>
              </div>
              <button type="submit" class="btn px-4 py-2" style="background-color: #c45c3a; color: #fff; border-radius: 8px; font-weight: 500;">
                <i class="bi bi-check2-circle me-2"></i>Update Attendance
              </button>
            </div>
          </div>
          <% } %>
        </form>
      </div>
    </div>
  </div>
</main>

<style>
  /* Custom form styles */
  .form-control:focus {
    border-color: #c45c3a;
    box-shadow: 0 0 0 0.2rem rgba(196, 92, 58, 0.15);
  }

  /* Table row hover effect */
  .table-hover tbody tr:hover {
    background-color: rgba(196, 92, 58, 0.03);
  }

  /* Button hover effects */
  .btn:hover {
    transform: translateY(-1px);
    transition: all 0.2s ease;
  }

  /* Card shadow on hover */
  .card:hover {
    box-shadow: 0 4px 12px rgba(26, 26, 26, 0.08);
    transition: box-shadow 0.3s ease;
  }
</style>

<%- include('partials/footer') %>
