<%- include('partials/header', { pageTitle: 'Inventory Alerts' }) %>
<%- include('partials/navbar', { user: user }) %>

<meta name="vapid-public" content="<%= vapidPublicKey %>">

<main class="main-content" style="margin-left: 0;">
  <div class="container-fluid" style="max-width: 1400px; margin: 0 auto;">
    <!-- Page Header -->
    <div class="page-header d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
      <div>
        <h1 class="page-title">Inventory Alerts</h1>
        <p class="page-subtitle">Real-time inventory level notifications</p>
      </div>
      <div class="d-flex align-items-center gap-2">
        <span class="badge badge-success" id="connection-status">
          <i class="bi bi-circle-fill me-1" style="font-size: 8px;"></i>
          Connected
        </span>
      </div>
    </div>

    <!-- Stats Row -->
    <div class="row g-4 mb-4">
      <div class="col-12 col-md-4">
        <div class="stat-card">
          <div class="stat-label">Total Alerts</div>
          <div class="stat-value" id="total-alerts"><%= alerts.length %></div>
        </div>
      </div>
      <div class="col-12 col-md-4">
        <div class="stat-card">
          <div class="stat-label">Low Stock Items</div>
          <div class="stat-value text-warning" id="low-stock-count"><%= alerts.filter(a => a.quantity <= 5).length %></div>
        </div>
      </div>
      <div class="col-12 col-md-4">
        <div class="stat-card">
          <div class="stat-label">Out of Stock</div>
          <div class="stat-value text-danger" id="out-of-stock-count"><%= alerts.filter(a => a.quantity === 0).length %></div>
        </div>
      </div>
    </div>

    <!-- Alerts Table -->
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">
          <i class="bi bi-bell me-2"></i>
          Recent Alerts
        </h2>
        <span class="badge badge-neutral" id="alert-count"><%= alerts.length %> alerts</span>
      </div>
      <div class="card-body p-0">
        <% if (alerts.length === 0) { %>
          <div class="empty-state">
            <div class="empty-state-icon">
              <i class="bi bi-bell-slash" style="font-size: 48px;"></i>
            </div>
            <h3 class="empty-state-title">No Alerts Yet</h3>
            <p class="empty-state-text">Inventory alerts will appear here when stock levels change.</p>
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table mb-0">
              <thead>
                <tr>
                  <th style="width: 30%;">Time</th>
                  <th style="width: 40%;">SKU</th>
                  <th style="width: 30%;">Inventory</th>
                </tr>
              </thead>
              <tbody id="alert-body">
                <% alerts.forEach(function(a){ %>
                  <tr>
                    <td>
                      <span class="text-secondary">
                        <i class="bi bi-clock me-1"></i>
                        <%= a.created_at.toLocaleString('en-CA', { hour12: false }) %>
                      </span>
                    </td>
                    <td>
                      <span class="fw-medium"><%= a.sku %></span>
                    </td>
                    <td>
                      <% if (a.quantity === 0) { %>
                        <span class="badge badge-danger">
                          <i class="bi bi-exclamation-triangle me-1"></i>
                          Out of Stock
                        </span>
                      <% } else if (a.quantity <= 5) { %>
                        <span class="badge badge-warning">
                          <i class="bi bi-exclamation-circle me-1"></i>
                          <%= a.quantity %> left
                        </span>
                      <% } else { %>
                        <span class="badge badge-success">
                          <i class="bi bi-check-circle me-1"></i>
                          <%= a.quantity %>
                        </span>
                      <% } %>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</main>

<style>
  /* Page-specific styles */
  .main-content {
    padding-top: 28px;
    padding-bottom: 40px;
  }

  /* New alert animation */
  @keyframes newAlert {
    0% {
      background-color: var(--terracotta-bg);
      transform: translateX(-10px);
      opacity: 0;
    }
    50% {
      background-color: var(--terracotta-bg);
    }
    100% {
      background-color: transparent;
      transform: translateX(0);
      opacity: 1;
    }
  }

  .alert-row-new {
    animation: newAlert 0.6s ease-out;
  }

  /* Connection status pulse */
  #connection-status.badge-success {
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
  }

  #connection-status.badge-danger {
    animation: none;
  }

  /* Table row hover enhancement */
  .table tbody tr {
    transition: background-color var(--transition-fast);
  }

  /* SKU styling */
  .table td .fw-medium {
    color: var(--text-primary);
    font-family: var(--font-mono, monospace);
    font-size: var(--text-sm);
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .stat-card {
      text-align: center;
    }
  }
</style>

<script>
  const alertBody = document.getElementById('alert-body');
  const connectionStatus = document.getElementById('connection-status');
  const totalAlertsEl = document.getElementById('total-alerts');
  const alertCountEl = document.getElementById('alert-count');

  let totalAlerts = <%= alerts.length %>;

  const evt = new EventSource('/webhook/logs/stream');

  evt.onopen = function() {
    connectionStatus.className = 'badge badge-success';
    connectionStatus.textContent = '';
    const icon = document.createElement('i');
    icon.className = 'bi bi-circle-fill me-1';
    icon.style.fontSize = '8px';
    connectionStatus.appendChild(icon);
    connectionStatus.appendChild(document.createTextNode('Connected'));
  };

  evt.onerror = function() {
    connectionStatus.className = 'badge badge-danger';
    connectionStatus.textContent = '';
    const icon = document.createElement('i');
    icon.className = 'bi bi-circle-fill me-1';
    icon.style.fontSize = '8px';
    connectionStatus.appendChild(icon);
    connectionStatus.appendChild(document.createTextNode('Disconnected'));
  };

  evt.onmessage = (event) => {
    const data = JSON.parse(event.data);
    if (data.alert) {
      addRow(data.alert);
    }
  };

  function addRow(alert) {
    const row = document.createElement('tr');
    row.className = 'alert-row-new';
    const time = new Date().toLocaleString('en-CA', { hour12: false });

    // Create time cell
    const timeCell = document.createElement('td');
    const timeSpan = document.createElement('span');
    timeSpan.className = 'text-secondary';
    const clockIcon = document.createElement('i');
    clockIcon.className = 'bi bi-clock me-1';
    timeSpan.appendChild(clockIcon);
    timeSpan.appendChild(document.createTextNode(time));
    timeCell.appendChild(timeSpan);

    // Create SKU cell
    const skuCell = document.createElement('td');
    const skuSpan = document.createElement('span');
    skuSpan.className = 'fw-medium';
    skuSpan.textContent = alert.sku;
    skuCell.appendChild(skuSpan);

    // Create inventory cell
    const invCell = document.createElement('td');
    const badge = document.createElement('span');
    const badgeIcon = document.createElement('i');
    badgeIcon.className = 'me-1';

    if (alert.quantity === 0) {
      badge.className = 'badge badge-danger';
      badgeIcon.classList.add('bi', 'bi-exclamation-triangle');
      badge.appendChild(badgeIcon);
      badge.appendChild(document.createTextNode('Out of Stock'));
    } else if (alert.quantity <= 5) {
      badge.className = 'badge badge-warning';
      badgeIcon.classList.add('bi', 'bi-exclamation-circle');
      badge.appendChild(badgeIcon);
      badge.appendChild(document.createTextNode(alert.quantity + ' left'));
    } else {
      badge.className = 'badge badge-success';
      badgeIcon.classList.add('bi', 'bi-check-circle');
      badge.appendChild(badgeIcon);
      badge.appendChild(document.createTextNode(String(alert.quantity)));
    }
    invCell.appendChild(badge);

    // Append cells to row
    row.appendChild(timeCell);
    row.appendChild(skuCell);
    row.appendChild(invCell);

    // Prepend to table body
    alertBody.prepend(row);

    // Update counters
    totalAlerts++;
    totalAlertsEl.textContent = totalAlerts;
    alertCountEl.textContent = totalAlerts + ' alerts';

    if (alertBody.rows.length > 50) {
      alertBody.deleteRow(-1);
    }
  }
</script>

<script src="/public/js/notification.js"></script>

<%- include('partials/footer') %>
