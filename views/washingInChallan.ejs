<%- include('partials/header', { pageTitle: 'Washing In Challan - ' + entry.lot_no }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/washingin/dashboard' }) %>

<!-- Main Content -->
<main class="main-content" style="margin-left: 0;">
  <div class="container" style="max-width: 900px; margin: 0 auto;">

    <!-- Page Header with Print Button -->
    <div class="page-header no-print">
      <div class="breadcrumbs">
        <a href="/washingin/dashboard">Washing In Dashboard</a>
        <span class="separator">/</span>
        <span>Challan #<%= entry.id %></span>
      </div>
      <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <h1 class="page-title">Washing In Challan</h1>
        <div class="d-flex gap-2">
          <button onclick="window.print()" class="btn btn-primary">
            <i class="bi bi-printer"></i>
            Print
          </button>
          <a href="/washingin/dashboard" class="btn btn-outline">
            <i class="bi bi-arrow-left"></i>
            Back to Dashboard
          </a>
        </div>
      </div>
    </div>

    <!-- Printable Challan Header -->
    <div class="print-header d-none">
      <h1 style="text-align: center; font-family: var(--font-display); font-size: 24px; margin-bottom: 4px;">KOTTY LIFESTYLE</h1>
      <h2 style="text-align: center; font-size: 16px; font-weight: 500; color: var(--text-secondary);">Washing In Challan</h2>
    </div>

    <!-- Challan Meta Details Card -->
    <div class="card mb-4">
      <div class="card-header">
        <h3 class="card-title">Challan Details</h3>
        <span class="badge badge-primary">
          <i class="bi bi-file-earmark-text me-1"></i>
          #<%= entry.id %>
        </span>
      </div>
      <div class="card-body">
        <div class="row g-4">
          <div class="col-md-3 col-6">
            <div class="detail-item">
              <span class="detail-label">Challan ID</span>
              <span class="detail-value">#<%= entry.id %></span>
            </div>
          </div>
          <div class="col-md-3 col-6">
            <div class="detail-item">
              <span class="detail-label">Date</span>
              <span class="detail-value">
                <%
                  const d = new Date(entry.created_at);
                  const pad = n => (n<10?'0':'')+n;
                %>
                <%= pad(d.getDate()) %>-<%= pad(d.getMonth()+1) %>-<%= d.getFullYear() %>
              </span>
            </div>
          </div>
          <div class="col-md-3 col-6">
            <div class="detail-item">
              <span class="detail-label">Lot No</span>
              <span class="detail-value"><%= entry.lot_no %></span>
            </div>
          </div>
          <div class="col-md-3 col-6">
            <div class="detail-item">
              <span class="detail-label">SKU</span>
              <span class="detail-value"><%= entry.sku %></span>
            </div>
          </div>
          <div class="col-md-3 col-6">
            <div class="detail-item">
              <span class="detail-label">Total Pieces</span>
              <span class="detail-value highlight"><%= entry.total_pieces %></span>
            </div>
          </div>
          <div class="col-md-3 col-6">
            <div class="detail-item">
              <span class="detail-label">Created By</span>
              <span class="detail-value"><%= user.username %></span>
            </div>
          </div>
          <% if (entry.remark) { %>
            <div class="col-md-6">
              <div class="detail-item">
                <span class="detail-label">Remark</span>
                <span class="detail-value"><%= entry.remark %></span>
              </div>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Attached Image (if any) -->
    <% if (entry.image_url) { %>
      <div class="card mb-4">
        <div class="card-header">
          <h3 class="card-title">Attached Image</h3>
        </div>
        <div class="card-body text-center">
          <img src="<%= entry.image_url %>" alt="Attached Image" class="challan-image">
        </div>
      </div>
    <% } %>

    <!-- Size Breakdown Table -->
    <div class="card mb-4">
      <div class="card-header">
        <h3 class="card-title">Size Breakdown</h3>
        <span class="badge badge-neutral"><%= sizes.length %> size<%= sizes.length !== 1 ? 's' : '' %></span>
      </div>
      <div class="table-container" style="border: none; border-radius: 0;">
        <table class="table">
          <thead>
            <tr>
              <th class="text-center" style="width: 80px;">Sl No.</th>
              <th>Size Label</th>
              <th class="text-end">Pieces</th>
            </tr>
          </thead>
          <tbody>
            <% let grandTot = 0; %>
            <% sizes.forEach((sz, i) => { grandTot += sz.pieces; %>
              <tr>
                <td class="text-center"><%= i + 1 %></td>
                <td><span class="fw-medium"><%= sz.size_label %></span></td>
                <td class="text-end"><%= sz.pieces %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <div class="card-footer">
        <div class="d-flex justify-content-end align-items-center gap-4">
          <span class="text-secondary" style="font-size: var(--text-sm);">Total Pieces</span>
          <span class="total-amount"><%= grandTot %></span>
        </div>
      </div>
    </div>

    <!-- Update Log (if any) -->
    <% if (updates.length) { %>
      <div class="card mb-4">
        <div class="card-header">
          <h3 class="card-title">Updates (Log)</h3>
          <span class="badge badge-neutral"><%= updates.length %> update<%= updates.length !== 1 ? 's' : '' %></span>
        </div>
        <div class="table-container" style="border: none; border-radius: 0;">
          <table class="table">
            <thead>
              <tr>
                <th class="text-center" style="width: 80px;">Sl No.</th>
                <th>Date & Time</th>
                <th>Size</th>
                <th class="text-end">Pieces Added</th>
              </tr>
            </thead>
            <tbody>
              <% updates.forEach((u, i) => { %>
                <tr>
                  <td class="text-center"><%= i + 1 %></td>
                  <td>
                    <% const up = new Date(u.updated_at); %>
                    <%= pad(up.getDate()) %>-<%= pad(up.getMonth()+1) %>-<%= up.getFullYear() %>
                    <%= pad(up.getHours()) %>:<%= pad(up.getMinutes()) %>
                  </td>
                  <td><span class="fw-medium"><%= u.size_label %></span></td>
                  <td class="text-end"><%= u.pieces %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>

    <!-- Signatures Section -->
    <div class="card signature-card">
      <div class="card-body">
        <div class="signatures">
          <div class="sig-box">
            <div class="sig-line"></div>
            <span>Issued By</span>
          </div>
          <div class="sig-box">
            <div class="sig-line"></div>
            <span>Checked By</span>
          </div>
          <div class="sig-box">
            <div class="sig-line"></div>
            <span>Received By</span>
          </div>
        </div>
      </div>
    </div>

  </div>
</main>

<style>
  /* Detail Item Styling */
  .detail-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .detail-label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
  }

  .detail-value {
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--text-primary);
  }

  .detail-value.highlight {
    color: var(--terracotta);
    font-family: var(--font-display);
    font-size: var(--text-lg);
  }

  /* Total Amount */
  .total-amount {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    color: var(--terracotta);
    font-weight: 400;
  }

  /* Table Enhancements */
  .fw-medium {
    font-weight: 500;
  }

  /* Challan Image */
  .challan-image {
    max-width: 100%;
    max-height: 300px;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-light);
  }

  /* Signatures Section */
  .signatures {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    margin-top: 20px;
  }

  .sig-box {
    flex: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .sig-line {
    width: 100%;
    height: 60px;
    border-bottom: 1px solid var(--charcoal);
  }

  .sig-box span {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-secondary);
  }

  .signature-card {
    margin-bottom: 40px;
  }

  /* Print Styles */
  @media print {
    @page {
      size: A4;
      margin: 10mm;
    }

    html, body {
      height: 100%;
      overflow: hidden;
    }

    .kotty-navbar,
    .breadcrumbs,
    .btn,
    .no-print {
      display: none !important;
    }

    .print-header {
      display: block !important;
      margin-bottom: 20px;
    }

    .main-content {
      margin-top: 0 !important;
      padding: 0 !important;
    }

    .card {
      box-shadow: none !important;
      border: 1px solid #ddd !important;
      break-inside: avoid;
    }

    .page-title {
      margin-bottom: 20px;
    }

    .badge {
      border: 1px solid #ccc !important;
      background: #f5f5f5 !important;
      color: #333 !important;
    }

    .signatures {
      margin-top: 40px;
    }

    .sig-line {
      height: 50px;
    }
  }

  /* Responsive adjustments */
  @media (max-width: 576px) {
    .signatures {
      flex-direction: column;
      gap: 32px;
    }

    .sig-box {
      width: 100%;
    }

    .sig-line {
      max-width: 200px;
    }
  }
</style>

<%- include('partials/footer') %>
