<%- include('partials/header', { pageTitle: 'Operation Payments' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/stitchingdashboard' }) %>

<main class="main-content">
  <div class="container-fluid" style="max-width: var(--content-max-width);">
    <!-- Page Header -->
    <div class="page-header">
      <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
          <div class="breadcrumbs">
            <a href="/stitchingdashboard">Stitching</a>
            <span class="separator">/</span>
            <span>Operation Payments</span>
          </div>
          <h1 class="page-title">Operation Payments</h1>
          <p class="page-subtitle">Record individual operation payments for stitching workers</p>
        </div>
        <div class="d-flex gap-2">
          <a href="/stitchingdashboard" class="btn btn-outline">
            <i class="bi bi-arrow-left"></i>
            Back
          </a>
        </div>
      </div>
    </div>

    <!-- Main Card -->
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">
          <i class="bi bi-receipt me-2" style="color: var(--terracotta);"></i>
          Payment Entry
        </h2>
      </div>
      <div class="card-body">
        <form method="POST" action="/stitchingdashboard/payments/operation/pay" id="opForm">
          <!-- Lot Selection -->
          <div class="mb-4">
            <label for="lotSelect" class="form-label">Select Lot</label>
            <select class="form-select" id="lotSelect" name="lot_no">
              <% lots.forEach(function(l){ %>
                <option value="<%= l.lot_no %>"><%= l.lot_no %> - <%= l.sku %></option>
              <% }) %>
            </select>
          </div>

          <!-- Operations Table -->
          <div class="table-container">
            <table class="table" id="opTable">
              <thead>
                <tr>
                  <th>Operation</th>
                  <th>Worker Name</th>
                  <th style="width: 120px;">Quantity</th>
                  <th style="width: 60px;"></th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>
                    <select class="form-select op" name="op">
                      <% operations.forEach(function(o){ %>
                        <option value="<%= o %>"><%= o %></option>
                      <% }) %>
                    </select>
                  </td>
                  <td>
                    <input type="text" class="form-control name" placeholder="Enter worker name" />
                  </td>
                  <td>
                    <input type="number" class="form-control qty" placeholder="Qty" min="0" />
                  </td>
                  <td class="text-center">
                    <button type="button" class="btn btn-sm btn-outline remove-row" style="padding: 4px 8px;" disabled>
                      <i class="bi bi-trash"></i>
                    </button>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>

          <!-- Action Buttons -->
          <div class="d-flex align-items-center justify-content-between mt-4 pt-3" style="border-top: 1px solid var(--border-light);">
            <button type="button" class="btn btn-secondary" id="addRow">
              <i class="bi bi-plus-lg"></i>
              Add Row
            </button>
            <button type="submit" class="btn btn-primary btn-lg">
              <i class="bi bi-cash-stack"></i>
              Process Payment
            </button>
          </div>

          <input type="hidden" name="payments" id="payments">
        </form>
      </div>
    </div>

    <!-- Help Card -->
    <div class="card mt-4">
      <div class="card-body">
        <div class="d-flex align-items-start gap-3">
          <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; background: var(--info-light); flex-shrink: 0;">
            <i class="bi bi-info-circle" style="color: var(--info);"></i>
          </div>
          <div>
            <h6 style="font-family: var(--font-display); margin-bottom: 8px;">How to use</h6>
            <ul class="mb-0" style="color: var(--text-secondary); font-size: var(--text-sm); padding-left: 1.25rem;">
              <li>Select the lot for which you want to record payments</li>
              <li>Enter the operation type, worker name, and quantity for each entry</li>
              <li>Click "Add Row" to add multiple operation entries</li>
              <li>Click "Process Payment" when ready to submit</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<script>
// Add Row functionality
document.getElementById('addRow').addEventListener('click', function(){
  const tbody = document.querySelector('#opTable tbody');
  const row = tbody.querySelector('tr').cloneNode(true);
  row.querySelectorAll('input').forEach(i => i.value = '');
  row.querySelector('.remove-row').disabled = false;
  tbody.appendChild(row);
  updateRemoveButtons();
});

// Remove Row functionality (delegated)
document.querySelector('#opTable tbody').addEventListener('click', function(e){
  const removeBtn = e.target.closest('.remove-row');
  if (removeBtn && !removeBtn.disabled) {
    removeBtn.closest('tr').remove();
    updateRemoveButtons();
  }
});

// Update remove button states
function updateRemoveButtons() {
  const rows = document.querySelectorAll('#opTable tbody tr');
  rows.forEach((row, index) => {
    const btn = row.querySelector('.remove-row');
    btn.disabled = rows.length === 1;
  });
}

// Form submission - collect data into hidden field
document.getElementById('opForm').addEventListener('submit', function(e){
  const rows = document.querySelectorAll('#opTable tbody tr');
  const data = [];
  rows.forEach(r => {
    const name = r.querySelector('.name').value.trim();
    const qty = r.querySelector('.qty').value;
    if (name && qty) {
      data.push({
        operation: r.querySelector('.op').value,
        name: name,
        qty: qty
      });
    }
  });

  if (data.length === 0) {
    e.preventDefault();
    if (window.KottyTrack) {
      KottyTrack.showToast('Please add at least one valid operation entry', 'warning');
    } else {
      alert('Please add at least one valid operation entry');
    }
    return;
  }

  document.getElementById('payments').value = JSON.stringify(data);
});
</script>

<%- include('partials/footer') %>
