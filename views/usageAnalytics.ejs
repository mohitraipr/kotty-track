<%- include('partials/header', { pageTitle: 'Usage Analytics' }) %>
<%- include('partials/navbar', { dashboardUrl: '/operator/dashboard' }) %>

<!-- Chart.js for analytics -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

<style>
  /* Analytics Dashboard Layout */
  .analytics-content {
    padding-top: calc(var(--navbar-height) + 28px);
    padding-bottom: 40px;
    min-height: 100vh;
  }

  /* Page Header */
  .analytics-header {
    margin-bottom: 28px;
  }

  .analytics-header h1 {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    color: var(--text-primary);
    margin-bottom: 8px;
  }

  .analytics-header p {
    color: var(--text-secondary);
    font-size: var(--text-base);
    margin: 0;
  }

  /* Action Buttons */
  .header-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* Filter Card */
  .filter-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 20px;
    margin-bottom: 24px;
  }

  .filter-card .form-label {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 6px;
  }

  .filter-card .form-control {
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    padding: 10px 14px;
    font-size: var(--text-sm);
    transition: all var(--transition-fast);
  }

  .filter-card .form-control:focus {
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px var(--terracotta-bg);
  }

  .filter-hint {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  /* Analytics Cards */
  .analytics-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 24px;
    margin-bottom: 24px;
    transition: all var(--transition-fast);
  }

  .analytics-card:hover {
    border-color: var(--border-medium);
    box-shadow: var(--shadow-sm);
  }

  .analytics-card-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border-light);
  }

  .analytics-card-header i {
    font-size: 20px;
    color: var(--terracotta);
  }

  .analytics-card-header h4 {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--text-primary);
    margin: 0;
  }

  /* Feature Usage Bars */
  .feature-bar {
    display: flex;
    align-items: center;
    margin-bottom: 14px;
  }

  .feature-name {
    width: 130px;
    font-weight: 500;
    font-size: var(--text-sm);
    color: var(--text-primary);
    flex-shrink: 0;
  }

  .feature-bar-outer {
    flex: 1;
    height: 28px;
    background: var(--cream-dark);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .feature-bar-inner {
    height: 100%;
    background: linear-gradient(90deg, var(--terracotta), var(--terracotta-light));
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: 10px;
    min-width: 40px;
    transition: width 0.5s var(--ease-out);
  }

  .feature-bar-inner span {
    color: white;
    font-size: var(--text-xs);
    font-weight: 600;
  }

  /* Chart Container */
  .chart-container {
    height: 280px;
    position: relative;
  }

  /* Top Routes List */
  .top-route {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 14px;
    background: var(--cream);
    border-radius: var(--radius-md);
    margin-bottom: 10px;
    transition: all var(--transition-fast);
  }

  .top-route:hover {
    background: var(--cream-dark);
  }

  .top-route .path {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-secondary);
  }

  .top-route .hits {
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--text-primary);
  }

  .top-route .badge {
    background: var(--terracotta-bg);
    color: var(--terracotta);
    font-size: var(--text-xs);
    padding: 3px 8px;
    border-radius: var(--radius-full);
    font-weight: 500;
  }

  /* Summary Stats */
  .summary-stats {
    display: flex;
    justify-content: space-around;
    text-align: center;
    padding: 20px 0;
  }

  .summary-stat .value {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    color: var(--text-primary);
    line-height: 1.2;
  }

  .summary-stat .label {
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 4px;
  }

  /* User Stats List */
  .user-stats-list {
    margin-top: 20px;
  }

  .user-stat-item {
    display: flex;
    justify-content: space-between;
    padding: 10px 0;
    border-bottom: 1px solid var(--border-light);
    font-size: var(--text-sm);
  }

  .user-stat-item:last-child {
    border-bottom: none;
  }

  .user-stat-item .feature {
    color: var(--text-primary);
    font-weight: 500;
  }

  .user-stat-item .count {
    color: var(--text-secondary);
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: 60px 24px;
  }

  .empty-state i {
    font-size: 56px;
    color: var(--text-muted);
    margin-bottom: 20px;
    display: block;
  }

  .empty-state h5 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--text-primary);
    margin-bottom: 8px;
  }

  .empty-state p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    max-width: 320px;
    margin: 0 auto;
  }

  /* Footer Timestamp */
  .page-footer {
    text-align: center;
    padding: 24px 0;
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .page-footer .btn-link {
    color: var(--terracotta);
    text-decoration: none;
    font-size: var(--text-xs);
    padding: 0;
  }

  .page-footer .btn-link:hover {
    text-decoration: underline;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .analytics-content {
      padding-left: 16px;
      padding-right: 16px;
    }

    .analytics-header h1 {
      font-size: var(--text-2xl);
    }

    .feature-name {
      width: 100px;
      font-size: var(--text-xs);
    }

    .summary-stats {
      flex-wrap: wrap;
      gap: 20px;
    }

    .summary-stat {
      flex: 1 1 30%;
    }

    .summary-stat .value {
      font-size: var(--text-2xl);
    }
  }
</style>

<div class="analytics-content">
  <div class="container" style="max-width: 1200px;">

    <% if (error && error.length) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <!-- Page Header -->
    <div class="analytics-header d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
      <div>
        <h1>Usage Analytics</h1>
        <p>Track feature usage and user engagement across the platform</p>
      </div>
      <div class="header-actions">
        <a href="/operator/system-health" class="btn btn-secondary btn-sm">
          <i class="bi bi-heart-pulse me-1"></i>System Health
        </a>
        <a href="/operator/dashboard" class="btn btn-secondary btn-sm">
          <i class="bi bi-arrow-left me-1"></i>Dashboard
        </a>
      </div>
    </div>

    <!-- Date Filter -->
    <div class="filter-card">
      <form method="GET" class="row g-3 align-items-end">
        <div class="col-md-3">
          <label class="form-label">Start Date</label>
          <input type="date" name="startDate" class="form-control" value="<%= startDate %>">
        </div>
        <div class="col-md-3">
          <label class="form-label">End Date</label>
          <input type="date" name="endDate" class="form-control" value="<%= endDate %>">
        </div>
        <div class="col-md-4">
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-funnel me-1"></i>Apply Filter
          </button>
          <a href="/operator/usage-analytics" class="btn btn-secondary">Reset</a>
        </div>
        <div class="col-md-2 text-end">
          <span class="filter-hint">Default: Last 7 days</span>
        </div>
      </form>
    </div>

    <% if (!stats.byFeature || stats.byFeature.length === 0) { %>
    <div class="analytics-card">
      <div class="empty-state">
        <i class="bi bi-bar-chart"></i>
        <h5>No Usage Data Yet</h5>
        <p>Usage tracking has just started. Data will appear as users access features across the platform.</p>
      </div>
    </div>
    <% } else { %>

    <div class="row">
      <!-- Feature Usage -->
      <div class="col-lg-6">
        <div class="analytics-card">
          <div class="analytics-card-header">
            <i class="bi bi-bar-chart-fill"></i>
            <h4>Usage by Feature</h4>
          </div>
          <%
            const maxHits = Math.max(...stats.byFeature.map(f => f.total_hits));
            stats.byFeature.forEach(feature => {
              const pct = (feature.total_hits / maxHits * 100).toFixed(0);
          %>
          <div class="feature-bar">
            <div class="feature-name"><%= feature.feature_name %></div>
            <div class="feature-bar-outer">
              <div class="feature-bar-inner" style="width: <%= pct %>%">
                <span><%= feature.total_hits %></span>
              </div>
            </div>
          </div>
          <% }); %>
        </div>
      </div>

      <!-- Daily Trend -->
      <div class="col-lg-6">
        <div class="analytics-card">
          <div class="analytics-card-header">
            <i class="bi bi-graph-up"></i>
            <h4>Daily Trend</h4>
          </div>
          <div class="chart-container">
            <canvas id="dailyChart"></canvas>
          </div>
        </div>
      </div>
    </div>

    <div class="row">
      <!-- Top Routes -->
      <div class="col-lg-6">
        <div class="analytics-card">
          <div class="analytics-card-header">
            <i class="bi bi-signpost-split-fill"></i>
            <h4>Top Routes</h4>
          </div>
          <% stats.topRoutes.slice(0, 10).forEach(route => { %>
          <div class="top-route">
            <div>
              <span class="path"><%= route.route_path %></span>
              <span class="badge ms-2"><%= route.feature_name %></span>
            </div>
            <span class="hits"><%= route.total_hits %> hits</span>
          </div>
          <% }); %>
        </div>
      </div>

      <!-- Summary Stats -->
      <div class="col-lg-6">
        <div class="analytics-card">
          <div class="analytics-card-header">
            <i class="bi bi-calculator-fill"></i>
            <h4>Summary</h4>
          </div>

          <div class="summary-stats">
            <div class="summary-stat">
              <div class="value">
                <%= stats.byFeature.reduce((sum, f) => sum + parseInt(f.total_hits), 0).toLocaleString() %>
              </div>
              <div class="label">Total Hits</div>
            </div>
            <div class="summary-stat">
              <div class="value">
                <%= stats.byFeature.length %>
              </div>
              <div class="label">Active Features</div>
            </div>
            <div class="summary-stat">
              <div class="value">
                <%= stats.byDay.length %>
              </div>
              <div class="label">Days Tracked</div>
            </div>
          </div>

          <hr style="border-color: var(--border-light); margin: 20px 0;">

          <h5 style="font-family: var(--font-display); font-size: var(--text-base); margin-bottom: 12px;">Unique Users by Feature</h5>
          <div class="user-stats-list">
            <% stats.byFeature.forEach(feature => { %>
            <div class="user-stat-item">
              <span class="feature"><%= feature.feature_name %></span>
              <span class="count"><%= feature.unique_users %> users</span>
            </div>
            <% }); %>
          </div>
        </div>
      </div>
    </div>
    <% } %>

    <!-- Page Footer -->
    <div class="page-footer">
      Page loaded: <%= new Date().toLocaleString('en-IN', { timeZone: 'Asia/Kolkata' }) %> IST
      <br>
      <button onclick="location.reload()" class="btn btn-link">
        <i class="bi bi-arrow-clockwise"></i> Refresh
      </button>
    </div>
  </div>
</div>

<% if (stats.byDay && stats.byDay.length > 0) { %>
<script>
  const ctx = document.getElementById('dailyChart').getContext('2d');
  new Chart(ctx, {
    type: 'line',
    data: {
      labels: <%- JSON.stringify(stats.byDay.map(d => new Date(d.date).toLocaleDateString('en-IN', { day: '2-digit', month: 'short' }))) %>,
      datasets: [{
        label: 'Page Views',
        data: <%- JSON.stringify(stats.byDay.map(d => d.total_hits)) %>,
        borderColor: '#c45c3a',
        backgroundColor: 'rgba(196, 92, 58, 0.1)',
        fill: true,
        tension: 0.3,
        borderWidth: 2
      }, {
        label: 'Unique Users',
        data: <%- JSON.stringify(stats.byDay.map(d => d.unique_users)) %>,
        borderColor: '#2d8a5f',
        backgroundColor: 'rgba(45, 138, 95, 0.1)',
        fill: true,
        tension: 0.3,
        borderWidth: 2
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          position: 'bottom',
          labels: {
            font: {
              family: "'Outfit', sans-serif",
              size: 12
            },
            color: '#5a5650',
            padding: 20,
            usePointStyle: true
          }
        }
      },
      scales: {
        x: {
          grid: {
            color: 'rgba(0, 0, 0, 0.05)'
          },
          ticks: {
            font: {
              family: "'Outfit', sans-serif",
              size: 11
            },
            color: '#78746a'
          }
        },
        y: {
          beginAtZero: true,
          grid: {
            color: 'rgba(0, 0, 0, 0.05)'
          },
          ticks: {
            font: {
              family: "'Outfit', sans-serif",
              size: 11
            },
            color: '#78746a'
          }
        }
      }
    }
  });
</script>
<% } %>

<%- include('partials/footer') %>
