<%- include('partials/header', { pageTitle: 'Washing Pendency Report' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/operator/dashboard' }) %>

<main class="main-content" style="margin-left: 0;">
  <div class="container" style="max-width: 1400px; margin: 0 auto;">
    <!-- Page Header -->
    <div class="page-header">
      <div class="breadcrumbs">
        <a href="/operator/dashboard">Dashboard</a>
        <span class="separator">/</span>
        <span>Washing Pendency Report</span>
      </div>
      <h1 class="page-title">Washing Pendency Report</h1>
      <p class="page-subtitle">Overview of pending and completed washing for all operators</p>
    </div>

    <!-- Summary Table Card -->
    <div class="card mb-4">
      <div class="card-header">
        <h2 class="card-title">
          <i class="bi bi-bar-chart-line me-2 text-terracotta"></i>
          All Washing Operators Summary
        </h2>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table mb-0">
            <thead>
              <tr>
                <th>User</th>
                <th>Total Assignments</th>
                <th>Completed</th>
                <th>Pending</th>
                <th>Completion Rate</th>
              </tr>
            </thead>
            <tbody>
              <% usersSummary.forEach(function(user) {
                   const rate = user.total_assignments > 0
                                ? ((user.completed_assignments / user.total_assignments) * 100).toFixed(0)
                                : 0;
              %>
              <tr>
                <td>
                  <div class="d-flex align-items-center gap-2">
                    <div class="user-avatar" style="width: 32px; height: 32px; font-size: 0.75rem;">
                      <%= user.username ? user.username.charAt(0).toUpperCase() : 'U' %>
                    </div>
                    <span class="fw-medium"><%= user.username %></span>
                  </div>
                </td>
                <td>
                  <span class="badge badge-neutral"><%= user.total_assignments %></span>
                </td>
                <td>
                  <span class="badge badge-success"><%= user.completed_assignments %></span>
                </td>
                <td>
                  <span class="badge badge-warning"><%= user.pending_assignments %></span>
                </td>
                <td style="min-width: 150px;">
                  <div class="d-flex align-items-center gap-2">
                    <div class="progress flex-grow-1" style="height: 8px;">
                      <div class="progress-bar <%= parseInt(rate) >= 70 ? 'success' : '' %>" role="progressbar" style="width: <%= rate %>%;"></div>
                    </div>
                    <span class="text-secondary" style="min-width: 40px; font-size: 0.875rem;"><%= rate %>%</span>
                  </div>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Detailed View Card -->
    <div class="card">
      <div class="card-header flex-wrap gap-3">
        <h2 class="card-title">
          <i class="bi bi-person-lines-fill me-2 text-terracotta"></i>
          Detailed Washing Report
        </h2>
        <!-- User Selection Form -->
        <form method="GET" action="/operator/pendency-report/washing" class="d-flex align-items-center gap-2 flex-wrap">
          <select name="user_id" class="form-select" style="min-width: 200px; max-width: 250px;">
            <option value="">-- Select User --</option>
            <% usersSummary.forEach(function(user) { %>
              <option value="<%= user.user_id %>" <%= (query.user_id == user.user_id ? 'selected' : '') %>><%= user.username %></option>
            <% }); %>
          </select>
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-search"></i>
            <span class="d-none d-sm-inline">View</span>
          </button>
        </form>
      </div>
      <div class="card-body">
        <% if (selectedUserId) { %>
          <!-- User Summary Stats -->
          <div class="row g-3 mb-4">
            <div class="col-12 col-sm-6">
              <div class="stat-card">
                <div class="stat-label">Total Assigned Pieces</div>
                <div class="stat-value"><%= detailedSummary.totalAssigned %></div>
              </div>
            </div>
            <div class="col-12 col-sm-6">
              <div class="stat-card" style="border-left: 3px solid var(--warning);">
                <div class="stat-label">Total Pending Pieces</div>
                <div class="stat-value text-warning"><%= detailedSummary.totalPending %></div>
              </div>
            </div>
          </div>

          <!-- Download Button -->
          <div class="mb-4">
            <a href="/operator/pendency-report/washing/download?user_id=<%= selectedUserId %>" class="btn btn-success">
              <i class="bi bi-file-earmark-excel"></i>
              Download Excel
            </a>
          </div>

          <% if (detailedAssignments.length > 0) { %>
            <div class="table-container">
              <div class="table-responsive">
                <table class="table mb-0">
                  <thead>
                    <tr>
                      <th>Lot No</th>
                      <th>Total Pieces</th>
                      <th>Washed</th>
                      <th>Pending</th>
                      <th>Assigned On</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% detailedAssignments.forEach(function(asg) { %>
                      <tr>
                        <td>
                          <span class="fw-medium text-terracotta"><%= asg.lot_no %></span>
                        </td>
                        <td><%= asg.total_pieces %></td>
                        <td>
                          <span class="badge badge-success"><%= asg.washed %></span>
                        </td>
                        <td>
                          <span class="badge badge-warning"><%= asg.pending %></span>
                        </td>
                        <td class="text-secondary">
                          <%= new Date(asg.assigned_on).toLocaleString('en-IN', {
                            year: 'numeric',
                            month: 'short',
                            day: 'numeric',
                            hour: '2-digit',
                            minute: '2-digit'
                          }) %>
                        </td>
                      </tr>
                    <% }); %>
                  </tbody>
                </table>
              </div>
            </div>
          <% } else { %>
            <div class="empty-state">
              <div class="empty-state-icon">
                <i class="bi bi-inbox" style="font-size: 64px;"></i>
              </div>
              <h3 class="empty-state-title">No Assignments Found</h3>
              <p class="empty-state-text">No detailed washing assignments found for the selected user.</p>
            </div>
          <% } %>
        <% } else { %>
          <div class="empty-state">
            <div class="empty-state-icon">
              <i class="bi bi-person-check" style="font-size: 64px;"></i>
            </div>
            <h3 class="empty-state-title">Select a User</h3>
            <p class="empty-state-text">Choose a user from the dropdown above to view detailed washing data.</p>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
