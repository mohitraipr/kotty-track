<%- include('partials/header', { pageTitle: 'GST Master - Accounts DC Challan' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/accounts-challan' }) %>

<% const isSapna = user && user.username && user.username.toLowerCase() === 'sapna'; %>

<!-- Main Content -->
<div class="main-content" style="margin-left: 0;">
  <div class="container-fluid" style="max-width: 1400px; margin: 0 auto;">

    <!-- Alerts -->
    <% if (error && error.length) { %>
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>
        <div>
          <% error.forEach(msg => { %>
            <div><%= msg %></div>
          <% }); %>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>
    <% if (success && success.length) { %>
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>
        <div>
          <% success.forEach(msg => { %>
            <div><%= msg %></div>
          <% }); %>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <!-- Page Header -->
    <div class="page-header">
      <div class="breadcrumbs">
        <a href="/accounts-challan">Accounts</a>
        <span class="separator">/</span>
        <span>GST Master</span>
      </div>
      <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
          <h1 class="page-title">GST Master</h1>
          <p class="page-subtitle">Manage sender and consignee GST profiles used in delivery challans.</p>
        </div>
        <a href="/accounts-challan" class="btn btn-secondary">
          <i class="bi bi-arrow-left"></i>
          <span>Back to Dashboard</span>
        </a>
      </div>
    </div>

    <!-- Tab Navigation -->
    <div class="card mb-4" style="padding: 8px 12px;">
      <div class="d-flex flex-wrap gap-2">
        <% if (isSapna) { %>
          <a href="/purchase" class="btn btn-ghost">
            <i class="bi bi-cart-fill"></i>
            <span>Purchase</span>
          </a>
        <% } %>
        <a href="/accounts-challan" class="btn btn-ghost">
          <i class="bi bi-file-earmark-text"></i>
          <span>DC Challan</span>
        </a>
        <a href="/accounts-challan/list" class="btn btn-ghost">
          <i class="bi bi-list-ul"></i>
          <span>Challan List</span>
        </a>
        <% if (isSapna) { %>
          <a href="/accounts-challan/gst" class="btn btn-primary">
            <i class="bi bi-receipt"></i>
            <span>GST Master</span>
          </a>
        <% } %>
      </div>
    </div>

    <div class="row g-4">
      <!-- Add GST Party Form -->
      <div class="col-lg-4">
        <div class="card">
          <div class="card-header">
            <h5 class="card-title">
              <i class="bi bi-plus-circle me-2 text-terracotta"></i>Add GST Party
            </h5>
          </div>
          <div class="card-body">
            <form action="/accounts-challan/gst" method="POST">
              <div class="form-group">
                <label for="partyType" class="form-label">
                  Party Type <span class="text-danger">*</span>
                </label>
                <select id="partyType" name="party_type" class="form-control form-select" required>
                  <option value="sender">Sender</option>
                  <option value="consignee">Consignee</option>
                </select>
              </div>

              <div class="form-group">
                <label for="name" class="form-label">
                  Name <span class="text-danger">*</span>
                </label>
                <input type="text" id="name" name="name" class="form-control form-input" required placeholder="Enter party name">
              </div>

              <div class="form-group">
                <label for="gstin" class="form-label">GSTIN</label>
                <input type="text" id="gstin" name="gstin" class="form-control form-input" placeholder="15-digit GSTIN">
              </div>

              <div class="form-group">
                <label for="state" class="form-label">State</label>
                <input type="text" id="state" name="state" class="form-control form-input" placeholder="State name">
              </div>

              <div class="form-group">
                <label for="pan" class="form-label">PAN</label>
                <input type="text" id="pan" name="pan" class="form-control form-input" placeholder="10-digit PAN">
              </div>

              <div class="form-group">
                <label for="address" class="form-label">Address</label>
                <textarea id="address" name="address" class="form-control form-textarea" rows="3" placeholder="Full address"></textarea>
              </div>

              <div class="form-group">
                <label for="placeOfSupply" class="form-label">Place of Supply</label>
                <input type="text" id="placeOfSupply" name="place_of_supply" class="form-control form-input" placeholder="Place of supply">
              </div>

              <div class="form-group">
                <label for="shortCode" class="form-label">Short Code</label>
                <input type="text" id="shortCode" name="short_code" class="form-control form-input" maxlength="6" placeholder="Max 6 chars">
                <small class="text-muted">Used in challan numbering</small>
              </div>

              <div class="form-group">
                <div class="form-check">
                  <input type="checkbox" class="form-check-input" id="isActive" name="is_active" checked style="border-color: var(--terracotta);">
                  <label class="form-check-label" for="isActive">Active</label>
                </div>
              </div>

              <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-plus-lg"></i>
                <span>Add GST Party</span>
              </button>
            </form>
          </div>
        </div>
      </div>

      <!-- GST Party List -->
      <div class="col-lg-8">
        <div class="card">
          <div class="card-header">
            <h5 class="card-title">
              <i class="bi bi-list-ul me-2 text-terracotta"></i>GST Party List
            </h5>
            <small class="text-muted">
              <i class="bi bi-info-circle me-1"></i>Edit details to keep challan data current
            </small>
          </div>
          <div class="table-container" style="border: none; border-radius: 0;">
            <div class="table-responsive">
              <table class="table mb-0">
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>Type</th>
                    <th>GSTIN</th>
                    <th>Short Code</th>
                    <th>Status</th>
                    <th>Action</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (parties && parties.length) { %>
                    <% parties.forEach(party => { %>
                      <tr>
                        <td>
                          <strong><%= party.name %></strong>
                          <% if (party.address) { %>
                            <br><small class="text-muted"><i class="bi bi-geo-alt me-1"></i><%= party.address %></small>
                          <% } %>
                        </td>
                        <td>
                          <% if (party.party_type === 'sender') { %>
                            <span class="badge badge-info">
                              <i class="bi bi-send me-1"></i>Sender
                            </span>
                          <% } else { %>
                            <span class="badge badge-primary">
                              <i class="bi bi-inbox me-1"></i>Consignee
                            </span>
                          <% } %>
                        </td>
                        <td><code style="background: var(--gray-100); padding: 2px 6px; border-radius: 4px;"><%= party.gstin || '-' %></code></td>
                        <td>
                          <% if (party.short_code) { %>
                            <span class="badge badge-neutral"><%= party.short_code %></span>
                          <% } else { %>
                            <span class="text-muted">-</span>
                          <% } %>
                        </td>
                        <td>
                          <% if (party.is_active) { %>
                            <span class="badge badge-success">
                              <i class="bi bi-check-circle me-1"></i>Active
                            </span>
                          <% } else { %>
                            <span class="badge badge-neutral">
                              <i class="bi bi-x-circle me-1"></i>Inactive
                            </span>
                          <% } %>
                        </td>
                        <td>
                          <button type="button" class="btn btn-sm btn-outline" data-bs-toggle="modal" data-bs-target="#editModal-<%= party.id %>">
                            <i class="bi bi-pencil"></i>
                            <span>Edit</span>
                          </button>
                        </td>
                      </tr>
                    <% }); %>
                  <% } else { %>
                    <tr>
                      <td colspan="6">
                        <div class="empty-state">
                          <div class="empty-state-icon">
                            <i class="bi bi-inbox" style="font-size: 48px;"></i>
                          </div>
                          <h5 class="empty-state-title">No GST Parties Found</h5>
                          <p class="empty-state-text">Add your first party using the form on the left.</p>
                        </div>
                      </td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Edit Modals -->
<% if (parties && parties.length) { %>
  <% parties.forEach(party => { %>
    <div class="modal fade" id="editModal-<%= party.id %>" tabindex="-1" aria-labelledby="editModalLabel-<%= party.id %>" aria-hidden="true">
      <div class="modal-dialog modal-lg">
        <form class="modal-content" action="/accounts-challan/gst/<%= party.id %>" method="POST" style="background: var(--bg-card); border-radius: var(--radius-xl);">
          <div class="modal-header" style="border-bottom: 1px solid var(--border-light); padding: 20px 24px;">
            <h5 class="modal-title font-display" id="editModalLabel-<%= party.id %>">
              <i class="bi bi-pencil-square me-2 text-terracotta"></i>Edit GST Party
            </h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body" style="padding: 24px;">
            <div class="row g-3">
              <div class="col-md-6">
                <div class="form-group mb-0">
                  <label class="form-label">Party Type</label>
                  <select name="party_type" class="form-control form-select">
                    <option value="sender" <%= party.party_type === 'sender' ? 'selected' : '' %>>Sender</option>
                    <option value="consignee" <%= party.party_type === 'consignee' ? 'selected' : '' %>>Consignee</option>
                  </select>
                </div>
              </div>
              <div class="col-md-6">
                <div class="form-group mb-0">
                  <label class="form-label">Name <span class="text-danger">*</span></label>
                  <input type="text" name="name" class="form-control form-input" value="<%= party.name %>" required>
                </div>
              </div>
              <div class="col-md-6">
                <div class="form-group mb-0">
                  <label class="form-label">GSTIN</label>
                  <input type="text" name="gstin" class="form-control form-input" value="<%= party.gstin || '' %>">
                </div>
              </div>
              <div class="col-md-6">
                <div class="form-group mb-0">
                  <label class="form-label">State</label>
                  <input type="text" name="state" class="form-control form-input" value="<%= party.state || '' %>">
                </div>
              </div>
              <div class="col-md-6">
                <div class="form-group mb-0">
                  <label class="form-label">PAN</label>
                  <input type="text" name="pan" class="form-control form-input" value="<%= party.pan || '' %>">
                </div>
              </div>
              <div class="col-md-6">
                <div class="form-group mb-0">
                  <label class="form-label">Place of Supply</label>
                  <input type="text" name="place_of_supply" class="form-control form-input" value="<%= party.place_of_supply || '' %>">
                </div>
              </div>
              <div class="col-12">
                <div class="form-group mb-0">
                  <label class="form-label">Address</label>
                  <textarea name="address" class="form-control form-textarea" rows="3"><%= party.address || '' %></textarea>
                </div>
              </div>
              <div class="col-md-6">
                <div class="form-group mb-0">
                  <label class="form-label">Short Code</label>
                  <input type="text" name="short_code" class="form-control form-input" value="<%= party.short_code || '' %>" maxlength="6">
                </div>
              </div>
              <div class="col-md-6">
                <div class="form-group mb-0 d-flex align-items-end h-100">
                  <div class="form-check">
                    <input type="checkbox" class="form-check-input" id="active-<%= party.id %>" name="is_active" <%= party.is_active ? 'checked' : '' %> style="border-color: var(--terracotta);">
                    <label class="form-check-label" for="active-<%= party.id %>">Active</label>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="modal-footer" style="border-top: 1px solid var(--border-light); padding: 16px 24px; background: var(--gray-50); border-radius: 0 0 var(--radius-xl) var(--radius-xl);">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
              <i class="bi bi-x-lg"></i>
              <span>Cancel</span>
            </button>
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-check-lg"></i>
              <span>Save Changes</span>
            </button>
          </div>
        </form>
      </div>
    </div>
  <% }); %>
<% } %>

<%- include('partials/footer') %>
