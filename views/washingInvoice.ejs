<%- include('partials/header', { pageTitle: 'Invoice #' + invoice.id }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/washingdashboard' }) %>

<!-- Main Content -->
<main class="main-content" style="margin-left: 0;">
  <div class="container" style="max-width: 900px; margin: 0 auto;">

    <!-- Page Header with Back Button -->
    <div class="page-header">
      <div class="breadcrumbs">
        <a href="/washingdashboard">Washing Dashboard</a>
        <span class="separator">/</span>
        <a href="/washingdashboard/payments">Payments</a>
        <span class="separator">/</span>
        <a href="/washingdashboard/payments/invoices">Invoices</a>
        <span class="separator">/</span>
        <span>Invoice #<%= invoice.id %></span>
      </div>
      <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <h1 class="page-title">Invoice #<%= invoice.id %></h1>
        <div class="d-flex gap-2">
          <button onclick="window.print()" class="btn btn-secondary">
            <i class="bi bi-printer"></i>
            Print
          </button>
          <a href="/washingdashboard/payments/invoices" class="btn btn-outline">
            <i class="bi bi-arrow-left"></i>
            Back to Invoices
          </a>
        </div>
      </div>
    </div>

    <!-- Invoice Details Card -->
    <div class="card mb-4">
      <div class="card-header">
        <h3 class="card-title">Invoice Details</h3>
        <span class="badge badge-primary">
          <i class="bi bi-file-earmark-text me-1"></i>
          Invoice
        </span>
      </div>
      <div class="card-body">
        <div class="row g-4">
          <div class="col-md-4">
            <div class="detail-item">
              <span class="detail-label">Washer</span>
              <span class="detail-value"><%= invoice.washer_name %></span>
            </div>
          </div>
          <div class="col-md-4">
            <div class="detail-item">
              <span class="detail-label">Operator</span>
              <span class="detail-value"><%= invoice.operator_name || '-' %></span>
            </div>
          </div>
          <div class="col-md-4">
            <div class="detail-item">
              <span class="detail-label">Date</span>
              <span class="detail-value"><%= invoice.created_at.toISOString ? invoice.created_at.toISOString().replace('T',' ').slice(0,19) : invoice.created_at %></span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Invoice Items Table -->
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">Invoice Items</h3>
        <span class="badge badge-neutral"><%= items.length %> item<%= items.length !== 1 ? 's' : '' %></span>
      </div>
      <div class="table-container" style="border: none; border-radius: 0;">
        <table class="table">
          <thead>
            <tr>
              <th>Lot</th>
              <th>Description</th>
              <th class="text-end">Qty</th>
              <th class="text-end">Rate</th>
              <th class="text-end">Amount</th>
            </tr>
          </thead>
          <tbody>
            <% items.forEach(function(it){ %>
              <tr>
                <td>
                  <span class="fw-medium"><%= it.lot_no %></span>
                </td>
                <td><%= it.description %></td>
                <td class="text-end"><%= it.qty %></td>
                <td class="text-end"><%= it.rate %></td>
                <td class="text-end fw-medium"><%= it.amount %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <div class="card-footer">
        <div class="d-flex justify-content-end align-items-center gap-4">
          <span class="text-secondary" style="font-size: var(--text-sm);">Total Amount</span>
          <span class="total-amount"><%= invoice.total_amount %></span>
        </div>
      </div>
    </div>

  </div>
</main>

<style>
  /* Detail Item Styling */
  .detail-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .detail-label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
  }

  .detail-value {
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--text-primary);
  }

  /* Total Amount */
  .total-amount {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    color: var(--terracotta);
    font-weight: 400;
  }

  /* Table Enhancements */
  .fw-medium {
    font-weight: 500;
  }

  /* Print Styles */
  @media print {
    .kotty-navbar,
    .breadcrumbs,
    .btn {
      display: none !important;
    }

    .main-content {
      margin-top: 0 !important;
      padding: 0 !important;
    }

    .card {
      box-shadow: none !important;
      border: 1px solid #ddd !important;
    }

    .page-title {
      margin-bottom: 20px;
    }
  }
</style>

<%- include('partials/footer') %>
