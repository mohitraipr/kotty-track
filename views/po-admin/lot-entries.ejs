<%- include('../partials/header', { pageTitle: 'PO Admin Lot Entries' }) %>
<%- include('../partials/navbar', { user: user, dashboardUrl: '/po-admin/dashboard' }) %>

<style>
  /* Page Layout - No sidebar for this page */
  .page-wrapper {
    padding-top: var(--navbar-height);
    min-height: 100vh;
    background: var(--bg-page);
  }

  .page-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 28px;
  }

  /* Page Header */
  .page-header {
    margin-bottom: 28px;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    color: var(--text-primary);
    margin-bottom: 6px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .page-title i {
    color: var(--terracotta);
  }

  .page-subtitle {
    font-size: var(--text-base);
    color: var(--text-secondary);
  }

  /* Filter Card */
  .filter-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 24px;
    margin-bottom: 24px;
    box-shadow: var(--shadow-xs);
  }

  .filter-card:hover {
    box-shadow: var(--shadow-sm);
  }

  .filter-label {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 8px;
    display: block;
  }

  .filter-input {
    width: 100%;
    padding: 10px 14px;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--text-primary);
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }

  .filter-input:hover {
    border-color: var(--border-medium);
  }

  .filter-input:focus {
    outline: none;
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px var(--terracotta-bg);
  }

  .filter-input::placeholder {
    color: var(--text-muted);
  }

  /* Buttons */
  .btn-filter {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 10px 18px;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    border-radius: var(--radius-md);
    border: 1px solid transparent;
    cursor: pointer;
    transition: all var(--transition-fast);
    text-decoration: none;
    white-space: nowrap;
  }

  .btn-filter:focus {
    outline: none;
    box-shadow: 0 0 0 3px var(--terracotta-bg);
  }

  .btn-primary {
    background: var(--terracotta);
    color: white;
    border-color: var(--terracotta);
  }

  .btn-primary:hover {
    background: var(--terracotta-dark);
    border-color: var(--terracotta-dark);
    color: white;
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  .btn-secondary {
    background: var(--bg-card);
    color: var(--text-primary);
    border-color: var(--border-medium);
  }

  .btn-secondary:hover {
    background: var(--gray-100);
    border-color: var(--border-dark);
    color: var(--text-primary);
    text-decoration: none;
  }

  .btn-success {
    background: var(--success);
    color: white;
    border-color: var(--success);
  }

  .btn-success:hover {
    background: #247a52;
    border-color: #247a52;
    color: white;
    text-decoration: none;
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  /* Table Card */
  .table-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-xs);
  }

  .table-card:hover {
    box-shadow: var(--shadow-sm);
  }

  .table-header {
    padding: 18px 22px;
    border-bottom: 1px solid var(--border-light);
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--gray-50);
  }

  .table-header-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--text-primary);
    margin: 0;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .table-header-title i {
    color: var(--terracotta);
  }

  .entry-count {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    background: var(--terracotta-bg);
    color: var(--terracotta);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: 600;
  }

  /* Data Table */
  .data-table {
    width: 100%;
    border-collapse: collapse;
  }

  .data-table thead th {
    padding: 14px 16px;
    text-align: left;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    background: var(--gray-50);
    border-bottom: 1px solid var(--border-light);
    white-space: nowrap;
  }

  .data-table tbody td {
    padding: 14px 16px;
    font-size: var(--text-sm);
    color: var(--text-primary);
    border-bottom: 1px solid var(--border-light);
    vertical-align: middle;
  }

  .data-table tbody tr:last-child td {
    border-bottom: none;
  }

  .data-table tbody tr:hover {
    background: var(--gray-50);
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: 60px 24px;
  }

  .empty-state-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto 20px;
    color: var(--text-muted);
    font-size: 48px;
  }

  .empty-state-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--text-primary);
    margin-bottom: 8px;
  }

  .empty-state-text {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    max-width: 320px;
    margin: 0 auto;
  }

  /* Lot Code Badge */
  .lot-badge {
    font-family: var(--font-mono, monospace);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--terracotta);
    background: var(--terracotta-bg);
    padding: 4px 10px;
    border-radius: var(--radius-md);
  }

  /* SKU Badge */
  .sku-badge {
    font-family: var(--font-mono, monospace);
    font-size: var(--text-sm);
    color: var(--text-primary);
  }

  /* Creator Badge */
  .creator-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    background: var(--info-light);
    color: var(--info);
    border-radius: var(--radius-md);
    font-size: var(--text-xs);
    font-weight: 500;
  }

  /* Quantity Badge */
  .quantity-badge {
    font-weight: 600;
    color: var(--text-primary);
  }

  /* Size Badge */
  .size-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 32px;
    padding: 4px 8px;
    background: var(--gray-100);
    color: var(--text-secondary);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-weight: 500;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .page-container {
      padding: 20px 16px;
    }

    .page-title {
      font-size: var(--text-2xl);
    }

    .filter-card {
      padding: 16px;
    }

    .table-header {
      padding: 14px 16px;
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }

    .data-table {
      font-size: var(--text-xs);
    }

    .data-table thead th,
    .data-table tbody td {
      padding: 10px 12px;
    }
  }
</style>

<div class="page-wrapper">
  <div class="page-container">
    <!-- Flash Messages -->
    <%- include('../partials/flashMessages') %>

    <!-- Page Header -->
    <div class="page-header">
      <h1 class="page-title">
        <i class="bi bi-archive"></i>
        PO Creator Lot Entries
      </h1>
      <p class="page-subtitle">View and search all lot entries created by PO creators</p>
    </div>

    <!-- Filter Card -->
    <div class="filter-card">
      <form class="row g-3" method="GET" action="/po-admin/lot-entries">
        <div class="col-md-3">
          <label class="filter-label">Filter by Date</label>
          <input type="date" name="date" class="filter-input" value="<%= selectedDate %>">
        </div>
        <div class="col-md-4">
          <label class="filter-label">Search (Lot or SKU)</label>
          <input type="text" name="search" class="filter-input" value="<%= searchTerm %>" placeholder="Enter lot code or SKU...">
        </div>
        <div class="col-md-5 d-flex align-items-end gap-2 flex-wrap">
          <button type="submit" class="btn-filter btn-primary">
            <i class="bi bi-funnel"></i> Apply Filters
          </button>
          <a href="/po-admin/lot-entries" class="btn-filter btn-secondary">
            <i class="bi bi-x-circle"></i> Reset
          </a>
          <a
            class="btn-filter btn-success"
            href="/po-admin/lot-entries/export?<%= new URLSearchParams({ date: selectedDate || '', search: searchTerm || '' }).toString() %>"
          >
            <i class="bi bi-file-earmark-excel"></i> Export Excel
          </a>
        </div>
      </form>
    </div>

    <!-- Table Card -->
    <div class="table-card">
      <div class="table-header">
        <h2 class="table-header-title">
          <i class="bi bi-list-ul"></i>
          Lot Entries
        </h2>
        <span class="entry-count">
          <i class="bi bi-box"></i>
          <%= entries.length %> entries
        </span>
      </div>

      <div class="table-responsive">
        <table class="data-table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Creator</th>
              <th>Lot Code</th>
              <th>SKU</th>
              <th>Size</th>
              <th>Quantity</th>
            </tr>
          </thead>
          <tbody>
            <% if (entries.length === 0) { %>
              <tr>
                <td colspan="6">
                  <div class="empty-state">
                    <div class="empty-state-icon">
                      <i class="bi bi-inbox"></i>
                    </div>
                    <div class="empty-state-title">No Lot Entries Found</div>
                    <p class="empty-state-text">There are no lot entries matching your current filters. Try adjusting your search criteria.</p>
                  </div>
                </td>
              </tr>
            <% } else { %>
              <% entries.forEach(entry => { %>
                <tr>
                  <td><%= new Date(entry.display_date || entry.created_at).toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata' }) %></td>
                  <td><span class="creator-badge"><i class="bi bi-person"></i> <%= entry.creator_username %></span></td>
                  <td><span class="lot-badge"><%= entry.lot_code %></span></td>
                  <td><span class="sku-badge"><%= entry.sku %></span></td>
                  <td><span class="size-badge"><%= entry.size || '-' %></span></td>
                  <td><span class="quantity-badge"><%= entry.quantity %></span></td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
