<%- include('partials/header', { pageTitle: 'Bulk Upload' }) %>
<%- include('partials/navbar', { user: typeof user !== 'undefined' ? user : {} }) %>

<!-- Main Content -->
<main class="main-content" style="margin-left: 0;">
  <div class="container" style="max-width: 1000px; margin: 0 auto;">

    <!-- Page Header -->
    <div class="page-header">
      <nav class="breadcrumbs">
        <a href="/dashboard">Dashboard</a>
        <span class="separator"><i class="bi bi-chevron-right"></i></span>
        <span>Bulk Upload</span>
      </nav>
      <h1 class="page-title">Bulk Upload & Assignment</h1>
      <p class="page-subtitle">Manage your uploads and assignments with ease</p>
    </div>

    <!-- Flash Messages -->
    <% if (error && error.length) { %>
      <div class="alert alert-danger">
        <i class="bi bi-exclamation-circle-fill me-2"></i>
        <%= error %>
      </div>
    <% } %>
    <% if (success && success.length) { %>
      <div class="alert alert-success">
        <i class="bi bi-check-circle-fill me-2"></i>
        <%= success %>
      </div>
    <% } %>

    <!-- Main Content Cards -->
    <div class="row g-4">
      <!-- Bulk Create Lots Section -->
      <div class="col-md-6">
        <div class="card h-100">
          <div class="card-header">
            <h2 class="card-title">
              <i class="bi bi-box-seam me-2 text-terracotta"></i>
              Bulk Create Lots
            </h2>
          </div>
          <div class="card-body">
            <p class="mb-3" style="color: var(--text-secondary);">
              Upload an Excel file to create multiple lots at once. Download the template first to ensure proper formatting.
            </p>

            <div class="mb-4">
              <a href="/bulk-upload/template" class="btn btn-outline w-100">
                <i class="bi bi-download"></i>
                Download Excel Template for Lots
              </a>
            </div>

            <form action="/bulk-upload/upload-lots" method="POST" enctype="multipart/form-data">
              <div class="form-group">
                <label for="excelFile" class="form-label">
                  <i class="bi bi-file-earmark-excel text-success me-2"></i>
                  Select Excel File
                </label>
                <input type="file" name="excelFile" id="excelFile" class="form-control form-input" accept=".xlsx,.xls" required>
              </div>
              <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-cloud-arrow-up"></i>
                Upload Lots
              </button>
            </form>
          </div>
        </div>
      </div>

      <!-- Bulk Assign Lots Section -->
      <div class="col-md-6">
        <div class="card h-100">
          <div class="card-header">
            <h2 class="card-title">
              <i class="bi bi-people me-2 text-terracotta"></i>
              Bulk Assign Lots to Stitching
            </h2>
          </div>
          <div class="card-body">
            <p class="mb-3" style="color: var(--text-secondary);">
              Assign multiple lots to stitching operators at once. Download the template for the correct format.
            </p>

            <div class="mb-4">
              <a href="/bulk-assign/template" class="btn btn-outline w-100">
                <i class="bi bi-download"></i>
                Download Excel Template for Assignments
              </a>
            </div>

            <form action="/bulk-assign" method="POST" enctype="multipart/form-data">
              <div class="form-group">
                <label for="assignmentFile" class="form-label">
                  <i class="bi bi-file-earmark-excel text-success me-2"></i>
                  Select Assignment Excel File
                </label>
                <input type="file" name="excelFile" id="assignmentFile" class="form-control form-input" accept=".xlsx,.xls" required>
              </div>
              <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-cloud-arrow-up"></i>
                Upload Assignments
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- Instructions Card -->
    <div class="card mt-4">
      <div class="card-header">
        <h2 class="card-title">
          <i class="bi bi-info-circle me-2"></i>
          Instructions
        </h2>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-6">
            <h6 style="font-family: var(--font-display); color: var(--terracotta); margin-bottom: 12px;">
              For Bulk Lot Creation:
            </h6>
            <ul style="color: var(--text-secondary); padding-left: 20px; margin-bottom: 0;">
              <li>Download the Excel template first</li>
              <li>Fill in the lot details according to the template format</li>
              <li>Ensure all required fields are filled</li>
              <li>Upload the completed Excel file</li>
            </ul>
          </div>
          <div class="col-md-6">
            <h6 style="font-family: var(--font-display); color: var(--terracotta); margin-bottom: 12px;">
              For Bulk Assignments:
            </h6>
            <ul style="color: var(--text-secondary); padding-left: 20px; margin-bottom: 0;">
              <li>Download the assignment template</li>
              <li>Enter lot numbers and operator details</li>
              <li>Verify operator names match existing records</li>
              <li>Upload the completed assignment file</li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <div class="text-center mt-4 mb-3" style="color: var(--text-muted); font-size: var(--text-sm);">
      <p>&copy; <%= new Date().getFullYear() %> KOTTY. All rights reserved.</p>
    </div>

  </div>
</main>

<%- include('partials/footer') %>
