    var id = el.id.replace('indentItem', '');
    var goodsId = $('#goods' + id).val();
    var goodsText = $('#goods' + id).find(':selected').text();
    var qty = parseFloat(document.getElementById('qty' + id).value) || 0;
    var lotNo = document.getElementById('lot' + id).value;
    var remark = document.getElementById('remark' + id).value.trim();
    if (goodsId && qty > 0) items.push({ goods_id: goodsId, goods_description: goodsText, quantity: qty, lot_no: lotNo || null, remark: remark || null });
  });
  if (items.length === 0) { showToast('Add at least one item with quantity', 'warning'); return; }
  var btn = document.getElementById('btnSubmitIndent');
  btn.disabled = true;
  try {
    var res = await fetch('/indent/stage-create', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ items: items }) });
    var data = await res.json();
    if (data.success) {
      showToast('Submitted ' + data.count + ' indent request(s)!', 'success');
      document.getElementById('indentItems').textContent = '';
      indentItemCount = 0;
      addIndentItem();
      loadIndentRequests();
    } else { showToast(data.error || 'Failed', 'error'); }
  } catch (e) { showToast('Error: ' + e.message, 'error'); }
  btn.disabled = false;
}

document.querySelector('[data-tab="indent"]').addEventListener('click', function() {
  if (document.getElementById('indentItems').children.length === 0) {
    loadRecentLots().then(function() { addIndentItem(); });
    loadIndentRequests();
  }
});

document.getElementById('searchInput').addEventListener('keypress', function(e) { if (e.key === 'Enter') searchLot(); });
var ht; document.getElementById('historySearch').addEventListener('input', function() { clearTimeout(ht); ht = setTimeout(function() { loadHistory(true); }, 300); });
loadToday(); loadHistory(true);
</script>

