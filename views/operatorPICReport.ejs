<%- include('partials/header', { pageTitle: 'PIC Report' }) %>
<%- include('partials/navbar', { dashboardUrl: '/operator/dashboard' }) %>

<!-- Main Content -->
<main class="main-content" style="margin-left: 0;">
  <div class="container-fluid" style="max-width: 1400px; margin: 0 auto;">

    <!-- Breadcrumbs -->
    <div class="breadcrumbs">
      <a href="/operator/dashboard"><i class="bi bi-house-door"></i> Dashboard</a>
      <span class="separator">/</span>
      <span>PIC Report</span>
    </div>

    <!-- Page Header -->
    <div class="page-header">
      <h1 class="page-title">PIC Report</h1>
      <p class="page-subtitle">Production In Count Report with Advanced Filtering</p>
    </div>

    <!-- Filter Card -->
    <div class="card mb-4">
      <div class="card-header">
        <h2 class="card-title"><i class="bi bi-funnel me-2"></i>Report Filters</h2>
      </div>
      <div class="card-body">
        <form id="filterForm">
          <div class="row g-3">
            <div class="col-md-4 col-lg-2">
              <label class="form-label">Lot Type</label>
              <select name="lotType" class="form-select form-input">
                <option value="all" <%= filters.lotType === 'all' ? 'selected' : '' %>>All</option>
                <option value="denim" <%= filters.lotType === 'denim' ? 'selected' : '' %>>Denim</option>
                <option value="hosiery" <%= filters.lotType === 'hosiery' ? 'selected' : '' %>>Hosiery</option>
              </select>
            </div>

            <div class="col-md-4 col-lg-2">
              <label class="form-label">Department</label>
              <select name="department" class="form-select form-input">
                <option value="all" <%= filters.department === 'all' ? 'selected' : '' %>>All</option>
                <option value="cutting" <%= filters.department === 'cutting' ? 'selected' : '' %>>Cutting</option>
                <option value="stitching" <%= filters.department === 'stitching' ? 'selected' : '' %>>Stitching</option>
                <option value="assembly" <%= filters.department === 'assembly' ? 'selected' : '' %>>Assembly</option>
                <option value="washing" <%= filters.department === 'washing' ? 'selected' : '' %>>Washing</option>
                <option value="washing_in" <%= filters.department === 'washing_in' ? 'selected' : '' %>>Washing In</option>
                <option value="finishing" <%= filters.department === 'finishing' ? 'selected' : '' %>>Finishing</option>
              </select>
            </div>

            <div class="col-md-4 col-lg-2">
              <label class="form-label">Status</label>
              <select name="status" class="form-select form-input">
                <option value="all" <%= filters.status === 'all' ? 'selected' : '' %>>All</option>
                <option value="pending" <%= filters.status === 'pending' ? 'selected' : '' %>>Pending</option>
                <option value="inline" <%= filters.status === 'inline' ? 'selected' : '' %>>In-Line</option>
                <option value="completed" <%= filters.status === 'completed' ? 'selected' : '' %>>Completed</option>
                <option value="denied" <%= filters.status === 'denied' ? 'selected' : '' %>>Denied</option>
                <option value="not_assigned" <%= filters.status === 'not_assigned' ? 'selected' : '' %>>Not Assigned</option>
              </select>
            </div>

            <div class="col-md-4 col-lg-2">
              <label class="form-label">Date Filter</label>
              <select name="dateFilter" class="form-select form-input">
                <option value="createdAt" <%= filters.dateFilter === 'createdAt' ? 'selected' : '' %>>Created At</option>
                <option value="assignedOn" <%= filters.dateFilter === 'assignedOn' ? 'selected' : '' %>>Assigned On</option>
              </select>
            </div>

            <div class="col-md-4 col-lg-2">
              <label class="form-label">Start Date</label>
              <input type="date" name="startDate" class="form-control form-input" value="<%= filters.startDate || '' %>">
            </div>

            <div class="col-md-4 col-lg-2">
              <label class="form-label">End Date</label>
              <input type="date" name="endDate" class="form-control form-input" value="<%= filters.endDate || '' %>">
            </div>
          </div>

          <div class="mt-4 d-flex gap-2 flex-wrap">
            <button type="button" class="btn btn-primary" onclick="downloadReport()">
              <i class="bi bi-download"></i>
              Download Report
            </button>
            <button type="reset" class="btn btn-secondary">
              <i class="bi bi-arrow-clockwise"></i>
              Reset
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Data Preview -->
    <% if (typeof rows !== 'undefined' && rows.length > 0) { %>
    <div class="card">
      <div class="card-header">
        <h2 class="card-title"><i class="bi bi-table me-2"></i>Data Preview</h2>
        <span class="badge badge-primary"><%= rows.length %> records</span>
      </div>
      <div class="card-body p-0">
        <%
          function statusBadge(s) {
            if (!s || s === 'N/A' || s === '—') return '<span class="text-muted">—</span>';
            const m = String(s).toLowerCase();
            if (m === 'completed') return '<span class="badge badge-success">Completed</span>';
            if (m === 'partial')   return '<span class="badge badge-warning">Partial</span>';
            if (m === 'in progress') return '<span class="badge badge-info">In Progress</span>';
            if (m === 'pending approval') return '<span class="badge badge-warning">Pending Approval</span>';
            if (m === 'denied')    return '<span class="badge badge-danger">Denied</span>';
            if (m === 'not started') return '<span class="badge badge-neutral">Not Started</span>';
            return '<span class="badge badge-neutral">' + s + '</span>';
          }
          function qtyOrDash(v) {
            if (v === '' || v === null || v === undefined) return '<span class="text-muted">—</span>';
            if (v === '—') return '<span class="text-muted">—</span>';
            return v;
          }
        %>
        <div class="table-container" style="border: none; border-radius: 0;">
          <div class="table-responsive">
            <table class="table table-sm mb-0" style="font-size: var(--text-xs);">
              <thead>
                <tr>
                  <th style="width:28px;"></th>
                  <th>Lot No</th>
                  <th>Ext Lot</th>
                  <th>Sort</th>
                  <th>SKU</th>
                  <th>Type</th>
                  <th>Cut</th>
                  <th>Created</th>
                  <th>Age</th>
                  <th>Current Stage</th>
                  <th>Pending</th>
                  <th>In Stage</th>
                  <th>Stitch</th>
                  <th>Assembly</th>
                  <th>Washing</th>
                  <th>Wash-In</th>
                  <th>Finishing</th>
                  <th>Rewash</th>
                  <th>Rejects</th>
                </tr>
              </thead>
              <tbody>
                <% rows.slice(0, 50).forEach(row => { %>
                <tr data-lot-no="<%= row.lotNo %>">
                  <td><button type="button" class="lse-toggle" aria-expanded="false" aria-label="Show size breakdown"><span class="lse-chevron">&#9654;</span></button></td>
                  <td><strong style="color: var(--terracotta);"><%= row.lotNo %></strong></td>
                  <td><%= row.externalLotNo || '—' %></td>
                  <td><%= row.sortNo || '—' %></td>
                  <td style="max-width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="<%= row.sku %>"><%= row.sku %></td>
                  <td>
                    <span class="badge <%= row.lotType === 'Denim' ? 'badge-primary' : 'badge-info' %>">
                      <%= row.lotType %>
                    </span>
                  </td>
                  <td><%= row.totalCut %></td>
                  <td><%= row.createdAt %></td>
                  <td><%= row.daysSinceCreated %>d</td>
                  <td>
                    <% if (row.currentStage === 'Done') { %>
                      <span class="badge badge-success">Done</span>
                    <% } else { %>
                      <span class="badge badge-warning"><%= row.currentStage %></span>
                    <% } %>
                  </td>
                  <td><strong><%= row.currentPendingQty || 0 %></strong></td>
                  <td><%= row.daysInStage === '' ? '—' : row.daysInStage + 'd' %></td>
                  <td>
                    <%- statusBadge(row.stitchStatus) %><br>
                    <small class="text-muted">
                      <%- qtyOrDash(row.stitchInQty) %> →
                      <%- qtyOrDash(row.stitchOutQty) %>
                      <% if (row.stitchPendingQty > 0) { %>
                        <span class="text-danger">(<%= row.stitchPendingQty %> pend)</span>
                      <% } %>
                    </small>
                  </td>
                  <td>
                    <%- statusBadge(row.assemblyStatus) %><br>
                    <small class="text-muted">
                      <%- qtyOrDash(row.assemblyInQty) %> →
                      <%- qtyOrDash(row.assemblyOutQty) %>
                      <% if (typeof row.assemblyPendingQty === 'number' && row.assemblyPendingQty > 0) { %>
                        <span class="text-danger">(<%= row.assemblyPendingQty %> pend)</span>
                      <% } %>
                    </small>
                  </td>
                  <td>
                    <%- statusBadge(row.washingStatus) %><br>
                    <small class="text-muted">
                      <%- qtyOrDash(row.washingInQty_in) %> →
                      <%- qtyOrDash(row.washingOutQty) %>
                      <% if (typeof row.washingPendingQty === 'number' && row.washingPendingQty > 0) { %>
                        <span class="text-danger">(<%= row.washingPendingQty %> pend)</span>
                      <% } %>
                    </small>
                  </td>
                  <td>
                    <%- statusBadge(row.washInStatus) %><br>
                    <small class="text-muted">
                      <%- qtyOrDash(row.washInInQty) %> →
                      <%- qtyOrDash(row.washInOutQty) %>
                      <% if (typeof row.washInPendingQty === 'number' && row.washInPendingQty > 0) { %>
                        <span class="text-danger">(<%= row.washInPendingQty %> pend)</span>
                      <% } %>
                    </small>
                  </td>
                  <td>
                    <%- statusBadge(row.finishingStatus) %><br>
                    <small class="text-muted">
                      <%- qtyOrDash(row.finishingInQty) %> →
                      <%- qtyOrDash(row.finishingOutQty) %>
                      <% if (row.finishingPendingQty > 0) { %>
                        <span class="text-danger">(<%= row.finishingPendingQty %> pend)</span>
                      <% } %>
                    </small>
                  </td>
                  <td>
                    <% if (row.rewashRequestedQty > 0) { %>
                      <small>
                        Req: <strong><%= row.rewashRequestedQty %></strong><br>
                        <% if (row.rewashPendingQty > 0) { %>
                          <span class="text-warning">Pend: <%= row.rewashPendingQty %></span><br>
                        <% } %>
                        <% if (row.rewashCompletedQty > 0) { %>
                          <span class="text-success">Done: <%= row.rewashCompletedQty %></span>
                        <% } %>
                      </small>
                    <% } else { %>
                      <span class="text-muted">—</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (row.totalRejectQty > 0) { %>
                      <strong class="text-danger"><%= row.totalRejectQty %></strong><br>
                      <small class="text-muted">
                        <% if (row.stitchRejectQty > 0) { %>St:<%= row.stitchRejectQty %><br><% } %>
                        <% if (row.washInRejectQty > 0) { %>WI:<%= row.washInRejectQty %><br><% } %>
                        <% if (row.finishingRejectQty > 0) { %>Fn:<%= row.finishingRejectQty %><% } %>
                      </small>
                      <% const reasons = [row.stitchRejectReasons, row.washInRejectReasons, row.finishingRejectReasons].filter(Boolean).join('; '); %>
                      <% if (reasons) { %>
                        <br><small title="<%= reasons %>" style="cursor: help; color: var(--text-secondary);">
                          <i class="bi bi-info-circle"></i> reasons
                        </small>
                      <% } %>
                    <% } else { %>
                      <span class="text-muted">—</span>
                    <% } %>
                  </td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      <% if (rows.length > 50) { %>
      <div class="card-footer">
        <p class="text-muted mb-0" style="font-size: var(--text-sm);">
          <i class="bi bi-info-circle me-1"></i>
          Showing first 50 of <%= rows.length %> records. Download the full report to see all data.
        </p>
      </div>
      <% } %>
    </div>
    <% } else { %>
    <!-- Empty State -->
    <div class="card">
      <div class="card-body">
        <div class="empty-state">
          <div class="empty-state-icon">
            <i class="bi bi-file-earmark-spreadsheet" style="font-size: 48px;"></i>
          </div>
          <h3 class="empty-state-title">No Data Available</h3>
          <p class="empty-state-text">Apply filters and download the report to view production data.</p>
        </div>
      </div>
    </div>
    <% } %>

  </div>
</main>

<!-- Loading Overlay -->
<div id="overlaySpinner" class="loading-overlay">
  <div class="loading-content">
    <div class="spinner" style="width: 48px; height: 48px; border-width: 3px;"></div>
    <h5>Generating Report</h5>
    <p>Please wait while we prepare your data...</p>
  </div>
</div>

<style>
  /* Loading Overlay Styles */
  .loading-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(26, 26, 26, 0.6);
    backdrop-filter: blur(4px);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 9999;
  }

  .loading-content {
    background: var(--bg-card);
    padding: 40px 48px;
    border-radius: var(--radius-xl);
    text-align: center;
    box-shadow: var(--shadow-xl);
  }

  .loading-content h5 {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--text-primary);
    margin-top: 20px;
    margin-bottom: 8px;
  }

  .loading-content p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin: 0;
  }

  /* Form input focus states with terracotta */
  .form-input:focus,
  .form-select:focus,
  .form-control:focus {
    border-color: var(--terracotta) !important;
    box-shadow: 0 0 0 3px var(--terracotta-bg) !important;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .main-content {
      padding: 20px 16px;
    }

    .loading-content {
      padding: 32px;
      margin: 0 16px;
    }
  }
</style>

<script>
  function showSpinner() {
    document.getElementById('overlaySpinner').style.display = 'flex';
  }

  function hideSpinner() {
    document.getElementById('overlaySpinner').style.display = 'none';
  }

  async function downloadReport() {
    try {
      const form = document.getElementById('filterForm');
      const formData = new FormData(form);
      const params = new URLSearchParams();

      for (const [key, val] of formData.entries()) {
        if (val) params.append(key, val);
      }
      params.set('download', '1');

      showSpinner();

      const response = await fetch('/operator/dashboard/pic-report?' + params.toString());
      if (!response.ok) throw new Error('Server error');

      const blob = await response.blob();
      const url = window.URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'PICReport-' + new Date().toISOString().split('T')[0] + '.xlsx';
      document.body.appendChild(a);
      a.click();
      a.remove();
      window.URL.revokeObjectURL(url);
    } catch (err) {
      alert('Error downloading report: ' + err.message);
    } finally {
      hideSpinner();
    }
  }
</script>
<script src="/public/js/lot-size-expand.js"></script>

<%- include('partials/footer') %>
