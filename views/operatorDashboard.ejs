<%- include('partials/footer') %>

<script src="https://unpkg.com/tabulator-tables@5.5.0/dist/js/tabulator.min.js"></script>

<script>
  const backToTopBtn = document.getElementById('backToTop');
  const sessionRange = document.getElementById('sessionRange');
  const refreshSessionUsage = document.getElementById('refreshSessionUsage');
  const sessionUsageTableBody = document.querySelector('#sessionUsageTable tbody');
  const sessionUsageEmpty = document.getElementById('sessionUsageEmpty');

  // Back to top button
  window.addEventListener('scroll', () => {
    backToTopBtn.style.display = window.pageYOffset > 300 ? 'flex' : 'none';
  });

  backToTopBtn.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // Account usage table (Mohit only)
  function formatDuration(seconds) {
    if (seconds === undefined || seconds === null) return '—';
    const totalSeconds = Math.max(0, Math.round(seconds));
    const hours = Math.floor(totalSeconds / 3600);
    const minutes = Math.floor((totalSeconds % 3600) / 60);
    if (hours === 0 && minutes === 0) return Math.max(1, Math.ceil(totalSeconds / 60)) + 'm';
    if (hours === 0) return minutes + 'm';
    return hours + 'h ' + minutes.toString().padStart(2, '0') + 'm';
  }

  function formatDate(dateValue) {
    if (!dateValue) return '—';
    return new Date(dateValue).toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata' });
  }

  function formatDateTime(dateValue) {
    if (!dateValue) return '—';
    return new Date(dateValue).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', hour12: true });
  }

  async function loadSessionUsage() {
    if (!sessionRange || !sessionUsageTableBody) return;
    if (sessionUsageEmpty) sessionUsageEmpty.classList.add('d-none');

    while (sessionUsageTableBody.firstChild) {
      sessionUsageTableBody.removeChild(sessionUsageTableBody.firstChild);
    }
    const loadingRow = document.createElement('tr');
    const loadingCell = document.createElement('td');
    loadingCell.setAttribute('colspan', '5');
    loadingCell.className = 'text-center text-muted py-4';
    loadingCell.textContent = 'Loading usage…';
    loadingRow.appendChild(loadingCell);
    sessionUsageTableBody.appendChild(loadingRow);

    try {
      const days = sessionRange.value;
      const response = await fetch('/operator/dashboard/api/session-usage?days=' + days);
      const payload = await response.json();
      const rows = Array.isArray(payload && payload.data) ? payload.data : [];

      while (sessionUsageTableBody.firstChild) {
        sessionUsageTableBody.removeChild(sessionUsageTableBody.firstChild);
      }

      if (!rows.length) {
        if (sessionUsageEmpty) sessionUsageEmpty.classList.remove('d-none');
        return;
      }

      rows.forEach(function(row) {
        const tr = document.createElement('tr');

        const dateCell = document.createElement('td');
        dateCell.textContent = formatDate(row.loginDate);
        tr.appendChild(dateCell);

        const userCell = document.createElement('td');
        const strong = document.createElement('strong');
        strong.textContent = row.username;
        userCell.appendChild(strong);
        tr.appendChild(userCell);

        const sessionsCell = document.createElement('td');
        sessionsCell.textContent = row.sessionCount;
        tr.appendChild(sessionsCell);

        const timeCell = document.createElement('td');
        timeCell.textContent = formatDuration(row.totalSeconds);
        tr.appendChild(timeCell);

        const lastActiveCell = document.createElement('td');
        lastActiveCell.textContent = formatDateTime(row.lastActivityAt);
        tr.appendChild(lastActiveCell);

        sessionUsageTableBody.appendChild(tr);
      });
    } catch (error) {
      console.error('Unable to load session usage:', error);
      while (sessionUsageTableBody.firstChild) {
        sessionUsageTableBody.removeChild(sessionUsageTableBody.firstChild);
      }
      const errorRow = document.createElement('tr');
      const errorCell = document.createElement('td');
      errorCell.setAttribute('colspan', '5');
      errorCell.className = 'text-danger text-center py-4';
      errorCell.textContent = 'Unable to load account usage right now.';
      errorRow.appendChild(errorCell);
      sessionUsageTableBody.appendChild(errorRow);
    }
  }

  if (sessionRange) {
    loadSessionUsage();
    sessionRange.addEventListener('change', loadSessionUsage);
  }

  if (refreshSessionUsage) {
    refreshSessionUsage.addEventListener('click', loadSessionUsage);
  }

  // Pendency table
  const deptFilter = document.getElementById('deptFilter');
  const table = new Tabulator("#pendencyTable", {
    layout: "fitColumns",
    pagination: "local",
    paginationSize: 50,
    ajaxURL: "/operator/dashboard/api/pendency?dept=all",
    placeholder: "No pendency data available",
    columns: [
      {
        title: "Lot No",
        field: "lot_no",
        width: 150,
        formatter: function(cell) {
          const lotNo = cell.getValue();
          const link = document.createElement('a');
          link.href = '#';
          link.style.cssText = 'color: var(--terracotta); font-weight: 600; text-decoration: none;';
          link.textContent = lotNo;
          link.onmouseover = function() { this.style.textDecoration = 'underline'; };
          link.onmouseout = function() { this.style.textDecoration = 'none'; };
          link.onclick = function(e) {
            e.preventDefault();
            showLotDetails(lotNo);
          };
          return link;
        }
      },
      { title: "Username", field: "username", width: 150 },
      { title: "Assigned", field: "assigned", width: 120 },
      { title: "Completed", field: "completed", width: 120 },
      {
        title: "Pending",
        field: "pending",
        width: 120,
        formatter: function(cell) {
          const val = cell.getValue();
          const span = document.createElement('span');
          span.className = 'badge-kotty';
          if (val > 100) {
            span.classList.add('badge-danger');
          } else if (val > 50) {
            span.classList.add('badge-warning');
          } else {
            span.classList.add('badge-success');
          }
          span.textContent = val;
          return span;
        }
      }
    ]
  });

  deptFilter.addEventListener('change', function(e) {
    const dept = e.target.value;
    table.setData('/operator/dashboard/api/pendency?dept=' + dept);
  });

  // Show lot details in modal
  function showLotDetails(lotNo) {
    const modal = new bootstrap.Modal(document.getElementById('lotModal'));
    const modalBody = document.getElementById('lotModalBody');

    while (modalBody.firstChild) {
      modalBody.removeChild(modalBody.firstChild);
    }
    const loadingDiv = document.createElement('div');
    loadingDiv.className = 'text-center py-4';
    const spinner = document.createElement('div');
    spinner.className = 'spinner-border';
    spinner.style.color = 'var(--terracotta)';
    loadingDiv.appendChild(spinner);
    const loadingText = document.createElement('p');
    loadingText.className = 'mt-2 text-muted';
    loadingText.textContent = 'Loading...';
    loadingDiv.appendChild(loadingText);
    modalBody.appendChild(loadingDiv);

    modal.show();

    fetch('/operator/dashboard/api/lot?lotNo=' + lotNo)
      .then(function(r) { return r.json(); })
      .then(function(data) {
        while (modalBody.firstChild) {
          modalBody.removeChild(modalBody.firstChild);
        }

        if (data.error) {
          const alert = document.createElement('div');
          alert.className = 'alert alert-danger';
          alert.textContent = data.error;
          modalBody.appendChild(alert);
          return;
        }

        const row = document.createElement('div');
        row.className = 'row';

        const col1 = document.createElement('div');
        col1.className = 'col-md-6';
        col1.innerHTML = '<p><strong>Lot No:</strong> ' + (data.lot_no || 'N/A') + '</p>' +
                        '<p><strong>SKU:</strong> ' + (data.sku || 'N/A') + '</p>' +
                        '<p><strong>Total Pieces:</strong> ' + (data.total_pieces || 'N/A') + '</p>' +
                        '<p><strong>Type:</strong> ' + (data.lot_type || 'N/A') + '</p>';

        const col2 = document.createElement('div');
        col2.className = 'col-md-6';
        col2.innerHTML = '<p><strong>Status:</strong> <span class="badge-kotty badge-info">' + (data.status || 'N/A') + '</span></p>' +
                        '<p><strong>Created:</strong> ' + (data.created_at ? new Date(data.created_at).toLocaleDateString() : 'N/A') + '</p>' +
                        '<p><strong>Department:</strong> ' + (data.current_department || 'N/A') + '</p>';

        row.appendChild(col1);
        row.appendChild(col2);
        modalBody.appendChild(row);
      })
      .catch(function(err) {
        while (modalBody.firstChild) {
          modalBody.removeChild(modalBody.firstChild);
        }
        const alert = document.createElement('div');
        alert.className = 'alert alert-danger';
        alert.textContent = 'Error loading lot details';
        modalBody.appendChild(alert);
      });
  }

  window.showLotDetails = showLotDetails;

  // ═══════════════════════════════════════════════════════════════════════════
  // INDENT FUNCTIONALITY
  // ═══════════════════════════════════════════════════════════════════════════

  var indentItemCount = 0;
  var recentLots = [];
  var indentLoaded = false;

  function toggleIndentSection() {
    var content = document.getElementById('indentContent');
    var toggle = document.querySelector('.indent-toggle');
    if (content.classList.contains('show')) {
      content.classList.remove('show');
      toggle.classList.remove('open');
    } else {
      content.classList.add('show');
      toggle.classList.add('open');
      if (!indentLoaded) {
        loadRecentLots().then(function() { addIndentItem(); });
        loadIndentRequests();
        indentLoaded = true;
      }
    }
  }

  function esc(str) {
    if (!str) return '';
    var d = document.createElement('div');
    d.textContent = str;
    return d.innerHTML;
  }

  function addIndentItem() {
    indentItemCount++;
    var id = indentItemCount;
    var container = document.getElementById('indentItems');
    var item = document.createElement('div');
    item.className = 'indent-item';
    item.id = 'indentItem' + id;

    var header = document.createElement('div');
    header.className = 'indent-item-header';
    var num = document.createElement('span');
    num.className = 'indent-item-num';
    num.textContent = 'Item #' + id;
    header.appendChild(num);
    var removeBtn = document.createElement('button');
    removeBtn.type = 'button';
    removeBtn.className = 'btn-remove-item';
    removeBtn.textContent = 'Remove';
    removeBtn.onclick = function() { item.remove(); };
    header.appendChild(removeBtn);
    item.appendChild(header);

    var row1 = document.createElement('div');
    row1.className = 'indent-row single';
    var div1 = document.createElement('div');
    var label1 = document.createElement('label');
    label1.className = 'indent-label';
    label1.textContent = 'Item *';
    div1.appendChild(label1);
    var sel = document.createElement('select');
    sel.className = 'indent-input';
    sel.id = 'goods' + id;
    sel.style.width = '100%';
    var opt = document.createElement('option');
    opt.value = '';
    opt.textContent = 'Search...';
    sel.appendChild(opt);
    div1.appendChild(sel);
    row1.appendChild(div1);
    item.appendChild(row1);

    var row2 = document.createElement('div');
    row2.className = 'indent-row';
    var div2a = document.createElement('div');
    var label2a = document.createElement('label');
    label2a.className = 'indent-label';
    label2a.textContent = 'Qty *';
    div2a.appendChild(label2a);
    var qtyInput = document.createElement('input');
    qtyInput.type = 'number';
    qtyInput.className = 'indent-input';
    qtyInput.id = 'qty' + id;
    qtyInput.min = '1';
    qtyInput.placeholder = 'Qty';
    div2a.appendChild(qtyInput);
    row2.appendChild(div2a);
    var div2b = document.createElement('div');
    var label2b = document.createElement('label');
    label2b.className = 'indent-label';
    label2b.textContent = 'Unit';
    div2b.appendChild(label2b);
    var unitInput = document.createElement('input');
    unitInput.type = 'text';
    unitInput.className = 'indent-input';
    unitInput.id = 'unit' + id;
    unitInput.readOnly = true;
    unitInput.placeholder = '-';
    div2b.appendChild(unitInput);
    row2.appendChild(div2b);
    item.appendChild(row2);

    var row3 = document.createElement('div');
    row3.className = 'indent-row single';
    var div3 = document.createElement('div');
    var label3 = document.createElement('label');
    label3.className = 'indent-label';
    label3.textContent = 'Lot (optional)';
    div3.appendChild(label3);
    var lotSel = document.createElement('select');
    lotSel.className = 'indent-input';
    lotSel.id = 'lot' + id;
    var defOpt = document.createElement('option');
    defOpt.value = '';
    defOpt.textContent = '-- No lot --';
    lotSel.appendChild(defOpt);
    recentLots.forEach(function(l) {
      var o = document.createElement('option');
      o.value = l;
      o.textContent = l.toUpperCase();
      lotSel.appendChild(o);
    });
    div3.appendChild(lotSel);
    row3.appendChild(div3);
    item.appendChild(row3);

    var row4 = document.createElement('div');
    row4.className = 'indent-row single';
    var div4 = document.createElement('div');
    var label4 = document.createElement('label');
    label4.className = 'indent-label';
    label4.textContent = 'Remark (optional)';
    div4.appendChild(label4);
    var remarkInput = document.createElement('input');
    remarkInput.type = 'text';
    remarkInput.className = 'indent-input';
    remarkInput.id = 'remark' + id;
    remarkInput.placeholder = 'e.g. urgent';
    div4.appendChild(remarkInput);
    row4.appendChild(div4);
    item.appendChild(row4);

    container.appendChild(item);

    $(sel).select2({
      placeholder: 'Search...',
      allowClear: true,
      width: '100%',
      minimumInputLength: 1,
      ajax: { url: '/indent/api/items', dataType: 'json', delay: 250, data: function(p) { return { q: p.term }; }, processResults: function(d) { return { results: d }; }, cache: true }
    });
    $(sel).on('select2:select', function(e) { if (e.params.data && e.params.data.unit) document.getElementById('unit' + id).value = e.params.data.unit; });
    $(sel).on('select2:clear', function() { document.getElementById('unit' + id).value = ''; });
  }

  async function loadRecentLots() {
    try {
      var res = await fetch('/indent/recent-lots');
      var data = await res.json();
      if (data.success) recentLots = data.lots || [];
    } catch (e) { console.error(e); }
  }

  async function loadIndentRequests() {
    try {
      var res = await fetch('/indent/my-requests?limit=15');
      var data = await res.json();
      var container = document.getElementById('indentRequestsList');
      container.textContent = '';
      if (!data.success || !data.requests || data.requests.length === 0) {
        container.textContent = 'No indent requests yet';
        container.style.textAlign = 'center';
        container.style.padding = '16px';
        container.style.color = 'var(--text-muted)';
        return;
      }
      data.requests.forEach(function(req) {
        var item = document.createElement('div');
        item.className = 'indent-request-item';
        var main = document.createElement('div');
        main.className = 'indent-request-main';
        var desc = document.createElement('div');
        desc.className = 'indent-request-desc';
        desc.textContent = req.goods_description;
        main.appendChild(desc);
        var meta = document.createElement('div');
        meta.className = 'indent-request-meta';
        meta.textContent = 'Qty: ' + req.quantity_requested;
        if (req.lot_no) {
          meta.appendChild(document.createTextNode(' • '));
          var lotSpan = document.createElement('span');
          lotSpan.className = 'indent-request-lot';
          lotSpan.textContent = req.lot_no.toUpperCase();
          meta.appendChild(lotSpan);
        }
        meta.appendChild(document.createTextNode(' • ' + new Date(req.created_at).toLocaleDateString('en-IN')));
        main.appendChild(meta);
        item.appendChild(main);
        var status = document.createElement('span');
        status.className = 'indent-request-status ' + req.status;
        status.textContent = req.status;
        item.appendChild(status);
        container.appendChild(item);
      });
    } catch (e) {
      console.error(e);
      document.getElementById('indentRequestsList').textContent = 'Failed to load';
    }
  }

  async function submitIndent() {
    var items = [];
    document.querySelectorAll('.indent-item').forEach(function(el) {
      var id = el.id.replace('indentItem', '');
      var goodsId = $('#goods' + id).val();
      var goodsText = $('#goods' + id).find(':selected').text();
      var qty = parseFloat(document.getElementById('qty' + id).value) || 0;
      var lotNo = document.getElementById('lot' + id).value;
      var remark = document.getElementById('remark' + id).value.trim();
      if (goodsId && qty > 0) items.push({ goods_id: goodsId, goods_description: goodsText, quantity: qty, lot_no: lotNo || null, remark: remark || null });
    });
    if (items.length === 0) { alert('Add at least one item with quantity'); return; }
    var btn = document.getElementById('btnSubmitIndent');
    btn.disabled = true;
    try {
      var res = await fetch('/indent/stage-create', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ items: items }) });
      var data = await res.json();
      if (data.success) {
        alert('Submitted ' + data.count + ' indent request(s)!');
        document.getElementById('indentItems').textContent = '';
        indentItemCount = 0;
        addIndentItem();
        loadIndentRequests();
      } else { alert(data.error || 'Failed'); }
    } catch (e) { alert('Error: ' + e.message); }
    btn.disabled = false;
  }
</script>
