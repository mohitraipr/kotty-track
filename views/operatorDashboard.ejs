<%- include('partials/header', { pageTitle: 'Operator Dashboard' }) %>
<!-- Select2 for indent item search -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<%- include('partials/navbar', { user: user, dashboardUrl: '/operator/dashboard' }) %>

<style>
  /* ═══════════════════════════════════════════════════════════════════════════
     OPERATOR DASHBOARD - Kotty Track Design System
     Industrial Textile Elegance
   ═══════════════════════════════════════════════════════════════════════════ */

  :root {
    --charcoal: #1a1a1a;
    --charcoal-light: #2d2d2d;
    --cream: #faf8f5;
    --cream-dark: #f0ebe3;
    --terracotta: #c45c3a;
    --terracotta-light: #d4826a;
    --terracotta-dark: #a84a2d;
    --success: #2d8a5f;
    --success-light: #e8f5ef;
    --warning: #c4873a;
    --warning-light: #fef3e2;
    --danger: #c23b22;
    --danger-light: #fdeaea;
    --info: #3a7bc4;
    --info-light: #e8f1fb;
    --text-primary: #1a1a1a;
    --text-secondary: #5a5a5a;
    --text-muted: #8a8a8a;
    --border: #e5e0d8;
    --border-light: #f0ebe3;
    --shadow-sm: 0 1px 3px rgba(26, 26, 26, 0.06);
    --shadow-md: 0 4px 12px rgba(26, 26, 26, 0.08);
    --shadow-lg: 0 8px 24px rgba(26, 26, 26, 0.12);
    --radius-sm: 6px;
    --radius-md: 10px;
    --radius-lg: 16px;
  }

  body {
    background: var(--cream);
    min-height: 100vh;
  }

  /* Main Layout */
  .dashboard-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 32px 24px;
    padding-top: calc(60px + 32px); /* navbar height + spacing */
  }

  /* Page Header */
  .page-header {
    margin-bottom: 32px;
    animation: fadeInUp 0.5s ease-out;
  }

  .page-title {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 2.25rem;
    font-weight: 400;
    color: var(--charcoal);
    margin-bottom: 6px;
    letter-spacing: -0.02em;
  }

  .page-subtitle {
    font-family: 'Outfit', sans-serif;
    font-size: 0.95rem;
    color: var(--text-secondary);
    font-weight: 400;
  }

  /* Stats Grid */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 32px;
    animation: fadeInUp 0.5s ease-out 0.1s backwards;
  }

  .stat-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 24px;
    position: relative;
    transition: all 0.25s ease;
    overflow: hidden;
  }

  .stat-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: var(--terracotta);
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .stat-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .stat-card:hover::before {
    opacity: 1;
  }

  .stat-card:nth-child(1)::before { background: var(--terracotta); }
  .stat-card:nth-child(2)::before { background: var(--info); }
  .stat-card:nth-child(3)::before { background: var(--success); }
  .stat-card:nth-child(4)::before { background: var(--warning); }

  .stat-label {
    font-family: 'Outfit', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 10px;
  }

  .stat-value {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 2.5rem;
    font-weight: 400;
    color: var(--charcoal);
    line-height: 1;
  }

  .stat-card:nth-child(1) .stat-value { color: var(--terracotta); }
  .stat-card:nth-child(2) .stat-value { color: var(--info); }
  .stat-card:nth-child(3) .stat-value { color: var(--success); }
  .stat-card:nth-child(4) .stat-value { color: var(--warning); }

  /* Info Banner */
  .info-banner {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 20px;
    background: linear-gradient(135deg, var(--cream-dark) 0%, white 100%);
    border: 1px solid var(--border);
    border-left: 4px solid var(--terracotta);
    border-radius: var(--radius-md);
    margin-bottom: 32px;
    font-family: 'Outfit', sans-serif;
    font-size: 0.9rem;
    color: var(--text-secondary);
    animation: fadeInUp 0.5s ease-out 0.15s backwards;
  }

  .info-banner i {
    font-size: 1.25rem;
    color: var(--terracotta);
    flex-shrink: 0;
  }

  .info-banner strong {
    color: var(--charcoal);
  }

  /* Section Header */
  .section-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
  }

  .section-title {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 1.35rem;
    font-weight: 400;
    color: var(--charcoal);
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0;
  }

  .section-title i {
    color: var(--terracotta);
    font-size: 1.1rem;
  }

  /* Action Categories */
  .action-categories {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: 32px;
    animation: fadeInUp 0.5s ease-out 0.2s backwards;
  }

  .action-category {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 20px;
    transition: all 0.25s ease;
  }

  .action-category:hover {
    box-shadow: var(--shadow-sm);
  }

  .category-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--border-light);
  }

  .category-icon {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
  }

  .category-icon.production { background: #fef0eb; color: var(--terracotta); }
  .category-icon.inventory { background: var(--success-light); color: var(--success); }
  .category-icon.washing { background: var(--info-light); color: var(--info); }
  .category-icon.reports { background: var(--warning-light); color: var(--warning); }
  .category-icon.hr { background: #fce7f3; color: #be185d; }
  .category-icon.management { background: #ede9fe; color: #7c3aed; }

  .category-title {
    font-family: 'Outfit', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--charcoal);
  }

  .category-actions {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
    gap: 10px;
  }

  .action-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 14px 10px;
    background: var(--cream);
    border: 1px solid transparent;
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--text-primary);
    transition: all 0.2s ease;
    text-align: center;
  }

  .action-card:hover {
    background: white;
    border-color: var(--terracotta-light);
    box-shadow: var(--shadow-sm);
    transform: translateY(-2px);
  }

  .action-card:hover i {
    color: var(--terracotta);
  }

  .action-card i {
    font-size: 1.3rem;
    color: var(--text-secondary);
    transition: color 0.2s ease;
  }

  .action-card-title {
    font-family: 'Outfit', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1.3;
  }

  /* Panel Card */
  .panel-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: 24px;
    animation: fadeInUp 0.5s ease-out 0.25s backwards;
  }

  .panel-header {
    padding: 18px 24px;
    border-bottom: 1px solid var(--border-light);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    background: linear-gradient(180deg, var(--cream) 0%, white 100%);
  }

  .panel-title {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--charcoal);
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0;
  }

  .panel-title i {
    color: var(--terracotta);
  }

  .panel-body {
    padding: 24px;
  }

  /* Forms & Inputs */
  .form-control, .form-select {
    font-family: 'Outfit', sans-serif;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-size: 0.875rem;
    padding: 8px 14px;
    background: white;
    transition: all 0.2s ease;
  }

  .form-control:focus, .form-select:focus {
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px rgba(196, 92, 58, 0.1);
    outline: none;
  }

  .form-select {
    cursor: pointer;
  }

  /* Buttons */
  .btn-kotty {
    font-family: 'Outfit', sans-serif;
    font-weight: 500;
    padding: 8px 18px;
    border-radius: var(--radius-sm);
    font-size: 0.875rem;
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .btn-kotty-primary {
    background: var(--terracotta);
    color: white;
  }

  .btn-kotty-primary:hover {
    background: var(--terracotta-dark);
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
  }

  /* Tables */
  .kotty-table {
    font-family: 'Outfit', sans-serif;
    font-size: 0.875rem;
    width: 100%;
    margin-bottom: 0;
  }

  .kotty-table thead th {
    background: var(--cream);
    border-bottom: 2px solid var(--border);
    color: var(--text-secondary);
    font-weight: 600;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 12px 14px;
    white-space: nowrap;
  }

  .kotty-table tbody td {
    padding: 12px 14px;
    border-bottom: 1px solid var(--border-light);
    vertical-align: middle;
    color: var(--text-primary);
  }

  .kotty-table tbody tr:last-child td {
    border-bottom: none;
  }

  .kotty-table tbody tr:hover {
    background: var(--cream);
  }

  /* Tabulator Overrides */
  .tabulator {
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    font-family: 'Outfit', sans-serif;
    font-size: 0.875rem;
    background: white;
  }

  .tabulator .tabulator-header {
    background: var(--cream);
    border-bottom: 2px solid var(--border);
  }

  .tabulator .tabulator-header .tabulator-col {
    background: transparent;
    border-right: 1px solid var(--border-light);
  }

  .tabulator .tabulator-header .tabulator-col-content {
    padding: 12px 14px;
  }

  .tabulator .tabulator-header .tabulator-col-title {
    font-weight: 600;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-secondary);
  }

  .tabulator-row {
    border-bottom: 1px solid var(--border-light);
  }

  .tabulator-row:hover {
    background: var(--cream) !important;
  }

  .tabulator-cell {
    padding: 12px 14px !important;
    border-right: none !important;
  }

  .tabulator-footer {
    background: var(--cream);
    border-top: 1px solid var(--border);
  }

  /* Badges */
  .badge-kotty {
    font-family: 'Outfit', sans-serif;
    font-weight: 500;
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .badge-success { background: var(--success-light); color: var(--success); }
  .badge-warning { background: var(--warning-light); color: var(--warning); }
  .badge-danger { background: var(--danger-light); color: var(--danger); }
  .badge-info { background: var(--info-light); color: var(--info); }

  /* SKU Insights Split */
  .sku-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }

  .sku-column h6 {
    font-family: 'Outfit', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .sku-column h6.top { color: var(--success); }
  .sku-column h6.bottom { color: var(--warning); }

  /* Back to Top */
  #backToTop {
    position: fixed;
    bottom: 28px;
    right: 28px;
    width: 48px;
    height: 48px;
    background: var(--terracotta);
    color: white;
    border: none;
    border-radius: 50%;
    display: none;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: var(--shadow-lg);
    transition: all 0.25s ease;
    z-index: 999;
    font-size: 1.1rem;
  }

  #backToTop:hover {
    background: var(--terracotta-dark);
    transform: translateY(-3px);
  }

  /* Modal Overrides */
  .modal-content {
    border: none;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }

  .modal-header {
    border-bottom: 1px solid var(--border);
    padding: 18px 24px;
    background: linear-gradient(180deg, var(--cream) 0%, white 100%);
  }

  .modal-title {
    font-family: 'DM Serif Display', Georgia, serif;
    font-weight: 400;
    font-size: 1.25rem;
    color: var(--charcoal);
  }

  .modal-body {
    padding: 24px;
    font-family: 'Outfit', sans-serif;
  }

  .modal-body p {
    margin-bottom: 10px;
    color: var(--text-secondary);
  }

  .modal-body strong {
    color: var(--charcoal);
  }

  /* Animations */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Responsive */
  @media (max-width: 1200px) {
    .action-categories {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 1024px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .sku-split {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .dashboard-container {
      padding: 20px 16px;
      padding-top: calc(60px + 20px); /* navbar height + spacing */
    }

    .stats-grid {
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .stat-card {
      padding: 18px 20px;
    }

    .stat-value {
      font-size: 2rem;
    }

    .page-title {
      font-size: 1.75rem;
    }

    .category-actions {
      grid-template-columns: repeat(2, 1fr);
    }

    .panel-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  /* Indent Section Styles */
  .indent-section { background: white; border: 1px solid var(--border); border-radius: var(--radius-md); margin-bottom: 24px; overflow: hidden; }
  .indent-toggle { width: 100%; padding: 16px 20px; display: flex; align-items: center; justify-content: space-between; background: var(--cream-dark); border: none; cursor: pointer; font-family: 'DM Serif Display', Georgia, serif; font-size: 1.1rem; color: var(--charcoal); }
  .indent-toggle:hover { background: var(--cream); }
  .indent-toggle i.chevron { transition: transform 0.2s; }
  .indent-toggle.open i.chevron { transform: rotate(180deg); }
  .indent-content { display: none; padding: 20px; border-top: 1px solid var(--border); }
  .indent-content.show { display: block; }
  .indent-card { background: var(--cream); border: 1px solid var(--border-light); border-radius: var(--radius-md); padding: 16px; margin-bottom: 16px; }
  .indent-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
  .indent-title { font-weight: 600; font-size: 0.9rem; color: var(--charcoal); }
  .btn-add-item { padding: 8px 14px; background: var(--terracotta); color: white; border: none; border-radius: var(--radius-sm); font-size: 0.8rem; font-weight: 500; cursor: pointer; }
  .btn-add-item:hover { background: var(--terracotta-dark); }
  .indent-items { display: flex; flex-direction: column; gap: 12px; }
  .indent-item { background: white; border: 1px solid var(--border-light); border-radius: var(--radius-md); padding: 16px; }
  .indent-item-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
  .indent-item-num { font-size: 0.8rem; font-weight: 600; color: var(--text-secondary); }
  .btn-remove-item { padding: 4px 8px; background: transparent; color: var(--danger); border: 1px solid var(--danger); border-radius: var(--radius-sm); font-size: 0.7rem; cursor: pointer; }
  .btn-remove-item:hover { background: var(--danger); color: white; }
  .indent-row { display: grid; grid-template-columns: 1fr 80px; gap: 10px; margin-bottom: 10px; }
  .indent-row.single { grid-template-columns: 1fr; }
  .indent-label { font-size: 0.8rem; font-weight: 500; margin-bottom: 4px; display: block; color: var(--text-secondary); }
  .indent-input { width: 100%; padding: 10px; font-size: 0.9rem; border: 1px solid var(--border); border-radius: var(--radius-sm); font-family: 'Outfit', sans-serif; }
  .indent-input:focus { border-color: var(--terracotta); outline: none; }
  .btn-submit-indent { width: 100%; padding: 14px; background: var(--success); color: white; border: none; border-radius: var(--radius-md); font-size: 0.95rem; font-weight: 600; cursor: pointer; font-family: 'Outfit', sans-serif; }
  .btn-submit-indent:hover:not(:disabled) { opacity: 0.9; }
  .btn-submit-indent:disabled { opacity: 0.6; cursor: not-allowed; }
  .indent-requests-list { margin-top: 16px; }
  .indent-request-item { display: flex; justify-content: space-between; align-items: flex-start; padding: 12px 0; border-bottom: 1px solid var(--border-light); gap: 12px; }
  .indent-request-item:last-child { border-bottom: none; }
  .indent-request-main { flex: 1; min-width: 0; }
  .indent-request-desc { font-size: 0.9rem; font-weight: 500; word-break: break-word; margin-bottom: 4px; }
  .indent-request-meta { font-size: 0.75rem; color: var(--text-muted); }
  .indent-request-lot { color: var(--terracotta); font-weight: 500; }
  .indent-request-status { padding: 4px 10px; border-radius: 20px; font-size: 0.65rem; font-weight: 600; text-transform: uppercase; }
  .indent-request-status.open { background: #fef3c7; color: #9a3412; }
  .indent-request-status.proceeding { background: #cffafe; color: #155e75; }
  .indent-request-status.arrived { background: #d1fae5; color: #065f46; }
  .select2-container--default .select2-selection--single { height: auto; padding: 6px 10px; border: 1px solid var(--border); border-radius: var(--radius-sm); }
</style>

<% const isMohit = (user?.username || '').toLowerCase() === 'mohitoperator'; %>

<div class="dashboard-container">
  <!-- Page Header -->
  <div class="page-header" style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 16px;">
    <div>
      <h1 class="page-title">Operator Dashboard</h1>
      <p class="page-subtitle">Production tracking and management overview</p>
    </div>
    <a href="/dashboard/rejected-lots" class="btn btn-outline-danger" style="display: inline-flex; align-items: center; gap: 8px;">
      <i class="bi bi-x-circle"></i> Rejected Lots
    </a>
  </div>

  <!-- Stats Grid -->
  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-label">Total Kits</div>
      <div class="stat-value"><%= lotCount %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Cut Pieces</div>
      <div class="stat-value"><%= totalPiecesCut %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Finished</div>
      <div class="stat-value"><%= totalFinished %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Users</div>
      <div class="stat-value"><%= userCount %></div>
    </div>
  </div>

  <!-- Info Banner -->
  <div class="info-banner">
    <i class="bi bi-lightbulb"></i>
    <span>Need to update stitching rates? Use the <strong>Rates</strong> action in Management section to download template and upload pricing.</span>
  </div>

  <!-- Indent Section (lot-aware wrapper) -->
  <div class="indent-section">
    <%- include('partials/indentWrapper', { user: user, stage: 'Operator' }) %>
  </div>

  <!-- Quick Actions -->
  <div class="section-header">
    <h2 class="section-title"><i class="bi bi-grid-3x3-gap"></i> Quick Actions</h2>
  </div>

  <div class="action-categories">
    <!-- Production -->
    <div class="action-category">
      <div class="category-header">
        <div class="category-icon production"><i class="bi bi-gear-fill"></i></div>
        <span class="category-title">Production</span>
      </div>
      <div class="category-actions">
        <a href="/operator/dashboard" class="action-card">
          <i class="bi bi-speedometer2"></i>
          <span class="action-card-title">Dashboard</span>
        </a>
        <a href="/operator/day-activity" class="action-card">
          <i class="bi bi-calendar-check"></i>
          <span class="action-card-title">Day Activity</span>
        </a>
        <a href="/operator/lot-tat" class="action-card">
          <i class="bi bi-stopwatch"></i>
          <span class="action-card-title">Lot TAT</span>
        </a>
        <a href="/operator/rewash-download" class="action-card">
          <i class="bi bi-arrow-repeat"></i>
          <span class="action-card-title">Rewash Excel</span>
        </a>
