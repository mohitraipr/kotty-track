<%- include('partials/header', { pageTitle: 'Fabric Manager Dashboard' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/fabric-manager/dashboard' }) %>

<style>
  /* Page-specific styles */
  .page-container {
    padding-top: calc(var(--navbar-height) + 28px);
    padding-bottom: 48px;
    min-height: 100vh;
  }

  .page-wrapper {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Page Header */
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 28px;
  }

  .page-header-left {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .page-icon {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-lg);
    background: var(--terracotta-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--terracotta);
    font-size: 20px;
  }

  .page-header-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  /* Search Section */
  .search-section {
    margin-bottom: 24px;
  }

  .search-row {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    align-items: center;
  }

  .search-form {
    display: flex;
    flex: 1;
    min-width: 280px;
    max-width: 500px;
    gap: 10px;
  }

  .search-form .form-control {
    flex: 1;
    padding: 10px 16px;
    font-size: var(--text-sm);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    background: var(--bg-card);
    transition: all var(--transition-fast);
  }

  .search-form .form-control:focus {
    outline: none;
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px var(--terracotta-bg);
  }

  /* Add Invoice Form Card */
  .add-invoice-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    margin-bottom: 24px;
    overflow: hidden;
  }

  .add-invoice-card .card-header {
    background: var(--gray-50);
    padding: 16px 22px;
    border-bottom: 1px solid var(--border-light);
  }

  .add-invoice-card .card-header h5 {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--text-primary);
    margin: 0;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .add-invoice-card .card-body {
    padding: 22px;
  }

  .form-label {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 6px;
    display: block;
  }

  .form-label .text-danger {
    color: var(--danger);
  }

  .form-control, .form-select {
    width: 100%;
    padding: 10px 14px;
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--text-primary);
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }

  .form-control:hover, .form-select:hover {
    border-color: var(--border-medium);
  }

  .form-control:focus, .form-select:focus {
    outline: none;
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px var(--terracotta-bg);
  }

  /* Table Card */
  .table-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-xs);
  }

  .table-responsive {
    overflow-x: auto;
  }

  .table-responsive::-webkit-scrollbar {
    height: 8px;
  }

  .table-responsive::-webkit-scrollbar-thumb {
    background: var(--gray-300);
    border-radius: var(--radius-full);
  }

  .table-responsive::-webkit-scrollbar-track {
    background: var(--gray-100);
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
  }

  .data-table thead {
    background: var(--gray-50);
  }

  .data-table th {
    padding: 14px 16px;
    text-align: left;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-light);
    white-space: nowrap;
  }

  .data-table th i {
    margin-right: 6px;
    color: var(--terracotta);
  }

  .data-table td {
    padding: 14px 16px;
    font-size: var(--text-sm);
    color: var(--text-primary);
    border-bottom: 1px solid var(--border-light);
  }

  .data-table tbody tr:last-child td {
    border-bottom: none;
  }

  .data-table tbody tr:hover {
    background: var(--gray-50);
  }

  .data-table .empty-row td {
    text-align: center;
    padding: 48px 16px;
    color: var(--text-muted);
    font-style: italic;
  }

  /* Action Buttons in Table */
  .action-buttons {
    display: flex;
    gap: 6px;
  }

  .btn-icon {
    width: 32px;
    height: 32px;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    border: 1px solid transparent;
    cursor: pointer;
    transition: all var(--transition-fast);
    font-size: var(--text-sm);
  }

  .btn-icon-info {
    background: var(--info-light);
    color: var(--info);
    border-color: transparent;
  }

  .btn-icon-info:hover {
    background: var(--info);
    color: white;
  }

  .btn-icon-secondary {
    background: var(--gray-100);
    color: var(--text-secondary);
    border-color: transparent;
  }

  .btn-icon-secondary:hover {
    background: var(--gray-200);
    color: var(--text-primary);
  }

  /* Pagination */
  .pagination-wrapper {
    padding: 16px 22px;
    display: flex;
    justify-content: center;
    border-top: 1px solid var(--border-light);
  }

  .pagination {
    display: flex;
    gap: 8px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .page-item .page-link {
    padding: 8px 14px;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-secondary);
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .page-item .page-link:hover:not(.disabled) {
    border-color: var(--terracotta);
    color: var(--terracotta);
    background: var(--terracotta-bg);
  }

  .page-item.disabled .page-link {
    color: var(--text-muted);
    pointer-events: none;
    opacity: 0.6;
  }

  /* Bottom Action Buttons */
  .bottom-actions {
    margin-top: 28px;
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 12px;
  }

  /* Print Styles */
  @media print {
    .no-print {
      display: none !important;
    }
    .page-container {
      padding-top: 0;
    }
    .kotty-navbar {
      display: none !important;
    }
    .table-card {
      box-shadow: none;
      border: 1px solid #ddd;
    }
  }

  /* Responsive */
  @media (max-width: 768px) {
    .page-wrapper {
      padding: 0 16px;
    }

    .page-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .page-header-actions {
      width: 100%;
    }

    .search-form {
      max-width: 100%;
      width: 100%;
    }

    .search-row {
      flex-direction: column;
      align-items: stretch;
    }

    .bottom-actions {
      flex-direction: column;
    }

    .bottom-actions .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<div class="page-container">
  <div class="page-wrapper">
    <!-- Flash Messages -->
    <%- include('partials/flashMessages') %>

    <!-- Page Header -->
    <div class="page-header">
      <div class="page-header-left">
        <div class="page-icon">
          <i class="bi bi-layers"></i>
        </div>
        <div>
          <h1 class="page-title">Fabric Invoices</h1>
          <p class="page-subtitle">Manage and track fabric invoices</p>
        </div>
      </div>
      <div class="page-header-actions no-print">
        <a href="/fabric-manager/download-excel?search=<%= encodeURIComponent(searchTerm) %>" class="btn btn-success btn-sm">
          <i class="bi bi-download"></i> Download Excel
        </a>
        <button class="btn btn-secondary btn-sm" onclick="window.print()">
          <i class="bi bi-printer"></i> Print
        </button>
      </div>
    </div>

    <!-- Search and Add Invoice Section -->
    <div class="search-section no-print">
      <div class="search-row">
        <!-- Search Form -->
        <form class="search-form" method="GET" action="/fabric-manager/dashboard">
          <input type="hidden" name="search" value="<%= searchTerm %>" />
          <input
            type="text"
            name="search"
            class="form-control"
            placeholder="Search by Invoice No or Vendor Name..."
            value="<%= searchTerm %>"
            aria-label="Search"
          />
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-search"></i> Search
          </button>
        </form>
        <!-- Add Invoice Button -->
        <button class="btn btn-outline" data-bs-toggle="collapse" data-bs-target="#addInvoiceForm" aria-expanded="false" aria-controls="addInvoiceForm">
          <i class="bi bi-plus-circle"></i> Add New Invoice
        </button>
      </div>
    </div>

    <!-- Insert New Fabric Invoice Form (Collapsible) -->
    <div class="collapse no-print" id="addInvoiceForm">
      <div class="add-invoice-card">
        <div class="card-header">
          <h5><i class="bi bi-plus-circle text-terracotta"></i> Insert New Fabric Invoice</h5>
        </div>
        <div class="card-body">
          <form action="/fabric-manager/insert/invoice" method="POST" class="row g-3">
            <div class="col-md-6">
              <label for="invoice_no" class="form-label">Invoice Number <span class="text-danger">*</span></label>
              <input type="text" class="form-control" id="invoice_no" name="invoice_no" required>
            </div>
            <div class="col-md-6">
              <label for="vendor_id" class="form-label">Vendor <span class="text-danger">*</span></label>
              <select class="form-select" id="vendor_id" name="vendor_id" required>
                <option value="">Select Vendor</option>
                <% vendors.forEach(vendor => { %>
                  <option value="<%= vendor.id %>"><%= vendor.name %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-6">
              <label for="date_invoice" class="form-label">Date Invoice <span class="text-danger">*</span></label>
              <input type="date" class="form-control" id="date_invoice" name="date_invoice" required>
            </div>
            <div class="col-md-6">
              <label for="date_received" class="form-label">Date Received <span class="text-danger">*</span></label>
              <input type="date" class="form-control" id="date_received" name="date_received" required>
            </div>
            <div class="col-md-4">
              <label for="total_roll_quantity" class="form-label">Total Roll Quantity <span class="text-danger">*</span></label>
              <input type="number" class="form-control" id="total_roll_quantity" name="total_roll_quantity" min="1" required>
            </div>
            <div class="col-md-4">
              <label for="fabric_type" class="form-label">Fabric Type</label>
              <input type="text" class="form-control" id="fabric_type" name="fabric_type">
            </div>
            <div class="col-md-4">
              <label for="invoice_weight" class="form-label">Invoice Weight</label>
              <input type="number" step="0.01" class="form-control" id="invoice_weight" name="invoice_weight">
            </div>
            <div class="col-md-4">
              <label for="received_weight" class="form-label">Received Weight</label>
              <input type="number" step="0.01" class="form-control" id="received_weight" name="received_weight">
            </div>
            <div class="col-md-8 d-flex align-items-end gap-2 flex-wrap">
              <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg"></i> Insert Invoice
              </button>
              <a href="/fabric-manager/bulk-upload" class="btn btn-secondary">
                <i class="bi bi-upload"></i> Bulk Upload Invoices
              </a>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- Fabric Invoices Table -->
    <div class="table-card">
      <div class="table-responsive">
        <table class="data-table">
          <thead>
            <tr>
              <th><i class="bi bi-hash"></i> ID</th>
              <th><i class="bi bi-file-text"></i> Invoice No</th>
              <th><i class="bi bi-truck"></i> Vendor Name</th>
              <th><i class="bi bi-calendar"></i> Date Invoice</th>
              <th><i class="bi bi-calendar-check"></i> Date Received</th>
              <th><i class="bi bi-box"></i> Total Rolls</th>
              <th><i class="bi bi-tag"></i> Fabric Type</th>
              <th><i class="bi bi-speedometer2"></i> Invoice Weight</th>
              <th><i class="bi bi-dash-circle"></i> Short Weight</th>
              <th><i class="bi bi-check-circle"></i> Received Weight</th>
              <th><i class="bi bi-person"></i> Created By</th>
              <th class="no-print"><i class="bi bi-gear"></i> Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (fabricInvoices.length === 0) { %>
              <tr class="empty-row">
                <td colspan="12">
                  <div class="empty-state">
                    <i class="bi bi-inbox" style="font-size: 48px; color: var(--text-muted); display: block; margin-bottom: 12px;"></i>
                    No Fabric Invoices Found
                  </div>
                </td>
              </tr>
            <% } else { %>
              <% fabricInvoices.forEach(invoice => { %>
                <tr>
                  <td><strong><%= invoice.id %></strong></td>
                  <td><span class="badge badge-primary"><%= invoice.invoice_no %></span></td>
                  <td><%= invoice.vendor_name %></td>
                  <td><%= invoice.date_invoice.toLocaleDateString('en-CA') %></td>
                  <td><%= invoice.date_received.toLocaleDateString('en-CA') %></td>
                  <td><%= invoice.total_roll_quantity %></td>
                  <td><%= invoice.fabric_type || 'N/A' %></td>
                  <td><%= invoice.invoice_weight || 'N/A' %></td>
                  <td><%= invoice.short_weight || 'N/A' %></td>
                  <td><%= invoice.received_weight || 'N/A' %></td>
                  <td><%= invoice.created_by %></td>
                  <td class="no-print">
                    <div class="action-buttons">
                      <a href="/fabric-manager/invoice/<%= invoice.id %>/rolls" class="btn-icon btn-icon-info" title="View Rolls" data-bs-toggle="tooltip">
                        <i class="bi bi-eye"></i>
                      </a>
                      <a href="/fabric-manager/invoice/<%= invoice.id %>/download-rolls" class="btn-icon btn-icon-secondary" title="Download Rolls" data-bs-toggle="tooltip">
                        <i class="bi bi-download"></i>
                      </a>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if (totalPages && totalPages > 1) { %>
        <div class="pagination-wrapper">
          <ul class="pagination">
            <li class="page-item <%= (currentPage <= 1) ? 'disabled' : '' %>">
              <a
                class="page-link"
                href="/fabric-manager/dashboard?search=<%= encodeURIComponent(searchTerm) %>&page=<%= currentPage - 1 %>"
                aria-label="Previous"
              >
                <i class="bi bi-chevron-left"></i> Previous
              </a>
            </li>
            <li class="page-item disabled">
              <span class="page-link">
                Page <%= currentPage %> of <%= totalPages %>
              </span>
            </li>
            <li class="page-item <%= (currentPage >= totalPages) ? 'disabled' : '' %>">
              <a
                class="page-link"
                href="/fabric-manager/dashboard?search=<%= encodeURIComponent(searchTerm) %>&page=<%= currentPage + 1 %>"
                aria-label="Next"
              >
                Next <i class="bi bi-chevron-right"></i>
              </a>
            </li>
          </ul>
        </div>
      <% } %>
    </div>

    <!-- Bottom Action Buttons -->
    <div class="bottom-actions no-print">
      <a href="/fabric-manager/bulk-upload" class="btn btn-outline">
        <i class="bi bi-upload"></i> Bulk Upload Fabric Invoices
      </a>
      <a href="/fabric-manager/bulk-upload/rolls" class="btn btn-secondary">
        <i class="bi bi-upload"></i> Bulk Upload Fabric Invoice Rolls
      </a>
      <a href="/fabric-manager/view" class="btn btn-primary">
        <i class="bi bi-eye"></i> Advanced View
      </a>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
