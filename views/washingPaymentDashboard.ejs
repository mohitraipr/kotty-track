<%- include('partials/header', { pageTitle: 'Washing Payments' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/washingdashboard' }) %>

<style>
  /* Page-specific styles */
  .content-wrapper {
    margin-top: var(--navbar-height);
    padding: 28px;
    min-height: calc(100vh - var(--navbar-height));
    background: var(--bg-page);
  }

  .page-header {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    margin-bottom: 28px;
  }

  .page-header-left {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    color: var(--text-primary);
    margin: 0;
  }

  .page-subtitle {
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .page-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* Search Section */
  .search-section {
    margin-bottom: 28px;
  }

  .search-wrapper {
    display: flex;
    max-width: 400px;
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--transition-fast);
  }

  .search-wrapper:focus-within {
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px var(--terracotta-bg);
  }

  .search-input {
    flex: 1;
    padding: 12px 16px;
    border: none;
    background: transparent;
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--text-primary);
    outline: none;
  }

  .search-input::placeholder {
    color: var(--text-muted);
  }

  .search-btn {
    padding: 12px 18px;
    background: var(--terracotta);
    border: none;
    color: white;
    cursor: pointer;
    transition: background var(--transition-fast);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .search-btn:hover {
    background: var(--terracotta-dark);
  }

  /* Washer Grid */
  .washer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }

  /* Washer Card */
  .washer-card-wrapper {
    display: block;
  }

  .washer-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--transition-fast);
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .washer-card:hover {
    border-color: var(--border-medium);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .washer-card-header {
    padding: 18px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--border-light);
    background: var(--gray-50);
  }

  .washer-info {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
    flex: 1;
  }

  .washer-avatar {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    background: var(--terracotta-bg);
    color: var(--terracotta);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
  }

  .washer-name {
    font-weight: 500;
    font-size: var(--text-base);
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .lot-count-badge {
    background: var(--info-light);
    color: var(--info);
    padding: 4px 10px;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 500;
    white-space: nowrap;
  }

  .washer-card-body {
    padding: 16px 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .view-lots-btn {
    width: 100%;
    padding: 10px 16px;
    background: transparent;
    border: 1px solid var(--terracotta);
    color: var(--terracotta);
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: all var(--transition-fast);
    margin-top: auto;
  }

  .view-lots-btn:hover {
    background: var(--terracotta-bg);
  }

  .view-lots-btn[aria-expanded="true"] {
    background: var(--terracotta);
    color: white;
  }

  .view-lots-btn[aria-expanded="true"]:hover {
    background: var(--terracotta-dark);
  }

  /* Lots Container */
  .lots-collapse {
    border-top: 1px solid var(--border-light);
    background: var(--gray-50);
  }

  .lot-container {
    padding: 16px 20px;
  }

  /* Lots Table */
  .lots-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
    margin-bottom: 12px;
  }

  .lots-table thead {
    background: var(--cream-dark);
  }

  .lots-table th {
    padding: 10px 12px;
    text-align: left;
    font-weight: 600;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-light);
  }

  .lots-table td {
    padding: 10px 12px;
    border-bottom: 1px solid var(--border-light);
    color: var(--text-primary);
  }

  .lots-table tbody tr:last-child td {
    border-bottom: none;
  }

  .lots-table tbody tr:hover {
    background: var(--cream);
  }

  .lot-checkbox {
    width: 18px;
    height: 18px;
    accent-color: var(--terracotta);
    cursor: pointer;
  }

  .proceed-btn {
    width: 100%;
    padding: 10px 16px;
    background: var(--success);
    border: none;
    color: white;
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: all var(--transition-fast);
  }

  .proceed-btn:hover {
    background: #247a50;
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
  }

  /* Loading & Empty States */
  .loading-state,
  .empty-state-inline {
    text-align: center;
    padding: 20px;
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  .loading-state i {
    animation: spin 1s linear infinite;
    margin-right: 8px;
  }

  .error-state {
    text-align: center;
    padding: 20px;
    color: var(--danger);
    font-size: var(--text-sm);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .content-wrapper {
      padding: 20px 16px;
    }

    .page-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .page-actions {
      width: 100%;
    }

    .page-actions .btn {
      flex: 1;
      justify-content: center;
    }

    .search-wrapper {
      max-width: 100%;
    }

    .washer-grid {
      grid-template-columns: 1fr;
    }

    .page-title {
      font-size: var(--text-2xl);
    }
  }
</style>

<div class="content-wrapper">
  <!-- Page Header -->
  <div class="page-header">
    <div class="page-header-left">
      <h1 class="page-title">Washing Payments</h1>
      <p class="page-subtitle">Manage payment records for washers</p>
    </div>
    <div class="page-actions">
      <a href="/washingdashboard/payments/invoices" class="btn btn-secondary">
        <i class="bi bi-receipt"></i>
        Invoices
      </a>
      <a href="/operator" class="btn btn-outline">
        <i class="bi bi-arrow-left"></i>
        Back
      </a>
    </div>
  </div>

  <!-- Search Section -->
  <div class="search-section">
    <div class="search-wrapper">
      <input type="text" class="search-input" placeholder="Search washer by name..." id="searchWasher">
      <button class="search-btn" type="button" id="searchBtn" title="Search washers">
        <i class="bi bi-search"></i>
      </button>
    </div>
  </div>

  <!-- Washer Cards Grid -->
  <div class="washer-grid" id="washerList">
    <% washers.forEach(function(w){ %>
      <div class="washer-card-wrapper" data-washer-name="<%= w.username.toLowerCase() %>" data-washer-id="<%= w.id %>">
        <div class="washer-card">
          <div class="washer-card-header">
            <div class="washer-info">
              <div class="washer-avatar">
                <i class="bi bi-person-fill"></i>
              </div>
              <span class="washer-name" title="<%= w.username %>"><%= w.username %></span>
            </div>
            <span class="lot-count-badge" id="count-<%= w.id %>"><%= w.lot_count %> lots</span>
          </div>
          <div class="washer-card-body">
            <button
              class="view-lots-btn"
              data-bs-toggle="collapse"
              data-bs-target="#lots-<%= w.id %>"
              aria-expanded="false"
              aria-controls="lots-<%= w.id %>"
              title="View lots for <%= w.username %>">
              <i class="bi bi-eye"></i>
              <span>View Lots</span>
            </button>
          </div>
          <div id="lots-<%= w.id %>" class="collapse lots-collapse" data-loaded="false">
            <div class="lot-container">
              <div class="loading-state">
                <i class="bi bi-arrow-repeat"></i>
                Select to view lots
              </div>
            </div>
          </div>
        </div>
      </div>
    <% }); %>
  </div>
</div>

<%- include('partials/footer') %>

<script>
  // Search functionality
  function filterWashers() {
    const q = document.getElementById('searchWasher').value.toLowerCase();
    document.querySelectorAll('.washer-card-wrapper').forEach(card => {
      const name = card.dataset.washerName;
      card.style.display = name.includes(q) ? '' : 'none';
    });
  }

  document.getElementById('searchBtn').addEventListener('click', filterWashers);
  document.getElementById('searchWasher').addEventListener('keydown', function(e){
    if (e.key === 'Enter') {
      e.preventDefault();
      filterWashers();
    }
  });

  // Live search on input
  document.getElementById('searchWasher').addEventListener('input', filterWashers);

  // Load lots on first expansion
  document.querySelectorAll('.lots-collapse').forEach(col => {
    col.addEventListener('show.bs.collapse', async function () {
      if (this.dataset.loaded === 'true') return;
      const washerId = this.id.split('-')[1];
      const container = this.querySelector('.lot-container');
      container.textContent = '';

      // Create loading state
      const loadingDiv = document.createElement('div');
      loadingDiv.className = 'loading-state';
      loadingDiv.innerHTML = '<i class="bi bi-arrow-repeat"></i> Loading lots...';
      container.appendChild(loadingDiv);

      try {
        const res = await fetch('/washingdashboard/payments/washer/' + washerId + '/lots');
        const data = await res.json();

        // Clear container
        container.textContent = '';

        if (!data.lots.length) {
          const emptyDiv = document.createElement('div');
          emptyDiv.className = 'empty-state-inline';
          emptyDiv.innerHTML = '<i class="bi bi-inbox"></i> No pending lots.';
          container.appendChild(emptyDiv);
          this.dataset.loaded = 'true';
          return;
        }

        // Create form
        const form = document.createElement('form');
        form.className = 'lotForm';

        // Create table
        const table = document.createElement('table');
        table.className = 'lots-table';

        // Create thead
        const thead = document.createElement('thead');
        const headerRow = document.createElement('tr');
        ['Lot No', 'Qty', 'Select'].forEach(text => {
          const th = document.createElement('th');
          th.textContent = text;
          headerRow.appendChild(th);
        });
        thead.appendChild(headerRow);
        table.appendChild(thead);

        // Create tbody
        const tbody = document.createElement('tbody');
        data.lots.forEach(l => {
          const tr = document.createElement('tr');

          const tdLot = document.createElement('td');
          tdLot.textContent = l.lot_no;
          tr.appendChild(tdLot);

          const tdQty = document.createElement('td');
          tdQty.textContent = l.total_pieces;
          tr.appendChild(tdQty);

          const tdSelect = document.createElement('td');
          const checkbox = document.createElement('input');
          checkbox.type = 'checkbox';
          checkbox.className = 'lot-checkbox';
          checkbox.name = 'lotIds';
          checkbox.value = l.id;
          tdSelect.appendChild(checkbox);
          tr.appendChild(tdSelect);

          tbody.appendChild(tr);
        });
        table.appendChild(tbody);
        form.appendChild(table);

        // Create proceed button
        const proceedBtn = document.createElement('button');
        proceedBtn.type = 'button';
        proceedBtn.className = 'proceed-btn';
        proceedBtn.innerHTML = '<i class="bi bi-arrow-right-circle"></i> Proceed to Payment';
        proceedBtn.addEventListener('click', function(){
          const ids = Array.from(form.querySelectorAll('input[name="lotIds"]:checked')).map(c=>c.value);
          if(!ids.length) {
            if (window.KottyTrack && window.KottyTrack.showToast) {
              window.KottyTrack.showToast('Please select at least one lot', 'warning');
            } else {
              alert('Please select at least one lot');
            }
            return;
          }
          window.location.href = '/washingdashboard/payments/summary?ids=' + ids.join(',');
        });
        form.appendChild(proceedBtn);

        container.appendChild(form);
        this.dataset.loaded = 'true';
      } catch (err) {
        container.textContent = '';
        const errorDiv = document.createElement('div');
        errorDiv.className = 'error-state';
        errorDiv.innerHTML = '<i class="bi bi-exclamation-triangle"></i> Failed to load lots';
        container.appendChild(errorDiv);
      }
    });
  });

  // Update button icon on collapse toggle
  document.querySelectorAll('.view-lots-btn').forEach(btn => {
    const collapseEl = document.querySelector(btn.dataset.bsTarget);
    if (collapseEl) {
      collapseEl.addEventListener('show.bs.collapse', () => {
        const icon = btn.querySelector('i');
        icon.classList.remove('bi-eye');
        icon.classList.add('bi-eye-slash');
        btn.querySelector('span').textContent = 'Hide Lots';
      });
      collapseEl.addEventListener('hide.bs.collapse', () => {
        const icon = btn.querySelector('i');
        icon.classList.remove('bi-eye-slash');
        icon.classList.add('bi-eye');
        btn.querySelector('span').textContent = 'View Lots';
      });
    }
  });
</script>
