<%- include('partials/header', { pageTitle: 'Stitching & Finishing Challan' }) %>
<%- include('partials/navbar', { user: typeof user !== 'undefined' ? user : { username: 'Guest' }, dashboardUrl: '/dashboard' }) %>

<!-- Print-specific styles -->
<style>
  /* A4 page settings for printing */
  @page {
    size: A4;
    margin: 10mm;
  }

  @media print {
    /* Hide non-printable elements */
    .kotty-navbar,
    .sidebar-overlay,
    .action-buttons,
    .no-print {
      display: none !important;
    }

    /* Reset body for print */
    body {
      background: white !important;
      padding: 0 !important;
      margin: 0 !important;
    }

    .main-content {
      margin: 0 !important;
      padding: 0 !important;
    }

    .challan-container {
      box-shadow: none !important;
      border: 2px solid #1a1a1a !important;
      margin: 0 !important;
      max-width: 100% !important;
      page-break-inside: avoid;
    }
  }

  /* Challan-specific styles */
  .challan-container {
    max-width: 800px;
    margin: 0 auto;
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    padding: 32px;
    border: 1px solid var(--border-light);
  }

  .company-header {
    text-align: center;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 2px solid var(--terracotta);
  }

  .company-header h1 {
    font-family: var(--font-display);
    font-size: 28px;
    color: var(--charcoal);
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .company-header p {
    margin: 4px 0;
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .challan-title {
    text-align: center;
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--terracotta);
    text-transform: uppercase;
    margin: 20px 0;
    padding: 12px;
    background: var(--terracotta-bg);
    border-radius: var(--radius-md);
  }

  /* Info table for challan details */
  .info-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 24px;
  }

  .info-table td {
    vertical-align: top;
    padding: 8px 12px;
    font-size: var(--text-sm);
  }

  .info-table .label {
    width: 35%;
    font-weight: 500;
    color: var(--text-secondary);
    white-space: nowrap;
  }

  .info-table .value {
    width: 65%;
    color: var(--text-primary);
    font-weight: 500;
  }

  /* Data tables (Sizes, etc.) */
  .data-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 24px;
    font-size: var(--text-sm);
  }

  .data-table th,
  .data-table td {
    border: 1px solid var(--border-medium);
    padding: 10px 12px;
    text-align: left;
  }

  .data-table th {
    background: var(--cream-dark);
    font-weight: 600;
    color: var(--charcoal);
  }

  .data-table td {
    background: var(--bg-card);
  }

  .data-table caption {
    margin-bottom: 8px;
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 500;
    text-transform: uppercase;
    text-align: left;
    color: var(--charcoal);
  }

  .total-row {
    font-weight: 600;
    background: var(--cream) !important;
  }

  /* Section headings */
  .section-heading {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    margin-top: 28px;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border-light);
    color: var(--charcoal);
  }

  /* Assignments & Updates */
  .assignment-card {
    background: var(--gray-50);
    border-radius: var(--radius-md);
    padding: 16px;
    margin-bottom: 12px;
    border-left: 3px solid var(--terracotta);
  }

  .assignment-card p {
    margin: 6px 0;
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .assignment-card strong {
    color: var(--text-primary);
    font-weight: 500;
  }

  .status-badge {
    display: inline-block;
    padding: 4px 10px;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
  }

  .status-pending {
    background: var(--warning-light);
    color: var(--warning);
  }

  .status-approved {
    background: var(--success-light);
    color: var(--success);
  }

  .status-denied {
    background: var(--danger-light);
    color: var(--danger);
  }

  .empty-text {
    color: var(--text-muted);
    font-style: italic;
    font-size: var(--text-sm);
  }

  /* Signatures */
  .signature-section {
    margin-top: 40px;
    display: flex;
    justify-content: space-between;
  }

  .signature-box {
    width: 45%;
    text-align: center;
  }

  .signature-box p {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-secondary);
    margin-bottom: 8px;
  }

  .signature-line {
    margin-top: 50px;
    border-top: 1px solid var(--charcoal);
    padding-top: 8px;
  }

  /* Action buttons */
  .action-buttons {
    text-align: center;
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid var(--border-light);
  }

  .btn-print {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background: var(--terracotta);
    color: white;
    border: none;
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    cursor: pointer;
    transition: all var(--transition-fast);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .btn-print:hover {
    background: var(--terracotta-dark);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  .btn-print i {
    font-size: 18px;
  }
</style>

<!-- Main Content Area -->
<main class="main-content" style="margin-left: 0;">
  <div class="container-fluid py-4" style="max-width: 900px; margin: 0 auto;">

    <div class="challan-container">
      <!-- Company Header -->
      <div class="company-header">
        <h1>Kotty Lifestyle Private Limited</h1>
        <p>GB-65, Bharat Vihar, Lakkarpur, Faridabad, 121009</p>
        <p>Mobile: 8920374028 | GSTIN: 06AAGCK0951K1ZH</p>
      </div>

      <div class="challan-title">Stitching to Finishing / Jeans Assembly Challan</div>

      <!-- Basic Challan Info -->
      <table class="info-table">
        <tr>
          <td class="label">Challan Date:</td>
          <td class="value">
            <% if (finishingAssignments && finishingAssignments.length > 0) { %>
              <%= finishingAssignments[0].assigned_on %>
            <% } else if (jeansAssignments && jeansAssignments.length > 0) { %>
              <%= jeansAssignments[0].assigned_on %>
            <% } else { %>
              ---
            <% } %>
          </td>
        </tr>
        <tr>
          <td class="label">Lot No:</td>
          <td class="value"><%= entry.lot_no %></td>
        </tr>
        <tr>
          <td class="label">SKU Number:</td>
          <td class="value"><%= entry.sku %></td>
        </tr>
        <tr>
          <td class="label">Assigned To:</td>
          <td class="value">
            <% if (finishingAssignments && finishingAssignments.length > 0) { %>
              <%= finishingAssignments[0].assignedUserName %>
            <% } else if (jeansAssignments && jeansAssignments.length > 0) { %>
              <%= jeansAssignments[0].assignedUserName %>
            <% } else { %>
              ---
            <% } %>
          </td>
        </tr>
        <tr>
          <td class="label">Entry ID:</td>
          <td class="value">#<%= entry.id %></td>
        </tr>
      </table>

      <!-- Size Details -->
      <table class="data-table">
        <caption>Size Details</caption>
        <thead>
          <tr>
            <th>Size Label</th>
            <th>Pieces</th>
          </tr>
        </thead>
        <tbody>
          <% sizes.forEach(sz => { %>
            <tr>
              <td><%= sz.size_label %></td>
              <td><%= sz.pieces %></td>
            </tr>
          <% }) %>
          <tr class="total-row">
            <td><strong>Total</strong></td>
            <td><strong><%= entry.total_pieces %></strong></td>
          </tr>
        </tbody>
      </table>

      <!-- Finishing Assignments -->
      <div class="section-heading">Finishing Assignments</div>
      <% if (finishingAssignments && finishingAssignments.length > 0) { %>
        <% finishingAssignments.forEach(fa => { %>
          <div class="assignment-card">
            <p><strong>Assigned To:</strong> <%= fa.assignedUserName %></p>
            <p><strong>Assigned By:</strong> <%= fa.masterUserName %></p>
            <p>
              <strong>Status:</strong>
              <% if (fa.is_approved === null) { %>
                <span class="status-badge status-pending">Pending</span>
              <% } else if (fa.is_approved === 1) { %>
                <span class="status-badge status-approved">Approved</span>
              <% } else { %>
                <span class="status-badge status-denied">Denied</span>
              <% } %>
            </p>
            <p><strong>Assigned On:</strong> <%= fa.assigned_on %></p>
            <p><strong>Target Day:</strong> <%= fa.target_day || 'N/A' %></p>
          </div>
        <% }) %>
      <% } else { %>
        <p class="empty-text">No finishing assignments found.</p>
      <% } %>

      <!-- Jeans Assembly Assignments -->
      <div class="section-heading">Jeans Assembly Assignments</div>
      <% if (jeansAssignments && jeansAssignments.length > 0) { %>
        <% jeansAssignments.forEach(ja => { %>
          <div class="assignment-card">
            <p><strong>Assigned To:</strong> <%= ja.assignedUserName %></p>
            <p><strong>Assigned By:</strong> <%= ja.masterUserName %></p>
            <p>
              <strong>Status:</strong>
              <% if (ja.is_approved === null) { %>
                <span class="status-badge status-pending">Pending</span>
              <% } else if (ja.is_approved === 1) { %>
                <span class="status-badge status-approved">Approved</span>
              <% } else { %>
                <span class="status-badge status-denied">Denied</span>
              <% } %>
            </p>
            <p><strong>Assigned On:</strong> <%= ja.assigned_on %></p>
            <p><strong>Target Day:</strong> <%= ja.target_day || 'N/A' %></p>
          </div>
        <% }) %>
      <% } else { %>
        <p class="empty-text">No jeans assembly assignments found.</p>
      <% } %>

      <!-- Update Logs -->
      <div class="section-heading">Update Logs</div>
      <% if (updates && updates.length) { %>
        <table class="data-table">
          <thead>
            <tr>
              <th>Size</th>
              <th>Pieces Added</th>
              <th>Updated At</th>
            </tr>
          </thead>
          <tbody>
            <% updates.forEach(u => { %>
              <tr>
                <td><%= u.size_label %></td>
                <td>+<%= u.pieces %></td>
                <td><%= u.updated_at %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <p class="empty-text">No updates found.</p>
      <% } %>

      <!-- Signature Section -->
      <div class="signature-section">
        <div class="signature-box">
          <p>Receiver's Signature</p>
          <div class="signature-line"></div>
        </div>
        <div class="signature-box">
          <p>Authorized Signatory</p>
          <div class="signature-line"></div>
        </div>
      </div>

      <!-- Print Button -->
      <div class="action-buttons no-print">
        <button class="btn-print" onclick="window.print()">
          <i class="bi bi-printer"></i>
          Print / Save as PDF
        </button>
      </div>

    </div><!-- .challan-container -->

  </div>
</main>

<%- include('partials/footer') %>
