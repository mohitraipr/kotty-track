<%- include('partials/header', { pageTitle: 'Inventory Alert Configuration' }) %>
<%- include('partials/navbar', { user: typeof user !== 'undefined' ? user : {} }) %>

<main class="main-content" style="margin-left: 0;">
  <div class="container-fluid" style="max-width: 1000px; margin: 0 auto;">
    <!-- Page Header -->
    <div class="page-header">
      <h1 class="page-title">Inventory Alert Configuration</h1>
      <p class="page-subtitle">Set custom stock thresholds for SKU-level notifications</p>
    </div>

    <!-- Flash Messages -->
    <% if (error && error.length > 0) { %>
      <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle me-2"></i>
        <%= error[0] %>
      </div>
    <% } %>
    <% if (success && success.length > 0) { %>
      <div class="alert alert-success">
        <i class="bi bi-check-circle me-2"></i>
        <%= success[0] %>
      </div>
    <% } %>

    <!-- Configuration Card -->
    <div class="card mb-4">
      <div class="card-header">
        <h2 class="card-title">
          <i class="bi bi-sliders me-2"></i>
          Add SKU Thresholds
        </h2>
      </div>
      <div class="card-body">
        <form method="POST" action="/webhook/config">
          <div class="form-group">
            <label for="rules" class="form-label">SKU Thresholds</label>
            <p class="text-secondary mb-2" style="font-size: var(--text-sm);">
              Enter one threshold per line in the format <code class="code-inline">SKU:THRESHOLD</code>
            </p>
            <textarea
              class="form-control form-textarea"
              id="rules"
              name="rules"
              rows="5"
              placeholder="ABC123:10&#10;XYZ789:5&#10;DEF456:15"
            ><%= configText %></textarea>
            <div class="form-text mt-2">
              <i class="bi bi-info-circle me-1"></i>
              Example: <code class="code-inline">ABC123:10</code> will alert when ABC123 stock falls to 10 or below.
            </div>
          </div>
          <div class="d-flex flex-wrap gap-2 mt-3">
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-save me-1"></i>
              Save Thresholds
            </button>
          </div>
        </form>

        <form method="POST" action="/webhook/config/remove-all" class="mt-3" onsubmit="return confirm('Remove all thresholds?');">
          <button type="submit" class="btn btn-outline" style="border-color: var(--warning); color: var(--warning);">
            <i class="bi bi-trash me-1"></i>
            Remove All Thresholds
          </button>
        </form>
      </div>
    </div>

    <!-- Existing Thresholds Card -->
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">
          <i class="bi bi-list-check me-2"></i>
          Existing Thresholds
        </h2>
        <span class="badge badge-neutral"><%= Object.keys(thresholds || {}).length %> configured</span>
      </div>
      <div class="card-body p-0">
        <% if (!thresholds || Object.keys(thresholds).length === 0) { %>
          <div class="empty-state">
            <div class="empty-state-icon">
              <i class="bi bi-bell-slash" style="font-size: 48px;"></i>
            </div>
            <h3 class="empty-state-title">No Thresholds Configured</h3>
            <p class="empty-state-text">Add SKU thresholds above to receive stock level alerts.</p>
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table mb-0">
              <thead>
                <tr>
                  <th style="width: 50%;">SKU</th>
                  <th style="width: 30%;">Threshold</th>
                  <th style="width: 20%;">Action</th>
                </tr>
              </thead>
              <tbody>
                <% for (const [sku, th] of Object.entries(thresholds || {})) { %>
                  <tr>
                    <td>
                      <span class="sku-code"><%= sku %></span>
                    </td>
                    <td>
                      <span class="badge badge-info">
                        <i class="bi bi-bell me-1"></i>
                        Alert at <%= th %>
                      </span>
                    </td>
                    <td>
                      <form method="POST" action="/webhook/config/remove" onsubmit="return confirm('Remove ' + '<%= sku %>' + '?');" style="display: inline;">
                        <input type="hidden" name="sku" value="<%= sku %>">
                        <button type="submit" class="btn btn-sm btn-danger">
                          <i class="bi bi-trash"></i>
                          <span class="d-none d-sm-inline ms-1">Remove</span>
                        </button>
                      </form>
                    </td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</main>

<style>
  /* Page-specific styles */
  .main-content {
    padding-top: 28px;
    padding-bottom: 40px;
  }

  /* Code inline styling */
  .code-inline {
    background: var(--gray-100);
    color: var(--terracotta);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono, monospace);
    font-size: var(--text-sm);
  }

  /* SKU code styling */
  .sku-code {
    font-family: var(--font-mono, monospace);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-primary);
  }

  /* Textarea enhancements */
  .form-textarea {
    font-family: var(--font-mono, monospace);
    font-size: var(--text-sm);
    line-height: 1.6;
    resize: vertical;
    min-height: 120px;
  }

  .form-textarea:focus {
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px var(--terracotta-bg);
  }

  /* Form text styling */
  .form-text {
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  /* Table row hover */
  .table tbody tr:hover {
    background: var(--gray-50);
  }

  /* Button enhancements */
  .btn-outline:hover {
    background: var(--warning-light);
    border-color: var(--warning);
    color: var(--warning);
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .card-body {
      padding: 16px;
    }

    .form-textarea {
      min-height: 100px;
    }
  }
</style>

<%- include('partials/footer') %>
