<%- include('partials/header', { pageTitle: 'Cutting Manager Dashboard' }) %>
<!-- Select2 for indent item search -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<%- include('partials/navbar', { user: user, dashboardUrl: '/cutting-manager/dashboard' }) %>

<style>
  .page-container {
    padding-top: calc(var(--navbar-height) + 24px);
    padding-bottom: 48px;
    min-height: 100vh;
  }
  .page-header { margin-bottom: 24px; }
  .page-title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    color: var(--text-primary);
    margin-bottom: 8px;
  }
  .page-subtitle { color: var(--text-secondary); font-size: var(--text-base); }
  .kotty-tabs {
    display: flex;
    gap: 8px;
    border-bottom: 2px solid var(--border-light);
    margin-bottom: 24px;
    flex-wrap: wrap;
  }
  .kotty-tab {
    padding: 12px 20px;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--text-sm);
    color: var(--text-secondary);
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    cursor: pointer;
    transition: var(--transition-base);
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
  }
  .kotty-tab:hover { color: var(--terracotta); }
  .kotty-tab.active { color: var(--terracotta); border-bottom-color: var(--terracotta); }
  .kotty-tab i { font-size: 1rem; }
  .kotty-card {
    background: var(--bg-card);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--border-light);
    overflow: hidden;
  }
  .kotty-card-header {
    padding: 20px 24px;
    border-bottom: 1px solid var(--border-light);
    background: var(--gray-50);
  }
  .kotty-card-header h2, .kotty-card-header h3 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0;
  }
  .kotty-card-header i { color: var(--terracotta); }
  .kotty-card-body { padding: 24px; }
  .kotty-table { width: 100%; border-collapse: separate; border-spacing: 0; }
  .kotty-table thead th {
    background: var(--gray-100);
    padding: 12px 16px;
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 2px solid var(--border-light);
    text-align: left;
    white-space: nowrap;
  }
  .kotty-table tbody td {
    padding: 14px 16px;
    border-bottom: 1px solid var(--border-light);
    vertical-align: middle;
    font-size: var(--text-sm);
  }
  .kotty-table tbody tr:hover { background: var(--gray-50); }
  .kotty-table tbody tr:last-child td { border-bottom: none; }
  .size-table { font-size: var(--text-xs); }
  .size-table th, .size-table td { padding: 6px 10px !important; }
  .kotty-form-label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-weight: 500;
    font-size: var(--text-sm);
    color: var(--text-primary);
    margin-bottom: 6px;
  }
  .kotty-form-label i { color: var(--terracotta); font-size: 0.875rem; }
  .kotty-input, .kotty-select, .kotty-textarea {
    width: 100%;
    padding: 10px 14px;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    border: 1px solid var(--border-medium);
    border-radius: var(--radius-md);
    background: var(--bg-card);
    color: var(--text-primary);
    transition: var(--transition-base);
  }
  .kotty-input:focus, .kotty-select:focus, .kotty-textarea:focus {
    outline: none;
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px var(--terracotta-bg);
  }
  .kotty-input:read-only { background: var(--gray-100); color: var(--text-secondary); }
  .kotty-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 10px 18px;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--text-sm);
    border-radius: var(--radius-md);
    border: none;
    cursor: pointer;
    transition: var(--transition-base);
    text-decoration: none;
  }
  .kotty-btn-primary { background: var(--terracotta); color: white; }
  .kotty-btn-primary:hover { background: var(--terracotta-dark); color: white; }
  .kotty-btn-secondary { background: var(--gray-200); color: var(--text-primary); }
  .kotty-btn-secondary:hover { background: var(--gray-300); }
  .kotty-btn-success { background: var(--success); color: white; }
  .kotty-btn-success:hover { background: #246e4c; }
  .kotty-btn-danger { background: var(--danger); color: white; }
  .kotty-btn-danger:hover { background: #a32f1a; }
  .kotty-btn-info { background: var(--info); color: white; }
  .kotty-btn-info:hover { background: #2d6aa8; }
  .kotty-btn-sm { padding: 6px 12px; font-size: var(--text-xs); }
  .kotty-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .kotty-btn-block { width: 100%; }
  .roll-section, .size-section {
    border: 1px solid var(--border-light);
    margin-bottom: 16px;
    padding: 20px;
    border-radius: var(--radius-lg);
    background: var(--gray-50);
    position: relative;
  }
  .roll-section .remove-roll-btn, .size-section .removeSizeBtn {
    position: absolute;
    top: 12px;
    right: 12px;
  }
  .kotty-progress {
    height: 24px;
    background: var(--gray-200);
    border-radius: var(--radius-full);
    overflow: hidden;
  }
  .kotty-progress-bar {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-xs);
    font-weight: 600;
    color: white;
    background: var(--info);
    transition: width 0.3s ease-in-out;
  }
  .kotty-progress-bar.danger { background: var(--danger); }
  .weightUsedInput.over-weight {
    border-color: var(--danger, #dc2626) !important;
    background: #fef2f2 !important;
    color: #b91c1c !important;
    font-weight: 600;
  }
  .autocomplete { position: relative; width: 100%; }
  .autocomplete-items {
    position: absolute;
    border: 1px solid var(--border-medium);
    border-top: none;
    z-index: 1000;
    top: 100%;
    left: 0;
    right: 0;
    max-height: 200px;
    overflow-y: auto;
    background: var(--bg-card);
    border-radius: 0 0 var(--radius-md) var(--radius-md);
    box-shadow: var(--shadow-md);
    display: none;
  }
  .autocomplete-items.d-block { display: block; }
  .autocomplete-items li {
    padding: 10px 14px;
    cursor: pointer;
    font-size: var(--text-sm);
    border-bottom: 1px solid var(--border-light);
  }
  .autocomplete-items li:last-child { border-bottom: none; }
  .autocomplete-items li:hover, .autocomplete-items li.active {
    background: var(--terracotta-bg);
    color: var(--terracotta);
  }
  .highlight {
    font-weight: 700;
    background: rgba(196, 92, 58, 0.2);
    color: var(--terracotta-dark);
  }
  .section-divider { border: none; border-top: 1px solid var(--border-light); margin: 24px 0; }
  .section-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
  }
  .section-title i { color: var(--terracotta); }
  .total-display {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    background: var(--terracotta-bg);
    border-radius: var(--radius-lg);
    margin-bottom: 20px;
  }
  .total-display strong { font-size: var(--text-base); color: var(--text-primary); }
  .total-display span { font-size: var(--text-xl); font-weight: 700; color: var(--terracotta); }
  .kotty-alert {
    padding: 14px 18px;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
  }
  .kotty-alert-danger { background: var(--danger-light); border: 1px solid var(--danger); color: var(--danger); }
  .kotty-alert-success { background: var(--success-light); border: 1px solid var(--success); color: var(--success); }
  .kotty-alert .btn-close { margin-left: auto; }
  .lot-image { max-width: 80px; border-radius: var(--radius-md); border: 1px solid var(--border-light); }
  .action-buttons { display: flex; flex-direction: column; gap: 8px; }
  @media (min-width: 576px) { .action-buttons { flex-direction: row; } }
  .weight-info { font-size: var(--text-xs); color: var(--text-secondary); margin-top: 8px; }
  .weight-info span { font-weight: 600; color: var(--terracotta); }
  @media (max-width: 768px) {
    .page-title { font-size: var(--text-2xl); }
    .kotty-card-body { padding: 16px; }
    .kotty-tabs { gap: 4px; }
    .kotty-tab { padding: 10px 14px; font-size: var(--text-xs); }
    .kotty-table thead th, .kotty-table tbody td { padding: 10px 12px; font-size: var(--text-xs); }
    .roll-section, .size-section { padding: 16px; }
  }
  /* Indent Styles */
  .indent-item { background: var(--gray-50); border: 1px solid var(--border-light); border-radius: var(--radius-md); padding: 16px; margin-bottom: 12px; }
  .indent-item-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
  .indent-item-num { font-size: var(--text-sm); font-weight: 600; color: var(--text-secondary); }
  .indent-row { display: grid; grid-template-columns: 1fr 100px; gap: 12px; margin-bottom: 10px; }
  .indent-row.single { grid-template-columns: 1fr; }
  .indent-label { font-size: var(--text-sm); font-weight: 500; margin-bottom: 4px; display: block; }
  .indent-request-item { display: flex; justify-content: space-between; align-items: flex-start; padding: 12px 0; border-bottom: 1px solid var(--border-light); gap: 12px; }
  .indent-request-item:last-child { border-bottom: none; }
  .indent-request-main { flex: 1; min-width: 0; }
  .indent-request-desc { font-size: var(--text-sm); font-weight: 500; word-break: break-word; margin-bottom: 4px; }
  .indent-request-meta { font-size: var(--text-xs); color: var(--text-secondary); }
  .indent-request-lot { color: var(--terracotta); font-weight: 500; }
  .indent-request-status { padding: 4px 10px; border-radius: 20px; font-size: var(--text-xs); font-weight: 600; text-transform: uppercase; }
  .indent-request-status.open { background: #fef3c7; color: #9a3412; }
  .indent-request-status.proceeding { background: #cffafe; color: #155e75; }
  .indent-request-status.arrived { background: #d1fae5; color: #065f46; }
  .select2-container--default .select2-selection--single { height: auto; padding: 8px 12px; border: 1px solid var(--border-light); border-radius: var(--radius-sm); }
</style>

<main class="page-container">
  <div class="container">
    <div class="page-header" style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 16px;">
      <div>
        <h1 class="page-title" data-i18n="cuttingManagerDashboardTitle">Cutting Manager Dashboard</h1>
        <p class="page-subtitle"><span data-i18n="welcomeUser">Welcome</span>, <strong><%= user.username %></strong> (<%= user.roleName %>)</p>
      </div>
      <div style="display: inline-flex; gap: 8px; flex-wrap: wrap;">
        <a href="/my-lots" class="kotty-btn kotty-btn-primary" style="display: inline-flex; align-items: center; gap: 8px;">
          <i class="bi bi-bag-check"></i> My Lots
        </a>
        <a href="/payments/my-payments" class="kotty-btn kotty-btn-secondary" style="display: inline-flex; align-items: center; gap: 8px;">
          <i class="bi bi-wallet2"></i> My Payments
        </a>
      </div>
    </div>

    <% if (error && error.length > 0) { %>
      <div class="kotty-alert kotty-alert-danger" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <div><%= error %></div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>

    <% if (success && success.length > 0) { %>
      <div class="kotty-alert kotty-alert-success" role="alert">
        <i class="bi bi-check-circle-fill"></i>
        <div><%= success %></div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>

    <div class="kotty-tabs" id="dashboardTabs" role="tablist">
      <button class="kotty-tab active" id="existing-lots-tab" data-bs-toggle="tab" data-bs-target="#existing-lots" type="button" role="tab" aria-controls="existing-lots" aria-selected="true">
        <i class="bi bi-folder-fill"></i><span data-i18n="existingCuttingLots">Existing Cutting Lots</span>
      </button>
      <button class="kotty-tab" id="create-lot-tab" data-bs-toggle="tab" data-bs-target="#create-lot" type="button" role="tab" aria-controls="create-lot" aria-selected="false">
        <i class="bi bi-plus-circle-fill"></i><span data-i18n="createNewCuttingLot">Create New Cutting Lot</span>
      </button>
      <button class="kotty-tab" id="indent-tab" data-bs-toggle="tab" data-bs-target="#indent-panel" type="button" role="tab" aria-controls="indent-panel" aria-selected="false">
        <i class="bi bi-box-seam"></i><span>Raise Indent</span>
      </button>
    </div>

    <div class="tab-content" id="dashboardTabsContent">
      <div class="tab-pane fade show active" id="existing-lots" role="tabpanel" aria-labelledby="existing-lots-tab">
        <div class="kotty-card">
          <div class="kotty-card-header">
            <h2><i class="bi bi-folder-fill"></i><span data-i18n="existingCuttingLots">Existing Cutting Lots</span></h2>
          </div>
          <div class="kotty-card-body" style="padding: 0;">
            <div class="table-responsive">
              <table class="kotty-table">
                <thead>
                  <tr>
                    <th style="width:28px;"></th>
                    <th data-i18n="idLabel">ID</th>
                    <th data-i18n="lotNumberLabel">Lot Number</th>
                    <th data-i18n="skuLabel">SKU</th>
                    <th data-i18n="fabricTypeLabel">Fabric Type</th>
                    <th data-i18n="tableLengthLabel">Table Length</th>
                    <th data-i18n="remarkLabel">Remark</th>
                    <th data-i18n="imageLabel">Image</th>
                    <th data-i18n="createdByLabel">Created By</th>
                    <th data-i18n="creationTimeLabel">Creation Time</th>
                    <th data-i18n="totalPiecesLabel">Total Pieces</th>
                    <th data-i18n="sizesLabel">Sizes</th>
                    <th data-i18n="actionsLabel">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (cuttingLots.length === 0) { %>
                    <tr><td colspan="13" class="text-center" style="padding: 40px;" data-i18n="noCuttingLotsAvailable">No cutting lots available.</td></tr>
                  <% } else { %>
                    <% cuttingLots.forEach(lot => { %>
                      <tr data-lot-no="<%= lot.lot_no %>">
                        <td><button type="button" class="lse-toggle" aria-expanded="false" aria-label="Show size breakdown"><span class="lse-chevron">&#9654;</span></button></td>
                        <td><%= lot.id %></td>
                        <td><strong><%= lot.lot_no %></strong></td>
                        <td><%= lot.sku %></td>
                        <td><%= lot.fabric_type %></td>
                        <td><%= lot.table_length ?? 'N/A' %></td>
                        <td><%= lot.remark || 'N/A' %></td>
                        <td><% if (lot.image_url) { %><img src="/<%= lot.image_url %>" alt="lot image" class="lot-image" /><% } else { %><i class="bi bi-image text-muted"></i> N/A<% } %></td>
                        <td><%= lot.created_by || 'N/A' %></td>
                        <td><%= lot.created_at ? new Date(lot.created_at).toLocaleString() : 'N/A' %></td>
                        <td><strong><%= lot.total_pieces || 0 %></strong></td>
                        <td>
                          <% if (lot.sizes && lot.sizes.length > 0) { %>
                            <table class="kotty-table size-table">
                              <thead><tr><th>Size</th><th>Pattern</th><th>Pieces</th></tr></thead>
                              <tbody><% lot.sizes.forEach(size => { %><tr><td><%= size.size_label %></td><td><%= size.pattern_count %></td><td><%= size.total_pieces %></td></tr><% }) %></tbody>
                            </table>
                          <% } else { %>N/A<% } %>
                        </td>
                        <td>
                          <div class="action-buttons">
                            <a href="/cutting-manager/generate-challan/<%= lot.id %>" class="kotty-btn kotty-btn-primary kotty-btn-sm"><i class="bi bi-file-earmark-arrow-down"></i>Challan</a>
                            <a href="/cutting-manager/lot-details/<%= lot.id %>" class="kotty-btn kotty-btn-info kotty-btn-sm"><i class="bi bi-eye"></i>Details</a>
                          </div>
                        </td>
                      </tr>
                    <% }) %>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <div class="tab-pane fade" id="create-lot" role="tabpanel" aria-labelledby="create-lot-tab">
        <div class="kotty-card">
          <div class="kotty-card-header">
            <h3><i class="bi bi-plus-circle-fill"></i><span data-i18n="createNewCuttingLot">Create New Cutting Lot</span></h3>
          </div>
          <div class="kotty-card-body">
            <form id="lotForm" method="POST" action="/cutting-manager/create-lot" enctype="multipart/form-data">
              <div class="row g-3">
                <div class="col-md-4">
                  <label for="lot_no" class="kotty-form-label"><i class="bi bi-hash"></i><span data-i18n="lotNumberGenerated">Lot Number (Generated)</span></label>
                  <input type="text" class="kotty-input" id="lot_no" name="lot_no" value="<%= generatedLotNumber %>" readonly />
                </div>
                <!-- SKU Builder -->
                <div class="col-md-8">
                  <label class="kotty-form-label"><i class="bi bi-barcode"></i><span>SKU Builder</span></label>
                  <div class="sku-builder" style="display: flex; gap: 8px; flex-wrap: wrap; align-items: flex-end;">
                    <div style="flex: 1; min-width: 80px;">
                      <label style="font-size: 0.7rem; color: #666;">Brand</label>
                      <select id="skuBrand" class="kotty-input" style="padding: 8px;">
                        <option value="KTT" selected>KTT</option>
                        <option value="KOTTY">KOTTY</option>
                        <option value="NW">NW</option>
                      </select>
                    </div>
                    <div style="flex: 1; min-width: 100px;">
                      <label style="font-size: 0.7rem; color: #666;">Gender (optional)</label>
                      <select id="skuGender" class="kotty-input" style="padding: 8px;">
                        <option value="">-- None --</option>
                        <option value="WOMENS">WOMENS</option>
                        <option value="MENS">MENS</option>
                        <option value="LADIES">LADIES</option>
                        <option value="BOYS">BOYS</option>
                        <option value="GIRLS">GIRLS</option>
                      </select>
                    </div>
                    <div style="flex: 1.5; min-width: 120px;">
                      <label style="font-size: 0.7rem; color: #666;">Category</label>
                      <div style="display: flex; gap: 4px;">
                        <select id="skuCategory" class="kotty-input" style="padding: 8px; flex: 1;" required>
                          <option value="">Select...</option>
                        </select>
                        <button type="button" id="btnAddCategory" class="kotty-btn" style="padding: 8px 12px; white-space: nowrap;" title="Add new category">+</button>
                      </div>
                    </div>
                    <div style="flex: 1; min-width: 80px;">
                      <label style="font-size: 0.7rem; color: #666;">Code</label>
                      <input type="number" id="skuCode" class="kotty-input" style="padding: 8px;" placeholder="123" min="1" required />
                    </div>
                  </div>
                  <input type="hidden" id="sku" name="sku" required />
                  <div id="skuPreview" style="margin-top: 8px; font-size: 0.9rem; color: #16a34a; font-weight: 600;">Preview: <span id="skuPreviewText">--</span></div>
                </div>
                <div class="col-md-4">
                  <label for="fabric_type_search" class="kotty-form-label"><i class="bi bi-hexagon-fill"></i><span data-i18n="fabricTypeLabel">Fabric Type</span></label>
                  <div class="autocomplete">
                    <input type="text" id="fabric_type_search" class="kotty-input" placeholder="Search Fabric Type..." aria-autocomplete="list" aria-controls="fabric_type_options" aria-expanded="false" aria-haspopup="listbox" required>
                    <input type="hidden" id="fabric_type" name="fabric_type" required>
                    <ul class="autocomplete-items list-group d-none" id="fabric_type_options" role="listbox"></ul>
                  </div>
                </div>
                <div class="col-md-4">
                  <label for="table_length" class="kotty-form-label"><i class="bi bi-rulers"></i><span data-i18n="tableLengthLabel">Table Length</span></label>
                  <input type="number" class="kotty-input" id="table_length" name="table_length" <%= isDenim ? 'required' : '' %> placeholder="<%= isDenim ? 'Table length (required for denim)' : 'Table length (optional)' %>" min="0" step="0.01" />
                </div>
                <div class="col-md-4">
                  <label for="remark" class="kotty-form-label"><i class="bi bi-chat-left-text"></i><span data-i18n="remarkLabel">Remark</span></label>
                  <textarea class="kotty-textarea" name="remark" id="remark" rows="2" placeholder="Any note..."></textarea>
                </div>
                <div class="col-md-4">
                  <label for="image" class="kotty-form-label"><i class="bi bi-image"></i><span data-i18n="imageLabel">Image</span></label>
                  <input type="file" class="kotty-input" name="image" id="image" accept="image/*" />
                </div>
              </div>

              <hr class="section-divider"/>
              <div class="mb-3">
                <h4 class="section-title"><i class="bi bi-list"></i><span data-i18n="sizesAndPatterns">Sizes and Patterns</span></h4>
                <div class="bulk-size-row mb-2" style="display:flex; gap:8px; align-items:center;">
                  <input type="text" class="kotty-input" id="bulkSizeInput"
                         placeholder="Quick entry: 26-1,28-2,30-2,32-1,34-1"
                         style="flex:1;" />
                  <button type="button" class="kotty-btn kotty-btn-primary kotty-btn-sm" id="bulkSizeApplyBtn">
                    <i class="bi bi-lightning-charge"></i> Apply
                  </button>
                </div>
                <div id="bulkSizeError" class="text-danger small mb-2" style="display:none;"></div>
                <div id="sizesContainer"></div>
                <button type="button" class="kotty-btn kotty-btn-secondary kotty-btn-sm" id="addSizeBtn"><i class="bi bi-plus-circle"></i><span data-i18n="addNewSize">Add New Size</span></button>
              </div>

              <hr class="section-divider"/>
              <div class="mb-3">
                <h4 class="section-title"><i class="bi bi-box-seam"></i><span data-i18n="rollsUsed">Rolls Used</span></h4>
                <div id="rollsContainer"></div>
                <button type="button" class="kotty-btn kotty-btn-primary kotty-btn-sm" id="addRollBtn" disabled><i class="bi bi-plus-circle"></i><span data-i18n="addAnotherRoll">Add Another Roll</span></button>
              </div>

              <hr class="section-divider"/>
              <div class="total-display">
                <strong data-i18n="totalPiecesCalc">Total Pieces (Calculated):</strong>
                <span id="totalPiecesDisplay">0</span>
              </div>

              <button type="submit" class="kotty-btn kotty-btn-success kotty-btn-block" id="createLotBtn" disabled><i class="bi bi-check-circle"></i><span data-i18n="createLotBtn">Create Lot</span></button>
            </form>
          </div>
        </div>
      </div>

      <!-- INDENT TAB PANE -->
      <div class="tab-pane fade" id="indent-panel" role="tabpanel" aria-labelledby="indent-tab">
        <%- include('partials/indentWrapper', { user: user, stage: 'Cutting' }) %>
      </div>
    </div>
  </div>
</main>

