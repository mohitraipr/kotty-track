  <div class="roll-section size-section">
    <button type="button" class="kotty-btn kotty-btn-danger kotty-btn-sm removeSizeBtn" aria-label="Remove size"><i class="bi bi-dash-circle"></i><span data-i18n="remove">Remove</span></button>
