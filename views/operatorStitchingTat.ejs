<%- include('partials/header', { pageTitle: 'Stitching TAT' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/operator/dashboard' }) %>

<!-- Main Content -->
<main class="main-content" style="margin-left: 0;">
  <div class="container-fluid" style="max-width: var(--content-max-width); margin: 0 auto;">
    <!-- Breadcrumbs -->
    <div class="breadcrumbs">
      <a href="/operator/dashboard">Dashboard</a>
      <span class="separator"><i class="bi bi-chevron-right"></i></span>
      <span>Stitching TAT</span>
    </div>

    <!-- Page Header -->
    <div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3">
      <div>
        <h1 class="page-title">Stitching TAT Summary</h1>
        <p class="page-subtitle">Turn Around Time report for all stitching masters</p>
      </div>
      <a href="/operator/stitching-tat?download=1" class="btn btn-primary">
        <i class="bi bi-download me-2"></i>Download ALL (Excel)
      </a>
    </div>

    <!-- Master Cards Grid -->
    <div class="row g-4">
      <% masterCards.forEach((mc) => { %>
        <div class="col-sm-6 col-md-4 col-lg-3">
          <div class="card master-card h-100">
            <div class="card-body d-flex flex-column">
              <div class="master-avatar">
                <%= mc.username.charAt(0).toUpperCase() %>
              </div>
              <h3 class="master-name"><%= mc.username %></h3>

              <div class="master-stats">
                <div class="stat-item">
                  <span class="stat-label">Pending Approval</span>
                  <span class="stat-value badge badge-warning"><%= mc.pendingApproval %></span>
                </div>
                <div class="stat-item">
                  <span class="stat-label">In-Line Pieces</span>
                  <span class="stat-value badge badge-primary"><%= mc.inLinePieces %></span>
                </div>
              </div>

              <div class="card-actions mt-auto">
                <a href="/operator/stitching-tat/<%= mc.masterId %>" class="btn btn-outline-primary btn-sm flex-grow-1">
                  <i class="bi bi-eye me-1"></i>View TAT
                </a>
                <a href="/operator/stitching-tat/<%= mc.masterId %>?download=1" class="btn btn-outline-success btn-sm flex-grow-1">
                  <i class="bi bi-file-earmark-arrow-down me-1"></i>Download
                </a>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>

    <!-- Empty State -->
    <% if (!masterCards || masterCards.length === 0) { %>
      <div class="card">
        <div class="card-body text-center py-5">
          <i class="bi bi-people" style="font-size: 3rem; color: var(--terracotta); opacity: 0.6;"></i>
          <h3 class="mt-3" style="font-family: var(--font-heading); color: var(--charcoal);">No Stitching Masters Found</h3>
          <p class="text-muted">There are no stitching masters with active assignments at this time.</p>
        </div>
      </div>
    <% } %>
  </div>
</main>

<style>
  /* Page-specific styles for Stitching TAT */
  .master-card {
    transition: transform var(--transition-base), box-shadow var(--transition-base);
    border: 1px solid var(--gray-200);
  }

  .master-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(26, 26, 26, 0.1);
  }

  .master-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--terracotta), #d4826a);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .master-name {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    color: var(--charcoal);
    margin-bottom: 1rem;
  }

  .master-stats {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    padding: 1rem;
    background: var(--gray-50);
    border-radius: var(--radius-md);
  }

  .stat-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .stat-label {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    font-weight: 500;
  }

  .stat-value {
    font-weight: 600;
  }

  .card-actions {
    display: flex;
    gap: 0.5rem;
  }

  .btn-outline-primary {
    border-color: var(--terracotta);
    color: var(--terracotta);
  }

  .btn-outline-primary:hover {
    background: var(--terracotta);
    border-color: var(--terracotta);
    color: white;
  }

  .btn-outline-success {
    border-color: #2e7d32;
    color: #2e7d32;
  }

  .btn-outline-success:hover {
    background: #2e7d32;
    border-color: #2e7d32;
    color: white;
  }

  /* Badge variants */
  .badge-warning {
    background: #fff3e0;
    color: #e65100;
  }

  .badge-primary {
    background: rgba(196, 92, 58, 0.1);
    color: var(--terracotta);
  }

  /* Responsive adjustments */
  @media (max-width: 576px) {
    .page-header {
      flex-direction: column;
      align-items: flex-start !important;
    }

    .page-header .btn {
      width: 100%;
    }

    .card-actions {
      flex-direction: column;
    }

    .card-actions .btn {
      width: 100%;
    }
  }
</style>

<%- include('partials/footer') %>
