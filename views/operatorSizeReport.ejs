<%- include('partials/header', { pageTitle: 'Size Report' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/operator/dashboard' }) %>

<!-- Main Content -->
<main class="main-content" style="margin-left: 0;">
  <div class="container-fluid" style="max-width: var(--content-max-width); margin: 0 auto;">
    <!-- Breadcrumbs -->
    <div class="breadcrumbs">
      <a href="/operator/dashboard">Dashboard</a>
      <span class="separator"><i class="bi bi-chevron-right"></i></span>
      <span>Size Report</span>
    </div>

    <!-- Page Header -->
    <div class="page-header">
      <h1 class="page-title">Size-Wise PIC Report</h1>
      <p class="page-subtitle">Production In Count Report with Size Breakdown <span class="text-muted">(Default: Last 7 days)</span></p>
    </div>

    <!-- Filter Card -->
    <div class="card mb-4">
      <div class="card-header">
        <h5 class="card-title"><i class="bi bi-funnel me-2"></i>Report Filters</h5>
      </div>
      <div class="card-body">
        <form id="filterForm">
          <div class="row g-3">
            <div class="col-md-4 col-lg-2">
              <label class="form-label">Lot Type</label>
              <select name="lotType" class="form-select form-input">
                <option value="all" <%= filters.lotType === 'all' ? 'selected' : '' %>>All</option>
                <option value="denim" <%= filters.lotType === 'denim' ? 'selected' : '' %>>Denim</option>
                <option value="hosiery" <%= filters.lotType === 'hosiery' ? 'selected' : '' %>>Hosiery</option>
              </select>
            </div>

            <div class="col-md-4 col-lg-2">
              <label class="form-label">Department</label>
              <select name="department" class="form-select form-input">
                <option value="all" <%= filters.department === 'all' ? 'selected' : '' %>>All</option>
                <option value="cutting" <%= filters.department === 'cutting' ? 'selected' : '' %>>Cutting</option>
                <option value="stitching" <%= filters.department === 'stitching' ? 'selected' : '' %>>Stitching</option>
                <option value="assembly" <%= filters.department === 'assembly' ? 'selected' : '' %>>Assembly</option>
                <option value="washing" <%= filters.department === 'washing' ? 'selected' : '' %>>Washing</option>
                <option value="washing_in" <%= filters.department === 'washing_in' ? 'selected' : '' %>>Washing In</option>
                <option value="finishing" <%= filters.department === 'finishing' ? 'selected' : '' %>>Finishing</option>
              </select>
            </div>

            <div class="col-md-4 col-lg-2">
              <label class="form-label">Status</label>
              <select name="status" class="form-select form-input">
                <option value="all" <%= filters.status === 'all' ? 'selected' : '' %>>All</option>
                <option value="pending" <%= filters.status === 'pending' ? 'selected' : '' %>>Pending</option>
                <option value="inline" <%= filters.status === 'inline' ? 'selected' : '' %>>In-Line</option>
                <option value="completed" <%= filters.status === 'completed' ? 'selected' : '' %>>Completed</option>
                <option value="denied" <%= filters.status === 'denied' ? 'selected' : '' %>>Denied</option>
                <option value="not_assigned" <%= filters.status === 'not_assigned' ? 'selected' : '' %>>Not Assigned</option>
              </select>
            </div>

            <div class="col-md-4 col-lg-2">
              <label class="form-label">Date Filter</label>
              <select name="dateFilter" class="form-select form-input">
                <option value="createdAt" <%= filters.dateFilter === 'createdAt' ? 'selected' : '' %>>Created At</option>
                <option value="assignedOn" <%= filters.dateFilter === 'assignedOn' ? 'selected' : '' %>>Assigned On</option>
              </select>
            </div>

            <div class="col-md-4 col-lg-2">
              <label class="form-label">Start Date</label>
              <input type="date" name="startDate" class="form-control form-input" value="<%= filters.startDate || '' %>">
            </div>

            <div class="col-md-4 col-lg-2">
              <label class="form-label">End Date</label>
              <input type="date" name="endDate" class="form-control form-input" value="<%= filters.endDate || '' %>">
            </div>
          </div>

          <div class="d-flex gap-2 mt-4">
            <button type="button" class="btn btn-primary" onclick="downloadReport()">
              <i class="bi bi-download me-2"></i>Download Report
            </button>
            <button type="reset" class="btn btn-outline-secondary">
              <i class="bi bi-arrow-clockwise me-2"></i>Reset
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Results Card -->
    <% if (typeof rows !== 'undefined' && rows.length > 0) { %>
    <div class="card">
      <div class="card-header">
        <h5 class="card-title">
          <i class="bi bi-table me-2"></i>Data Preview
        </h5>
        <span class="badge badge-neutral"><%= rows.length %> records with size breakdown</span>
      </div>
      <%
        function escHtml(x) {
          return String(x).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
        }
        function statusBadge(s) {
          if (!s || s === 'N/A' || s === '—') return '<span class="text-muted">—</span>';
          const m = String(s).toLowerCase();
          if (m === 'completed') return '<span class="badge badge-success">Completed</span>';
          if (m === 'partial')   return '<span class="badge badge-warning">Partial</span>';
          if (m === 'in progress') return '<span class="badge badge-info">In Progress</span>';
          if (m === 'pending approval') return '<span class="badge badge-warning">Pending Approval</span>';
          if (m === 'denied')    return '<span class="badge badge-danger">Denied</span>';
          if (m === 'not started') return '<span class="badge badge-neutral">Not Started</span>';
          return '<span class="badge badge-neutral">' + escHtml(s) + '</span>';
        }
        function qtyOrDash(v) {
          if (v === '' || v === null || v === undefined || v === '—') return '<span class="text-muted">—</span>';
          return escHtml(v);
        }
      %>
      <div class="table-responsive">
        <table class="table table-sm" style="font-size: var(--text-xs);">
          <thead>
            <tr>
              <th>Lot No</th>
              <th>Manual Lot</th>
              <th>Fabric</th>
              <th>SKU_Size</th>
              <th>Type</th>
              <th>Cut</th>
              <th>Current Stage</th>
              <th>Pending</th>
              <th>Stitch</th>
              <th>Assembly</th>
              <th>Washing</th>
              <th>Wash-In</th>
              <th>Finishing</th>
              <th>Rejects</th>
              <th>Dispatched</th>
            </tr>
          </thead>
          <tbody>
            <% rows.slice(0, 50).forEach(row => { %>
            <tr>
              <td><strong><%= row.lotNo %></strong></td>
              <td><%= row.externalLotNo || '—' %></td>
              <td><%= row.fabricType || '—' %></td>
              <td><code class="text-muted"><%= row.sku_size %></code></td>
              <td><span class="badge <%= row.lotType === 'Denim' ? 'badge-primary' : 'badge-info' %>"><%= row.lotType %></span></td>
              <td><%= row.totalCut %></td>
              <td>
                <% if (row.currentStage === 'Done') { %>
                  <span class="badge badge-success">Done</span>
                <% } else { %>
                  <span class="badge badge-warning"><%= row.currentStage %></span>
                <% } %>
              </td>
              <td><strong><%= row.currentPendingQty || 0 %></strong></td>
              <td>
                <%- statusBadge(row.stitchStatus) %><br>
                <small class="text-muted">
                  <%- qtyOrDash(row.stitchOutQty) %>
                </small>
              </td>
              <td>
                <%- statusBadge(row.assemblyStatus) %><br>
                <small class="text-muted">
                  <%- qtyOrDash(row.assemblyInQty) %> → <%- qtyOrDash(row.assemblyOutQty) %>
                  <% if (typeof row.assemblyPendingQty === 'number' && row.assemblyPendingQty > 0) { %>
                    <span class="text-danger">(<%= row.assemblyPendingQty %> pend)</span>
                  <% } %>
                </small>
              </td>
              <td>
                <%- statusBadge(row.washingStatus) %><br>
                <small class="text-muted">
                  <%- qtyOrDash(row.washingInQty_in) %> → <%- qtyOrDash(row.washingOutQty) %>
                  <% if (typeof row.washingPendingQty === 'number' && row.washingPendingQty > 0) { %>
                    <span class="text-danger">(<%= row.washingPendingQty %> pend)</span>
                  <% } %>
                </small>
              </td>
              <td>
                <%- statusBadge(row.washInStatus) %><br>
                <small class="text-muted">
                  <%- qtyOrDash(row.washInInQty) %> → <%- qtyOrDash(row.washInOutQty) %>
                  <% if (typeof row.washInPendingQty === 'number' && row.washInPendingQty > 0) { %>
                    <span class="text-danger">(<%= row.washInPendingQty %> pend)</span>
                  <% } %>
                </small>
              </td>
              <td>
                <%- statusBadge(row.finishingStatus) %><br>
                <small class="text-muted">
                  <%- qtyOrDash(row.finishingInQty) %> → <%- qtyOrDash(row.finishingOutQty) %>
                  <% if (row.finishingPendingQty > 0) { %>
                    <span class="text-danger">(<%= row.finishingPendingQty %> pend)</span>
                  <% } %>
                </small>
              </td>
              <td>
                <% if (row.totalRejectQty > 0) { %>
                  <strong class="text-danger"><%= row.totalRejectQty %></strong><br>
                  <small class="text-muted">
                    <% if (row.stitchRejectQty > 0) { %>St:<%= row.stitchRejectQty %> <% } %>
                    <% if (row.washInRejectQty > 0) { %>WI:<%= row.washInRejectQty %> <% } %>
                    <% if (row.finishingRejectQty > 0) { %>Fn:<%= row.finishingRejectQty %><% } %>
                  </small>
                  <% const reasons = [row.stitchRejectReasons, row.washInRejectReasons, row.finishingRejectReasons].filter(Boolean).join('; '); %>
                  <% if (reasons) { %>
                    <br><small title="<%= reasons %>" style="cursor: help;"><i class="bi bi-info-circle"></i></small>
                  <% } %>
                <% } else { %>
                  <span class="text-muted">—</span>
                <% } %>
              </td>
              <td>
                <% if (row.dispatchedQty > 0) { %>
                  <span class="badge badge-success"><%= row.dispatchedQty %></span>
                  <% if (row.destinations) { %>
                    <br><small class="text-muted"><%= row.destinations %></small>
                  <% } %>
                <% } else { %>
                  <span class="text-muted">—</span>
                <% } %>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% if (rows.length > 50) { %>
      <div class="card-footer text-muted">
        Showing first 50 of <%= rows.length %> records. Download the full report to see all data.
      </div>
      <% } %>
    </div>
    <% } %>
  </div>
</main>

<!-- Loading Overlay -->
<div id="overlaySpinner" class="overlay-spinner">
  <div class="spinner-content">
    <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;"></div>
    <h5>Generating Size Report</h5>
    <p>Please wait...</p>
  </div>
</div>

<style>
  /* Page-specific styles */
  code {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    background: var(--gray-100);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
  }

  .table td code {
    color: var(--text-secondary);
  }

  .table th {
    white-space: nowrap;
  }

  /* Loading overlay */
  .overlay-spinner {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(26, 26, 26, 0.6);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 9999;
  }

  .overlay-spinner .spinner-content {
    background: var(--surface-primary);
    padding: 2rem;
    border-radius: var(--radius-lg);
    text-align: center;
    min-width: 280px;
    box-shadow: var(--shadow-lg);
  }

  .overlay-spinner .spinner-content h5 {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-primary);
    margin-top: 1rem;
    margin-bottom: 0.5rem;
  }

  .overlay-spinner .spinner-content p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin: 0;
  }

  .spinner-border.text-primary {
    color: var(--terracotta) !important;
  }

  /* Badge variants for this page */
  .badge-info {
    background: var(--info);
    color: white;
  }

  .badge-success {
    background: var(--success);
    color: white;
  }

  .badge-warning {
    background: var(--warning);
    color: var(--charcoal);
  }

  .badge-primary {
    background: var(--terracotta);
    color: white;
  }

  /* Responsive table scroll indicator */
  .table-responsive {
    position: relative;
  }

  .table-responsive::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 30px;
    height: 100%;
    background: linear-gradient(to left, rgba(250,248,245,0.9), transparent);
    pointer-events: none;
    opacity: 0;
    transition: opacity var(--transition-fast);
  }

  @media (max-width: 1200px) {
    .table-responsive::after {
      opacity: 1;
    }
  }

  /* Card footer styling */
  .card-footer {
    padding: 1rem 1.5rem;
    background: var(--gray-50);
    border-top: 1px solid var(--border-color);
    font-size: var(--text-sm);
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
  }

  /* Form input overrides for date inputs */
  input[type="date"].form-input {
    padding: 10px 14px;
  }
</style>

<script>
  function showSpinner() {
    document.getElementById('overlaySpinner').style.display = 'flex';
  }

  function hideSpinner() {
    document.getElementById('overlaySpinner').style.display = 'none';
  }

  async function downloadReport() {
    try {
      const form = document.getElementById('filterForm');
      const formData = new FormData(form);
      const params = new URLSearchParams();

      for (const [key, val] of formData.entries()) {
        if (val) params.append(key, val);
      }
      params.set('download', '1');

      showSpinner();

      const response = await fetch('/operator/dashboard/pic-size-report?' + params.toString());
      if (!response.ok) throw new Error('Server error');

      const blob = await response.blob();
      const url = window.URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'PICReport-BySize-' + new Date().toISOString().split('T')[0] + '.xlsx';
      document.body.appendChild(a);
      a.click();
      a.remove();
      window.URL.revokeObjectURL(url);
    } catch (err) {
      alert('Error downloading report: ' + err.message);
    } finally {
      hideSpinner();
    }
  }
</script>

<%- include('partials/footer') %>
