<!-- views/washingAssignWashingIn.ejs -->
<%- include('partials/header', { pageTitle: 'Assign to Washing In' }) %>
<%- include('partials/navbar') %>

<!-- Main Content -->
<main class="main-content" style="margin-left: 0;">
  <div class="container" style="max-width: 1200px; margin: 0 auto;">

    <!-- Page Header -->
    <div class="page-header">
      <div class="breadcrumbs">
        <a href="/washingin"><i class="bi bi-house"></i> Dashboard</a>
        <span class="separator">/</span>
        <span>Assign to Washing In</span>
      </div>
      <h1 class="page-title">Assign to Washing In</h1>
      <p class="page-subtitle">Assign partial sizes from washing to washing in operators</p>
    </div>

    <!-- Flash Message Area -->
    <div id="flashMessage"></div>

    <!-- Search Card -->
    <div class="card mb-4">
      <div class="card-body">
        <div class="row align-items-end">
          <div class="col-md-8">
            <label for="searchInput" class="form-label">
              <i class="bi bi-search me-1"></i> Search by Lot or SKU
            </label>
            <input type="text" id="searchInput" class="form-control form-input" placeholder="Type to filter lots and SKUs...">
          </div>
          <div class="col-md-4 mt-3 mt-md-0">
            <a href="/washingin" class="btn btn-secondary w-100">
              <i class="bi bi-arrow-left"></i> Back to Dashboard
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Container for unassigned data from washing_data -->
    <div id="assignmentsContainer">
      <!-- Loading State -->
      <div class="card">
        <div class="card-body text-center py-5">
          <div class="spinner mx-auto mb-3" style="width: 40px; height: 40px;"></div>
          <p class="text-secondary mb-0">Loading unassigned sizes...</p>
        </div>
      </div>
    </div>

    <!-- Form for Washing In Assignment (AJAX submission) -->
    <form id="assignWashingInForm" class="mt-4">
      <div class="card">
        <div class="card-header">
          <h3 class="card-title">
            <i class="bi bi-calendar-check me-2"></i> Assignment Options
          </h3>
        </div>
        <div class="card-body">
          <div class="row">
            <div class="col-md-4">
              <label for="target_day" class="form-label">Target Day (optional)</label>
              <input type="date" name="target_day" id="target_day" class="form-control form-input">
              <small class="text-muted mt-1 d-block">Set a target completion date for these assignments</small>
            </div>
          </div>
        </div>
        <div class="card-footer">
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-send"></i> Submit Washing In Assignments
          </button>
        </div>
      </div>
    </form>
  </div>
</main>

<style>
  /* Page-specific styles */
  .assignment-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    margin-bottom: 20px;
    overflow: hidden;
    transition: box-shadow var(--transition-fast);
  }

  .assignment-card:hover {
    box-shadow: var(--shadow-md);
  }

  .assignment-card-header {
    background: var(--gray-50);
    padding: 16px 20px;
    border-bottom: 1px solid var(--border-light);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 16px;
  }

  .assignment-card-header .lot-info {
    font-weight: 500;
    color: var(--text-primary);
  }

  .assignment-card-header .lot-info strong {
    color: var(--terracotta);
  }

  .assignment-card-header .wash-data-badge {
    background: var(--charcoal);
    color: var(--cream);
    padding: 4px 10px;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 500;
  }

  .assignment-card-body {
    padding: 0;
  }

  .assignment-table {
    width: 100%;
    margin: 0;
  }

  .assignment-table th {
    background: var(--cream-dark);
    padding: 12px 16px;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-light);
  }

  .assignment-table td {
    padding: 14px 16px;
    font-size: var(--text-sm);
    color: var(--text-primary);
    border-bottom: 1px solid var(--border-light);
    vertical-align: middle;
  }

  .assignment-table tbody tr:last-child td {
    border-bottom: none;
  }

  .assignment-table tbody tr:hover {
    background: var(--gray-50);
  }

  .assignment-table .size-label {
    font-weight: 500;
    color: var(--charcoal);
  }

  .assignment-table .pieces-count {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--terracotta);
  }

  .assignment-table .form-select {
    min-width: 200px;
  }

  /* Empty state styling */
  .empty-state {
    text-align: center;
    padding: 60px 24px;
  }

  .empty-state-icon {
    width: 80px;
    height: 80px;
    background: var(--cream-dark);
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    color: var(--text-muted);
    font-size: 32px;
  }

  .empty-state-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--text-primary);
    margin-bottom: 8px;
  }

  .empty-state-text {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    max-width: 320px;
    margin: 0 auto;
  }

  /* Alert customization */
  .alert-permanent {
    animation: none;
  }

  @media (max-width: 768px) {
    .assignment-card-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .assignment-table {
      display: block;
      overflow-x: auto;
    }

    .assignment-table .form-select {
      min-width: 180px;
    }
  }
</style>

<script>
  // Global variables
  let washingInUsers = [];
  let allData = []; // => Array of objects like: { washing_data_id, lot_no, sku, sizes: [{ size_label, pieces }] }

  const searchInput = document.getElementById('searchInput');
  const assignmentsContainer = document.getElementById('assignmentsContainer');
  const assignWashingInForm = document.getElementById('assignWashingInForm');
  const flashMessageDiv = document.getElementById('flashMessage');

  // Flash message helper
  function showFlashMessage(type, message) {
    const iconMap = {
      'success': 'check-circle-fill',
      'danger': 'exclamation-triangle-fill',
      'warning': 'exclamation-circle-fill',
      'info': 'info-circle-fill'
    };
    flashMessageDiv.innerHTML = `
      <div class="alert alert-${type} alert-dismissible fade show d-flex align-items-center" role="alert">
        <i class="bi bi-${iconMap[type] || 'info-circle-fill'} me-2"></i>
        <div>${message}</div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    `;
  }

  // Fetch washing_in users
  async function fetchWashingInUsers() {
    try {
      const resp = await fetch('/washingdashboard/assign-washing-in/users', {
        headers: { 'Accept': 'application/json' },
        credentials: 'same-origin'
      });
      if (!resp.ok) throw new Error('HTTP ' + resp.status);
      const json = await resp.json();
      washingInUsers = json.data || [];
    } catch (err) {
      console.error('[ERROR] fetchWashingInUsers =>', err);
      showFlashMessage('danger', 'Error fetching washing_in users.');
    }
  }

  // Fetch unassigned data from washing_data
  async function fetchUnassignedData() {
    try {
      const resp = await fetch('/washingdashboard/assign-washing-in/data', {
        headers: { 'Accept': 'application/json' },
        credentials: 'same-origin'
      });
      if (!resp.ok) throw new Error('HTTP ' + resp.status);
      const json = await resp.json();
      allData = json.data || [];
      renderData();
    } catch (err) {
      console.error('[ERROR] fetchUnassignedData =>', err);
      assignmentsContainer.innerHTML = `
        <div class="card">
          <div class="card-body">
            <div class="alert alert-danger mb-0">
              <i class="bi bi-exclamation-triangle-fill me-2"></i>
              Error loading data. Please refresh the page and try again.
            </div>
          </div>
        </div>
      `;
    }
  }

  function renderData() {
    assignmentsContainer.innerHTML = '';

    if (!allData.length) {
      assignmentsContainer.innerHTML = `
        <div class="card">
          <div class="empty-state">
            <div class="empty-state-icon">
              <i class="bi bi-inbox"></i>
            </div>
            <h3 class="empty-state-title">No Unassigned Sizes</h3>
            <p class="empty-state-text">All sizes have been assigned to washing in operators. Check back later for new assignments.</p>
          </div>
        </div>
      `;
      return;
    }

    const filterVal = searchInput.value.trim().toLowerCase();
    const filtered = allData.filter(entry =>
      (`${entry.lot_no} ${entry.sku}`).toLowerCase().includes(filterVal)
    );

    if (!filtered.length) {
      assignmentsContainer.innerHTML = `
        <div class="card">
          <div class="empty-state">
            <div class="empty-state-icon">
              <i class="bi bi-search"></i>
            </div>
            <h3 class="empty-state-title">No Matching Results</h3>
            <p class="empty-state-text">No lots or SKUs match your search. Try adjusting your search terms.</p>
          </div>
        </div>
      `;
      return;
    }

    // For each "entry": { washing_data_id, lot_no, sku, sizes: [...] }
    filtered.forEach(entry => {
      const wDataId = entry.washing_data_id; // ID from washing_data
      const card = document.createElement('div');
      card.classList.add('assignment-card');
      card.innerHTML = `
        <div class="assignment-card-header">
          <span class="lot-info">
            <i class="bi bi-box-seam me-1"></i>
            <strong>Lot:</strong> ${entry.lot_no}
          </span>
          <span class="lot-info">
            <i class="bi bi-upc me-1"></i>
            <strong>SKU:</strong> ${entry.sku}
          </span>
          <span class="wash-data-badge">
            <i class="bi bi-hash"></i> WashData ID: ${wDataId}
          </span>
        </div>
        <div class="assignment-card-body">
          <table class="assignment-table">
            <thead>
              <tr>
                <th style="width: 25%;">Size Label</th>
                <th style="width: 25%;">Pieces</th>
                <th style="width: 50%;">Assign Washing In User</th>
              </tr>
            </thead>
            <tbody id="tbody-asg-${wDataId}"></tbody>
          </table>
        </div>
      `;
      assignmentsContainer.appendChild(card);
      const tbody = document.getElementById(`tbody-asg-${wDataId}`);
      entry.sizes.forEach(sz => {
        const tr = document.createElement('tr');
        const optionsHtml = washingInUsers.map(u => `<option value="${u.id}">${u.username}</option>`).join('');
        tr.innerHTML = `
          <td><span class="size-label">${sz.size_label}</span></td>
          <td><span class="pieces-count">${sz.pieces}</span></td>
          <td>
            <select class="form-select form-input washingInSelect">
              <option value="">-- Select Washing In User --</option>
              ${optionsHtml}
            </select>
          </td>
        `;
        tbody.appendChild(tr);
      });
    });
  }

  searchInput.addEventListener('input', renderData);

  // On form submit, gather selected Washing In users for each size
  assignWashingInForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const finalObj = {};

    // Loop over allData again to read user selections
    allData.forEach(entry => {
      const wDataId = entry.washing_data_id;
      const tbody = document.getElementById(`tbody-asg-${wDataId}`);
      if (!tbody) return;
      const rows = tbody.querySelectorAll('tr');
      rows.forEach(r => {
        const sizeLabel = r.cells[0].textContent.trim();
        const selectElem = r.cells[2].querySelector('select.washingInSelect');
        const userId = selectElem.value;
        if (userId) {
          // front-end final object => { userId: [ { washing_data_id, size_label }, ... ] }
          if (!finalObj[userId]) finalObj[userId] = [];
          finalObj[userId].push({
            washing_data_id: wDataId,    // <-- the route expects "washing_data_id"
            size_label: sizeLabel
          });
        }
      });
    });

    const payload = {
      target_day: document.getElementById('target_day').value,
      washingInAssignments: finalObj
    };

    try {
      const resp = await fetch('/washingdashboard/assign-washing-in', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        credentials: 'same-origin',
        body: JSON.stringify(payload)
      });
      const result = await resp.json();
      if (result.success) {
        showFlashMessage('success', result.message || 'Washing In assignments submitted successfully!');
        // Re-fetch data so we remove assigned items from the UI
        await fetchUnassignedData();
      } else {
        showFlashMessage('danger', result.error || 'Error submitting assignments.');
      }
    } catch (err) {
      console.error('[ERROR] Washing In Assignment Submission =>', err);
      showFlashMessage('danger', 'Error submitting assignments.');
    }
  });

  (async function init() {
    await fetchWashingInUsers();
    await fetchUnassignedData();
  })();
</script>

<%- include('partials/footer') %>
