<%- include('partials/header', { pageTitle: 'Challan Dashboard' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/challandashboard' }) %>

<!-- Main Content Area -->
<main class="main-content" style="margin-left: 0;">
  <div class="container-fluid" style="max-width: 1400px; margin: 0 auto;">

    <!-- Flash Messages -->
    <% if (error && error.length) { %>
      <div class="alert alert-danger">
        <i class="bi bi-exclamation-circle me-2"></i>
        <% error.forEach(msg => { %>
          <span><%= msg %></span>
        <% }); %>
      </div>
    <% } %>
    <% if (success && success.length) { %>
      <div class="alert alert-success">
        <i class="bi bi-check-circle me-2"></i>
        <% success.forEach(msg => { %>
          <span><%= msg %></span>
        <% }); %>
      </div>
    <% } %>

    <!-- Page Header -->
    <div class="page-header">
      <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
        <div>
          <h1 class="page-title">Challan Dashboard</h1>
          <p class="page-subtitle">Manage and generate challans for washing assignments</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
          <button id="selectAllBtn" class="btn btn-secondary">
            <i class="bi bi-check2-all"></i>
            <span>Select All</span>
          </button>
          <button id="generateChallanBtn" class="btn btn-primary" disabled>
            <i class="bi bi-file-earmark-text"></i>
            <span>Generate Challan</span>
          </button>
          <button id="downloadChallanBtn" class="btn btn-success" disabled>
            <i class="bi bi-download"></i>
            <span>Download Challan</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Search Section -->
    <div class="card mb-4">
      <div class="card-body py-3">
        <div class="row align-items-center">
          <div class="col-md-6 col-lg-4">
            <div class="position-relative">
              <i class="bi bi-search position-absolute" style="left: 14px; top: 50%; transform: translateY(-50%); color: var(--text-muted);"></i>
              <input
                type="text"
                id="searchInput"
                class="form-input"
                placeholder="Search by SKU, Lot No, or Cutting Remark"
                value="<%= search %>"
                style="padding-left: 42px;"
              />
            </div>
          </div>
          <div class="col-md-6 col-lg-8 mt-3 mt-md-0">
            <div class="d-flex flex-wrap gap-2 justify-content-md-end">
              <a href="/challandashboard" class="btn btn-ghost">
                <i class="bi bi-house"></i>
                <span>Dashboard</span>
              </a>
              <a href="/challanlist" class="btn btn-ghost">
                <i class="bi bi-list-ul"></i>
                <span>Challan List</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Assignments Table -->
    <div class="table-container">
      <div class="table-responsive">
        <table class="table mb-0" id="assignmentsTable">
          <thead>
            <tr>
              <th style="width: 50px;">
                <input type="checkbox" id="selectAllCheckbox" class="form-check-input" style="margin: 0; cursor: pointer;">
              </th>
              <th>ID</th>
              <th>Lot No</th>
              <th>SKU</th>
              <th>Total Pieces</th>
              <th>Assembly Remark</th>
              <th>Cutting Remark</th>
              <th>Target Day</th>
              <th>Assigned On</th>
              <th>Status</th>
              <th>Assignment Remark</th>
              <th>Washer</th>
              <th>Master</th>
            </tr>
          </thead>
          <tbody>
            <% if (assignments && assignments.length) { %>
              <% assignments.forEach(a => { %>
                <tr data-id="<%= a.washing_id %>">
                  <td>
                    <input type="checkbox" class="rowCheckbox form-check-input" style="cursor: pointer;">
                  </td>
                  <td><span class="font-monospace"><%= a.washing_id %></span></td>
                  <td><span class="badge badge-primary"><%= a.lot_no %></span></td>
                  <td><%= a.sku %></td>
                  <td><strong><%= a.total_pieces %></strong></td>
                  <td><%= a.assembly_remark || '-' %></td>
                  <td><%= a.cutting_remark || '-' %></td>
                  <td><%= a.target_day ? new Date(a.target_day).toLocaleDateString() : '-' %></td>
                  <td><%= a.assigned_on ? new Date(a.assigned_on).toLocaleString() : '-' %></td>
                  <td>
                    <% if (a.is_approved === 1) { %>
                      <span class="badge badge-success">Approved</span>
                    <% } else if (a.is_approved === 0) { %>
                      <span class="badge badge-danger">Denied</span>
                    <% } else { %>
                      <span class="badge badge-warning">Pending</span>
                    <% } %>
                  </td>
                  <td><%= a.assignment_remark || '-' %></td>
                  <td><%= a.washer_username %></td>
                  <td><%= a.master_username %></td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr id="noRecordsRow">
                <td colspan="13" class="text-center py-5">
                  <div class="empty-state">
                    <i class="bi bi-inbox empty-state-icon" style="font-size: 48px;"></i>
                    <h4 class="empty-state-title mt-3">No Records Found</h4>
                    <p class="empty-state-text">There are no washing assignments available at the moment.</p>
                  </div>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Load More Button -->
    <div class="text-center mt-4 mb-4">
      <button id="loadMoreBtn" class="btn btn-secondary">
        <i class="bi bi-arrow-down-circle me-2"></i>
        Load More
      </button>
    </div>
  </div>
</main>

<!-- Generate Challan Modal -->
<div class="modal fade" id="challanModal" tabindex="-1" role="dialog" aria-labelledby="challanModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg" role="document">
    <div class="modal-content" style="border-radius: var(--radius-xl); border: none; box-shadow: var(--shadow-xl);">
      <div class="modal-header" style="background: var(--charcoal); border-radius: var(--radius-xl) var(--radius-xl) 0 0;">
        <h5 class="modal-title" id="challanModalLabel" style="font-family: var(--font-display); color: white;">
          <i class="bi bi-file-earmark-text me-2"></i>Generate Challan
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" style="padding: 24px; background: var(--cream);">
        <div class="table-container">
          <div class="table-responsive">
            <table class="table mb-0" id="modalTable">
              <thead>
                <tr>
                  <th>Challan (Lot No)</th>
                  <th>SKU</th>
                  <th>Total Pieces</th>
                  <th>Cutting Remark</th>
                </tr>
              </thead>
              <tbody>
                <!-- Selected rows will be injected here via JavaScript -->
              </tbody>
            </table>
          </div>
        </div>
      </div>
      <div class="modal-footer" style="background: var(--cream-dark); border-radius: 0 0 var(--radius-xl) var(--radius-xl);">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
          <i class="bi bi-x-lg me-1"></i>Cancel
        </button>
        <button id="confirmChallanBtn" type="button" class="btn btn-primary">
          <i class="bi bi-check-lg me-1"></i>Confirm
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Page-specific Styles -->
<style>
  .main-content {
    padding-top: 28px;
    padding-bottom: 40px;
    background: var(--cream);
    min-height: calc(100vh - var(--navbar-height));
  }

  .table-responsive {
    overflow-x: auto;
  }

  .table th {
    white-space: nowrap;
    position: sticky;
    top: 0;
    background: var(--cream-dark);
    z-index: 10;
    color: var(--charcoal);
  }

  .table td {
    vertical-align: middle;
    background: var(--bg-card);
  }

  .table tbody tr:hover td {
    background: var(--cream);
  }

  .form-check-input {
    width: 18px;
    height: 18px;
    border: 2px solid var(--border-medium);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .form-check-input:checked {
    background-color: var(--terracotta);
    border-color: var(--terracotta);
  }

  .form-check-input:focus {
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px var(--terracotta-bg);
  }

  .font-monospace {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  /* Selected row highlight */
  tr.selected td {
    background-color: var(--terracotta-bg) !important;
  }

  /* Card styling */
  .card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    box-shadow: var(--shadow-sm);
  }

  /* Table container */
  .table-container {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  /* Page header styling */
  .page-header {
    margin-bottom: 24px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border-light);
  }

  .page-title {
    font-family: var(--font-display);
    color: var(--charcoal);
    font-size: var(--text-3xl);
  }

  .page-subtitle {
    color: var(--text-secondary);
    margin-top: 4px;
  }

  /* Button enhancements */
  .btn-primary {
    background: var(--terracotta);
    border-color: var(--terracotta);
  }

  .btn-primary:hover:not(:disabled) {
    background: var(--terracotta-dark);
    border-color: var(--terracotta-dark);
  }

  .btn-primary:disabled {
    background: var(--gray-400);
    border-color: var(--gray-400);
    cursor: not-allowed;
    opacity: 0.7;
  }

  .btn-success:disabled {
    background: var(--gray-400);
    border-color: var(--gray-400);
    cursor: not-allowed;
    opacity: 0.7;
  }

  /* Search input styling */
  .form-input {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }

  .form-input:focus {
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px var(--terracotta-bg);
    outline: none;
  }

  /* Badge styling */
  .badge-primary {
    background: var(--terracotta-bg);
    color: var(--terracotta);
    font-weight: 500;
  }

  .badge-success {
    background: var(--success-light);
    color: var(--success);
  }

  .badge-warning {
    background: var(--warning-light);
    color: var(--warning);
  }

  .badge-danger {
    background: var(--danger-light);
    color: var(--danger);
  }

  /* Load more button */
  #loadMoreBtn {
    min-width: 160px;
  }

  #loadMoreBtn .spinner {
    display: inline-block;
    width: 16px;
    height: 16px;
    border: 2px solid var(--border-light);
    border-top-color: var(--terracotta);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Empty state */
  .empty-state {
    padding: 40px 20px;
  }

  .empty-state-icon {
    color: var(--text-muted);
  }

  .empty-state-title {
    font-family: var(--font-display);
    color: var(--charcoal);
  }

  .empty-state-text {
    color: var(--text-secondary);
  }

  /* Alert styling */
  .alert {
    border-radius: var(--radius-md);
    border: none;
  }

  .alert-danger {
    background: var(--danger-light);
    color: var(--danger);
    border-left: 4px solid var(--danger);
  }

  .alert-success {
    background: var(--success-light);
    color: var(--success);
    border-left: 4px solid var(--success);
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .page-header .btn span {
      display: none;
    }

    .page-header .btn {
      padding: 10px;
    }

    .page-title {
      font-size: var(--text-2xl);
    }

    .main-content {
      padding: 20px 16px;
    }
  }

  /* Modal styling */
  .modal.fade .modal-dialog {
    transition: transform 0.3s ease-out;
  }

  .modal-content {
    background: var(--cream);
  }

  #modalTable th {
    background: var(--cream-dark);
  }

  #modalTable td {
    background: var(--bg-card);
  }
</style>

<!-- JavaScript -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
  // Debounce: delay execution until user stops typing.
  function debounce(func, wait) {
    let timeout;
    return function(...args) {
      clearTimeout(timeout);
      timeout = setTimeout(() => func.apply(this, args), wait);
    };
  }

  // Global state variables.
  let currentOffset = document.querySelectorAll('#assignmentsTable tbody tr').length;
  let currentSearchQuery = document.getElementById('searchInput').value || '';
  let selectedRows = [];

  // Helper function to escape HTML for safe rendering
  function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  // Update or append table rows.
  function updateTable(assignments, append) {
    const tbody = document.querySelector('#assignmentsTable tbody');
    if (!append) {
      while (tbody.firstChild) {
        tbody.removeChild(tbody.firstChild);
      }
    }

    if (assignments && assignments.length) {
      assignments.forEach(a => {
        const tr = document.createElement('tr');
        tr.setAttribute('data-id', a.washing_id);

        // Checkbox cell
        const tdCheckbox = document.createElement('td');
        const checkbox = document.createElement('input');
        checkbox.type = 'checkbox';
        checkbox.className = 'rowCheckbox form-check-input';
        checkbox.style.cursor = 'pointer';
        tdCheckbox.appendChild(checkbox);
        tr.appendChild(tdCheckbox);

        // ID cell
        const tdId = document.createElement('td');
        const spanId = document.createElement('span');
        spanId.className = 'font-monospace';
        spanId.textContent = a.washing_id;
        tdId.appendChild(spanId);
        tr.appendChild(tdId);

        // Lot No cell
        const tdLotNo = document.createElement('td');
        const spanLotNo = document.createElement('span');
        spanLotNo.className = 'badge badge-primary';
        spanLotNo.textContent = a.lot_no;
        tdLotNo.appendChild(spanLotNo);
        tr.appendChild(tdLotNo);

        // SKU cell
        const tdSku = document.createElement('td');
        tdSku.textContent = a.sku;
        tr.appendChild(tdSku);

        // Total Pieces cell
        const tdPieces = document.createElement('td');
        const strongPieces = document.createElement('strong');
        strongPieces.textContent = a.total_pieces;
        tdPieces.appendChild(strongPieces);
        tr.appendChild(tdPieces);

        // Assembly Remark cell
        const tdAssemblyRemark = document.createElement('td');
        tdAssemblyRemark.textContent = a.assembly_remark || '-';
        tr.appendChild(tdAssemblyRemark);

        // Cutting Remark cell
        const tdCuttingRemark = document.createElement('td');
        tdCuttingRemark.textContent = a.cutting_remark || '-';
        tr.appendChild(tdCuttingRemark);

        // Target Day cell
        const tdTargetDay = document.createElement('td');
        tdTargetDay.textContent = a.target_day ? new Date(a.target_day).toLocaleDateString() : '-';
        tr.appendChild(tdTargetDay);

        // Assigned On cell
        const tdAssignedOn = document.createElement('td');
        tdAssignedOn.textContent = a.assigned_on ? new Date(a.assigned_on).toLocaleString() : '-';
        tr.appendChild(tdAssignedOn);

        // Approval Status cell
        const tdStatus = document.createElement('td');
        const spanStatus = document.createElement('span');
        if (a.is_approved === 1) {
          spanStatus.className = 'badge badge-success';
          spanStatus.textContent = 'Approved';
        } else if (a.is_approved === 0) {
          spanStatus.className = 'badge badge-danger';
          spanStatus.textContent = 'Denied';
        } else {
          spanStatus.className = 'badge badge-warning';
          spanStatus.textContent = 'Pending';
        }
        tdStatus.appendChild(spanStatus);
        tr.appendChild(tdStatus);

        // Assignment Remark cell
        const tdAssignmentRemark = document.createElement('td');
        tdAssignmentRemark.textContent = a.assignment_remark || '-';
        tr.appendChild(tdAssignmentRemark);

        // Washer cell
        const tdWasher = document.createElement('td');
        tdWasher.textContent = a.washer_username;
        tr.appendChild(tdWasher);

        // Master cell
        const tdMaster = document.createElement('td');
        tdMaster.textContent = a.master_username;
        tr.appendChild(tdMaster);

        tbody.appendChild(tr);
      });
    } else if (!append) {
      const tr = document.createElement('tr');
      tr.id = 'noRecordsRow';
      const td = document.createElement('td');
      td.setAttribute('colspan', '13');
      td.className = 'text-center py-5';

      const emptyState = document.createElement('div');
      emptyState.className = 'empty-state';

      const icon = document.createElement('i');
      icon.className = 'bi bi-inbox empty-state-icon';
      icon.style.fontSize = '48px';
      emptyState.appendChild(icon);

      const title = document.createElement('h4');
      title.className = 'empty-state-title mt-3';
      title.textContent = 'No Records Found';
      emptyState.appendChild(title);

      const text = document.createElement('p');
      text.className = 'empty-state-text';
      text.textContent = 'There are no washing assignments available at the moment.';
      emptyState.appendChild(text);

      td.appendChild(emptyState);
      tr.appendChild(td);
      tbody.appendChild(tr);
    }
    attachCheckboxHandlers();
  }

  // Fetch search results (real-time).
  async function fetchSearchResults(query) {
    currentOffset = 0;
    const url = '/challandashboard/search?search=' + encodeURIComponent(query) + '&offset=' + currentOffset;
    try {
      const response = await fetch(url);
      const data = await response.json();
      updateTable(data.assignments, false);
      currentOffset += data.assignments.length;
      const loadMoreBtn = document.getElementById('loadMoreBtn');
      loadMoreBtn.disabled = (data.assignments.length < 50);
      if (data.assignments.length < 50) {
        loadMoreBtn.innerHTML = '<i class="bi bi-check-circle me-2"></i>No more records';
      } else {
        loadMoreBtn.innerHTML = '<i class="bi bi-arrow-down-circle me-2"></i>Load More';
      }
    } catch (error) {
      console.error('Error fetching search results:', error);
    }
  }

  // Load more data.
  async function loadMoreData() {
    const loadMoreBtn = document.getElementById('loadMoreBtn');
    loadMoreBtn.disabled = true;
    loadMoreBtn.innerHTML = '<span class="spinner me-2"></span>Loading...';

    // Always call the search endpoint—empty query returns all records.
    const baseUrl = '/challandashboard/search?search=' + encodeURIComponent(currentSearchQuery);
    const url = baseUrl + '&offset=' + currentOffset;

    try {
      const response = await fetch(url);
      const data = await response.json();
      let assignments = data.assignments;
      updateTable(assignments, true);

      if (assignments.length) {
        currentOffset += assignments.length;
        loadMoreBtn.disabled = false;
        loadMoreBtn.innerHTML = '<i class="bi bi-arrow-down-circle me-2"></i>Load More';
      } else {
        loadMoreBtn.innerHTML = '<i class="bi bi-check-circle me-2"></i>No more records';
      }
    } catch (error) {
      console.error('Error loading more data:', error);
      loadMoreBtn.disabled = false;
      loadMoreBtn.innerHTML = '<i class="bi bi-arrow-down-circle me-2"></i>Load More';
    }
  }

  // Attach change event handlers for row checkboxes.
  function attachCheckboxHandlers() {
    const checkboxes = document.querySelectorAll('.rowCheckbox');
    checkboxes.forEach(checkbox => {
      // Remove any previous listener.
      checkbox.removeEventListener('change', checkbox.changeHandler);

      checkbox.changeHandler = function() {
        selectedRows = [];
        document.querySelectorAll('.rowCheckbox').forEach(cb => {
          const tr = cb.closest('tr');
          if (cb.checked) {
            tr.classList.add('selected');
            selectedRows.push({
              washing_id: tr.getAttribute('data-id'),
              lot_no: tr.children[2].textContent,
              sku: tr.children[3].textContent,
              total_pieces: tr.children[4].textContent,
              cutting_remark: tr.children[6].textContent
            });
          } else {
            tr.classList.remove('selected');
          }
        });
        const enableState = selectedRows.length > 0;
        document.getElementById('generateChallanBtn').disabled = !enableState;
        document.getElementById('downloadChallanBtn').disabled = !enableState;
      };
      checkbox.addEventListener('change', checkbox.changeHandler);
    });
  }

  // "Select All" checkbox functionality.
  document.getElementById('selectAllCheckbox').addEventListener('change', function() {
    const checked = this.checked;
    document.querySelectorAll('.rowCheckbox').forEach(cb => {
      cb.checked = checked;
      cb.dispatchEvent(new Event('change'));
    });
  });

  // "Select All" button functionality.
  document.getElementById('selectAllBtn').addEventListener('click', function() {
    document.querySelectorAll('.rowCheckbox').forEach(cb => {
      if (!cb.checked) {
        cb.checked = true;
        cb.dispatchEvent(new Event('change'));
      }
    });
  });

  // Load More button event.
  document.getElementById('loadMoreBtn').addEventListener('click', loadMoreData);

  // Debounced search.
  const searchInput = document.getElementById('searchInput');
  searchInput.addEventListener('input', debounce((e) => {
    currentSearchQuery = e.target.value;
    currentOffset = 0;
    fetchSearchResults(currentSearchQuery);
  }, 300));

  // "Generate Challan" button event.
  document.getElementById('generateChallanBtn').addEventListener('click', function() {
    const modalTbody = document.querySelector('#modalTable tbody');
    while (modalTbody.firstChild) {
      modalTbody.removeChild(modalTbody.firstChild);
    }
    selectedRows.forEach(row => {
      const tr = document.createElement('tr');

      // Lot No cell
      const tdLotNo = document.createElement('td');
      const spanLotNo = document.createElement('span');
      spanLotNo.className = 'badge badge-primary';
      spanLotNo.textContent = row.lot_no;
      tdLotNo.appendChild(spanLotNo);
      tr.appendChild(tdLotNo);

      // SKU cell
      const tdSku = document.createElement('td');
      tdSku.textContent = row.sku;
      tr.appendChild(tdSku);

      // Total Pieces cell
      const tdPieces = document.createElement('td');
      const strongPieces = document.createElement('strong');
      strongPieces.textContent = row.total_pieces;
      tdPieces.appendChild(strongPieces);
      tr.appendChild(tdPieces);

      // Cutting Remark cell
      const tdCuttingRemark = document.createElement('td');
      tdCuttingRemark.textContent = row.cutting_remark || '-';
      tr.appendChild(tdCuttingRemark);

      modalTbody.appendChild(tr);
    });
    // Use Bootstrap 5 modal
    const modal = new bootstrap.Modal(document.getElementById('challanModal'));
    modal.show();
  });

  // "Download Challan" button event.
  document.getElementById('downloadChallanBtn').addEventListener('click', function() {
    alert('Download Challan would process selected data: ' + JSON.stringify(selectedRows));
  });

  // "Confirm" button in modal: dynamically create and submit a form.
  document.getElementById('confirmChallanBtn').addEventListener('click', function() {
    var form = document.createElement('form');
    form.method = 'POST';
    form.action = '/challandashboard/generate';
    var input = document.createElement('input');
    input.type = 'hidden';
    input.name = 'selectedRows';
    input.value = JSON.stringify(selectedRows);
    form.appendChild(input);
    document.body.appendChild(form);
    form.submit();
  });

  // Ensure handlers are attached after the DOM loads.
  document.addEventListener('DOMContentLoaded', attachCheckboxHandlers);
</script>

<%- include('partials/footer') %>
