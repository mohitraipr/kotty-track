  <!-- ─── My Work / My Payments ─────────────── -->
  <section class="sx-info">
    <div class="sx-info-tabs">
      <button class="sx-info-tab active" id="tabWork" onclick="switchInfoTab('work')">My Work</button>
      <button class="sx-info-tab" id="tabPayments" onclick="switchInfoTab('payments')">My Payments</button>
    </div>

    <!-- My Work -->
    <div class="sx-info-body" id="workTab">
      <div class="sx-controls">
        <select id="historyDays">
          <option value="1">Today</option>
          <option value="7" selected>7 days</option>
          <option value="30">30 days</option>
          <option value="90">90 days</option>
        </select>
        <select id="historyType">
          <option value="all">All actions</option>
          <option value="approve">Take into stitching</option>
          <option value="complete">Mark as done</option>
          <option value="reject">Rejected pieces</option>
        </select>
        <span class="spacer"></span>
        <button class="sx-btn-export" onclick="downloadHistoryExcel()">⬇ Excel</button>
      </div>
      <div id="historyList" class="sx-timeline">
        <div class="sx-placeholder"><div class="sx-placeholder-mark">·</div><p>Loading…</p></div>
      </div>
    </div>

    <!-- My Payments -->
    <div class="sx-info-body" id="paymentsTab" style="display: none;">
      <div class="sx-controls">
        <select id="payDays">
          <option value="7">7 days</option>
          <option value="30" selected>30 days</option>
          <option value="90">90 days</option>
          <option value="365">1 year</option>
        </select>
        <select id="payStatus">
          <option value="all">All</option>
          <option value="pending" selected>Pending only</option>
          <option value="paid">Paid only</option>
        </select>
        <span class="spacer"></span>
        <button class="sx-btn-export" onclick="downloadPaymentsExcel()">⬇ Excel</button>
      </div>
      <div id="paySummary" class="sx-pay-summary"></div>
      <div id="payList">
        <div class="sx-placeholder"><div class="sx-placeholder-mark">·</div><p>Loading…</p></div>
      </div>
    </div>
  </section>
</main>

<!-- ─── Modal: event detail + lot journey ─── -->
<div id="modalOverlay" class="sx sx-modal-overlay" role="dialog" aria-modal="true">
  <div class="sx-modal" id="modalCard">
    <div class="sx-modal-head">
      <div class="sx-modal-title-block">
        <p class="sx-modal-eyebrow" id="modalEyebrow">Event detail</p>
        <h3 class="sx-modal-title" id="modalTitle">—</h3>
      </div>
      <button class="sx-modal-close" onclick="closeModal()" aria-label="Close">×</button>
    </div>
    <div class="sx-modal-body" id="modalBody"></div>
  </div>
</div>

<div class="sx sx-toasts" id="toastArea"></div>

<script>
'use strict';

const BASE = '/washingdashboard';
const STAGE_LABEL = 'Washing';
// Stage feature flags. Per-stage views override these at generation time.
const STAGE_FEATURES = { rewash: false, dispatch: false };
// Human-readable name of the upstream stage / source pool. Used by the
// "total ready" label and "waiting for upstream" empty-state copy.
const UPSTREAM_LABEL = 'jeans assembly';
const UPSTREAM_NOUN  = 'assembled';

let currentLot = null;
let currentState = null;
let infoTab = 'work';

// ─── helpers ─────────────────────────────────
const el = id => document.getElementById(id);
const fmt = n => Number(n || 0).toLocaleString();
const fmtMoney = n => '₹ ' + Number(n || 0).toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 2 });
const escapeText = s => String(s).replace(/[&<>]/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c]));
const fmtDate = ts => {
  if (!ts) return '—';
  const d = new Date(ts);
  return d.toLocaleString(undefined, { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' });
};
const fmtDateLong = ts => {
  if (!ts) return '—';
  return new Date(ts).toLocaleString();
};

function toast(msg, kind) {
  const t = document.createElement('div');
  t.className = 'sx-toast ' + (kind || '');
  t.textContent = msg;
  el('toastArea').appendChild(t);
  setTimeout(() => { t.style.opacity = '0'; t.style.transition = 'opacity 0.3s'; }, 3500);
  setTimeout(() => t.remove(), 3800);
}

function api(method, url, body) {
  const opts = { method, headers: { 'Content-Type': 'application/json' } };
  if (body) opts.body = JSON.stringify(body);
  return fetch(url, opts).then(async r => {
    const data = await r.json().catch(() => ({}));
    if (!r.ok) throw new Error(data.error || ('HTTP ' + r.status));
    return data;
  });
}

// pill in header — show user
try {
  const u = <%- JSON.stringify(user || {}) %>;
  if (u && u.username) el('pageUserPill').textContent = u.username;
} catch (_) {}

// ─── search ────────────────────────────────
async function runSearch() {
  const q = el('searchInput').value.trim();
  if (!q) return;
  const btn = el('searchBtn');
  btn.disabled = true; btn.textContent = '…';
  try {
    const data = await api('GET', BASE + '/event/search?q=' + encodeURIComponent(q));
    const wrap = el('searchResults');
    wrap.textContent = '';
    if (!data.lots.length) {
      wrap.innerHTML = '<div class="sx-placeholder"><div class="sx-placeholder-mark">·</div><p>No lots found for &ldquo;' + escapeText(q) + '&rdquo;</p></div>';
      wrap.classList.add('show'); return;
    }
    if (data.lots.length === 1) { wrap.classList.remove('show'); await selectLot(data.lots[0]); return; }
    data.lots.forEach(lot => {
      const row = document.createElement('div');
      row.className = 'sx-search-row-result';
      row.onclick = () => selectLot(lot);
      const isDenim = (lot.flow_type || '').toLowerCase() === 'denim' || (lot.flow_type === null && lot.is_denim_cutter);
      row.innerHTML = `
        <span class="sx-result-no">${escapeText((lot.manual_lot_number || lot.lot_no || '').toUpperCase())}</span>
        <span class="sx-result-meta">${lot.manual_lot_number ? 'Lot ' + escapeText((lot.lot_no || '').toUpperCase()) + ' · ' : ''}${escapeText(lot.sku || '—')} · ${fmt(Number(lot.total_pieces || 0))} pcs cut</span>
        <span class="sx-flow ${isDenim ? 'denim' : 'hosiery'}">${isDenim ? 'denim' : 'hosiery'}</span>
      `;
      wrap.appendChild(row);
    });
    wrap.classList.add('show');
  } catch (err) { toast('Search failed: ' + err.message, 'error'); }
  finally { btn.disabled = false; btn.textContent = 'Search'; }
}
el('searchBtn').addEventListener('click', runSearch);
el('searchInput').addEventListener('keydown', e => { if (e.key === 'Enter') runSearch(); });

// ─── select lot ────────────────────────────
async function selectLot(lot) {
  el('searchResults').classList.remove('show');
  currentLot = lot;
  await refreshState();
}

async function refreshState() {
  if (!currentLot) return;
  try {
    currentState = await api('GET', BASE + '/event/lot-state/' + currentLot.id);
    renderState();
  } catch (err) { toast('Could not load lot: ' + err.message, 'error'); }
}

function renderStageUsers(su) {
  const ju = document.getElementById('lotJourneyUsers');
  if (!ju) return;
  su = su || [];
  if (!su.length) { ju.style.display = 'none'; return; }
  const esc = (v) => String(v == null ? '' : v).replace(/[<>&]/g, (c) => ({ '<': '&lt;', '>': '&gt;', '&': '&amp;' }[c]));
  let lastDone = -1;
  su.forEach((s, i) => { if (s.master) lastDone = i; });
  ju.className = 'sx-rail';
  ju.style.display = '';
  ju.innerHTML = su.map((s, i) => {
    const has = !!s.master;
    let cls = 'sx-rail-step';
    if (i === lastDone) cls += ' current';
    else if (has) cls += ' done';
    const node = (i === lastDone) ? '●' : (has ? '✓' : '');
    return '<div class="' + cls + '">'
      + '<div class="sx-rail-node">' + node + '</div>'
      + '<div class="sx-rail-lbl">' + esc(s.label) + '</div>'
      + (has ? '<div class="sx-rail-who" title="' + esc(s.master) + '">' + esc(s.master) + '</div>' : '')
      + '</div>';
  }).join('');
}

function renderState() {
  if (!currentState) return;
  const { lot, stage_aggregates: agg, upstream_sizes, open_approvals: open } = currentState;

  el('lotNo').textContent = (lot.manual_lot_number || lot.lot_no || '').toUpperCase();
  el('lotSku').textContent = lot.sku || '—';
  el('lotCutter').textContent = lot.cutting_master || '—';
  const isDenim = (lot.flow_type || '').toLowerCase() === 'denim' || (lot.flow_type === null && lot.is_denim_cutter);
  const flowEl = el('lotFlow');
  flowEl.className = 'sx-flow ' + (isDenim ? 'denim' : 'hosiery');
  flowEl.textContent = isDenim ? 'denim' : 'hosiery';

  renderStageUsers(currentState.stage_users);

  const remarkNote = el('cuttingRemarkNote');
  if (lot.cutting_remark) {
    el('cuttingRemarkText').textContent = lot.cutting_remark;
    remarkNote.style.display = 'flex';
  } else { remarkNote.style.display = 'none'; }

  el('aggApproved').textContent = fmt(agg.approved);
  el('aggCompleted').textContent = fmt(agg.completed);
  el('aggRejected').textContent = fmt(agg.rejected);
  el('aggInline').textContent = fmt(agg.inline);

  const totalCut = upstream_sizes.reduce((a, s) => a + (Number(s.cut_qty || s.stitched_qty || s.assembled_qty || s.washed_qty || s.upstream_qty) || 0), 0);
  el('totalCut').textContent = fmt(totalCut);
  const totalLbl = el('totalLabel'); if (totalLbl) totalLbl.textContent = 'total ' + UPSTREAM_NOUN;

  // size chips (compact)
  const chips = el('sizeChips'); chips.textContent = '';
  upstream_sizes.forEach(s => {
    const cut = s.cut_qty || s.stitched_qty || s.assembled_qty || s.washed_qty || s.upstream_qty || 0;
    const completed = s.completed || 0;
    const approved = s.approved || 0;
    let cls = 's-empty';
    let glyph = '';
    if (cut > 0 && completed >= cut) { cls = 's-done'; glyph = '✓'; }
    else if (approved > 0) { cls = 's-progress'; glyph = '·'; }
    const chip = document.createElement('div');
    chip.className = 'sx-chip ' + cls;
    chip.innerHTML = `
      <span class="sx-chip-label">${escapeText(s.size_label)}</span>
      <span class="sx-chip-num">${fmt(completed)} / ${fmt(cut)}</span>
      ${glyph ? '<span class="sx-chip-status">' + glyph + '</span>' : ''}
    `;
    chips.appendChild(chip);
  });

  el('lotCard').classList.add('show');
  el('actionsSection').classList.add('show');
  renderActions();
}

// ═════════════════════════════════════════════════════
// Auto-action panel
// ═════════════════════════════════════════════════════
async function renderActions() {
  const wrap = el('actionsContainer');
  wrap.innerHTML = '';
  const totalAvailable = currentState.upstream_total_available || 0;
  const open = currentState.open_approvals;

  let cards = 0;
  if (totalAvailable > 0) {
    cards++;
    wrap.appendChild(buildTakeCard());
  }
  open.forEach(a => {
    cards++;
    wrap.appendChild(buildDoneCard(a));
  });
  // Dispatch (finishing only) — show card if there's anything ready to ship
  if (STAGE_FEATURES.dispatch) {
    try {
      const ds = await api('GET', BASE + '/event/dispatch-state/' + currentLot.id);
      const summary = ds.lot_summary || { available: 0 };
      if ((summary.available || 0) > 0) {
        cards++;
        wrap.appendChild(buildDispatchCard(ds));
      }
    } catch (err) {
      console.warn('dispatch-state failed', err.message);
    }
  }
  if (cards === 0) {
    const card = document.createElement('div');
    card.className = 'sx-action-card is-empty';
    const agg = currentState.stage_aggregates || { approved: 0, completed: 0, rejected: 0, inline: 0 };
    const upstreamPool = (currentState.upstream_sizes || []).reduce(
      (a, s) => a + (Number(s.cut_qty || s.stitched_qty || s.assembled_qty || s.washed_qty || s.upstream_qty) || 0), 0
    );
    let mark = '✓';
    let title = '';
    let sub = '';
    if (upstreamPool === 0 && agg.approved === 0) {
      // Nothing has reached this stage yet
      mark = '⌛';
      title = `Not ready yet — waiting for ${UPSTREAM_LABEL} to finish this lot.`;
      sub = `As soon as pieces are completed at ${UPSTREAM_LABEL}, they'll show up here for you to take.`;
    } else if (agg.approved > 0 && agg.inline === 0) {
      // Everything that came in has been completed/rejected
      title = `This lot is fully processed at ${STAGE_LABEL.toLowerCase()}.`;
      sub = 'Nothing for you to do here.';
    } else if (agg.inline > 0) {
      // Owner-locked: someone else is mid-batch
      mark = '👥';
      title = 'Other operators are working on this lot.';
      sub = `${fmt(agg.inline)} pieces are inline with someone else's batch — you can't act on them.`;
    } else {
      // upstream pool > 0 but available = 0 (everything taken, none open)
      title = `Nothing left to take — everyone took what they needed.`;
      sub = 'Wait for them to mark their pieces done.';
    }
    card.innerHTML = `
      <div class="sx-empty-mark">${mark}</div>
      <p>${escapeText(title)}<small>${escapeText(sub)}</small></p>
    `;
    wrap.appendChild(card);
    el('actionsHeading').textContent = '— this lot —';
  } else {
    el('actionsHeading').textContent = cards === 1 ? 'What you can do' : 'What you can do · ' + cards + ' actions';
  }
}

// ─── Dispatch card (finishing only) ───────────────────────────
function buildDispatchCard(state) {
  const card = document.createElement('div');
  card.className = 'sx-action-card is-dispatch';
  const summary = state.lot_summary || { available: 0 };

  card.innerHTML = `
    <div class="sx-action-card-body">
      <div class="sx-action-row">
        <div class="sx-action-icon">→</div>
        <div class="sx-action-text">
          <p class="sx-action-title">Dispatch <span class="qty">${fmt(summary.available)}</span> finished pieces</p>
          <p class="sx-action-sub">Pieces you've completed and not yet shipped. Pick a destination and the pieces to send.</p>
        </div>
      </div>
      <button class="sx-action-cta" data-action="dispatch-toggle-form">
        <span class="sx-action-cta-check">→</span>
        Open dispatch form
      </button>
    </div>
    <button class="sx-action-toggle" data-action="dispatch-toggle">
      <span class="arrow">⌄</span> ${state.batches.length} batch${state.batches.length === 1 ? '' : 'es'} ready
    </button>
    <div class="sx-action-form" id="dispatchForm"></div>
  `;

  const form = card.querySelector('#dispatchForm');
  state.batches.forEach((b, idx) => {
    if ((b.available || 0) === 0) return;
    const block = document.createElement('div');
    block.className = 'sx-dispatch-batch';
    block.dataset.fdId = String(b.finishing_data_id);
    const created = b.created_at ? new Date(b.created_at).toLocaleDateString(undefined, { day: 'numeric', month: 'short' }) : '';
    block.innerHTML = `
      <div class="sx-dispatch-batch-head">
        Batch <span class="b">#${b.finishing_data_id}</span> · ${fmt(b.available)} available${created ? ' · completed ' + escapeText(created) : ''}
      </div>
      <div class="sx-input-list" data-list="dispatch-sizes-${idx}"></div>
      <div class="sx-dest-row">
        <select data-input="destination-${idx}">
          <option value="">— Select destination —</option>
          <option value="Warehouse">Warehouse</option>
          <option value="Ajio">Ajio</option>
          <option value="Myntra">Myntra</option>
          <option value="Amazon">Amazon</option>
          <option value="Flipkart">Flipkart</option>
          <option value="Shopify">Shopify (own store)</option>
          <option value="other">Other…</option>
        </select>
        <input type="text" placeholder="Custom destination" data-input="custom-dest-${idx}" />
      </div>
      <div class="sx-totals" style="margin-top: 0.625rem;">
        <span class="l">Dispatching from this batch</span>
        <span class="v" data-display="dispatch-total-${idx}">0</span>
      </div>
      <button class="sx-form-submit" data-action="dispatch-submit" data-idx="${idx}">Dispatch from batch #${b.finishing_data_id}</button>
    `;

    const sizeList = block.querySelector(`[data-list="dispatch-sizes-${idx}"]`);
    b.sizes.forEach(s => {
      if ((s.available || 0) === 0) return;
      const sRow = document.createElement('div');
      sRow.className = 'sx-input-row';
      sRow.innerHTML = `
        <span class="sx-input-label">${escapeText(s.size_label)}</span>
        <span class="sx-input-avail"><span class="n">${fmt(s.available)}</span> ready</span>
        <div class="sx-stepper">
          <button type="button" data-step="-10">−10</button>
          <button type="button" data-step="-1">−</button>
          <input type="number" min="0" max="${s.available}" value="${s.available}"
                 data-size="${escapeText(s.size_label)}" data-avail="${s.available}" data-batch="${idx}" />
          <button type="button" data-step="1">+</button>
          <button type="button" data-step="10">+10</button>
        </div>
      `;
      bindStepper(sRow, () => recalcDispatchTotal(card, idx));
      sizeList.appendChild(sRow);
    });
    form.appendChild(block);

    block.querySelector(`[data-action="dispatch-submit"]`).addEventListener('click',
      () => doDispatch(card, idx, b.finishing_data_id));
    recalcDispatchTotal(card, idx);
  });

  card.querySelector('[data-action="dispatch-toggle"]').addEventListener('click', () => card.classList.toggle('expanded'));
  card.querySelector('[data-action="dispatch-toggle-form"]').addEventListener('click', () => card.classList.add('expanded'));

  return card;
}

function recalcDispatchTotal(card, idx) {
  const inputs = card.querySelectorAll(`[data-list="dispatch-sizes-${idx}"] input[data-size]`);
  let total = 0;
  inputs.forEach(i => {
    let v = parseInt(i.value, 10);
    if (!Number.isFinite(v) || v < 0) v = 0;
    const max = Number(i.dataset.avail) || 0;
    if (v > max) { v = max; i.value = v; }
    total += v;
  });
  const t = card.querySelector(`[data-display="dispatch-total-${idx}"]`);
  if (t) t.textContent = fmt(total);
}

async function doDispatch(card, idx, finishing_data_id) {
  const inputs = card.querySelectorAll(`[data-list="dispatch-sizes-${idx}"] input[data-size]`);
  const sizes = [];
  inputs.forEach(i => {
    const p = parseInt(i.value, 10) || 0;
    if (p > 0) sizes.push({ size_label: i.dataset.size, pieces: p });
  });
  if (!sizes.length) { toast('No pieces selected', 'error'); return; }
  const destSel = card.querySelector(`[data-input="destination-${idx}"]`);
  const customInput = card.querySelector(`[data-input="custom-dest-${idx}"]`);
  let dest = (destSel && destSel.value) || '';
  if (dest === 'other') dest = (customInput && customInput.value || '').trim();
  if (!dest) { toast('Pick a destination', 'error'); return; }
  const total = sizes.reduce((a, s) => a + s.pieces, 0);
  if (!confirm('Dispatch ' + fmt(total) + ' pieces from batch #' + finishing_data_id + ' to ' + dest + '?')) return;
  try {
    await api('POST', BASE + '/event/dispatch', {
      finishing_data_id, destination: dest === 'other' ? 'other' : dest,
      custom_destination: dest, sizes,
    });
    toast('Dispatched ' + fmt(total) + ' pieces ✓', 'success');
    await refreshState();
  } catch (err) { toast('Could not dispatch: ' + err.message, 'error'); }
}

