<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
<title>Washing</title>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
</head>
<body>

<style>
  /* ───────────────────────────────────────────────────────────────
     STITCHING DASHBOARD v3
     Enterprise-clean, mobile-first, factory-friendly.
     Inter throughout, indigo accent, strict color coding.
     ─────────────────────────────────────────────────────────────── */

  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap');

  /* Scope all rules under .sx so we don't fight global kotty-theme styles */
  .sx {
    --c-bg:        #f7f8fa;
    --c-card:      #ffffff;
    --c-border:    #e5e7eb;
    --c-border-2:  #eef0f4;

    --c-text:      #0f172a;   /* slate-900 */
    --c-text-2:    #475569;   /* slate-600 */
    --c-text-3:    #94a3b8;   /* slate-400 */

    --c-primary:        #2563eb;   /* indigo-600 */
    --c-primary-hover:  #1d4ed8;   /* indigo-700 */
    --c-primary-soft:   #eff6ff;   /* indigo-50 */
    --c-primary-strip:  #3b82f6;   /* indigo-500 */

    --c-success:        #16a34a;   /* emerald-600 */
    --c-success-hover:  #15803d;
    --c-success-soft:   #dcfce7;

    --c-warning:        #b45309;   /* amber-600 */
    --c-warning-soft:   #fef3c7;

    --c-danger:         #dc2626;   /* red-600 */
    --c-danger-hover:   #b91c1c;
    --c-danger-soft:    #fee2e2;

    --shadow-sm:  0 1px 2px rgba(15, 23, 42, 0.04);
    --shadow:     0 1px 3px rgba(15, 23, 42, 0.06), 0 1px 2px rgba(15, 23, 42, 0.04);
    --shadow-lg:  0 8px 24px rgba(15, 23, 42, 0.08), 0 2px 6px rgba(15, 23, 42, 0.04);
    --shadow-xl:  0 24px 48px rgba(15, 23, 42, 0.18), 0 8px 16px rgba(15, 23, 42, 0.08);

    --r-sm: 8px;
    --r:    12px;
    --r-lg: 16px;
    --r-xl: 20px;
    --r-pill: 999px;

    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    color: var(--c-text);
    -webkit-font-smoothing: antialiased;
  }

  body { background: #f7f8fa; }

  .sx-page {
    max-width: 960px;
    margin: 0 auto;
    padding: calc(64px + 1.25rem) 1rem 6rem;
    min-height: 100vh;
  }

  /* ── Stitch shell chrome (matches the Kotty Floor hub) ───────────── */
  .flx-top {
    position: fixed; top: 0; left: 0; right: 0; height: 64px; z-index: 50;
    background: #f7f8fa; border-bottom: 1px solid #e5e7eb;
    display: flex; align-items: center; justify-content: space-between; padding: 0 16px;
  }
  .flx-top .brand { display: flex; align-items: center; gap: 10px; }
  .flx-top .brand .material-symbols-outlined { color: #2563eb; }
  .flx-top .brand h1 {
    font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 18px;
    text-transform: uppercase; letter-spacing: 0.08em; color: #2563eb; margin: 0;
  }
  .flx-top .u {
    width: 40px; height: 40px; border-radius: 999px; background: #eff6ff; color: #2563eb;
    display: grid; place-items: center; font-family: 'Space Grotesk', sans-serif; font-weight: 700;
    text-decoration: none; border: 1px solid rgba(37,99,235,0.1);
  }
  .flx-nav {
    position: fixed; bottom: 0; left: 0; right: 0; height: 64px; z-index: 50;
    background: #ffffff; border-top: 1px solid #e5e7eb;
    display: flex; justify-content: space-around; align-items: center;
    padding-bottom: env(safe-area-inset-bottom);
  }
  .flx-nav a {
    display: flex; flex-direction: column; align-items: center; gap: 2px; text-decoration: none;
    color: #64748b; font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em;
  }
  .flx-nav a.active { color: #2563eb; }
  .flx-nav a .material-symbols-outlined { font-size: 24px; }
  .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400; vertical-align: middle; }
  .flx-top .flx-actions { display: flex; align-items: center; gap: 12px; }
  .flx-top .flx-home { color: #64748b; display: flex; }
  .flx-top .flx-user { font-size: 13px; font-weight: 600; color: #0f172a; }
  .flx-top .flx-logout { display: inline-flex; align-items: center; gap: 6px; color: #dc2626;
    text-decoration: none; font-size: 13px; font-weight: 600; padding: 6px 10px;
    border: 1px solid #fecaca; border-radius: 8px; }
  .flx-top .flx-logout .material-symbols-outlined { font-size: 18px; }
  @media (max-width: 420px) { .flx-top .flx-user, .flx-top .flx-logout-t { display: none; } }

  /* Stage rail — the lot's journey (cut → stitch → … → finish) */
  .sx-rail { display: flex; flex-wrap: wrap; align-items: flex-start; gap: 4px 0; margin: 16px 0 4px; }
  .sx-rail-step { display: flex; flex-direction: column; align-items: center; flex: 1 1 0; min-width: 56px; position: relative; }
  .sx-rail-step::before { content: ''; position: absolute; top: 14px; left: -50%; width: 100%; height: 2px; background: #e5e7eb; z-index: 0; }
  .sx-rail-step:first-child::before { display: none; }
  .sx-rail-step.done::before, .sx-rail-step.current::before { background: #16a34a; }
  .sx-rail-node { width: 30px; height: 30px; border-radius: 999px; border: 2px solid #e5e7eb; background: #fff;
    display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 15px; font-weight: 700; z-index: 1; }
  .sx-rail-step.done .sx-rail-node { border-color: #16a34a; color: #16a34a; }
  .sx-rail-step.current .sx-rail-node { background: #2563eb; border-color: #2563eb; color: #fff; box-shadow: 0 0 0 4px #eff6ff; }
  .sx-rail-lbl { font-size: 10px; text-transform: uppercase; letter-spacing: .04em; color: #64748b; font-weight: 700; margin-top: 5px; text-align: center; }
  .sx-rail-who { font-size: 10px; color: #0f172a; font-weight: 600; margin-top: 1px; text-align: center; max-width: 64px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  /* ─── Page header ──────────────────────────────────────── */
  .sx-head {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 1.25rem;
    gap: 1rem; flex-wrap: wrap;
  }
  .sx-head h1 {
    font-size: clamp(1.5rem, 3.5vw, 1.875rem);
    font-weight: 700;
    color: var(--c-text);
    margin: 0;
    letter-spacing: -0.02em;
  }
  .sx-head .pill {
    font-size: 0.75rem; font-weight: 500;
    padding: 0.25rem 0.625rem;
    background: var(--c-card); border: 1px solid var(--c-border);
    color: var(--c-text-2);
    border-radius: var(--r-pill);
  }

  /* ─── Search ──────────────────────────────────────────── */
  .sx-search {
    background: var(--c-card);
    border: 1px solid var(--c-border);
    border-radius: var(--r-lg);
    padding: 0.875rem;
    margin-bottom: 1rem;
    box-shadow: var(--shadow-sm);
  }
  .sx-search-row { display: flex; gap: 0.5rem; align-items: center; }
  .sx-search-icon {
    flex: 0 0 auto; width: 36px; height: 36px;
    display: flex; align-items: center; justify-content: center;
    color: var(--c-text-3); margin-left: 0.25rem;
  }
  .sx-search input {
    flex: 1; min-width: 0;
    border: none; outline: none; background: transparent;
    font-family: inherit;
    font-size: 1rem; padding: 0.625rem 0.5rem;
    color: var(--c-text);
  }
  .sx-search input::placeholder { color: var(--c-text-3); }
  .sx-btn {
    border: none; cursor: pointer;
    font-family: inherit; font-weight: 600; font-size: 0.9375rem;
    padding: 0.625rem 1.125rem;
    border-radius: var(--r);
    transition: all 0.15s;
  }
  .sx-btn-primary {
    background: var(--c-primary); color: white;
    box-shadow: 0 1px 2px rgba(79, 70, 229, 0.25);
  }
  .sx-btn-primary:hover { background: var(--c-primary-hover); transform: translateY(-1px); box-shadow: 0 4px 12px rgba(79, 70, 229, 0.35); }
  .sx-btn-primary:disabled { background: var(--c-text-3); cursor: not-allowed; transform: none; box-shadow: none; }
  .sx-btn-ghost {
    background: transparent; color: var(--c-text-2); border: 1px solid var(--c-border);
  }
  .sx-btn-ghost:hover { background: var(--c-bg); color: var(--c-text); }

  .sx-search-results {
    margin-top: 0.875rem;
    border-top: 1px solid var(--c-border-2);
    padding-top: 0.625rem;
    display: none;
  }
  .sx-search-results.show { display: block; animation: fadeIn 0.2s; }
  .sx-search-row-result {
    display: flex; align-items: center; gap: 1rem;
    padding: 0.75rem 0.625rem;
    border-radius: var(--r-sm);
    cursor: pointer;
    transition: background 0.12s;
  }
  .sx-search-row-result:hover { background: var(--c-bg); }
  .sx-search-row-result + .sx-search-row-result { border-top: 1px solid var(--c-border-2); }
  .sx-result-no {
    font-weight: 700; color: var(--c-text); font-size: 0.9375rem;
    min-width: 7rem; letter-spacing: 0.02em;
  }
  .sx-result-meta { flex: 1; color: var(--c-text-2); font-size: 0.875rem; }
  .sx-flow {
    font-size: 0.75rem; font-weight: 500;
    padding: 0.2rem 0.625rem; border-radius: var(--r-pill);
    text-transform: capitalize;
  }
  .sx-flow.denim { background: var(--c-primary-soft); color: var(--c-primary); }
  .sx-flow.hosiery { background: #f0f9ff; color: #0369a1; }

  /* ─── Lot context card ────────────────────────────────── */
  .sx-lot {
    background: var(--c-card); border: 1px solid var(--c-border);
    border-radius: var(--r-xl);
    padding: 1.25rem 1.25rem 1rem;
    box-shadow: var(--shadow);
    margin-bottom: 1rem;
    display: none;
  }
  .sx-lot.show { display: block; animation: slideUpFade 0.3s ease-out; }

  .sx-lot-head {
    display: flex; align-items: center; justify-content: space-between; gap: 0.75rem;
    margin-bottom: 0.25rem;
  }
  .sx-lot-no {
    font-size: clamp(1.5rem, 4.5vw, 2rem);
    font-weight: 800;
    color: var(--c-text);
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin: 0;
  }
  .sx-lot-meta {
    color: var(--c-text-2); font-size: 0.875rem;
    margin: 0.25rem 0 0.875rem;
  }
  .sx-lot-meta strong { color: var(--c-text); font-weight: 600; }

  .sx-cutting-remark {
    display: flex; gap: 0.625rem; align-items: flex-start;
    padding: 0.75rem 0.875rem;
    background: var(--c-warning-soft);
    border-radius: var(--r);
    margin-bottom: 1rem;
    border-left: 3px solid var(--c-warning);
  }
  .sx-cutting-remark .label {
    font-size: 0.75rem; font-weight: 700;
    color: var(--c-warning); white-space: nowrap;
    text-transform: uppercase; letter-spacing: 0.05em;
    padding-top: 1px;
  }
  .sx-cutting-remark .text {
    color: var(--c-text); font-size: 0.875rem; line-height: 1.5;
    flex: 1;
  }

  /* aggregate strip — 4 stats */
  .sx-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.5rem;
    margin: 0.875rem 0 1.125rem;
  }
  .sx-stat {
    background: var(--c-bg); border-radius: var(--r);
    padding: 0.75rem 0.625rem;
    text-align: center;
  }
  .sx-stat .l {
    font-size: 0.6875rem; font-weight: 600;
    color: var(--c-text-3);
    text-transform: uppercase; letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }
  .sx-stat .v {
    font-size: clamp(1.25rem, 3.5vw, 1.625rem);
    font-weight: 700; line-height: 1;
    color: var(--c-text);
    font-variant-numeric: tabular-nums;
  }
  .sx-stat.is-completed { background: var(--c-success-soft); }
  .sx-stat.is-completed .l { color: var(--c-success); }
  .sx-stat.is-completed .v { color: var(--c-success); }
  .sx-stat.is-rejected { background: var(--c-danger-soft); }
  .sx-stat.is-rejected .l { color: var(--c-danger); }
  .sx-stat.is-rejected .v { color: var(--c-danger); }
  .sx-stat.is-inline { background: var(--c-warning-soft); }
  .sx-stat.is-inline .l { color: var(--c-warning); }
  .sx-stat.is-inline .v { color: var(--c-warning); }

  /* size chips — compact, color coded */
  .sx-sizes-label {
    font-size: 0.75rem; font-weight: 600;
    color: var(--c-text-3); text-transform: uppercase; letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }
  .sx-sizes-label .total { color: var(--c-text-2); margin-left: 0.5rem; font-weight: 500; text-transform: none; letter-spacing: normal; }
  .sx-chip-row {
    display: flex; flex-wrap: wrap; gap: 0.375rem;
  }
  .sx-chip {
    display: inline-flex; align-items: center; gap: 0.375rem;
    padding: 0.375rem 0.625rem;
    background: var(--c-bg); border: 1px solid var(--c-border);
    border-radius: var(--r-pill);
    font-size: 0.8125rem;
    cursor: default;
    transition: all 0.15s;
  }
  .sx-chip-label { font-weight: 700; color: var(--c-text); font-variant-numeric: tabular-nums; }
  .sx-chip-num   { color: var(--c-text-2); font-variant-numeric: tabular-nums; }
  .sx-chip-status {
    font-size: 0.75rem;
    width: 16px; height: 16px;
    border-radius: 50%;
    display: inline-flex; align-items: center; justify-content: center;
    color: white; font-weight: 700;
    flex-shrink: 0;
  }
  .sx-chip.s-done { background: var(--c-success-soft); border-color: transparent; }
  .sx-chip.s-done .sx-chip-label { color: var(--c-success); }
  .sx-chip.s-done .sx-chip-num { color: var(--c-success); }
  .sx-chip.s-done .sx-chip-status { background: var(--c-success); }
  .sx-chip.s-progress { background: var(--c-warning-soft); border-color: transparent; }
  .sx-chip.s-progress .sx-chip-label { color: var(--c-warning); }
  .sx-chip.s-progress .sx-chip-num { color: var(--c-warning); }
  .sx-chip.s-progress .sx-chip-status { background: var(--c-warning); }
  .sx-chip.s-empty { /* default neutral state */ }

  /* ─── Action panel ──────────────────────────────────── */
  .sx-actions { display: none; }
  .sx-actions.show { display: block; }

  .sx-actions-h {
    font-size: 0.75rem; font-weight: 700;
    color: var(--c-text-3);
    text-transform: uppercase; letter-spacing: 0.06em;
    margin: 0 0 0.625rem;
    padding: 0 0.25rem;
  }

  .sx-action-card {
    background: var(--c-card); border: 1px solid var(--c-border);
    border-radius: var(--r-xl);
    box-shadow: var(--shadow);
    margin-bottom: 0.875rem;
    overflow: hidden;
    position: relative;
  }
  .sx-action-card::before {
    content: ''; position: absolute; top: 0; left: 0; bottom: 0;
    width: 4px;
    background: var(--c-primary);
  }
  .sx-action-card.is-done::before { background: var(--c-success); }
  .sx-action-card.is-empty::before { display: none; }

  .sx-action-card-body {
    padding: 1.125rem 1.25rem 1.125rem 1.5rem;
  }
  .sx-action-row {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: 1rem; margin-bottom: 1rem;
  }
  .sx-action-icon {
    flex: 0 0 auto;
    width: 44px; height: 44px;
    border-radius: var(--r);
    display: flex; align-items: center; justify-content: center;
    background: var(--c-primary-soft); color: var(--c-primary);
    font-size: 1.125rem; font-weight: 700;
  }
  .sx-action-card.is-done .sx-action-icon { background: var(--c-success-soft); color: var(--c-success); }
  .sx-action-card.is-empty .sx-action-icon { background: var(--c-bg); color: var(--c-text-3); }

  .sx-action-text { flex: 1; min-width: 0; }
  .sx-action-title {
    font-size: 1.0625rem; font-weight: 700; color: var(--c-text);
    margin: 0; line-height: 1.3;
    letter-spacing: -0.01em;
  }
  .sx-action-title .qty {
    font-size: 1.375rem; font-weight: 800;
    color: var(--c-primary); font-variant-numeric: tabular-nums;
    margin: 0 0.125rem;
  }
  .sx-action-card.is-done .sx-action-title .qty { color: var(--c-success); }
  .sx-action-sub {
    color: var(--c-text-2); font-size: 0.875rem;
    margin: 0.25rem 0 0;
  }

  .sx-action-cta {
    width: 100%;
    padding: 0.875rem 1rem;
    border: none; border-radius: var(--r);
    cursor: pointer;
    background: var(--c-primary); color: white;
    font-family: inherit; font-weight: 600; font-size: 0.9375rem;
    display: flex; align-items: center; justify-content: center; gap: 0.5rem;
    box-shadow: 0 1px 2px rgba(79, 70, 229, 0.25);
    transition: all 0.15s;
  }
  .sx-action-cta:hover { background: var(--c-primary-hover); transform: translateY(-1px); box-shadow: 0 4px 12px rgba(79, 70, 229, 0.35); }
  .sx-action-card.is-done .sx-action-cta { background: var(--c-success); box-shadow: 0 1px 2px rgba(22, 163, 74, 0.25); }
  .sx-action-card.is-done .sx-action-cta:hover { background: var(--c-success-hover); box-shadow: 0 4px 12px rgba(22, 163, 74, 0.35); }
  .sx-action-cta-check {
    width: 22px; height: 22px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 0.75rem; font-weight: 700;
  }
  .sx-action-cta:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

  .sx-action-toggle {
    display: block;
    width: 100%; margin-top: 0.5rem;
    padding: 0.625rem;
    background: transparent; border: none; cursor: pointer;
    color: var(--c-text-2); font-family: inherit; font-size: 0.8125rem; font-weight: 500;
    text-align: center;
    border-top: 1px solid var(--c-border-2);
    margin-left: -1.5rem; margin-right: -1.25rem; margin-bottom: -1.125rem; margin-top: 1rem;
    border-bottom-left-radius: var(--r-xl); border-bottom-right-radius: var(--r-xl);
    transition: all 0.15s;
  }
  .sx-action-toggle:hover { background: var(--c-bg); color: var(--c-text); }
  .sx-action-toggle .arrow { display: inline-block; margin-right: 0.25rem; transition: transform 0.2s; }
  .sx-action-card.expanded .sx-action-toggle .arrow { transform: rotate(180deg); }
  .sx-action-card.expanded .sx-action-toggle { background: var(--c-bg); color: var(--c-text); }

  .sx-action-form { display: none; padding: 1rem 1.25rem 1.25rem 1.5rem; border-top: 1px solid var(--c-border); background: #fafbfd; }
  .sx-action-card.expanded .sx-action-form { display: block; }
  /* TAKE/REWASH/REJECT: keep splits always visible, hide toggle + form's redundant submit (hero CTA submits) */
  .sx-action-card.always-open .sx-action-form { display: block; }
  .sx-action-card.always-open .sx-action-toggle { display: none; }
  .sx-action-card.always-open [data-action="take-submit"] { display: none; }
  /* Auto-derived TAKE: read-only input, no stepper buttons */
  .sx-stepper.is-take-readonly button { display: none; }
  .sx-stepper.is-take-readonly input {
    width: 5rem; font-weight: 700; font-size: 1.05rem;
    background: var(--c-primary-soft); border-color: transparent;
    color: var(--c-primary); cursor: default;
  }
  .sx-stepper.is-take-readonly input:focus { outline: none; box-shadow: none; }
  .sx-form-helper {
    font-size: 0.8125rem; color: var(--c-text-2);
    margin: 0 0 0.75rem;
  }

  .sx-input-list { display: flex; flex-direction: column; gap: 0.625rem; }
  .sx-input-row {
    display: grid; grid-template-columns: 3rem 1fr auto; gap: 0.625rem;
    align-items: center;
    padding: 0.625rem;
    background: var(--c-card); border: 1px solid var(--c-border);
    border-radius: var(--r);
  }
  /* Per-size card with stacked buckets — used by Take card to split a
     size into 2 (take/reject) or 3 (take/rewash/reject) buckets. */
  .sx-input-card {
    display: grid; grid-template-columns: 1fr; gap: 0.5rem;
    padding: 0.75rem 0.75rem 0.625rem;
    background: var(--c-card); border: 1px solid var(--c-border);
    border-radius: var(--r);
  }
  .sx-input-card-head {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 0.625rem;
  }
  .sx-input-card-head .label {
    font-size: 1.125rem; font-weight: 800;
    color: var(--c-text); letter-spacing: -0.01em;
    font-variant-numeric: tabular-nums;
  }
  .sx-input-card-head .avail {
    font-size: 0.75rem; color: var(--c-text-2);
  }
  .sx-input-card-head .avail .n {
    color: var(--c-text); font-weight: 700; font-variant-numeric: tabular-nums;
  }
  .sx-bucket-row {
    display: flex; align-items: center; gap: 0.5rem;
    flex-wrap: wrap; justify-content: flex-end;
  }
  .sx-bucket {
    display: flex; align-items: center; gap: 0.375rem;
  }
  .sx-bucket-tag {
    font-size: 0.6875rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.05em;
    padding: 0.25rem 0.5rem;
    border-radius: var(--r-sm);
    flex-shrink: 0;
  }
  .sx-bucket-tag.take   { background: var(--c-primary-soft); color: var(--c-primary); }
  .sx-bucket-tag.rewash { background: var(--c-warning-soft); color: var(--c-warning); }
  .sx-bucket-tag.reject { background: var(--c-danger-soft);  color: var(--c-danger); }

  .sx-input-label {
    font-weight: 700; font-size: 1rem; color: var(--c-text); text-align: center;
    font-variant-numeric: tabular-nums;
  }
  .sx-input-avail { font-size: 0.75rem; color: var(--c-text-2); }
  .sx-input-avail .n { color: var(--c-text); font-weight: 600; font-variant-numeric: tabular-nums; }
  .sx-stepper { display: flex; align-items: center; gap: 0.25rem; }
  .sx-stepper button {
    width: 2.25rem; height: 2.25rem;
    border: 1px solid var(--c-border); background: var(--c-card);
    border-radius: var(--r-sm); cursor: pointer;
    font-family: inherit; font-size: 0.875rem; font-weight: 600;
    color: var(--c-text);
    transition: all 0.1s;
  }
  .sx-stepper button:hover { background: var(--c-primary-soft); border-color: var(--c-primary); color: var(--c-primary); }
  .sx-stepper button:disabled { opacity: 0.4; cursor: not-allowed; }
  .sx-stepper input {
    width: 4rem; height: 2.25rem; text-align: center;
    border: 1px solid var(--c-border); border-radius: var(--r-sm);
    background: var(--c-card); font-family: inherit;
    font-size: 0.9375rem; font-weight: 600; color: var(--c-text);
    font-variant-numeric: tabular-nums;
  }
  .sx-stepper input:focus { outline: none; border-color: var(--c-primary); box-shadow: 0 0 0 3px var(--c-primary-soft); }
  .sx-stepper.is-mini button { width: 1.875rem; height: 1.875rem; font-size: 0.75rem; }
  .sx-stepper.is-mini input { width: 3rem; height: 1.875rem; font-size: 0.8125rem; }
  .sx-stepper.is-rewash input { background: #fffbeb; border-color: #fde68a; color: var(--c-warning); }
  .sx-stepper.is-rewash input:focus { border-color: var(--c-warning); box-shadow: 0 0 0 3px var(--c-warning-soft); }
  .sx-stepper.is-rewash button:hover { background: var(--c-warning-soft); border-color: var(--c-warning); color: var(--c-warning); }
  .sx-stepper.is-reject input { background: #fef2f2; border-color: #fecaca; color: var(--c-danger); }
  .sx-stepper.is-reject input:focus { border-color: var(--c-danger); box-shadow: 0 0 0 3px var(--c-danger-soft); }
  .sx-stepper.is-reject button:hover { background: var(--c-danger-soft); border-color: var(--c-danger); color: var(--c-danger); }

  .sx-totals-grid {
    display: grid; grid-template-columns: 1fr; gap: 0.5rem;
    margin-top: 0.875rem;
  }
  .sx-totals-grid.cols-2 { grid-template-columns: 1fr 1fr; }
  .sx-totals-grid.cols-3 { grid-template-columns: repeat(3, 1fr); }
  .sx-mini-total {
    padding: 0.625rem 0.75rem;
    background: var(--c-bg); border-radius: var(--r);
    text-align: center;
  }
  .sx-mini-total.is-take   { background: var(--c-primary-soft); }
  .sx-mini-total.is-take   .l, .sx-mini-total.is-take   .v { color: var(--c-primary); }
  .sx-mini-total.is-rewash { background: var(--c-warning-soft); }
  .sx-mini-total.is-rewash .l, .sx-mini-total.is-rewash .v { color: var(--c-warning); }
  .sx-mini-total.is-reject { background: var(--c-danger-soft); }
  .sx-mini-total.is-reject .l, .sx-mini-total.is-reject .v { color: var(--c-danger); }
  .sx-mini-total .l {
    font-size: 0.6875rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.04em;
    margin-bottom: 0.125rem; opacity: 0.9;
  }
  .sx-mini-total .v {
    font-size: 1.375rem; font-weight: 800;
    font-variant-numeric: tabular-nums; line-height: 1;
  }

  /* Dispatch card (finishing) */
  .sx-action-card.is-dispatch::before { background: #0ea5e9; }
  .sx-action-card.is-dispatch .sx-action-icon { background: #e0f2fe; color: #0284c7; }
  .sx-action-card.is-dispatch .sx-action-title .qty { color: #0284c7; }
  .sx-action-card.is-dispatch .sx-action-cta { background: #0284c7; box-shadow: 0 1px 2px rgba(2,132,199,0.25); }
  .sx-action-card.is-dispatch .sx-action-cta:hover { background: #0369a1; box-shadow: 0 4px 12px rgba(2,132,199,0.35); }
  .sx-action-card.is-dispatch .sx-form-submit { background: #0284c7; }
  .sx-action-card.is-dispatch .sx-form-submit:hover { background: #0369a1; }
  .sx-action-card.is-dispatch .sx-totals { background: #e0f2fe; }
  .sx-action-card.is-dispatch .sx-totals .l, .sx-action-card.is-dispatch .sx-totals .v { color: #0284c7; }
  .sx-dispatch-batch + .sx-dispatch-batch { margin-top: 0.875rem; padding-top: 0.875rem; border-top: 1px dashed var(--c-border); }
  .sx-dispatch-batch-head {
    font-size: 0.8125rem; font-weight: 600; color: var(--c-text-2);
    margin-bottom: 0.5rem;
  }
  .sx-dispatch-batch-head .b { color: var(--c-text); font-weight: 700; }
  .sx-dest-row {
    display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem;
    margin-top: 0.625rem;
  }
  .sx-dest-row select, .sx-dest-row input {
    width: 100%; padding: 0.5rem 0.625rem; box-sizing: border-box;
    border: 1px solid var(--c-border); border-radius: var(--r-sm);
    background: var(--c-card); font-family: inherit; font-size: 0.875rem;
    color: var(--c-text);
  }
  @media (max-width: 480px) {
    .sx-dest-row { grid-template-columns: 1fr; }
  }

  .sx-form-row { margin-top: 0.625rem; }
  .sx-form-row input[type="text"] {
    width: 100%; padding: 0.625rem 0.75rem; box-sizing: border-box;
    border: 1px solid var(--c-border); border-radius: var(--r);
    background: var(--c-card); font-family: inherit; font-size: 0.875rem;
    color: var(--c-text);
  }
  .sx-form-row input[type="text"]:focus { outline: none; border-color: var(--c-primary); box-shadow: 0 0 0 3px var(--c-primary-soft); }

  .sx-totals {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.875rem 1rem;
    background: var(--c-primary-soft);
    border-radius: var(--r);
    margin-top: 0.875rem;
  }
  .sx-totals .l { font-size: 0.8125rem; font-weight: 600; color: var(--c-primary); text-transform: uppercase; letter-spacing: 0.04em; }
  .sx-totals .v { font-size: 1.5rem; font-weight: 800; color: var(--c-primary); font-variant-numeric: tabular-nums; line-height: 1; }

  .sx-form-submit {
    width: 100%; margin-top: 0.875rem;
    padding: 0.875rem;
    border: none; cursor: pointer;
    background: var(--c-primary); color: white;
    border-radius: var(--r);
    font-family: inherit; font-weight: 600; font-size: 0.9375rem;
    transition: all 0.15s;
  }
  .sx-form-submit:hover { background: var(--c-primary-hover); }
  .sx-action-card.is-done .sx-form-submit { background: var(--c-success); }
  .sx-action-card.is-done .sx-form-submit:hover { background: var(--c-success-hover); }
  .sx-action-card.is-done .sx-totals { background: var(--c-success-soft); }
  .sx-action-card.is-done .sx-totals .l { color: var(--c-success); }
  .sx-action-card.is-done .sx-totals .v { color: var(--c-success); }

  /* reject sub-section */
  .sx-reject-toggle {
    margin-top: 0.875rem;
    padding: 0.625rem 0.875rem;
    background: var(--c-danger-soft);
    border: 1px solid #fecaca;
    border-radius: var(--r);
    color: var(--c-danger);
    font-family: inherit; font-size: 0.8125rem; font-weight: 600;
    cursor: pointer; text-align: center;
    transition: all 0.15s;
  }
  .sx-reject-toggle:hover { background: #fee2e2; border-color: #fca5a5; }
  .sx-reject-section { display: none; padding-top: 0.875rem; }
  .sx-reject-section.show { display: block; animation: slideUpFade 0.2s; }
  .sx-reject-row {
    display: grid; grid-template-columns: 3rem 1fr auto; gap: 0.625rem;
    align-items: center;
    padding: 0.5rem 0.625rem;
    background: var(--c-card); border: 1px solid #fecaca;
    border-radius: var(--r);
  }
  .sx-reject-row .sx-stepper input:focus { border-color: var(--c-danger); box-shadow: 0 0 0 3px var(--c-danger-soft); }

  /* nothing-to-do state */
  .sx-action-card.is-empty {
    text-align: center;
    padding: 2.25rem 1.25rem;
    border: 1px dashed var(--c-border);
    background: transparent; box-shadow: none;
  }
  .sx-action-card.is-empty .sx-empty-mark {
    width: 56px; height: 56px;
    margin: 0 auto 0.625rem;
    background: var(--c-success-soft); color: var(--c-success);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.5rem; font-weight: 700;
  }
  .sx-action-card.is-empty p { color: var(--c-text-2); font-size: 0.9375rem; margin: 0; }
  .sx-action-card.is-empty p small { display: block; font-size: 0.8125rem; color: var(--c-text-3); margin-top: 0.25rem; }

  /* ─── Bottom info section: My Work / My Payments ───── */
  .sx-info {
    background: var(--c-card); border: 1px solid var(--c-border);
    border-radius: var(--r-xl);
    box-shadow: var(--shadow);
    overflow: hidden;
    margin-top: 1rem;
  }
  .sx-info-tabs {
    display: flex; padding: 0.5rem;
    background: var(--c-bg);
    border-bottom: 1px solid var(--c-border);
  }
  .sx-info-tab {
    flex: 1;
    padding: 0.625rem 0.5rem;
    background: transparent; border: none; cursor: pointer;
    font-family: inherit; font-size: 0.875rem; font-weight: 500;
    color: var(--c-text-2);
    border-radius: var(--r-sm);
    transition: all 0.15s;
  }
  .sx-info-tab:hover { color: var(--c-text); background: var(--c-card); }
  .sx-info-tab.active { background: var(--c-card); color: var(--c-primary); font-weight: 600; box-shadow: var(--shadow-sm); }

  .sx-info-body { padding: 1rem 1.125rem 1.25rem; }

  .sx-controls {
    display: flex; flex-wrap: wrap; gap: 0.5rem;
    margin-bottom: 0.875rem; align-items: center;
  }
  .sx-controls select {
    padding: 0.5rem 0.875rem 0.5rem 0.75rem;
    border: 1px solid var(--c-border); border-radius: var(--r-sm);
    background: var(--c-card);
    font-family: inherit; font-size: 0.8125rem; font-weight: 500;
    color: var(--c-text);
    cursor: pointer;
  }
  .sx-controls select:focus { outline: none; border-color: var(--c-primary); }
  .sx-controls .spacer { flex: 1; }
  .sx-btn-export {
    padding: 0.5rem 0.875rem;
    background: var(--c-card); border: 1px solid var(--c-border);
    border-radius: var(--r-sm);
    color: var(--c-text-2);
    font-family: inherit; font-size: 0.8125rem; font-weight: 500;
    cursor: pointer; display: inline-flex; align-items: center; gap: 0.375rem;
    transition: all 0.15s;
  }
  .sx-btn-export:hover { background: var(--c-success-soft); color: var(--c-success); border-color: var(--c-success); }

  /* timeline (My Work) */
  .sx-timeline {}
  .sx-event {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.875rem;
    padding: 0.75rem 0.625rem;
    border-radius: var(--r);
    cursor: pointer;
    align-items: center;
    transition: background 0.15s;
    border: 1px solid transparent;
  }
  .sx-event + .sx-event { margin-top: 0.25rem; }
  .sx-event:hover { background: var(--c-bg); border-color: var(--c-border-2); }
  .sx-event-dot {
    width: 36px; height: 36px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.875rem; font-weight: 700;
    color: white;
  }
  .sx-event-dot.t-approve { background: var(--c-primary); }
  .sx-event-dot.t-complete { background: var(--c-success); }
  .sx-event-dot.t-reject { background: var(--c-danger); }
  .sx-event-main { min-width: 0; }
  .sx-event-line1 { font-size: 0.9375rem; font-weight: 600; color: var(--c-text); }
  .sx-event-line2 { font-size: 0.75rem; color: var(--c-text-3); margin-top: 0.125rem; }
  .sx-event-pieces {
    font-size: 1.125rem; font-weight: 700;
    color: var(--c-text); font-variant-numeric: tabular-nums;
  }

  /* My Payments */
  .sx-pay-summary {
    display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .sx-pay-summary-card {
    padding: 0.875rem 1rem;
    background: var(--c-bg); border: 1px solid var(--c-border-2);
    border-radius: var(--r);
  }
  .sx-pay-summary-card.is-pending { background: var(--c-warning-soft); border-color: transparent; }
  .sx-pay-summary-card.is-paid { background: var(--c-success-soft); border-color: transparent; }
  .sx-pay-summary-card .l { font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--c-text-3); margin-bottom: 0.25rem; }
  .sx-pay-summary-card.is-pending .l { color: var(--c-warning); }
  .sx-pay-summary-card.is-paid .l { color: var(--c-success); }
  .sx-pay-summary-card .v { font-size: 1.5rem; font-weight: 800; color: var(--c-text); font-variant-numeric: tabular-nums; line-height: 1.05; }
  .sx-pay-summary-card.is-pending .v { color: var(--c-warning); }
  .sx-pay-summary-card.is-paid .v { color: var(--c-success); }
  .sx-pay-summary-card .s { font-size: 0.75rem; color: var(--c-text-2); margin-top: 0.25rem; font-variant-numeric: tabular-nums; }

  .sx-pay-row {
    display: grid; grid-template-columns: 1fr auto auto; gap: 0.625rem;
    align-items: center;
    padding: 0.75rem 0.625rem;
    border-radius: var(--r-sm);
    transition: background 0.12s;
  }
  .sx-pay-row + .sx-pay-row { border-top: 1px solid var(--c-border-2); }
  .sx-pay-row:hover { background: var(--c-bg); }
  .sx-pay-main { min-width: 0; }
  .sx-pay-lot { font-size: 0.875rem; font-weight: 600; color: var(--c-text); letter-spacing: 0.02em; }
  .sx-pay-meta { font-size: 0.75rem; color: var(--c-text-3); margin-top: 0.125rem; }
  .sx-pay-amt { font-size: 1.0625rem; font-weight: 700; color: var(--c-text); font-variant-numeric: tabular-nums; }
  .sx-pay-status {
    font-size: 0.6875rem; font-weight: 700; padding: 0.2rem 0.5rem;
    border-radius: var(--r-pill); text-transform: uppercase; letter-spacing: 0.04em;
  }
  .sx-pay-status.pending { background: var(--c-warning-soft); color: var(--c-warning); }
  .sx-pay-status.paid { background: var(--c-success-soft); color: var(--c-success); }
  .sx-pay-status.cancelled { background: var(--c-bg); color: var(--c-text-3); }

  /* placeholders / empty states */
  .sx-placeholder {
    text-align: center; padding: 2.5rem 1rem;
    color: var(--c-text-3);
  }
  .sx-placeholder-mark {
    width: 48px; height: 48px;
    margin: 0 auto 0.625rem;
    background: var(--c-bg);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.125rem; color: var(--c-text-3);
  }
  .sx-placeholder p { font-size: 0.9375rem; color: var(--c-text-2); margin: 0; }
  .sx-placeholder p small { display: block; margin-top: 0.25rem; font-size: 0.8125rem; color: var(--c-text-3); }

  /* ─── Modal: lot journey detail ───────────────────────── */
  .sx-modal-overlay {
    position: fixed; inset: 0;
    background: rgba(15, 23, 42, 0.6);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    z-index: 1000;
    display: none;
    align-items: center; justify-content: center;
    padding: 0.5rem;
    animation: fadeIn 0.15s;
  }
  .sx-modal-overlay.show { display: flex; }
  .sx-modal {
    background: var(--c-card);
    border-radius: var(--r-xl);
    width: 100%; max-width: 640px;
    max-height: 92vh;
    overflow: hidden;
    box-shadow: var(--shadow-xl);
    animation: modalIn 0.25s cubic-bezier(0.32, 0.72, 0, 1);
    display: flex; flex-direction: column;
  }
  .sx-modal-head {
    padding: 1.125rem 1.25rem;
    border-bottom: 1px solid var(--c-border);
    display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem;
  }
  .sx-modal-title-block { min-width: 0; flex: 1; }
  .sx-modal-eyebrow {
    font-size: 0.6875rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.06em;
    color: var(--c-primary);
    margin: 0 0 0.25rem;
  }
  .sx-modal-title {
    font-size: 1.125rem; font-weight: 700;
    color: var(--c-text); margin: 0;
    letter-spacing: -0.01em;
  }
  .sx-modal-close {
    width: 36px; height: 36px;
    background: var(--c-bg); border: none;
    border-radius: 50%;
    cursor: pointer;
    color: var(--c-text-2);
    font-size: 1.25rem;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.15s;
    flex-shrink: 0;
  }
  .sx-modal-close:hover { background: var(--c-border); color: var(--c-text); }

  .sx-modal-body {
    overflow-y: auto;
    padding: 1.25rem;
  }

  .sx-modal-section {
    margin-bottom: 1.25rem;
  }
  .sx-modal-section:last-child { margin-bottom: 0; }
  .sx-modal-section-h {
    font-size: 0.6875rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.06em;
    color: var(--c-text-3);
    margin: 0 0 0.625rem;
  }

  .sx-modal-detail-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 0.625rem;
    background: var(--c-bg);
    padding: 0.875rem;
    border-radius: var(--r);
  }
  .sx-modal-detail-cell .l {
    font-size: 0.6875rem; font-weight: 600; color: var(--c-text-3);
    text-transform: uppercase; letter-spacing: 0.04em;
    margin-bottom: 0.25rem;
  }
  .sx-modal-detail-cell .v {
    font-size: 0.9375rem; font-weight: 600; color: var(--c-text);
    font-variant-numeric: tabular-nums;
    word-break: break-word;
  }
  .sx-modal-detail-cell.full { grid-column: 1 / -1; }

  .sx-modal-chips {
    display: flex; flex-wrap: wrap; gap: 0.375rem;
    margin-top: 0.25rem;
  }

  .sx-journey {
    border-left: 2px solid var(--c-border);
    padding-left: 1rem;
    margin-left: 0.5rem;
  }
  .sx-journey-step {
    position: relative;
    padding: 0.625rem 0.625rem;
    border-radius: var(--r-sm);
    background: var(--c-bg);
  }
  .sx-journey-step + .sx-journey-step { margin-top: 0.5rem; }
  .sx-journey-step::before {
    content: ''; position: absolute;
    left: -1.4375rem; top: 1rem;
    width: 11px; height: 11px;
    border-radius: 50%;
    background: var(--c-card);
    border: 2px solid var(--c-primary);
  }
  .sx-journey-step.t-complete::before { border-color: var(--c-success); background: var(--c-success); }
  .sx-journey-step.t-reject::before { border-color: var(--c-danger); background: var(--c-danger); }
  .sx-journey-step.is-current { background: var(--c-primary-soft); }
  .sx-journey-step.is-current::before { background: var(--c-primary); }
  .sx-journey-step-head {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 0.5rem; margin-bottom: 0.125rem;
  }
  .sx-journey-pill {
    font-size: 0.6875rem; font-weight: 700;
    padding: 0.125rem 0.5rem;
    border-radius: var(--r-pill);
    text-transform: uppercase; letter-spacing: 0.04em;
  }
  .sx-journey-pill.t-approve { background: var(--c-primary-soft); color: var(--c-primary); }
  .sx-journey-pill.t-complete { background: var(--c-success-soft); color: var(--c-success); }
  .sx-journey-pill.t-reject { background: var(--c-danger-soft); color: var(--c-danger); }
  .sx-journey-when { font-size: 0.75rem; color: var(--c-text-3); }
  .sx-journey-pieces {
    font-size: 1rem; font-weight: 700; color: var(--c-text);
    font-variant-numeric: tabular-nums;
  }
  .sx-journey-by { font-size: 0.75rem; color: var(--c-text-2); margin-top: 0.125rem; }
  .sx-journey-detail {
    display: flex; flex-wrap: wrap; gap: 0.25rem;
    margin-top: 0.375rem;
  }
  .sx-journey-detail .sx-chip {
    padding: 0.125rem 0.5rem;
    font-size: 0.75rem;
    background: var(--c-card);
  }

  /* ─── Toasts ──────────────────────────────────────── */
  .sx-toasts {
    position: fixed; bottom: 1rem; right: 1rem;
    display: flex; flex-direction: column; gap: 0.5rem;
    z-index: 2000; max-width: 360px;
  }
  .sx-toast {
    padding: 0.75rem 1rem;
    background: var(--c-text);
    color: white;
    border-radius: var(--r);
    font-size: 0.875rem;
    box-shadow: var(--shadow-lg);
    animation: slideUpFade 0.25s cubic-bezier(0.32, 0.72, 0, 1);
    display: flex; align-items: center; gap: 0.5rem;
  }
  .sx-toast.success { background: var(--c-success); }
  .sx-toast.error { background: var(--c-danger); }
  .sx-toast::before {
    content: ''; width: 16px; height: 16px;
    border-radius: 50%;
    background: rgba(255,255,255,0.25);
    flex-shrink: 0;
  }

  /* ─── Animations ─────────────────────────────────── */
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes slideUpFade {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.97) translateY(8px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  /* ─── Mobile / tablet ─────────────────────────────── */
  @media (max-width: 640px) {
    .sx-page { padding-left: 0.625rem; padding-right: 0.625rem; }
    .sx-stats { grid-template-columns: repeat(2, 1fr); }
    .sx-pay-summary { grid-template-columns: 1fr; }
    .sx-pay-row { grid-template-columns: 1fr auto; }
    .sx-pay-status { grid-column: 1 / -1; justify-self: start; }
    .sx-modal-overlay { align-items: flex-end; padding: 0; }
    .sx-modal {
      max-height: 90vh;
      border-radius: var(--r-xl) var(--r-xl) 0 0;
      animation: sheetUp 0.3s cubic-bezier(0.32, 0.72, 0, 1);
    }
    @keyframes sheetUp {
      from { transform: translateY(100%); }
      to { transform: translateY(0); }
    }
  }
  /* Numbers are the hero (floor design system) */
  .sx-lot-no, .sx-stat .v, .sx-chip-label, .sx-chip-num, .sx-mini-total .v, .sx-input-avail .n {
    font-family: 'Space Grotesk','Inter',sans-serif; letter-spacing: -0.01em;
  }
</style>

<header class="flx-top">
  <div class="brand">
    <span class="material-symbols-outlined">local_laundry_service</span>
    <h1>Washing</h1>
  </div>
  <div class="flx-actions">
    <a class="flx-home" href="/operator/hub" title="Home"><span class="material-symbols-outlined">home</span></a>
    <span class="flx-user"><%= (user && user.username) ? user.username : 'Operator' %></span>
    <a class="flx-logout" href="/logout"><span class="material-symbols-outlined">logout</span><span class="flx-logout-t">Log out</span></a>
  </div>
</header>

<main class="sx sx-page">

  <!-- ─── Header ──────────────────────────── -->
  <header class="sx-head">
    <h1>Washing</h1>
    <span class="pill" id="pageUserPill">—</span>
  </header>

  <!-- ─── Search ──────────────────────────── -->
  <section class="sx-search">
    <div class="sx-search-row">
      <span class="sx-search-icon">⌕</span>
      <input type="text" id="searchInput" placeholder="Type lot number or SKU and press Enter" autofocus />
      <button id="searchBtn" class="sx-btn sx-btn-primary">Search</button>
    </div>
    <div id="searchResults" class="sx-search-results"></div>
  </section>

  <!-- ─── Lot context ──────────────────────── -->
  <section id="lotCard" class="sx-lot">
    <div class="sx-lot-head">
      <h2 class="sx-lot-no" id="lotNo">—</h2>
      <span class="sx-flow denim" id="lotFlow">denim</span>
    </div>
    <p class="sx-lot-meta">
      <strong id="lotSku">—</strong> · cut by <strong id="lotCutter">—</strong>
    </p>
    <div class="sx-cutting-remark" id="cuttingRemarkNote" style="display: none;">
      <span class="label">From cutting</span>
      <span class="text" id="cuttingRemarkText"></span>
    </div>
    <div class="sx-journey" id="lotJourneyUsers" style="display:none;"></div>

    <div class="sx-stats">
      <div class="sx-stat"><div class="l">Approved</div><div class="v" id="aggApproved">0</div></div>
      <div class="sx-stat is-completed"><div class="l">Completed</div><div class="v" id="aggCompleted">0</div></div>
      <div class="sx-stat is-rejected"><div class="l">Rejected</div><div class="v" id="aggRejected">0</div></div>
      <div class="sx-stat is-inline"><div class="l">Inline</div><div class="v" id="aggInline">0</div></div>
    </div>

    <div class="sx-sizes-label">
      Pieces by size <span class="total"><span id="totalLabel">total cut</span> <span id="totalCut">0</span></span>
    </div>
    <div class="sx-chip-row" id="sizeChips"></div>
  </section>

  <!-- ─── Auto-action panel ─────────────────── -->
  <section id="actionsSection" class="sx-actions">
    <p class="sx-actions-h" id="actionsHeading">What you can do</p>
