function bindStepper(row, onChange) {
  const input = row.querySelector('input');
  const max = Number(input.dataset.max || input.dataset.avail) || 0;
  row.querySelectorAll('button[data-step]').forEach(btn => {
    btn.addEventListener('click', () => {
      const cur = parseInt(input.value, 10) || 0;
      let next = cur + parseInt(btn.dataset.step, 10);
      if (next < 0) next = 0;
      if (next > max) next = max;
      input.value = next;
      input.dispatchEvent(new Event('input', { bubbles: true }));
    });
  });
  input.addEventListener('input', onChange);
}

function recalcDoneTotals(card, approve) {
  const caps = approve.remaining_sizes;
  const doneInputs = card.querySelectorAll('input[data-kind="done"]');
  const rejInputs = card.querySelectorAll('input[data-kind="reject"]');
  const rejBySize = {}; rejInputs.forEach(i => rejBySize[i.dataset.size] = i);
  const doneBySize = {}; doneInputs.forEach(i => doneBySize[i.dataset.size] = i);

  let done = 0, rej = 0;

  doneInputs.forEach(i => {
    let v = parseInt(i.value, 10); if (!Number.isFinite(v) || v < 0) v = 0;
    const cap = caps[i.dataset.size] || 0;
    const r = parseInt((rejBySize[i.dataset.size] || {}).value, 10) || 0;
    if (v + r > cap) { v = Math.max(0, cap - r); i.value = v; }
    done += v;
  });
  rejInputs.forEach(i => {
    let v = parseInt(i.value, 10); if (!Number.isFinite(v) || v < 0) v = 0;
    const cap = caps[i.dataset.size] || 0;
    const d = parseInt((doneBySize[i.dataset.size] || {}).value, 10) || 0;
    if (v + d > cap) { v = Math.max(0, cap - d); i.value = v; }
    rej += v;
  });
  card.querySelector('[data-display="done-total"]').textContent = fmt(done);
  card.querySelector('[data-display="reject-total"]').textContent = fmt(rej);
}

async function doMarkDoneAll(approve) {
  const completed = Object.entries(approve.remaining_sizes).map(([size_label, pieces]) => ({ size_label, pieces }));
  const total = completed.reduce((a, s) => a + s.pieces, 0);
  if (!confirm('Mark ' + fmt(total) + ' pieces of ' + (currentLot.lot_no || '').toUpperCase() + ' as done?')) return;
  await doMarkDoneRequest(approve.event_id, completed, [], null, null);
}

async function doMarkDoneFromForm(card, approve) {
  const completed = {}, rejected = {};
  card.querySelectorAll('input[data-kind="done"]').forEach(i => {
    const v = parseInt(i.value, 10) || 0;
    if (v > 0) completed[i.dataset.size] = (completed[i.dataset.size] || 0) + v;
  });
  card.querySelectorAll('input[data-kind="reject"]').forEach(i => {
    const v = parseInt(i.value, 10) || 0;
    if (v > 0) rejected[i.dataset.size] = (rejected[i.dataset.size] || 0) + v;
  });
  const cs = Object.entries(completed).map(([size_label, pieces]) => ({ size_label, pieces }));
  const rs = Object.entries(rejected).map(([size_label, pieces]) => ({ size_label, pieces }));
  if (!cs.length && !rs.length) { toast('Nothing entered', 'error'); return; }

  const cTotal = cs.reduce((a, s) => a + s.pieces, 0);
  const rTotal = rs.reduce((a, s) => a + s.pieces, 0);
  let msg = '';
  if (cTotal) msg += 'Mark ' + fmt(cTotal) + ' done';
  if (rTotal) msg += (msg ? ', ' : '') + 'reject ' + fmt(rTotal);
  if (!confirm(msg + ' for ' + (currentLot.lot_no || '').toUpperCase() + '?')) return;

  const remark = card.querySelector('[data-input="done-remark"]').value.trim() || null;
  const reason = card.querySelector('[data-input="reject-reason"]').value.trim() || null;
  await doMarkDoneRequest(approve.event_id, cs, rs, remark, reason);
}

async function doMarkDoneRequest(parentId, completed_sizes, rejected_sizes, complete_remark, reject_reason) {
  try {
    await api('POST', BASE + '/event/complete', {
      parent_event_id: parentId, completed_sizes, rejected_sizes,
      complete_remark, reject_reason,
    });
    toast('Saved ✓', 'success');
    await refreshState();
    if (infoTab === 'work') loadHistory();
  } catch (err) { toast('Could not save: ' + err.message, 'error'); }
}

// ─── My Work / My Payments ───────────────────
function switchInfoTab(tab) {
  infoTab = tab;
  el('tabWork').classList.toggle('active', tab === 'work');
  el('tabPayments').classList.toggle('active', tab === 'payments');
  el('workTab').style.display = tab === 'work' ? 'block' : 'none';
  el('paymentsTab').style.display = tab === 'payments' ? 'block' : 'none';
  if (tab === 'work') loadHistory();
  else loadPayments();
}

async function loadHistory() {
  const days = el('historyDays').value;
  const type = el('historyType').value;
  const list = el('historyList');
  list.innerHTML = '<div class="sx-placeholder"><div class="sx-placeholder-mark">·</div><p>Loading…</p></div>';
  try {
    const data = await api('GET', BASE + '/event/history?days=' + encodeURIComponent(days) + '&type=' + encodeURIComponent(type));
    if (!data.events || !data.events.length) {
      list.innerHTML = '<div class="sx-placeholder"><div class="sx-placeholder-mark">·</div><p>No work in this range.</p></div>';
      return;
    }
    list.textContent = '';
    const labelFor = { approve: 'Took into ' + STAGE_LABEL.toLowerCase(), complete: 'Marked as done', reject: 'Rejected pieces' };
    const dotGlyph = { approve: '↘', complete: '✓', reject: '×' };
    data.events.forEach(e => {
      const row = document.createElement('div');
      row.className = 'sx-event';
      row.dataset.eventId = e.id;
      row.dataset.lotNo = e.lot_no || '';
      row.dataset.cuttingLotId = e.cutting_lot_id || '';
      row.onclick = () => openEventModal(e);
      row.innerHTML = `
        <div class="sx-event-dot t-${e.event_type}">${dotGlyph[e.event_type] || ''}</div>
        <div class="sx-event-main">
          <div class="sx-event-line1">${escapeText(labelFor[e.event_type] || e.event_type)} · <span style="color: var(--c-text-2); font-weight: 500;">${escapeText(e.lot_no || '—')}</span></div>
          <div class="sx-event-line2">${fmtDate(e.created_at)}${e.remark ? ' · ' + escapeText(String(e.remark).slice(0, 50)) : ''}</div>
        </div>
        <div class="sx-event-pieces">${fmt(e.pieces)}</div>
      `;
      list.appendChild(row);
    });
  } catch (err) {
    list.innerHTML = '<div class="sx-placeholder"><div class="sx-placeholder-mark">!</div><p>Could not load: ' + escapeText(err.message) + '</p></div>';
  }
}

el('historyDays').addEventListener('change', loadHistory);
el('historyType').addEventListener('change', loadHistory);

function downloadHistoryExcel() {
  const days = el('historyDays').value;
  const type = el('historyType').value;
  window.location = BASE + '/event/export?days=' + encodeURIComponent(days) + '&type=' + encodeURIComponent(type);
}

async function loadPayments() {
  const days = el('payDays').value;
  const status = el('payStatus').value;
  const sumWrap = el('paySummary');
  const list = el('payList');
  sumWrap.innerHTML = '';
  list.innerHTML = '<div class="sx-placeholder"><div class="sx-placeholder-mark">·</div><p>Loading…</p></div>';
  try {
    const data = await api('GET', BASE + '/event/payments?days=' + encodeURIComponent(days) + '&status=' + encodeURIComponent(status));
    const s = data.summary;
    sumWrap.innerHTML = `
      <div class="sx-pay-summary-card is-pending">
        <div class="l">Pending</div>
        <div class="v">${fmtMoney(s.pending_amount)}</div>
        <div class="s">${fmt(s.pending_qty)} pieces</div>
      </div>
      <div class="sx-pay-summary-card is-paid">
        <div class="l">Paid</div>
        <div class="v">${fmtMoney(s.paid_amount)}</div>
        <div class="s">${fmt(s.paid_qty)} pieces</div>
      </div>
    `;
    if (!data.payments || !data.payments.length) {
      list.innerHTML = '<div class="sx-placeholder"><div class="sx-placeholder-mark">·</div><p>No payments in this range.</p></div>';
      return;
    }
    list.textContent = '';
    data.payments.forEach(p => {
      const row = document.createElement('div');
      row.className = 'sx-pay-row';
      row.innerHTML = `
        <div class="sx-pay-main">
          <div class="sx-pay-lot">${escapeText(p.lot_no || '—')}</div>
          <div class="sx-pay-meta">${escapeText(p.sku || '')} · ${fmt(p.qty)} pcs · ${fmtDate(p.created_at)}${p.rate_configured ? '' : ' · <span style="color: var(--c-danger);">rate not set</span>'}</div>
        </div>
        <div class="sx-pay-amt">${fmtMoney(p.total_amount)}</div>
        <span class="sx-pay-status ${p.status}">${p.status}</span>
      `;
      list.appendChild(row);
    });
  } catch (err) {
    list.innerHTML = '<div class="sx-placeholder"><div class="sx-placeholder-mark">!</div><p>Could not load: ' + escapeText(err.message) + '</p></div>';
  }
}

el('payDays').addEventListener('change', loadPayments);
el('payStatus').addEventListener('change', loadPayments);

function downloadPaymentsExcel() {
  const days = el('payDays').value;
  const status = el('payStatus').value;
  window.location = BASE + '/event/payments/export?days=' + encodeURIComponent(days) + '&status=' + encodeURIComponent(status);
}

// ─── Modal: event detail + lot journey ────────
async function openEventModal(event) {
  el('modalEyebrow').textContent = STAGE_LABEL + ' · event';
  const labelMap = { approve: 'Took into ' + STAGE_LABEL.toLowerCase(), complete: 'Marked as done', reject: 'Rejected pieces' };
  el('modalTitle').textContent = (labelMap[event.event_type] || event.event_type) + ' — ' + (event.lot_no || '');
  const body = el('modalBody');

  // 1) Event detail
  const sizesChips = Object.entries(event.sizes || {}).length
    ? '<div class="sx-modal-chips">' + Object.entries(event.sizes).map(([k, v]) => `<span class="sx-chip s-empty"><span class="sx-chip-label">${escapeText(k)}</span><span class="sx-chip-num">${fmt(v)}</span></span>`).join('') + '</div>'
    : '<span style="color: var(--c-text-3);">no size detail</span>';

  body.innerHTML = `
    <div class="sx-modal-section">
      <p class="sx-modal-section-h">This event</p>
      <div class="sx-modal-detail-grid">
        <div class="sx-modal-detail-cell"><div class="l">Lot</div><div class="v">${escapeText(event.lot_no || '—')}</div></div>
        <div class="sx-modal-detail-cell"><div class="l">SKU</div><div class="v">${escapeText(event.sku || '—')}</div></div>
        <div class="sx-modal-detail-cell"><div class="l">Pieces</div><div class="v">${fmt(event.pieces)}</div></div>
        <div class="sx-modal-detail-cell"><div class="l">Action</div><div class="v" style="text-transform: capitalize;">${escapeText(event.event_type)}</div></div>
        <div class="sx-modal-detail-cell full"><div class="l">When</div><div class="v">${fmtDateLong(event.created_at)}</div></div>
        ${event.remark ? `<div class="sx-modal-detail-cell full"><div class="l">Remark</div><div class="v" style="font-weight: 500;">${escapeText(event.remark)}</div></div>` : ''}
        <div class="sx-modal-detail-cell full"><div class="l">Sizes</div>${sizesChips}</div>
      </div>
    </div>
    <div class="sx-modal-section">
      <p class="sx-modal-section-h">Lot journey at ${STAGE_LABEL.toLowerCase()}</p>
      <div id="modalJourney"><div class="sx-placeholder"><div class="sx-placeholder-mark">·</div><p>Loading lot history…</p></div></div>
    </div>
  `;
  el('modalOverlay').classList.add('show');

  // load lot journey if we have cutting_lot_id; many history rows include it
  // (the backend will be wired to return cutting_lot_id alongside events)
  const lotId = event.cutting_lot_id;
  if (lotId) {
    try {
      const data = await api('GET', BASE + '/event/lot-journey/' + lotId);
      renderJourney(data.events || [], event.id);
    } catch (err) {
      el('modalJourney').innerHTML = '<div class="sx-placeholder"><p style="color: var(--c-text-3);">Could not load journey: ' + escapeText(err.message) + '</p></div>';
    }
  } else {
    el('modalJourney').innerHTML = '<div class="sx-placeholder"><p style="color: var(--c-text-3);">Lot journey unavailable for this row.</p></div>';
  }
}

function renderJourney(events, currentEventId) {
  const wrap = el('modalJourney');
  if (!events.length) {
    wrap.innerHTML = '<div class="sx-placeholder"><p style="color: var(--c-text-3);">No events recorded.</p></div>';
    return;
  }
  const labelMap = { approve: 'Took in', complete: 'Marked done', reject: 'Rejected' };
  let html = '<div class="sx-journey">';
  events.forEach(e => {
    const sizes = e.sizes && Object.keys(e.sizes).length
      ? '<div class="sx-journey-detail">' + Object.entries(e.sizes).map(([k, v]) => `<span class="sx-chip s-empty"><span class="sx-chip-label">${escapeText(k)}</span><span class="sx-chip-num">${fmt(v)}</span></span>`).join('') + '</div>'
      : '';
    html += `
      <div class="sx-journey-step t-${e.event_type}${e.id === currentEventId ? ' is-current' : ''}">
        <div class="sx-journey-step-head">
          <span class="sx-journey-pill t-${e.event_type}">${escapeText(labelMap[e.event_type] || e.event_type)}</span>
          <span class="sx-journey-when">${fmtDate(e.created_at)}</span>
        </div>
        <div class="sx-journey-pieces">${fmt(e.pieces)} pcs</div>
        ${e.operator ? `<div class="sx-journey-by">by ${escapeText(e.operator)}${e.remark ? ' — ' + escapeText(String(e.remark).slice(0, 80)) : ''}</div>` : ''}
        ${sizes}
      </div>
    `;
  });
  html += '</div>';
  wrap.innerHTML = html;
}

function closeModal() {
  el('modalOverlay').classList.remove('show');
}

// click outside to close, escape to close
el('modalOverlay').addEventListener('click', e => { if (e.target === el('modalOverlay')) closeModal(); });
document.addEventListener('keydown', e => { if (e.key === 'Escape' && el('modalOverlay').classList.contains('show')) closeModal(); });

// initial load
loadHistory();
</script>

