<%- include('partials/header', { pageTitle: 'Warehouse Access' }) %>
<%- include('partials/navbar', { user: user }) %>

<main class="main-content" style="margin-left: 0;">
  <div class="container-fluid" style="max-width: 1200px; margin: 0 auto;">
    <!-- Page Header -->
    <div class="page-header d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
      <div>
        <h1 class="page-title">Warehouse Access</h1>
        <p class="page-subtitle">Assign Delhi or Faridabad visibility to Out of Stock users</p>
      </div>
      <a href="/easyecom/stock-market" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-2"></i>
        Back to Out-of-Stock
      </a>
    </div>

    <!-- Alert Messages -->
    <% if (error && error.length) { %>
      <div class="alert alert-danger d-flex align-items-center gap-2" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <%= error[0] %>
      </div>
    <% } %>
    <% if (success && success.length) { %>
      <div class="alert alert-success d-flex align-items-center gap-2" role="alert">
        <i class="bi bi-check-circle-fill"></i>
        <%= success[0] %>
      </div>
    <% } %>

    <div class="row g-4">
      <!-- Update Access Form -->
      <div class="col-12 col-lg-5">
        <div class="card h-100">
          <div class="card-header">
            <h2 class="card-title">
              <i class="bi bi-shield-lock me-2" style="color: var(--terracotta);"></i>
              Update Access
            </h2>
          </div>
          <div class="card-body">
            <form method="POST" id="access-form">
              <div class="mb-4">
                <label class="form-label fw-medium">User</label>
                <select name="userId" id="userId" class="form-select" required>
                  <option value="">Select user</option>
                  <% users.forEach(u => { %>
                    <option value="<%= u.id %>"><%= u.username %></option>
                  <% }); %>
                </select>
              </div>

              <div class="mb-4">
                <label class="form-label fw-medium d-block">Warehouses</label>
                <div class="warehouse-options">
                  <% warehouses.forEach((w) => { %>
                    <div class="form-check warehouse-check mb-2">
                      <input class="form-check-input" type="checkbox" name="warehouses" value="<%= w.id %>" id="wh-<%= w.id %>">
                      <label class="form-check-label" for="wh-<%= w.id %>">
                        <i class="bi bi-building me-2" style="color: var(--terracotta);"></i>
                        <%= w.label %>
                      </label>
                    </div>
                  <% }); %>
                </div>
                <small class="text-muted d-block mt-2">
                  <i class="bi bi-info-circle me-1"></i>
                  Select one or both warehouses for the chosen user.
                </small>
              </div>

              <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-save me-2"></i>
                Save Access
              </button>
            </form>
          </div>
        </div>
      </div>

      <!-- Current Assignments Table -->
      <div class="col-12 col-lg-7">
        <div class="card h-100">
          <div class="card-header">
            <h2 class="card-title">
              <i class="bi bi-people me-2" style="color: var(--terracotta);"></i>
              Current Assignments
            </h2>
            <span class="badge badge-neutral"><%= users.length %> users</span>
          </div>
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table mb-0">
                <thead>
                  <tr>
                    <th style="width: 40%;">User</th>
                    <th style="width: 60%;">Warehouses</th>
                  </tr>
                </thead>
                <tbody>
                  <% users.forEach((u) => { %>
                    <% const assigned = assignments[u.id] || []; %>
                    <tr>
                      <td>
                        <div class="d-flex align-items-center gap-2">
                          <div class="user-avatar-sm">
                            <%= u.username.charAt(0).toUpperCase() %>
                          </div>
                          <span class="fw-medium"><%= u.username %></span>
                        </div>
                      </td>
                      <td>
                        <% if (assigned.length === 0) { %>
                          <span class="badge badge-neutral">
                            <i class="bi bi-globe me-1"></i>
                            All (default)
                          </span>
                        <% } else { %>
                          <% assigned.forEach((id, idx) => { %>
                            <% const wh = warehouses.find((w) => w.id === id); %>
                            <span class="badge badge-terracotta me-1">
                              <i class="bi bi-building me-1"></i>
                              <%= wh ? wh.label : id %>
                            </span>
                          <% }); %>
                        <% } %>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<style>
  /* Page-specific styles */
  .user-avatar-sm {
    width: 32px;
    height: 32px;
    border-radius: var(--radius-full);
    background: var(--terracotta);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 500;
    font-size: var(--text-sm);
    flex-shrink: 0;
  }

  .warehouse-check {
    padding: 12px 16px;
    background: var(--gray-50);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-light);
    transition: all var(--transition-fast);
  }

  .warehouse-check:hover {
    background: var(--cream-dark);
    border-color: var(--border-medium);
  }

  .warehouse-check .form-check-input:checked ~ .form-check-label {
    color: var(--terracotta);
    font-weight: 500;
  }

  .warehouse-check .form-check-input:checked {
    background-color: var(--terracotta);
    border-color: var(--terracotta);
  }

  .badge-neutral {
    background: var(--gray-100);
    color: var(--text-secondary);
    font-weight: 500;
    padding: 6px 12px;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
  }

  .badge-terracotta {
    background: var(--terracotta-bg);
    color: var(--terracotta);
    font-weight: 500;
    padding: 6px 12px;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
  }

  .table th {
    background: var(--gray-50);
    font-weight: 600;
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-secondary);
    padding: 14px 22px;
    border-bottom: 1px solid var(--border-light);
  }

  .table td {
    padding: 16px 22px;
    vertical-align: middle;
    border-bottom: 1px solid var(--border-light);
  }

  .table tbody tr:last-child td {
    border-bottom: none;
  }

  .table tbody tr:hover {
    background: var(--gray-50);
  }

  .form-select, .form-control {
    border: 1px solid var(--border-medium);
    border-radius: var(--radius-md);
    padding: 10px 14px;
    font-size: var(--text-base);
    transition: all var(--transition-fast);
  }

  .form-select:focus, .form-control:focus {
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px var(--terracotta-bg);
    outline: none;
  }

  .form-label {
    color: var(--text-primary);
    font-size: var(--text-sm);
    margin-bottom: 8px;
  }

  .alert {
    border-radius: var(--radius-lg);
    padding: 14px 18px;
    font-size: var(--text-sm);
    border: none;
  }

  .alert-danger {
    background: var(--danger-light);
    color: var(--danger);
  }

  .alert-success {
    background: var(--success-light);
    color: var(--success);
  }
</style>

<script>
  const assignmentData = <%- JSON.stringify(assignments || {}) %>;
  const warehouses = <%- JSON.stringify(warehouses || []) %>;

  function setWarehouseChecks(userId) {
    const ids = assignmentData[userId] || [];
    warehouses.forEach((w) => {
      const checkbox = document.getElementById(`wh-${w.id}`);
      if (checkbox) {
        checkbox.checked = ids.includes(w.id);
      }
    });
  }

  document.getElementById('userId')?.addEventListener('change', (e) => {
    setWarehouseChecks(Number(e.target.value));
  });
</script>

<%- include('partials/footer') %>
