<%- include('partials/pmHead', { pageTitle: 'Production Manager' }) %>
<%- include('partials/pmSidebar', { active: 'dashboard', user: user }) %>


<div class="main">
  <header class="topbar">
    <div class="search">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m20 20-3-3"/></svg>
      <input placeholder="Search style, lot, or order…" id="topSearch">
    </div>
    <div class="actions">
      <a class="pm-btn" href="/pm/api/recommendations.csv">Export CSV</a>
      <% if (userRole === 'admin') { %><button class="pm-btn primary" id="pullNowBtn">Run pull</button><% } %>
    </div>
  </header>
  <main class="content">

  <div class="page-head">
    <div>
      <h1 class="page-h">Overview</h1>
      <p class="page-sub">Cutting recommendations · DRR · open lots · marketplace POs</p>
    </div>
  </div>

  <div class="pm-banner <%= warming ? 'show' : '' %>" id="warmingBanner">
    DRR warming up: inventory snapshot history &lt; 7 days. Calendar-day DRR is being used as fallback.
  </div>

  <div class="pm-summary" id="pmSummary"></div>

  <!-- PRIORITY TO CUT -->
  <section class="pm-panel active" data-panel="cutting">
    <h2 class="section-h" style="margin-top:6px">Priority to cut
      <div class="pm-toolbar">
        <input type="text" id="cuttingSearch" placeholder="Search style…">
        <select id="cuttingTrigger">
          <option value="all">All</option>
          <option value="red">Cut now</option>
          <option value="amber">Cut soon</option>
          <option value="green">Covered</option>
        </select>
        <button class="pm-btn" id="cuttingRefresh">Refresh</button>
      </div>
    </h2>
    <div class="tcard">
      <table class="prio" id="cuttingTable">
        <thead>
          <tr>
            <th class="l">Style</th>
            <th>Stock</th>
            <th>Days left</th>
            <th>Suggested cut</th>
            <th class="l" style="padding-left:32px">Status</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>
    <div class="tfoot" id="cuttingFoot"></div>
  </section>

  <!-- DEAD STOCK -->
  <section class="pm-panel" data-panel="dead">
    <div class="pm-card">
      <div class="pm-card-head">
        <h2>Dead Stock</h2>
        <div class="pm-toolbar">
          <label style="font-size:0.75rem; color: var(--text-2);">Window (days)</label>
          <input type="number" id="deadDays" value="45" min="7" max="365" style="width:6rem;">
          <button class="pm-btn" id="deadRefresh">Refresh</button>
        </div>
      </div>
      <div class="pm-card-body">
        <div class="pm-table-wrap">
          <table class="pm-table" id="deadTable">
            <thead>
              <tr>
                <th>SKU</th>
                <th>Style</th>
                <th>Size</th>
                <th>SOH</th>
                <th>Days Dormant</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- OPEN LOTS -->
  <section class="pm-panel" data-panel="lots">
    <div class="pm-card">
      <div class="pm-card-head">
        <h2>Open Cutting Lots</h2>
        <div class="pm-toolbar">
          <button class="pm-btn primary" id="addLotBtn">+ Add Lot</button>
        </div>
      </div>
      <div class="pm-card-body">
        <div class="pm-table-wrap">
          <table class="pm-table" id="lotsTable">
            <thead>
              <tr>
                <th>SKU</th>
                <th>Style</th>
                <th>Size</th>
                <th>Qty</th>
                <th>Expected completion</th>
                <th>Created at</th>
                <th></th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- MARKETPLACE POS -->
  <section class="pm-panel" data-panel="pos">
    <div class="pm-card">
      <div class="pm-card-head">
        <h2>Marketplace POs</h2>
        <div class="pm-toolbar">
          <span style="font-size:0.75rem; color: var(--text-2);">
            Expected columns: <code>marketplace, po_number, sku, size, qty, required_by_date</code>
          </span>
        </div>
      </div>
      <div class="pm-card-body">
        <label class="pm-drop" id="poDrop">
          <input type="file" id="poFile" accept=".xlsx">
          <div>Drop an .xlsx here or click to choose</div>
          <div style="font-size:0.75rem; color: var(--text-3); margin-top: 0.25rem;">Up to 25 MB</div>
        </label>
        <div id="poUploadStatus" style="margin-top: 0.75rem; font-size: 0.875rem;"></div>
        <div class="pm-table-wrap" style="margin-top: 1rem;">
          <table class="pm-table" id="posTable">
            <thead>
              <tr>
                <th>Marketplace</th>
                <th>PO Number</th>
                <th>Lines</th>
                <th>Total Qty</th>
                <th>Status</th>
                <th>Uploaded</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- CONFIG -->
  <section class="pm-panel" data-panel="config">
    <div class="pm-card">
      <div class="pm-card-head">
        <h2>Lead Time Overrides</h2>
      </div>
      <div class="pm-card-body">
        <form id="configForm" class="pm-grid" style="margin-bottom: 1rem;">
          <div class="pm-field">
            <label>Scope</label>
            <select name="scope">
              <option value="style">Style</option>
              <option value="sku">SKU</option>
            </select>
          </div>
          <div class="pm-field">
            <label>Key (style/SKU)</label>
            <input type="text" name="key_value" required>
          </div>
          <div class="pm-field">
            <label>Default LT (days)</label>
            <input type="number" name="default_lead_time_days" min="0">
          </div>
          <div class="pm-field">
            <label>Fabric LT (days)</label>
            <input type="number" name="fabric_lead_time_days" min="0">
          </div>
          <div class="pm-field">
            <label>Safety (days)</label>
            <input type="number" name="safety_days" min="0">
          </div>
          <div class="pm-field">
            <label>Override DRR</label>
            <input type="number" name="override_drr" step="0.001" min="0">
          </div>
          <div class="pm-field" style="justify-content: end;">
            <label>&nbsp;</label>
            <button type="submit" class="pm-btn primary">Save Override</button>
          </div>
        </form>
        <div class="pm-table-wrap">
          <table class="pm-table" id="configTable">
            <thead>
              <tr>
                <th>Scope</th>
                <th>Key</th>
                <th>Default LT</th>
                <th>Fabric LT</th>
                <th>Safety</th>
                <th>Override DRR</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  </main>
</div>

<!-- Add-lot modal -->
<div class="pm-modal-backdrop" id="lotModal">
  <div class="pm-modal">
    <h3>Add Open Cutting Lot</h3>
    <form id="lotForm" class="pm-grid">
      <div class="pm-field"><label>SKU</label><input type="text" name="sku" required></div>
      <div class="pm-field"><label>Style</label><input type="text" name="style"></div>
      <div class="pm-field"><label>Size</label><input type="text" name="size"></div>
      <div class="pm-field"><label>Qty</label><input type="number" name="qty" min="1" required></div>
      <div class="pm-field" style="grid-column: 1 / -1;">
        <label>Expected completion date</label>
        <input type="date" name="expected_completion_date" required>
      </div>
      <div style="grid-column: 1 / -1; display: flex; justify-content: flex-end; gap: 0.5rem;">
        <button type="button" class="pm-btn" id="lotCancel">Cancel</button>
        <button type="submit" class="pm-btn primary">Save</button>
      </div>
    </form>
  </div>
</div>

<script>
const $  = (id) => document.getElementById(id);
const $$ = (sel, root = document) => Array.from(root.querySelectorAll(sel));

function fmtNum(v, digits = 0) {
  if (v === null || v === undefined || Number.isNaN(Number(v))) return '—';
  return Number(v).toFixed(digits);
}
function escapeHtml(s) {
  return String(s == null ? '' : s)
    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
}

// Summary cards
function compactNum(n) {
  n = Number(n) || 0;
  if (n >= 1e7) return (n / 1e7).toFixed(1) + ' Cr';
  if (n >= 1e5) return (n / 1e5).toFixed(1) + ' L';
  if (n >= 1e3) return (n / 1e3).toFixed(1) + 'k';
  return String(Math.round(n));
}
function fmtDate(d) { return d ? new Date(d).toLocaleDateString('en-IN', { day: '2-digit', month: 'short' }) : ''; }

const KPI_ICON = {
  cut:  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M20 4 8.12 15.88M14.47 14.48 20 20M8.12 8.12 12 12"/></svg>',
  prod: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 21V8l6 4V8l6 4V5l6 3v13H3z"/></svg>',
  inv:  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M21 8 12 3 3 8l9 5 9-5z"/><path d="M3 8v8l9 5 9-5V8"/></svg>',
  sales:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 17l6-6 4 4 8-8"/><path d="M21 7v5h-5"/></svg>',
};
function kpiSpark(series) {
  if (!series || series.length < 2) return '';
  const max = Math.max(...series), min = Math.min(...series, 0), span = (max - min) || 1;
  const pts = series.map((v, i) => {
    const x = (i / (series.length - 1)) * 100;
    const y = 26 - ((v - min) / span) * 22;
    return x.toFixed(1) + ',' + y.toFixed(1);
  });
  const last = pts[pts.length - 1].split(',');
  return `<svg class="spark" viewBox="0 0 100 30" preserveAspectRatio="none"><polyline points="${pts.join(' ')}"/><circle class="dot" cx="${last[0]}" cy="${last[1]}" r="2.4"/></svg>`;
}
function kpiCard(label, tile, icon, val, trendCls, trendIcon, trendText, sparkHtml) {
  return `<div class="kpi">
    <div class="top"><span class="label">${label}</span><span class="tile ${tile}">${icon}</span></div>
    <div class="val num">${val}</div>
    ${sparkHtml || ''}
    <div class="trend ${trendCls}">${trendIcon}${trendText}</div>
  </div>`;
}
async function loadSummary() {
  const box = $('pmSummary');
  try {
    const s = await (await fetch('/pm/api/summary')).json();
    if (!s.ok) { box.innerHTML = ''; return; }
    const cards = [];

    if (s.cut_priority) {
      const cp = s.cut_priority;
      cards.push(kpiCard('To cut today', 'red', KPI_ICON.cut, compactNum(cp.totalSuggested), 'red',
        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12" y2="17"/></svg>',
        `${cp.red || 0} styles urgent`));
    }
    if (s.wip) {
      cards.push(kpiCard('In production', 'blue', KPI_ICON.prod, compactNum(s.wip.totalInHand), 'muted',
        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="9"/><path d="m8 12 3 3 5-6"/></svg>',
        'pieces across all stages'));
    }
    if (s.inventory) {
      cards.push(kpiCard('Inventory', 'green', KPI_ICON.inv, compactNum(s.inventory.units), 'green',
        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M20 6 9 17l-5-5"/></svg>',
        `units · as of ${fmtDate(s.inventory.as_of)}`));
    }
    if (s.sales_by_day && s.sales_by_day.length) {
      const days = s.sales_by_day;
      const avg = Math.round(days.reduce((a, d) => a + d.qty, 0) / days.length);
      const last = days[days.length - 1];
      cards.push(kpiCard('Sales / day', 'blue', KPI_ICON.sales, compactNum(avg), 'muted',
        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M7 17 17 7M8 7h9v9"/></svg>',
        `last ${fmtDate(last.date)}: ${compactNum(last.qty)}`,
        kpiSpark(days.slice(-14).map(d => Number(d.qty) || 0))));
    }
    box.innerHTML = cards.join('');
  } catch (_) { box.innerHTML = ''; }
}
loadSummary();

// Panels are now driven from the sidebar Tools group via the URL hash (#dead, #lots, …).
const TOOL_VIEWS = ['dead', 'lots', 'pos', 'config'];
function viewFromHash() { const h = (location.hash || '').replace('#', '').toLowerCase(); return TOOL_VIEWS.includes(h) ? h : 'cutting'; }
function showPanel(key) {
  $$('.pm-panel').forEach(p => p.classList.toggle('active', p.dataset.panel === key));
  // sync sidebar highlight: Dashboard for the default view, the matching tool otherwise
  $$('.sidebar [data-view]').forEach(a => a.classList.toggle('active', a.dataset.view === key));
  const dash = document.querySelector('.sidebar a[href="/pm"]');
  if (dash) dash.classList.toggle('active', key === 'cutting');
  if (key === 'cutting') loadCutting();
  else if (key === 'dead') loadDead();
  else if (key === 'lots') loadLots();
  else if (key === 'pos') loadPos();
  else if (key === 'config') loadConfig();
}
window.addEventListener('hashchange', () => showPanel(viewFromHash()));

// ── CUTTING TODAY ───────────────────────────────────────────────
async function loadCutting() {
  const search = $('cuttingSearch').value.trim();
  const trigger = $('cuttingTrigger').value;
  const params = new URLSearchParams();
  if (search) params.set('search', search);
  if (trigger && trigger !== 'all') params.set('trigger', trigger);
  const tbody = $('cuttingTable').querySelector('tbody');
  tbody.innerHTML = `<tr><td colspan="6" class="pm-empty">Loading…</td></tr>`;
  { const _f = $('cuttingFoot'); if (_f) _f.textContent = ''; }
  try {
    const r = await fetch('/pm/api/styles?' + params.toString(), { headers: { Accept: 'application/json' } });
    const json = await r.json();
    if (!json.ok && json.warning) {
      tbody.innerHTML = `<tr><td colspan="6" class="pm-empty">${escapeHtml(json.warning)}</td></tr>`;
      return;
    }
    if (json.dataQuality === 'warming_up') $('warmingBanner').classList.add('show');
    const items = json.items || [];
    if (!items.length) {
      tbody.innerHTML = `<tr><td colspan="6" class="pm-empty">No styles.</td></tr>`;
      return;
    }
    const STATUS = { red: ['red', 'Cut now'], amber: ['amber', 'Cut soon'], green: ['green', 'Covered'] };
    tbody.innerHTML = items.map(s => {
      const tg = s.trigger || 'green';
      const st = STATUS[tg] || STATUS.green;
      const doh = s.worst_size_doh == null ? null : Math.round(s.worst_size_doh);
      const daysCls = tg === 'red' ? 'red' : 'muted';
      const sug = Number(s.suggested_cut_qty) || 0;
      const action = sug > 0
        ? `<a class="btn-sm assign" href="/pm/cut-planning?style=${encodeURIComponent(s.style)}">Assign</a>`
        : `<a class="btn-sm review" href="/pm/style/${encodeURIComponent(s.style)}">Review</a>`;
      return `<tr class="clickable" data-style="${escapeHtml(s.style)}">
        <td class="style"><div class="row"><span class="swatch"></span><div><div class="code">${escapeHtml(s.style)}</div><div class="fab">DRR ${fmtNum(s.avg_drr, 2)}/day</div></div></div></td>
        <td><span class="num">${fmtNum(s.total_soh)}</span></td>
        <td class="days ${daysCls}"><span class="num">${doh == null ? '—' : doh + 'd'}</span></td>
        <td class="cut"><span class="num">${sug ? fmtNum(sug) : '0'}</span></td>
        <td class="status" style="padding-left:32px"><span class="pill ${st[0]}">${st[1]}</span></td>
        <td><span class="actwrap" onclick="event.stopPropagation()">${action}</span></td>
      </tr>`;
    }).join('');
    const foot = $('cuttingFoot');
    if (foot) foot.textContent = 'Showing ' + items.length + ' style' + (items.length === 1 ? '' : 's') + ' requiring attention';
    tbody.querySelectorAll('tr.clickable').forEach(tr => {
      tr.addEventListener('click', () => {
        window.location.href = '/pm/style/' + encodeURIComponent(tr.dataset.style);
      });
    });
  } catch (err) {
    tbody.innerHTML = `<tr><td colspan="6" class="pm-empty">Error: ${escapeHtml(err.message)}</td></tr>`;
  }
}
$('cuttingSearch').addEventListener('input', debounce(loadCutting, 250));
$('cuttingTrigger').addEventListener('change', loadCutting);
$('cuttingRefresh').addEventListener('click', loadCutting);

function debounce(fn, ms) {
  let t; return (...a) => { clearTimeout(t); t = setTimeout(() => fn(...a), ms); };
}

// ── DEAD STOCK ─────────────────────────────────────────────────
async function loadDead() {
  const days = parseInt($('deadDays').value, 10) || 45;
  const tbody = $('deadTable').querySelector('tbody');
  tbody.innerHTML = `<tr><td colspan="5" class="pm-empty">Loading…</td></tr>`;
  try {
    const r = await fetch('/pm/api/dead-stock?days=' + days, { headers: { Accept: 'application/json' } });
    const json = await r.json();
    if (!json.ok && json.warning) {
      tbody.innerHTML = `<tr><td colspan="5" class="pm-empty">${escapeHtml(json.warning)}</td></tr>`;
      return;
    }
    const items = json.items || [];
    if (!items.length) {
      tbody.innerHTML = `<tr><td colspan="5" class="pm-empty">No dead stock.</td></tr>`;
      return;
    }
    tbody.innerHTML = items.map(d => `
      <tr>
        <td>${escapeHtml(d.sku)}</td>
        <td>${escapeHtml(d.style)}</td>
        <td>${escapeHtml(d.size)}</td>
        <td>${fmtNum(d.soh)}</td>
        <td>${fmtNum(d.days_dormant)}</td>
      </tr>
    `).join('');
  } catch (err) {
    tbody.innerHTML = `<tr><td colspan="5" class="pm-empty">Error: ${escapeHtml(err.message)}</td></tr>`;
  }
}
$('deadRefresh').addEventListener('click', loadDead);

// ── OPEN LOTS ──────────────────────────────────────────────────
async function loadLots() {
  const tbody = $('lotsTable').querySelector('tbody');
  tbody.innerHTML = `<tr><td colspan="7" class="pm-empty">Loading…</td></tr>`;
  try {
    const r = await fetch('/pm/open-lots', { headers: { Accept: 'application/json' } });
    const json = await r.json();
    if (!json.ok && json.warning) {
      tbody.innerHTML = `<tr><td colspan="7" class="pm-empty">${escapeHtml(json.warning)}</td></tr>`;
      return;
    }
    const items = json.items || [];
    if (!items.length) {
      tbody.innerHTML = `<tr><td colspan="7" class="pm-empty">No open lots.</td></tr>`;
      return;
    }
    tbody.innerHTML = items.map(l => `
      <tr>
        <td>${escapeHtml(l.sku)}</td>
        <td>${escapeHtml(l.style)}</td>
        <td>${escapeHtml(l.size)}</td>
        <td>${fmtNum(l.qty)}</td>
        <td>${l.expected_completion_date ? new Date(l.expected_completion_date).toISOString().slice(0,10) : ''}</td>
        <td>${l.created_at ? new Date(l.created_at).toISOString().slice(0,16).replace('T',' ') : ''}</td>
        <td><button class="pm-btn danger" data-close="${l.id}">Close</button></td>
      </tr>
    `).join('');
    tbody.querySelectorAll('[data-close]').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!confirm('Close this lot?')) return;
        const id = btn.dataset.close;
        const r = await fetch('/pm/open-lots/' + id + '/close', { method: 'POST', headers: { Accept: 'application/json' } });
        const j = await r.json();
        if (!j.ok) alert(j.error || 'Failed');
        loadLots();
      });
    });
  } catch (err) {
    tbody.innerHTML = `<tr><td colspan="7" class="pm-empty">Error: ${escapeHtml(err.message)}</td></tr>`;
  }
}
$('addLotBtn').addEventListener('click', () => $('lotModal').classList.add('show'));
$('lotCancel').addEventListener('click', () => $('lotModal').classList.remove('show'));
$('lotForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  const body = {};
  for (const [k, v] of fd.entries()) body[k] = v;
  const r = await fetch('/pm/open-lots', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
    body: JSON.stringify(body),
  });
  const j = await r.json();
  if (!j.ok) return alert(j.error || 'Failed');
  $('lotModal').classList.remove('show');
  e.target.reset();
  loadLots();
});

// ── MARKETPLACE POS ────────────────────────────────────────────
async function loadPos() {
  const tbody = $('posTable').querySelector('tbody');
  tbody.innerHTML = `<tr><td colspan="6" class="pm-empty">Loading…</td></tr>`;
  try {
    const r = await fetch('/pm/marketplace-pos', { headers: { Accept: 'application/json' } });
    const json = await r.json();
    if (!json.ok && json.warning) {
      tbody.innerHTML = `<tr><td colspan="6" class="pm-empty">${escapeHtml(json.warning)}</td></tr>`;
      return;
    }
    const items = json.items || [];
    if (!items.length) {
      tbody.innerHTML = `<tr><td colspan="6" class="pm-empty">No POs uploaded.</td></tr>`;
      return;
    }
    tbody.innerHTML = items.map(p => `
      <tr>
        <td>${escapeHtml(p.marketplace)}</td>
        <td>${escapeHtml(p.po_number)}</td>
        <td>${fmtNum(p.lines_count)}</td>
        <td>${fmtNum(p.total_qty)}</td>
        <td>${escapeHtml(p.status)}</td>
        <td>${p.uploaded_at ? new Date(p.uploaded_at).toISOString().slice(0,16).replace('T',' ') : ''}</td>
      </tr>
    `).join('');
  } catch (err) {
    tbody.innerHTML = `<tr><td colspan="6" class="pm-empty">Error: ${escapeHtml(err.message)}</td></tr>`;
  }
}

const poDrop = $('poDrop');
const poFile = $('poFile');
['dragenter', 'dragover'].forEach(ev => poDrop.addEventListener(ev, e => {
  e.preventDefault(); poDrop.classList.add('dragging');
}));
['dragleave', 'drop'].forEach(ev => poDrop.addEventListener(ev, e => {
  e.preventDefault(); poDrop.classList.remove('dragging');
}));
poDrop.addEventListener('drop', e => {
  if (e.dataTransfer.files && e.dataTransfer.files[0]) uploadPo(e.dataTransfer.files[0]);
});
poFile.addEventListener('change', () => {
  if (poFile.files && poFile.files[0]) uploadPo(poFile.files[0]);
});
async function uploadPo(file) {
  const status = $('poUploadStatus');
  status.textContent = 'Uploading ' + file.name + '…';
  const fd = new FormData();
  fd.append('file', file);
  try {
    const r = await fetch('/pm/marketplace-pos/upload', { method: 'POST', body: fd });
    const j = await r.json();
    if (!j.ok) {
      status.style.color = 'var(--danger)';
      status.textContent = 'Failed: ' + (j.error || 'unknown error');
      return;
    }
    status.style.color = 'var(--success)';
    status.textContent = `Parsed ${j.pos_created || 1} PO(s), ${j.lines_count} line(s).`;
    loadPos();
  } catch (err) {
    status.style.color = 'var(--danger)';
    status.textContent = 'Failed: ' + err.message;
  }
}

// ── CONFIG ─────────────────────────────────────────────────────
async function loadConfig() {
  const tbody = $('configTable').querySelector('tbody');
  tbody.innerHTML = `<tr><td colspan="6" class="pm-empty">Loading…</td></tr>`;
  try {
    const r = await fetch('/pm/config/lead-times', { headers: { Accept: 'application/json' } });
    const json = await r.json();
    if (!json.ok && json.warning) {
      tbody.innerHTML = `<tr><td colspan="6" class="pm-empty">${escapeHtml(json.warning)}</td></tr>`;
      return;
    }
    const items = json.items || [];
    if (!items.length) {
      tbody.innerHTML = `<tr><td colspan="6" class="pm-empty">No overrides yet.</td></tr>`;
      return;
    }
    tbody.innerHTML = items.map(c => `
      <tr>
        <td>${escapeHtml(c.scope)}</td>
        <td>${escapeHtml(c.key_value)}</td>
        <td>${fmtNum(c.default_lead_time_days)}</td>
        <td>${fmtNum(c.fabric_lead_time_days)}</td>
        <td>${fmtNum(c.safety_days)}</td>
        <td>${c.override_drr == null ? '—' : fmtNum(c.override_drr, 3)}</td>
      </tr>
    `).join('');
  } catch (err) {
    tbody.innerHTML = `<tr><td colspan="6" class="pm-empty">Error: ${escapeHtml(err.message)}</td></tr>`;
  }
}
$('configForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  const body = {};
  for (const [k, v] of fd.entries()) body[k] = v;
  const r = await fetch('/pm/config/lead-times', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
    body: JSON.stringify(body),
  });
  const j = await r.json();
  if (!j.ok) return alert(j.error || 'Failed');
  e.target.reset();
  loadConfig();
});

// ── Pull now (admin only) ──────────────────────────────────────
const pullBtn = $('pullNowBtn');
if (pullBtn) {
  pullBtn.addEventListener('click', async () => {
    pullBtn.disabled = true; pullBtn.textContent = 'Queuing…';
    try {
      const r = await fetch('/pm/pull-now', { method: 'POST', headers: { Accept: 'application/json' } });
      const j = await r.json();
      if (j.ok) {
        pullBtn.textContent = 'Queued ✓';
        setTimeout(() => { pullBtn.textContent = 'Run Pull Now'; pullBtn.disabled = false; }, 2500);
      } else {
        alert(j.error || 'Failed to queue.');
        pullBtn.textContent = 'Run Pull Now'; pullBtn.disabled = false;
      }
    } catch (err) {
      alert('Failed: ' + err.message);
      pullBtn.textContent = 'Run Pull Now'; pullBtn.disabled = false;
    }
  });
}

// Initial load — honour the URL hash so deep links (/pm#lots) open the right panel
showPanel(viewFromHash());
</script>

