<% const pageTitle = 'Cash Flow - Pending Refunds' %>
<%- include('../partials/header') %>
<%- include('../partials/navbar', { dashboardUrl: '/returns/dashboard' }) %>

<style>
  /* Page Layout */
  .page-container {
    padding-top: calc(var(--navbar-height) + 24px);
    padding-bottom: 48px;
    min-height: 100vh;
    background: var(--bg-page);
  }

  .container-main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Page Header */
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 32px;
    flex-wrap: wrap;
    gap: 16px;
  }

  .page-header h1 {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    color: var(--text-primary);
    margin-bottom: 4px;
  }

  .page-header p {
    color: var(--text-secondary);
    font-size: var(--text-base);
  }

  /* Summary Cards Grid */
  .summary-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 20px;
    margin-bottom: 32px;
  }

  .summary-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 24px;
    text-align: center;
    transition: all var(--transition-fast);
  }

  .summary-card:hover {
    box-shadow: var(--shadow-sm);
    border-color: var(--border-medium);
  }

  .summary-card.primary {
    background: var(--terracotta);
    border-color: var(--terracotta);
    color: white;
  }

  .summary-card.primary .summary-label {
    color: rgba(255, 255, 255, 0.85);
  }

  .summary-value {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    color: var(--text-primary);
    line-height: 1.2;
    margin-bottom: 8px;
  }

  .summary-card.primary .summary-value {
    color: white;
  }

  .summary-value.success { color: var(--success); }
  .summary-value.warning { color: var(--warning); }

  .summary-label {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 500;
  }

  /* Section Cards */
  .section-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    margin-bottom: 24px;
    overflow: hidden;
  }

  .section-header {
    padding: 18px 24px;
    border-bottom: 1px solid var(--border-light);
    background: var(--gray-50);
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--text-primary);
  }

  .section-header i {
    font-size: 20px;
  }

  .section-header .count {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  /* Refund List */
  .refund-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .refund-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 24px;
    border-bottom: 1px solid var(--border-light);
    transition: background var(--transition-fast);
    flex-wrap: wrap;
    gap: 16px;
  }

  .refund-item:hover {
    background: var(--gray-50);
  }

  .refund-item:last-child {
    border-bottom: none;
  }

  .refund-info {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    flex: 1;
    min-width: 280px;
  }

  .refund-avatar {
    width: 48px;
    height: 48px;
    background: var(--terracotta-bg);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--terracotta);
    flex-shrink: 0;
  }

  .refund-avatar.ready {
    background: var(--success-light);
    color: var(--success);
  }

  .refund-avatar.waiting {
    background: var(--warning-light);
    color: var(--warning);
  }

  .refund-avatar.prepaid {
    background: var(--info-light);
    color: var(--info);
  }

  .refund-details h4 {
    margin: 0 0 4px 0;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--text-primary);
  }

  .refund-details p {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .bank-info {
    background: var(--gray-100);
    border-radius: var(--radius-md);
    padding: 10px 14px;
    margin-top: 10px;
    font-size: var(--text-sm);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .bank-info .label {
    color: var(--text-secondary);
    font-weight: 500;
  }

  .bank-info .value {
    color: var(--text-primary);
    font-weight: 500;
  }

  /* Badges */
  .badge-waiting {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--warning-light);
    color: var(--warning);
    padding: 4px 12px;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
    margin-top: 8px;
  }

  .badge-ready {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--success-light);
    color: var(--success);
    padding: 4px 12px;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
    margin-top: 8px;
  }

  /* Refund Amount Section */
  .refund-amount {
    text-align: right;
    flex-shrink: 0;
  }

  .refund-amount .amount {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--text-primary);
    margin-bottom: 4px;
  }

  .refund-amount .method {
    font-size: var(--text-xs);
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 12px;
  }

  /* Action Buttons */
  .action-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 10px 18px;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: 500;
    border: none;
    cursor: pointer;
    transition: all var(--transition-fast);
    text-decoration: none;
  }

  .action-btn-success {
    background: var(--success);
    color: white;
  }

  .action-btn-success:hover {
    background: #247d50;
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
  }

  .action-btn-warning {
    background: var(--warning);
    color: white;
  }

  .action-btn-warning:hover {
    background: #b37731;
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: 48px 24px;
    color: var(--text-secondary);
  }

  .empty-state i {
    font-size: 48px;
    color: var(--text-muted);
    margin-bottom: 16px;
    display: block;
  }

  .empty-state p {
    margin: 0;
    font-size: var(--text-base);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .page-container {
      padding-top: calc(var(--navbar-height) + 16px);
    }

    .container-main {
      padding: 0 16px;
    }

    .page-header h1 {
      font-size: var(--text-2xl);
    }

    .summary-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .summary-card {
      padding: 16px;
    }

    .summary-value {
      font-size: var(--text-2xl);
    }

    .refund-item {
      padding: 16px;
    }

    .refund-info {
      min-width: 100%;
    }

    .refund-amount {
      width: 100%;
      text-align: left;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 12px;
      border-top: 1px solid var(--border-light);
    }
  }
</style>

<div class="page-container">
  <div class="container-main">
    <!-- Page Header -->
    <div class="page-header">
      <div>
        <h1>Cash Flow - Pending Refunds</h1>
        <p>Track and process pending customer refunds</p>
      </div>
      <a href="/returns/dashboard" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Back to Returns
      </a>
    </div>

    <!-- Summary Cards -->
    <div class="summary-grid">
      <div class="summary-card primary">
        <div class="summary-value"><%= formatCurrency(totalPending) %></div>
        <div class="summary-label">Total Pending</div>
      </div>
      <div class="summary-card">
        <div class="summary-value"><%= pendingRefunds.length %></div>
        <div class="summary-label">Pending Refunds</div>
      </div>
      <div class="summary-card">
        <div class="summary-value success"><%= withBankDetails %></div>
        <div class="summary-label">Ready to Pay</div>
      </div>
      <div class="summary-card">
        <div class="summary-value warning"><%= withoutBankDetails %></div>
        <div class="summary-label">Awaiting Bank Details</div>
      </div>
    </div>

    <!-- Ready to Pay Section -->
    <div class="section-card">
      <div class="section-header">
        <i class="bi bi-check-circle-fill" style="color: var(--success);"></i>
        Ready to Pay <span class="count">(<%= withBankDetails %>)</span>
      </div>
      <% const readyToPay = pendingRefunds.filter(r => r.bank_submitted_at); %>
      <% if (readyToPay.length === 0) { %>
        <div class="empty-state">
          <i class="bi bi-inbox"></i>
          <p>No refunds ready to pay</p>
        </div>
      <% } else { %>
        <ul class="refund-list">
          <% readyToPay.forEach(refund => { %>
          <li class="refund-item">
            <div class="refund-info">
              <div class="refund-avatar ready">
                <%= (refund.customer_name || 'C').charAt(0).toUpperCase() %>
              </div>
              <div class="refund-details">
                <h4><%= refund.customer_name || 'Customer' %></h4>
                <p><%= refund.return_id %> | <%= refund.customer_phone || '-' %></p>
                <% if (refund.upi_id) { %>
                <div class="bank-info">
                  <i class="bi bi-phone"></i>
                  <span class="label">UPI:</span>
                  <span class="value"><%= refund.upi_id %></span>
                </div>
                <% } else if (refund.account_number) { %>
                <div class="bank-info">
                  <i class="bi bi-bank"></i>
                  <span class="label">Bank:</span>
                  <span class="value"><%= refund.bank_name %> | A/C: <%= maskAccountNumber(refund.account_number) %></span>
                </div>
                <% } %>
              </div>
            </div>
            <div class="refund-amount">
              <div class="amount"><%= formatCurrency(refund.refund_amount) %></div>
              <div class="method"><%= refund.order_type === 'cod' ? 'UPI/Bank' : 'Shopify' %></div>
              <a href="/returns/<%= refund.id %>?action=refund" class="action-btn action-btn-success">
                <i class="bi bi-check-lg"></i> Process Refund
              </a>
            </div>
          </li>
          <% }) %>
        </ul>
      <% } %>
    </div>

    <!-- Awaiting Bank Details Section -->
    <div class="section-card">
      <div class="section-header">
        <i class="bi bi-hourglass-split" style="color: var(--warning);"></i>
        Awaiting Bank Details <span class="count">(<%= withoutBankDetails %>)</span>
      </div>
      <% const awaitingDetails = pendingRefunds.filter(r => !r.bank_submitted_at && r.order_type === 'cod'); %>
      <% if (awaitingDetails.length === 0) { %>
        <div class="empty-state">
          <i class="bi bi-inbox"></i>
          <p>No refunds awaiting bank details</p>
        </div>
      <% } else { %>
        <ul class="refund-list">
          <% awaitingDetails.forEach(refund => { %>
          <li class="refund-item">
            <div class="refund-info">
              <div class="refund-avatar waiting">
                <%= (refund.customer_name || 'C').charAt(0).toUpperCase() %>
              </div>
              <div class="refund-details">
                <h4><%= refund.customer_name || 'Customer' %></h4>
                <p><%= refund.return_id %> | <%= refund.customer_phone || '-' %></p>
                <span class="badge-waiting">
                  <i class="bi bi-clock"></i> Waiting for bank details
                </span>
              </div>
            </div>
            <div class="refund-amount">
              <div class="amount"><%= formatCurrency(refund.refund_amount) %></div>
              <button class="action-btn action-btn-warning" onclick="sendBankLink(<%= refund.id %>)">
                <i class="bi bi-send"></i> Send Link
              </button>
            </div>
          </li>
          <% }) %>
        </ul>
      <% } %>
    </div>

    <!-- Prepaid Refunds Section -->
    <% const prepaidRefunds = pendingRefunds.filter(r => r.order_type === 'prepaid'); %>
    <% if (prepaidRefunds.length > 0) { %>
    <div class="section-card">
      <div class="section-header">
        <i class="bi bi-credit-card" style="color: var(--info);"></i>
        Prepaid Refunds <span class="count">(<%= prepaidRefunds.length %>)</span>
      </div>
      <ul class="refund-list">
        <% prepaidRefunds.forEach(refund => { %>
        <li class="refund-item">
          <div class="refund-info">
            <div class="refund-avatar prepaid">
              <%= (refund.customer_name || 'C').charAt(0).toUpperCase() %>
            </div>
            <div class="refund-details">
              <h4><%= refund.customer_name || 'Customer' %></h4>
              <p><%= refund.return_id %> | Order: <%= refund.shopify_order_name %></p>
              <span class="badge-ready">
                <i class="bi bi-credit-card"></i> Prepaid - Refund via Shopify
              </span>
            </div>
          </div>
          <div class="refund-amount">
            <div class="amount"><%= formatCurrency(refund.refund_amount) %></div>
            <a href="/returns/<%= refund.id %>?action=refund" class="action-btn action-btn-success">
              <i class="bi bi-check-lg"></i> Process Shopify Refund
            </a>
          </div>
        </li>
        <% }) %>
      </ul>
    </div>
    <% } %>
  </div>
</div>

<script>
  async function sendBankLink(id) {
    const res = await fetch(`/returns/${id}/send-bank-link`, { method: 'POST' });
    const data = await res.json();
    if (data.success) {
      alert(`Bank link generated!\n\n${data.link}\n\nSend to: ${data.phone}`);
      navigator.clipboard.writeText(data.link);
    } else {
      alert(data.message || 'Failed');
    }
  }
</script>

<%- include('../partials/footer') %>
