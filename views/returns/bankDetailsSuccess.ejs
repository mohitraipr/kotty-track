<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Details Submitted - Kotty Returns</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">

  <style>
    :root {
      /* Brand Colors */
      --charcoal: #1a1a1a;
      --charcoal-light: #2d2d2d;
      --cream: #faf8f5;
      --cream-dark: #f0ebe3;
      --terracotta: #c45c3a;
      --terracotta-light: #d4826a;
      --terracotta-dark: #a34a2d;

      /* Success Colors */
      --success: #2d8a5f;
      --success-light: #3da872;
      --success-bg: #e8f5ee;

      /* Text Colors */
      --text-primary: #1a1a1a;
      --text-secondary: #5a5650;
      --text-muted: #a8a49a;

      /* Other */
      --border-light: #e8e6e1;
      --shadow-sm: 0 2px 8px rgba(26, 26, 26, 0.06);
      --shadow-md: 0 4px 24px rgba(26, 26, 26, 0.08);
      --shadow-lg: 0 8px 32px rgba(26, 26, 26, 0.12);

      /* Typography */
      --font-display: 'DM Serif Display', Georgia, serif;
      --font-body: 'Outfit', -apple-system, BlinkMacSystemFont, sans-serif;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: var(--font-body);
      background: var(--cream);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 24px;
      color: var(--text-primary);
      position: relative;
      overflow: hidden;
    }

    /* Subtle background pattern */
    body::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background:
        radial-gradient(circle at 20% 20%, rgba(196, 92, 58, 0.03) 0%, transparent 50%),
        radial-gradient(circle at 80% 80%, rgba(45, 138, 95, 0.03) 0%, transparent 50%);
      pointer-events: none;
    }

    .success-container {
      max-width: 460px;
      width: 100%;
      background: #ffffff;
      border-radius: 20px;
      padding: 52px 44px;
      box-shadow: var(--shadow-lg);
      text-align: center;
      border: 1px solid var(--border-light);
      position: relative;
      z-index: 1;
      animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @keyframes slideUp {
      from {
        opacity: 0;
        transform: translateY(24px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* Animated Success Icon */
    .success-icon-wrapper {
      position: relative;
      margin: 0 auto 32px;
      width: 96px;
      height: 96px;
    }

    .success-icon {
      width: 96px;
      height: 96px;
      background: linear-gradient(135deg, var(--success) 0%, var(--success-light) 100%);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 12px 32px rgba(45, 138, 95, 0.3);
      animation: scaleIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s backwards;
    }

    @keyframes scaleIn {
      from {
        transform: scale(0);
      }
      to {
        transform: scale(1);
      }
    }

    .success-icon i {
      font-size: 48px;
      color: white;
      animation: checkIn 0.4s ease-out 0.5s backwards;
    }

    @keyframes checkIn {
      from {
        opacity: 0;
        transform: scale(0.5);
      }
      to {
        opacity: 1;
        transform: scale(1);
      }
    }

    /* Celebration rings */
    .success-ring {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 96px;
      height: 96px;
      border: 2px solid var(--success);
      border-radius: 50%;
      opacity: 0;
      animation: ringPulse 1.5s ease-out 0.6s;
    }

    .success-ring:nth-child(2) {
      animation-delay: 0.8s;
    }

    @keyframes ringPulse {
      0% {
        transform: translate(-50%, -50%) scale(1);
        opacity: 0.6;
      }
      100% {
        transform: translate(-50%, -50%) scale(1.8);
        opacity: 0;
      }
    }

    .success-title {
      font-family: var(--font-display);
      font-size: 34px;
      font-weight: 400;
      color: var(--text-primary);
      margin-bottom: 14px;
      line-height: 1.2;
      animation: fadeIn 0.5s ease-out 0.4s backwards;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(8px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .success-message {
      font-size: 16px;
      color: var(--text-secondary);
      margin-bottom: 36px;
      line-height: 1.7;
      font-weight: 400;
      animation: fadeIn 0.5s ease-out 0.5s backwards;
    }

    .info-box {
      background: var(--cream);
      border-radius: 14px;
      padding: 26px;
      margin-bottom: 36px;
      border: 1px solid var(--border-light);
      animation: fadeIn 0.5s ease-out 0.6s backwards;
    }

    .info-row {
      display: flex;
      justify-content: space-between;
      gap: 20px;
    }

    .info-item {
      flex: 1;
      text-align: center;
    }

    .info-item .label {
      font-size: 11px;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-weight: 500;
      margin-bottom: 8px;
    }

    .info-item .value {
      font-family: var(--font-display);
      font-size: 22px;
      color: var(--text-primary);
    }

    .info-item .value.success-text {
      color: var(--success);
    }

    .info-divider {
      width: 1px;
      background: var(--border-light);
      margin: 0 4px;
    }

    .home-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 16px 36px;
      background: var(--charcoal);
      color: white;
      text-decoration: none;
      border-radius: 10px;
      font-family: var(--font-body);
      font-size: 15px;
      font-weight: 500;
      transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
      border: none;
      cursor: pointer;
      animation: fadeIn 0.5s ease-out 0.7s backwards;
    }

    .home-btn:hover {
      background: var(--charcoal-light);
      color: white;
      transform: translateY(-3px);
      box-shadow: 0 8px 24px rgba(26, 26, 26, 0.2);
    }

    .home-btn:active {
      transform: translateY(-1px);
    }

    .home-btn i {
      font-size: 18px;
      transition: transform 0.25s ease;
    }

    .home-btn:hover i {
      transform: translateX(3px);
    }

    .brand-footer {
      margin-top: 36px;
      padding-top: 28px;
      border-top: 1px solid var(--border-light);
      animation: fadeIn 0.5s ease-out 0.8s backwards;
    }

    .brand-logo {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      color: var(--text-muted);
      font-size: 14px;
    }

    .brand-logo .logo-mark {
      width: 32px;
      height: 32px;
      background: var(--terracotta);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-display);
      font-size: 16px;
      color: white;
    }

    .brand-logo span {
      font-family: var(--font-display);
      font-size: 18px;
      color: var(--text-secondary);
    }

    /* Confetti particles */
    .confetti {
      position: absolute;
      width: 10px;
      height: 10px;
      opacity: 0;
    }

    .confetti-1 {
      background: var(--terracotta);
      top: 20%;
      left: 15%;
      animation: confettiFall 2s ease-out 0.8s forwards;
      border-radius: 2px;
      transform: rotate(45deg);
    }

    .confetti-2 {
      background: var(--success);
      top: 15%;
      right: 20%;
      animation: confettiFall 2.2s ease-out 0.9s forwards;
      border-radius: 50%;
    }

    .confetti-3 {
      background: var(--terracotta-light);
      top: 25%;
      left: 25%;
      animation: confettiFall 1.8s ease-out 1s forwards;
      width: 8px;
      height: 8px;
    }

    .confetti-4 {
      background: var(--success-light);
      top: 18%;
      right: 30%;
      animation: confettiFall 2.1s ease-out 0.85s forwards;
      border-radius: 2px;
      transform: rotate(30deg);
    }

    .confetti-5 {
      background: var(--terracotta);
      top: 22%;
      right: 15%;
      animation: confettiFall 1.9s ease-out 1.1s forwards;
      border-radius: 50%;
      width: 6px;
      height: 6px;
    }

    .confetti-6 {
      background: var(--success);
      top: 20%;
      left: 35%;
      animation: confettiFall 2.3s ease-out 0.95s forwards;
      width: 8px;
      height: 8px;
      border-radius: 2px;
    }

    @keyframes confettiFall {
      0% {
        opacity: 1;
        transform: translateY(0) rotate(0deg) scale(1);
      }
      100% {
        opacity: 0;
        transform: translateY(120px) rotate(360deg) scale(0.5);
      }
    }

    /* Trust indicators */
    .trust-text {
      margin-top: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      font-size: 13px;
      color: var(--text-muted);
    }

    .trust-text i {
      color: var(--success);
      font-size: 14px;
    }

    @media (max-width: 480px) {
      .success-container {
        padding: 40px 28px;
        border-radius: 16px;
      }

      .success-title {
        font-size: 28px;
      }

      .success-icon-wrapper {
        width: 80px;
        height: 80px;
      }

      .success-icon {
        width: 80px;
        height: 80px;
      }

      .success-icon i {
        font-size: 40px;
      }

      .success-ring {
        width: 80px;
        height: 80px;
      }

      .info-row {
        flex-direction: column;
        gap: 20px;
      }

      .info-divider {
        display: none;
      }

      .info-item .value {
        font-size: 20px;
      }

      .home-btn {
        width: 100%;
        padding: 16px 24px;
      }

      .confetti {
        display: none;
      }
    }
  </style>
</head>
<body>
  <!-- Confetti particles -->
  <div class="confetti confetti-1"></div>
  <div class="confetti confetti-2"></div>
  <div class="confetti confetti-3"></div>
  <div class="confetti confetti-4"></div>
  <div class="confetti confetti-5"></div>
  <div class="confetti confetti-6"></div>

  <div class="success-container">
    <div class="success-icon-wrapper">
      <div class="success-ring"></div>
      <div class="success-ring"></div>
      <div class="success-icon">
        <i class="bi bi-check-lg"></i>
      </div>
    </div>

    <h1 class="success-title">Details Submitted</h1>

    <p class="success-message">
      <%= message || 'Your bank details have been submitted successfully. Your refund will be processed within 2-3 business days.' %>
    </p>

    <% if (typeof returnData !== 'undefined' && returnData) { %>
    <div class="info-box">
      <div class="info-row">
        <div class="info-item">
          <div class="label">Return ID</div>
          <div class="value"><%= returnData.return_id %></div>
        </div>
        <div class="info-divider"></div>
        <div class="info-item">
          <div class="label">Refund Amount</div>
          <div class="value success-text"><%= returnData.refund_amount ? '\u20B9' + parseFloat(returnData.refund_amount).toLocaleString('en-IN') : 'Processing' %></div>
        </div>
      </div>
    </div>
    <% } %>

    <a href="https://kotty.in" class="home-btn">
      Continue Shopping
      <i class="bi bi-arrow-right"></i>
    </a>

    <div class="brand-footer">
      <div class="brand-logo">
        <div class="logo-mark">K</div>
        <span>Kotty</span>
      </div>
      <div class="trust-text">
        <i class="bi bi-shield-check"></i>
        Secure refund processing
      </div>
    </div>
  </div>
</body>
</html>
