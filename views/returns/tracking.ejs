<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Track Your Return - Kotty</title>
  <meta name="description" content="Track the status of your Kotty return request">

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <!-- Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">

  <style>
    :root {
      /* Brand Colors */
      --charcoal: #1a1a1a;
      --cream: #faf8f5;
      --cream-dark: #f0ebe3;
      --cream-darker: #e5dfd4;
      --terracotta: #c45c3a;
      --terracotta-light: #d4826a;
      --terracotta-dark: #a34a2d;
      --terracotta-bg: rgba(196, 92, 58, 0.08);

      /* Semantic Colors */
      --success: #2d8a5f;
      --success-light: #e8f5ee;
      --danger: #c23b22;
      --danger-light: #fdf2f0;

      /* Neutral Grays */
      --gray-100: #f5f5f3;
      --gray-200: #e8e6e1;
      --gray-300: #d4d1c9;
      --gray-400: #a8a49a;
      --gray-500: #78746a;
      --gray-600: #5a5650;

      /* Typography */
      --font-display: 'DM Serif Display', Georgia, serif;
      --font-body: 'Outfit', -apple-system, BlinkMacSystemFont, sans-serif;
      --font-mono: 'SF Mono', 'Fira Code', monospace;
    }

    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    body {
      font-family: var(--font-body);
      background: var(--cream);
      min-height: 100vh;
      padding: 24px 20px 48px;
      color: var(--charcoal);
      line-height: 1.5;
    }

    /* Container */
    .tracking-container {
      max-width: 600px;
      margin: 0 auto;
    }

    /* Brand Header */
    .brand-header {
      text-align: center;
      margin-bottom: 32px;
      padding-top: 8px;
    }

    .brand-link {
      display: inline-block;
      font-family: var(--font-display);
      font-size: 32px;
      color: var(--charcoal);
      text-decoration: none;
      letter-spacing: 0.08em;
      transition: color 0.2s ease;
    }

    .brand-link:hover {
      color: var(--terracotta);
    }

    .page-title {
      font-family: var(--font-body);
      font-size: 14px;
      font-weight: 400;
      color: var(--gray-500);
      margin-top: 8px;
      letter-spacing: 0.02em;
    }

    /* Main Card */
    .card {
      background: white;
      border: 1px solid var(--gray-200);
      border-radius: 16px;
      box-shadow: 0 4px 24px rgba(26, 26, 26, 0.06);
      overflow: hidden;
      margin-bottom: 24px;
    }

    /* Card Header */
    .card-header-custom {
      background: var(--charcoal);
      color: white;
      padding: 28px 28px 24px;
      position: relative;
    }

    .card-header-custom::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--terracotta), var(--terracotta-light));
    }

    .return-id {
      font-size: 12px;
      opacity: 0.7;
      margin-bottom: 8px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      font-weight: 500;
    }

    .order-info {
      font-family: var(--font-display);
      font-size: 24px;
      font-weight: 400;
      line-height: 1.3;
    }

    .status-badge {
      display: inline-block;
      padding: 8px 16px;
      border-radius: 24px;
      font-size: 11px;
      font-weight: 600;
      margin-top: 16px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .status-pending_review { background: rgba(255,255,255,0.12); }
    .status-approved { background: rgba(255,255,255,0.12); }
    .status-pickup_scheduled { background: rgba(255,255,255,0.12); }
    .status-picked_up { background: rgba(255,255,255,0.12); }
    .status-in_transit { background: rgba(255,255,255,0.12); }
    .status-received { background: rgba(255,255,255,0.12); }
    .status-refund_pending { background: rgba(255,255,255,0.12); }
    .status-refunded { background: var(--success); }
    .status-rejected { background: var(--danger); }
    .status-cancelled { background: var(--danger); }

    .card-body {
      padding: 28px;
    }

    /* Progress Tracker */
    .progress-tracker {
      display: flex;
      justify-content: space-between;
      margin-bottom: 36px;
      position: relative;
    }

    .progress-tracker::before {
      content: '';
      position: absolute;
      top: 18px;
      left: 28px;
      right: 28px;
      height: 2px;
      background: var(--gray-200);
      z-index: 1;
    }

    .progress-step {
      display: flex;
      flex-direction: column;
      align-items: center;
      position: relative;
      z-index: 2;
      flex: 1;
    }

    .step-circle {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: var(--gray-200);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      color: var(--gray-500);
      margin-bottom: 10px;
      transition: all 0.3s ease;
      font-weight: 500;
    }

    .step-circle.active {
      background: var(--terracotta);
      color: white;
      box-shadow: 0 4px 16px rgba(196, 92, 58, 0.35);
    }

    .step-circle.completed {
      background: var(--success);
      color: white;
    }

    .step-label {
      font-size: 11px;
      color: var(--gray-500);
      text-align: center;
      max-width: 64px;
      font-weight: 500;
      letter-spacing: 0.01em;
    }

    .step-label.active {
      color: var(--terracotta);
      font-weight: 600;
    }

    .step-label.completed {
      color: var(--success);
    }

    /* Timeline */
    .timeline {
      margin-bottom: 28px;
    }

    .timeline-item {
      display: flex;
      gap: 16px;
      padding-bottom: 24px;
      position: relative;
    }

    .timeline-item:not(:last-child)::before {
      content: '';
      position: absolute;
      left: 15px;
      top: 36px;
      bottom: 0;
      width: 2px;
      background: var(--gray-200);
    }

    .timeline-icon {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      font-size: 14px;
    }

    .timeline-icon.completed {
      background: var(--success-light);
      color: var(--success);
    }

    .timeline-icon.active {
      background: var(--terracotta-bg);
      color: var(--terracotta);
    }

    .timeline-icon.pending {
      background: var(--gray-100);
      color: var(--gray-400);
    }

    .timeline-content {
      flex: 1;
      padding-top: 4px;
    }

    .timeline-content h4 {
      font-family: var(--font-display);
      font-size: 16px;
      font-weight: 400;
      color: var(--charcoal);
      margin: 0 0 4px 0;
    }

    .timeline-content p {
      font-size: 13px;
      color: var(--gray-600);
      margin: 0;
      line-height: 1.5;
    }

    .timeline-content .date {
      font-size: 12px;
      color: var(--gray-400);
      margin-top: 6px;
      display: block;
    }

    /* AWB Tracking Box */
    .awb-box {
      background: var(--cream);
      border: 1px solid var(--gray-200);
      border-radius: 12px;
      padding: 20px;
      margin-bottom: 24px;
    }

    .awb-label {
      font-size: 11px;
      color: var(--gray-500);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 6px;
      font-weight: 500;
    }

    .awb-number {
      font-size: 20px;
      font-weight: 600;
      color: var(--charcoal);
      font-family: var(--font-mono);
      letter-spacing: 0.03em;
    }

    .courier-name {
      font-size: 13px;
      color: var(--gray-600);
      margin-top: 8px;
    }

    .track-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 20px;
      background: var(--terracotta);
      color: white;
      text-decoration: none;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 500;
      margin-top: 16px;
      transition: all 0.2s ease;
    }

    .track-btn:hover {
      background: var(--terracotta-dark);
      color: white;
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(196, 92, 58, 0.3);
    }

    .track-btn i {
      font-size: 14px;
    }

    /* Refund Info Box */
    .refund-box {
      background: var(--success-light);
      border: 1px solid rgba(45, 138, 95, 0.15);
      border-radius: 12px;
      padding: 20px;
    }

    .refund-label {
      font-size: 13px;
      color: var(--success);
      margin-bottom: 6px;
      font-weight: 500;
    }

    .refund-amount {
      font-family: var(--font-display);
      font-size: 32px;
      font-weight: 400;
      color: var(--success);
      line-height: 1.2;
    }

    .refund-method {
      font-size: 13px;
      color: var(--gray-600);
      margin-top: 8px;
      line-height: 1.5;
    }

    /* Rejected/Cancelled Status Card */
    .status-message-card {
      text-align: center;
      padding: 40px 24px;
    }

    .status-icon-wrapper {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 20px;
    }

    .status-icon-wrapper.rejected {
      background: var(--danger-light);
    }

    .status-icon-wrapper.rejected i {
      font-size: 28px;
      color: var(--danger);
    }

    .status-message-card h4 {
      font-family: var(--font-display);
      font-size: 22px;
      color: var(--charcoal);
      margin-bottom: 12px;
    }

    .status-message-card p {
      color: var(--gray-600);
      margin: 0;
      font-size: 15px;
      line-height: 1.6;
      max-width: 320px;
      margin: 0 auto;
    }

    /* Help Box */
    .help-box {
      text-align: center;
      padding: 28px;
      background: white;
      border: 1px solid var(--gray-200);
      border-radius: 12px;
    }

    .help-box p {
      margin: 0;
      color: var(--gray-600);
      font-size: 14px;
    }

    .help-box p:first-child {
      margin-bottom: 8px;
      font-weight: 500;
      color: var(--charcoal);
    }

    .help-box a {
      color: var(--terracotta);
      font-weight: 500;
      text-decoration: none;
      transition: color 0.2s ease;
    }

    .help-box a:hover {
      color: var(--terracotta-dark);
      text-decoration: underline;
    }

    /* Footer Branding */
    .footer-brand {
      text-align: center;
      margin-top: 32px;
      padding-top: 24px;
      border-top: 1px solid var(--gray-200);
    }

    .footer-brand span {
      font-size: 12px;
      color: var(--gray-400);
      letter-spacing: 0.02em;
    }

    .footer-brand a {
      color: var(--terracotta);
      text-decoration: none;
      font-weight: 500;
    }

    .footer-brand a:hover {
      text-decoration: underline;
    }

    /* Responsive Styles */
    @media (max-width: 480px) {
      body {
        padding: 16px 16px 40px;
      }

      .brand-header {
        margin-bottom: 24px;
      }

      .brand-link {
        font-size: 26px;
      }

      .card-header-custom {
        padding: 24px 20px 20px;
      }

      .order-info {
        font-size: 20px;
      }

      .card-body {
        padding: 20px;
      }

      .step-label {
        font-size: 9px;
        max-width: 52px;
      }

      .step-circle {
        width: 32px;
        height: 32px;
        font-size: 12px;
      }

      .progress-tracker::before {
        top: 15px;
        left: 22px;
        right: 22px;
      }

      .timeline-content h4 {
        font-size: 15px;
      }

      .refund-amount {
        font-size: 28px;
      }

      .awb-number {
        font-size: 17px;
      }
    }
  </style>
</head>
<body>
  <div class="tracking-container">
    <!-- Brand Header -->
    <header class="brand-header">
      <a href="https://kotty.in" class="brand-link">KOTTY</a>
      <p class="page-title">Return Tracking</p>
    </header>

    <!-- Main Tracking Card -->
    <article class="card">
      <div class="card-header-custom">
        <div class="return-id">Return ID: <%= returnData.return_id %></div>
        <div class="order-info">
          Order <%= returnData.shopify_order_name || '#' + returnData.id %>
          <% if (returnData.original_total) { %>
          | <%= formatCurrency(returnData.original_total) %>
          <% } %>
        </div>
        <span class="status-badge status-<%= returnData.status %>">
          <%= statusConfig.label || returnData.status.replace(/_/g, ' ').toUpperCase() %>
        </span>
      </div>

      <div class="card-body">
        <!-- Progress Tracker -->
        <%
          const stages = [
            { key: 'submitted', label: 'Submitted', statuses: ['pending_review'] },
            { key: 'approved', label: 'Approved', statuses: ['approved', 'pickup_scheduled'] },
            { key: 'picked', label: 'Picked Up', statuses: ['picked_up', 'in_transit'] },
            { key: 'received', label: 'Received', statuses: ['received', 'refund_pending', 'refund_processing'] },
            { key: 'refunded', label: 'Refunded', statuses: ['refunded'] }
          ];

          const statusOrder = ['pending_review', 'approved', 'pickup_scheduled', 'picked_up', 'in_transit', 'received', 'refund_pending', 'refund_processing', 'refunded'];
          const currentIndex = statusOrder.indexOf(returnData.status);

          function getStageState(stage) {
            const stageStatuses = stage.statuses;
            for (let s of stageStatuses) {
              if (returnData.status === s) return 'active';
              if (statusOrder.indexOf(s) < currentIndex) return 'completed';
            }
            return 'pending';
          }
        %>

        <div class="progress-tracker">
          <% stages.forEach((stage, idx) => {
            const state = getStageState(stage);
          %>
          <div class="progress-step">
            <div class="step-circle <%= state %>">
              <% if (state === 'completed') { %>
                <i class="bi bi-check"></i>
              <% } else { %>
                <%= idx + 1 %>
              <% } %>
            </div>
            <div class="step-label <%= state %>"><%= stage.label %></div>
          </div>
          <% }) %>
        </div>

        <!-- Timeline -->
        <div class="timeline">
          <% if (returnData.refunded_at) { %>
          <div class="timeline-item">
            <div class="timeline-icon completed"><i class="bi bi-check-lg"></i></div>
            <div class="timeline-content">
              <h4>Refund Processed</h4>
              <p>Your refund has been processed successfully</p>
              <span class="date"><%= formatDate(returnData.refunded_at, 'long') %></span>
            </div>
          </div>
          <% } else if (['refund_pending', 'refund_processing'].includes(returnData.status)) { %>
          <div class="timeline-item">
            <div class="timeline-icon active"><i class="bi bi-hourglass-split"></i></div>
            <div class="timeline-content">
              <h4>Refund Processing</h4>
              <p>Your refund is being processed</p>
            </div>
          </div>
          <% } %>

          <% if (returnData.received_at) { %>
          <div class="timeline-item">
            <div class="timeline-icon completed"><i class="bi bi-check-lg"></i></div>
            <div class="timeline-content">
              <h4>Package Received</h4>
              <p>We've received your return at our warehouse</p>
              <span class="date"><%= formatDate(returnData.received_at, 'long') %></span>
            </div>
          </div>
          <% } %>

          <% if (returnData.picked_at) { %>
          <div class="timeline-item">
            <div class="timeline-icon completed"><i class="bi bi-check-lg"></i></div>
            <div class="timeline-content">
              <h4>Picked Up</h4>
              <p>
                <% if (returnData.courier_name) { %>
                Picked up by <%= returnData.courier_name %>
                <% } else { %>
                Package picked up by courier
                <% } %>
              </p>
              <span class="date"><%= formatDate(returnData.picked_at, 'long') %></span>
            </div>
          </div>
          <% } else if (['pickup_scheduled'].includes(returnData.status)) { %>
          <div class="timeline-item">
            <div class="timeline-icon active"><i class="bi bi-truck"></i></div>
            <div class="timeline-content">
              <h4>Pickup Scheduled</h4>
              <p>Courier will pick up your package soon</p>
            </div>
          </div>
          <% } %>

          <% if (returnData.approved_at) { %>
          <div class="timeline-item">
            <div class="timeline-icon completed"><i class="bi bi-check-lg"></i></div>
            <div class="timeline-content">
              <h4>Return Approved</h4>
              <p>Your return request has been approved</p>
              <span class="date"><%= formatDate(returnData.approved_at, 'long') %></span>
            </div>
          </div>
          <% } else if (returnData.status === 'pending_review') { %>
          <div class="timeline-item">
            <div class="timeline-icon active"><i class="bi bi-hourglass-split"></i></div>
            <div class="timeline-content">
              <h4>Under Review</h4>
              <p>We're reviewing your return request</p>
            </div>
          </div>
          <% } %>

          <div class="timeline-item">
            <div class="timeline-icon completed"><i class="bi bi-check-lg"></i></div>
            <div class="timeline-content">
              <h4>Return Requested</h4>
              <p>You submitted a return request</p>
              <span class="date"><%= formatDate(returnData.requested_at, 'long') %></span>
            </div>
          </div>
        </div>

        <!-- AWB Tracking -->
        <% if (returnData.awb_number) { %>
        <div class="awb-box">
          <div class="awb-label">Tracking Number</div>
          <div class="awb-number"><%= returnData.awb_number %></div>
          <% if (returnData.courier_name) { %>
          <div class="courier-name">via <%= returnData.courier_name %></div>
          <% } %>
          <%
            let trackingUrl = returnData.courier_tracking_url;
            if (!trackingUrl && returnData.courier_name) {
              const courier = returnData.courier_name.toLowerCase();
              if (courier.includes('delhivery')) {
                trackingUrl = `https://www.delhivery.com/track/package/${returnData.awb_number}`;
              } else if (courier.includes('bluedart')) {
                trackingUrl = `https://www.bluedart.com/tracking/${returnData.awb_number}`;
              } else if (courier.includes('xpressbees')) {
                trackingUrl = `https://www.xpressbees.com/track/${returnData.awb_number}`;
              } else if (courier.includes('dtdc')) {
                trackingUrl = `https://www.dtdc.in/tracking/${returnData.awb_number}`;
              }
            }
          %>
          <% if (trackingUrl) { %>
          <a href="<%= trackingUrl %>" target="_blank" rel="noopener noreferrer" class="track-btn">
            <i class="bi bi-box-arrow-up-right"></i>
            Track on <%= returnData.courier_name || 'Courier' %>
          </a>
          <% } %>
        </div>
        <% } %>

        <!-- Refund Info -->
        <% if (returnData.refund_amount) { %>
        <div class="refund-box">
          <div class="refund-label">Refund Amount</div>
          <div class="refund-amount"><%= formatCurrency(returnData.refund_amount) %></div>
          <div class="refund-method">
            <% if (returnData.order_type === 'prepaid') { %>
            To be refunded to your original payment method
            <% } else { %>
            To be refunded via UPI/Bank Transfer
            <% } %>
          </div>
        </div>
        <% } %>
      </div>
    </article>

    <!-- Rejected/Cancelled Status -->
    <% if (['rejected', 'cancelled'].includes(returnData.status)) { %>
    <article class="card">
      <div class="status-message-card">
        <div class="status-icon-wrapper rejected">
          <i class="bi bi-x-lg"></i>
        </div>
        <h4>Return <%= returnData.status === 'rejected' ? 'Rejected' : 'Cancelled' %></h4>
        <p>
          <% if (returnData.status === 'rejected') { %>
          Unfortunately, your return request was not approved. Please contact support for more details.
          <% } else { %>
          This return request has been cancelled.
          <% } %>
        </p>
      </div>
    </article>
    <% } %>

    <!-- Help Box -->
    <aside class="help-box">
      <p>Need help with your return?</p>
      <p><a href="mailto:support@kotty.in">support@kotty.in</a></p>
    </aside>

    <!-- Footer Branding -->
    <footer class="footer-brand">
      <span>Shop more at <a href="https://kotty.in">kotty.in</a></span>
    </footer>
  </div>
</body>
</html>
