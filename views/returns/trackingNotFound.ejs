<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Return Not Found - Kotty</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">

  <style>
    :root {
      /* Brand Colors */
      --charcoal: #1a1a1a;
      --cream: #faf8f5;
      --cream-dark: #f0ebe3;
      --cream-darker: #e5dfd4;
      --terracotta: #c45c3a;
      --terracotta-light: #d4826a;
      --terracotta-dark: #a34a2d;
      --terracotta-bg: rgba(196, 92, 58, 0.08);

      /* Text Colors */
      --text-primary: #1a1a1a;
      --text-secondary: #5a5650;
      --text-muted: #a8a49a;

      /* Borders & Shadows */
      --border-light: #e8e6e1;
      --border-medium: #d4d1c9;
      --shadow-sm: 0 2px 4px rgba(26, 26, 26, 0.06);
      --shadow-md: 0 4px 12px rgba(26, 26, 26, 0.08);

      /* Border Radius */
      --radius-md: 6px;
      --radius-lg: 8px;
      --radius-xl: 12px;
      --radius-2xl: 16px;
      --radius-full: 9999px;

      /* Typography */
      --font-display: 'DM Serif Display', Georgia, serif;
      --font-body: 'Outfit', -apple-system, BlinkMacSystemFont, sans-serif;

      /* Transitions */
      --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
      --transition-fast: 150ms var(--ease-out);
      --transition-base: 200ms var(--ease-out);
    }

    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    body {
      font-family: var(--font-body);
      background-color: var(--cream);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 24px;
      color: var(--text-primary);
    }

    .brand-header {
      margin-bottom: 32px;
      text-align: center;
    }

    .brand-logo {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      color: var(--charcoal);
    }

    .brand-logo:hover {
      text-decoration: none;
      color: var(--charcoal);
    }

    .brand-icon {
      width: 40px;
      height: 40px;
      background: var(--terracotta);
      border-radius: var(--radius-md);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-display);
      font-size: 20px;
      color: white;
    }

    .brand-text {
      font-family: var(--font-display);
      font-size: 26px;
      letter-spacing: -0.01em;
    }

    .not-found-card {
      max-width: 460px;
      width: 100%;
      background: #ffffff;
      border-radius: var(--radius-2xl);
      padding: 44px 36px;
      box-shadow: var(--shadow-md);
      text-align: center;
      border: 1px solid var(--border-light);
    }

    .not-found-icon {
      width: 88px;
      height: 88px;
      background: var(--cream);
      border-radius: var(--radius-full);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 24px;
      border: 2px solid var(--cream-dark);
    }

    .not-found-icon i {
      font-size: 36px;
      color: var(--terracotta);
    }

    .not-found-title {
      font-family: var(--font-display);
      font-size: 28px;
      font-weight: 400;
      color: var(--text-primary);
      margin-bottom: 10px;
      letter-spacing: -0.02em;
    }

    .not-found-message {
      font-size: 15px;
      color: var(--text-secondary);
      margin-bottom: 28px;
      line-height: 1.65;
      font-weight: 400;
    }

    .search-box {
      background: var(--cream);
      border-radius: var(--radius-xl);
      padding: 20px;
      margin-bottom: 20px;
      border: 1px solid var(--cream-dark);
    }

    .search-box input {
      width: 100%;
      padding: 12px 14px;
      border: 1px solid var(--border-light);
      border-radius: var(--radius-md);
      font-size: 15px;
      font-family: var(--font-body);
      margin-bottom: 12px;
      background: #ffffff;
      color: var(--text-primary);
      transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    }

    .search-box input::placeholder {
      color: var(--text-muted);
    }

    .search-box input:hover {
      border-color: var(--border-medium);
    }

    .search-box input:focus {
      outline: none;
      border-color: var(--terracotta);
      box-shadow: 0 0 0 3px var(--terracotta-bg);
    }

    .search-box button {
      width: 100%;
      padding: 12px 16px;
      background: var(--terracotta);
      color: #ffffff;
      border: none;
      border-radius: var(--radius-md);
      font-weight: 500;
      font-family: var(--font-body);
      font-size: 15px;
      cursor: pointer;
      transition: background-color var(--transition-fast), transform var(--transition-fast), box-shadow var(--transition-fast);
    }

    .search-box button:hover {
      background: var(--terracotta-dark);
      box-shadow: var(--shadow-sm);
    }

    .search-box button:active {
      transform: scale(0.98);
    }

    .search-box button:focus {
      outline: none;
      box-shadow: 0 0 0 3px var(--terracotta-bg);
    }

    .home-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 24px;
      background: var(--cream);
      color: var(--text-primary);
      text-decoration: none;
      border-radius: var(--radius-md);
      font-weight: 500;
      font-size: 14px;
      transition: background-color var(--transition-fast), border-color var(--transition-fast);
      border: 1px solid var(--cream-dark);
    }

    .home-link:hover {
      background: var(--cream-dark);
      border-color: var(--cream-darker);
      color: var(--text-primary);
      text-decoration: none;
    }

    .home-link i {
      font-size: 16px;
    }

    .contact-section {
      margin-top: 24px;
      padding-top: 20px;
      border-top: 1px solid var(--border-light);
    }

    .contact-section p {
      margin: 0;
      color: var(--text-secondary);
      font-size: 14px;
    }

    .contact-section a {
      color: var(--terracotta);
      font-weight: 500;
      text-decoration: none;
      transition: color var(--transition-fast);
    }

    .contact-section a:hover {
      color: var(--terracotta-dark);
      text-decoration: underline;
    }

    @media (max-width: 480px) {
      body {
        padding: 20px 16px;
      }

      .brand-header {
        margin-bottom: 24px;
      }

      .brand-icon {
        width: 36px;
        height: 36px;
        font-size: 18px;
      }

      .brand-text {
        font-size: 22px;
      }

      .not-found-card {
        padding: 32px 24px;
      }

      .not-found-icon {
        width: 72px;
        height: 72px;
        margin-bottom: 20px;
      }

      .not-found-icon i {
        font-size: 30px;
      }

      .not-found-title {
        font-size: 24px;
      }

      .not-found-message {
        font-size: 14px;
        margin-bottom: 24px;
      }

      .search-box {
        padding: 16px;
      }

      .search-box input,
      .search-box button {
        padding: 11px 12px;
        font-size: 14px;
      }
    }
  </style>
</head>
<body>
  <header class="brand-header">
    <a href="https://kotty.in" class="brand-logo">
      <span class="brand-icon">K</span>
      <span class="brand-text">Kotty</span>
    </a>
  </header>

  <main class="not-found-card">
    <div class="not-found-icon">
      <i class="bi bi-search"></i>
    </div>

    <h1 class="not-found-title">Return Not Found</h1>

    <p class="not-found-message">
      We couldn't find a return with this ID. Please check the ID and try again.
    </p>

    <div class="search-box">
      <form action="/returns/track" method="GET" id="searchForm">
        <input type="text" name="id" placeholder="Enter Return ID (e.g., RET-20260125-AB12)"
               pattern="RET-\d{8}-[A-Z0-9]{4}" title="Format: RET-YYYYMMDD-XXXX">
        <button type="submit">Track Return</button>
      </form>
    </div>

    <a href="https://kotty.in" class="home-link">
      <i class="bi bi-house"></i>
      Go to Homepage
    </a>

    <div class="contact-section">
      <p>Need help? Contact us at <a href="mailto:support@kotty.in">support@kotty.in</a></p>
    </div>
  </main>

  <script>
    document.getElementById('searchForm').addEventListener('submit', function(e) {
      e.preventDefault();
      const id = this.querySelector('input[name="id"]').value.trim();
      if (id) {
        window.location.href = '/returns/track/' + encodeURIComponent(id);
      }
    });
  </script>
</body>
</html>
