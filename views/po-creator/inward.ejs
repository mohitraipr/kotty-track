<%- include('../partials/header', { pageTitle: 'Inward Entry' }) %>
<%- include('../partials/navbar', { dashboardUrl: '/po-creator/dashboard' }) %>

<main class="main-content" style="margin-left: 0;">
  <div class="container-fluid" style="max-width: 1400px; margin: 0 auto;">
    <!-- Page Header -->
    <div class="page-header">
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
          <h1 class="page-title"><i class="bi bi-box-arrow-in-down me-2"></i>Inward Entry</h1>
          <p class="page-subtitle">Create new carton entries with multiple SKUs</p>
        </div>
        <a href="/po-creator/dashboard" class="btn btn-secondary">
          <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
      </div>
    </div>

    <%- include('../partials/flashMessages') %>

    <!-- Success Message -->
    <div class="alert alert-success" id="successMsg" style="display: none;">
      <i class="bi bi-check-circle-fill me-2"></i>
      <span id="successText"></span>
    </div>

    <!-- Bulk Upload Card -->
    <div class="card mb-4" id="bulk-upload">
      <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-4">
          <div>
            <h5 class="card-title mb-1"><i class="bi bi-upload me-2" style="color: var(--terracotta);"></i>Bulk Upload via Excel</h5>
            <p class="text-muted mb-0" style="font-size: var(--text-sm);">Download the template, fill in carton + SKU rows, and upload to create entries in bulk.</p>
          </div>
          <div class="d-flex flex-wrap gap-3 align-items-center">
            <a class="btn btn-outline" href="/po-creator/inward/template">
              <i class="bi bi-file-earmark-arrow-down"></i> Download Template
            </a>
            <form action="/po-creator/inward/bulk-upload" method="POST" enctype="multipart/form-data" class="d-flex gap-2 align-items-center">
              <input type="file" name="inwardFile" class="form-control" style="min-width: 200px;" accept=".xlsx" required>
              <button type="submit" class="btn btn-success">
                <i class="bi bi-cloud-arrow-up"></i> Upload
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- Inward Form -->
    <form id="inwardForm">
      <div id="cartonsContainer">
        <!-- Cartons will be added here dynamically -->
      </div>

      <div class="text-center mb-4">
        <button type="button" class="btn btn-success btn-lg" onclick="addCartonSection()">
          <i class="bi bi-plus-circle"></i> Add Another Carton
        </button>
      </div>

      <div class="text-center">
        <button type="submit" class="btn btn-primary btn-lg" style="min-width: 200px;">
          <i class="bi bi-check-circle"></i> Submit All Cartons
        </button>
      </div>
    </form>
  </div>
</main>

<style>
  /* Inward Entry Page Specific Styles */
  .carton-section {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 24px;
    margin-bottom: 24px;
    box-shadow: var(--shadow-xs);
  }

  .carton-header {
    background: var(--terracotta);
    color: white;
    padding: 14px 20px;
    border-radius: var(--radius-md);
    margin-bottom: 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .carton-header h5 {
    font-family: var(--font-display);
    margin: 0;
    font-size: var(--text-lg);
  }

  .sku-row {
    background: var(--cream);
    padding: 20px;
    border-radius: var(--radius-md);
    margin-bottom: 16px;
    border: 1px solid var(--border-light);
    position: relative;
  }

  .sku-row-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border-light);
  }

  .sku-row-header strong {
    font-family: var(--font-display);
    font-size: var(--text-base);
    color: var(--charcoal);
  }

  .sku-preview {
    background: var(--terracotta);
    color: white;
    padding: 10px 16px;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: var(--text-base);
    display: inline-block;
    margin-top: 8px;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
  }

  .sku-details-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
    padding: 12px 16px;
    background: var(--cream-dark);
    border-radius: var(--radius-md);
  }

  .sku-details-header h6 {
    font-family: var(--font-display);
    margin: 0;
    color: var(--charcoal);
  }

  .remove-btn {
    background: var(--danger);
    color: white;
    border: none;
    padding: 8px 14px;
    border-radius: var(--radius-md);
    cursor: pointer;
    font-size: var(--text-sm);
    font-family: var(--font-body);
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: all var(--transition-fast);
  }

  .remove-btn:hover {
    background: #a32b1a;
    transform: translateY(-1px);
  }

  .add-sku-btn {
    background: var(--success);
    color: white;
    border: none;
    padding: 8px 16px;
    border-radius: var(--radius-md);
    cursor: pointer;
    font-size: var(--text-sm);
    font-family: var(--font-body);
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: all var(--transition-fast);
  }

  .add-sku-btn:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  /* Override form-control for this page */
  .form-control, .form-select {
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    padding: 10px 14px;
    font-family: var(--font-body);
    font-size: var(--text-base);
    transition: all var(--transition-fast);
  }

  .form-control:focus, .form-select:focus {
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px var(--terracotta-bg);
    outline: none;
  }

  .form-label {
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 6px;
    font-size: var(--text-sm);
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .carton-section {
      padding: 16px;
    }

    .carton-header {
      flex-direction: column;
      gap: 12px;
      text-align: center;
    }

    .sku-row {
      padding: 16px;
    }

    .bulk-upload-actions {
      flex-direction: column;
      width: 100%;
    }

    .bulk-upload-actions form {
      width: 100%;
      flex-direction: column;
    }
  }
</style>

<script>
  const brandCodes = <%- JSON.stringify(brandCodes.map(b => b.code)) %>;
  const categories = <%- JSON.stringify(categories.map(c => c.name)) %>;
  const panelNames = <%- JSON.stringify(panelNames) %>;
  let cartonCounter = 0;
  let skuCounters = {};

  function generateSKUPreview(cartonId, skuId) {
    const brandCode = document.getElementById(`brandCode_${cartonId}_${skuId}`).value;
    const category = document.getElementById(`category_${cartonId}_${skuId}`).value;
    const skuCode = document.getElementById(`skuCode_${cartonId}_${skuId}`).value;

    let preview = '';
    if (brandCode && category && skuCode) {
      preview = brandCode + category + skuCode;
    } else {
      preview = 'SKU Preview';
    }

    document.getElementById(`skuPreview_${cartonId}_${skuId}`).textContent = preview;
  }

  function createSelectElement(id, options, onchangeHandler) {
    const select = document.createElement('select');
    select.className = 'form-select';
    select.id = id;
    select.required = true;
    if (onchangeHandler) {
      select.onchange = onchangeHandler;
    }

    const defaultOption = document.createElement('option');
    defaultOption.value = '';
    defaultOption.textContent = 'Select';
    select.appendChild(defaultOption);

    options.forEach(opt => {
      const option = document.createElement('option');
      option.value = opt;
      option.textContent = opt;
      select.appendChild(option);
    });

    return select;
  }

  function createInputElement(type, id, additionalAttrs) {
    const input = document.createElement('input');
    input.type = type;
    input.className = 'form-control';
    input.id = id;
    input.required = true;
    if (additionalAttrs) {
      Object.keys(additionalAttrs).forEach(key => {
        input[key] = additionalAttrs[key];
      });
    }
    return input;
  }

  function addSKURow(cartonId) {
    if (!skuCounters[cartonId]) {
      skuCounters[cartonId] = 0;
    }
    skuCounters[cartonId]++;
    const skuId = skuCounters[cartonId];

    const skuRow = document.createElement('div');
    skuRow.className = 'sku-row';
    skuRow.id = `skuRow_${cartonId}_${skuId}`;

    // Create header
    const header = document.createElement('div');
    header.className = 'sku-row-header';

    const headerTitle = document.createElement('strong');
    headerTitle.textContent = `SKU #${skuId}`;

    const removeBtn = document.createElement('button');
    removeBtn.type = 'button';
    removeBtn.className = 'remove-btn';
    removeBtn.onclick = () => removeSKURow(cartonId, skuId);
    removeBtn.innerHTML = '<i class="bi bi-trash"></i> Remove';

    header.appendChild(headerTitle);
    header.appendChild(removeBtn);
    skuRow.appendChild(header);

    // Create row container
    const rowContainer = document.createElement('div');
    rowContainer.className = 'row';

    // Brand Code
    const brandCol = document.createElement('div');
    brandCol.className = 'col-md-2 mb-3';
    const brandLabel = document.createElement('label');
    brandLabel.className = 'form-label';
    brandLabel.textContent = 'Brand Code *';
    const brandSelect = createSelectElement(
      `brandCode_${cartonId}_${skuId}`,
      brandCodes,
      () => generateSKUPreview(cartonId, skuId)
    );
    brandCol.appendChild(brandLabel);
    brandCol.appendChild(brandSelect);
    rowContainer.appendChild(brandCol);

    // Category
    const catCol = document.createElement('div');
    catCol.className = 'col-md-3 mb-3';
    const catLabel = document.createElement('label');
    catLabel.className = 'form-label';
    catLabel.textContent = 'Category *';
    const catSelect = createSelectElement(
      `category_${cartonId}_${skuId}`,
      categories,
      () => generateSKUPreview(cartonId, skuId)
    );
    catCol.appendChild(catLabel);
    catCol.appendChild(catSelect);
    rowContainer.appendChild(catCol);

    // SKU Code
    const skuCodeCol = document.createElement('div');
    skuCodeCol.className = 'col-md-2 mb-3';
    const skuCodeLabel = document.createElement('label');
    skuCodeLabel.className = 'form-label';
    skuCodeLabel.textContent = 'SKU Code *';
    const skuCodeInput = createInputElement('text', `skuCode_${cartonId}_${skuId}`);
    skuCodeInput.onkeyup = () => generateSKUPreview(cartonId, skuId);
    skuCodeCol.appendChild(skuCodeLabel);
    skuCodeCol.appendChild(skuCodeInput);
    rowContainer.appendChild(skuCodeCol);

    // Size
    const sizeCol = document.createElement('div');
    sizeCol.className = 'col-md-2 mb-3';
    const sizeLabel = document.createElement('label');
    sizeLabel.className = 'form-label';
    sizeLabel.textContent = 'Size *';
    const sizeInput = createInputElement('text', `size_${cartonId}_${skuId}`);
    sizeCol.appendChild(sizeLabel);
    sizeCol.appendChild(sizeInput);
    rowContainer.appendChild(sizeCol);

    // Quantity
    const qtyCol = document.createElement('div');
    qtyCol.className = 'col-md-2 mb-3';
    const qtyLabel = document.createElement('label');
    qtyLabel.className = 'form-label';
    qtyLabel.textContent = 'Quantity *';
    const qtyInput = createInputElement('number', `quantity_${cartonId}_${skuId}`, { min: 1 });
    qtyCol.appendChild(qtyLabel);
    qtyCol.appendChild(qtyInput);
    rowContainer.appendChild(qtyCol);

    // SKU Preview
    const previewCol = document.createElement('div');
    previewCol.className = 'col-md-12';
    const previewLabel = document.createElement('strong');
    previewLabel.style.color = 'var(--text-secondary)';
    previewLabel.textContent = 'Full SKU: ';
    const previewSpan = document.createElement('span');
    previewSpan.className = 'sku-preview';
    previewSpan.id = `skuPreview_${cartonId}_${skuId}`;
    previewSpan.textContent = 'SKU Preview';
    previewCol.appendChild(previewLabel);
    previewCol.appendChild(previewSpan);
    rowContainer.appendChild(previewCol);

    skuRow.appendChild(rowContainer);
    document.getElementById(`skuContainer_${cartonId}`).appendChild(skuRow);
  }

  function removeSKURow(cartonId, skuId) {
    const row = document.getElementById(`skuRow_${cartonId}_${skuId}`);
    if (row) {
      row.remove();
    }
  }

  function addCartonSection() {
    cartonCounter++;
    const cartonId = cartonCounter;

    const cartonSection = document.createElement('div');
    cartonSection.className = 'carton-section';
    cartonSection.id = `cartonSection_${cartonId}`;

    // Create carton header
    const header = document.createElement('div');
    header.className = 'carton-header';

    const headerTitle = document.createElement('h5');
    headerTitle.innerHTML = '<i class="bi bi-box-seam me-2"></i>Carton #' + cartonId;

    const removeBtn = document.createElement('button');
    removeBtn.type = 'button';
    removeBtn.className = 'remove-btn';
    removeBtn.onclick = () => removeCartonSection(cartonId);
    removeBtn.innerHTML = '<i class="bi bi-trash"></i> Remove Carton';

    header.appendChild(headerTitle);
    header.appendChild(removeBtn);
    cartonSection.appendChild(header);

    // Create main fields row
    const fieldsRow = document.createElement('div');
    fieldsRow.className = 'row mb-4';

    // Panel Name
    const panelCol = document.createElement('div');
    panelCol.className = 'col-md-4 mb-3';
    const panelLabel = document.createElement('label');
    panelLabel.className = 'form-label';
    panelLabel.textContent = 'Panel Name *';
    const panelSelect = document.createElement('select');
    panelSelect.className = 'form-select';
    panelSelect.id = `panelName_${cartonId}`;
    panelSelect.required = true;
    const defaultPanelOpt = document.createElement('option');
    defaultPanelOpt.value = '';
    defaultPanelOpt.textContent = 'Select Panel';
    panelSelect.appendChild(defaultPanelOpt);
    panelNames.forEach(panel => {
      const opt = document.createElement('option');
      opt.value = panel.name;
      opt.textContent = panel.name;
      panelSelect.appendChild(opt);
    });
    const panelSmall = document.createElement('small');
    panelSmall.className = 'text-muted';
    panelSmall.textContent = 'Carton number will be auto-generated based on panel';
    panelCol.appendChild(panelLabel);
    panelCol.appendChild(panelSelect);
    panelCol.appendChild(panelSmall);
    fieldsRow.appendChild(panelCol);

    // Date of Packing
    const dateCol = document.createElement('div');
    dateCol.className = 'col-md-4 mb-3';
    const dateLabel = document.createElement('label');
    dateLabel.className = 'form-label';
    dateLabel.textContent = 'Date of Packing *';
    const dateInput = createInputElement('date', `dateOfPacking_${cartonId}`);
    dateCol.appendChild(dateLabel);
    dateCol.appendChild(dateInput);
    fieldsRow.appendChild(dateCol);

    // Packed By
    const packedCol = document.createElement('div');
    packedCol.className = 'col-md-4 mb-3';
    const packedLabel = document.createElement('label');
    packedLabel.className = 'form-label';
    packedLabel.textContent = 'Packed By *';
    const packedInput = createInputElement('text', `packedBy_${cartonId}`);
    packedCol.appendChild(packedLabel);
    packedCol.appendChild(packedInput);
    fieldsRow.appendChild(packedCol);

    cartonSection.appendChild(fieldsRow);

    // SKU Details section
    const skuSection = document.createElement('div');
    skuSection.className = 'mb-3';

    const skuHeader = document.createElement('div');
    skuHeader.className = 'sku-details-header';

    const skuHeaderTitle = document.createElement('h6');
    skuHeaderTitle.innerHTML = '<i class="bi bi-tags me-2"></i>SKU Details';

    const addSkuBtn = document.createElement('button');
    addSkuBtn.type = 'button';
    addSkuBtn.className = 'add-sku-btn';
    addSkuBtn.onclick = () => addSKURow(cartonId);
    addSkuBtn.innerHTML = '<i class="bi bi-plus"></i> Add SKU';

    skuHeader.appendChild(skuHeaderTitle);
    skuHeader.appendChild(addSkuBtn);
    skuSection.appendChild(skuHeader);

    const skuContainer = document.createElement('div');
    skuContainer.id = `skuContainer_${cartonId}`;
    skuSection.appendChild(skuContainer);

    cartonSection.appendChild(skuSection);

    document.getElementById('cartonsContainer').appendChild(cartonSection);
    addSKURow(cartonId); // Add first SKU row automatically
  }

  function removeCartonSection(cartonId) {
    const section = document.getElementById(`cartonSection_${cartonId}`);
    if (section) {
      section.remove();
    }
  }

  // Add first carton on page load
  window.addEventListener('DOMContentLoaded', () => {
    addCartonSection();
  });

  // Form submission
  document.getElementById('inwardForm').addEventListener('submit', async (e) => {
    e.preventDefault();

    const cartons = [];
    const cartonSections = document.querySelectorAll('.carton-section');

    cartonSections.forEach(section => {
      const cartonId = section.id.split('_')[1];
      const panelName = document.getElementById(`panelName_${cartonId}`).value;
      const dateOfPacking = document.getElementById(`dateOfPacking_${cartonId}`).value;
      const packedBy = document.getElementById(`packedBy_${cartonId}`).value;

      const skus = [];
      const skuRows = section.querySelectorAll('.sku-row');

      skuRows.forEach(row => {
        const skuId = row.id.split('_')[2];
        const brandCode = document.getElementById(`brandCode_${cartonId}_${skuId}`).value;
        const category = document.getElementById(`category_${cartonId}_${skuId}`).value;
        const skuCode = document.getElementById(`skuCode_${cartonId}_${skuId}`).value;
        const size = document.getElementById(`size_${cartonId}_${skuId}`).value;
        const quantity = document.getElementById(`quantity_${cartonId}_${skuId}`).value;

        if (brandCode && category && skuCode && size && quantity) {
          skus.push({
            brand_code: brandCode,
            category: category,
            sku_code: skuCode,
            size: size,
            quantity: parseInt(quantity)
          });
        }
      });

      if (panelName && dateOfPacking && packedBy && skus.length > 0) {
        cartons.push({
          panel_name: panelName,
          date_of_packing: dateOfPacking,
          packed_by: packedBy,
          skus: skus
        });
      }
    });

    if (cartons.length === 0) {
      alert('Please add at least one carton with SKUs');
      return;
    }

    try {
      let successCount = 0;
      let failedCount = 0;

      for (const carton of cartons) {
        const response = await fetch('/po-creator/api/inward', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(carton)
        });

        if (response.ok) {
          successCount++;
        } else {
          failedCount++;
          const data = await response.json();
          console.error('Failed to save carton:', carton.carton_number, data.error);
        }
      }

      if (successCount > 0) {
        document.getElementById('successMsg').style.display = 'flex';
        document.getElementById('successText').textContent =
          `Successfully saved ${successCount} carton(s)!${failedCount > 0 ? ` ${failedCount} failed.` : ''}`;

        setTimeout(() => {
          window.location.href = '/po-creator/inward/view';
        }, 2000);
      } else {
        alert('Failed to save any cartons. Please check the data and try again.');
      }
    } catch (error) {
      console.error('Error:', error);
      alert('Error submitting form');
    }
  });
</script>

<%- include('../partials/footer') %>
