<%- include('../partials/header', { pageTitle: 'Manage Categories' }) %>
<%- include('../partials/navbar', { user: user, dashboardUrl: '/po-creator/operator/dashboard' }) %>

<style>
  /* Manage Categories Page Styles */
  .categories-container {
    padding-top: calc(var(--navbar-height) + 28px);
    padding-bottom: 40px;
    min-height: 100vh;
  }

  /* Page Header */
  .page-header {
    margin-bottom: 28px;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    color: var(--text-primary);
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .page-title i {
    color: var(--terracotta);
  }

  .page-subtitle {
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  /* Back Button */
  .btn-back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-secondary);
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .btn-back:hover {
    color: var(--text-primary);
    border-color: var(--border-medium);
    background: var(--gray-50);
  }

  /* Form Card */
  .form-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 24px;
    margin-bottom: 28px;
  }

  .form-card-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--text-primary);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .form-card-title i {
    color: var(--terracotta);
  }

  .form-row {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    align-items: flex-end;
  }

  .form-group {
    flex: 1;
    min-width: 200px;
  }

  .form-group.small {
    flex: 0 0 auto;
  }

  .form-label {
    display: block;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 8px;
  }

  .form-control {
    width: 100%;
    padding: 10px 14px;
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--text-primary);
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }

  .form-control::placeholder {
    color: var(--text-muted);
  }

  .form-control:hover {
    border-color: var(--border-medium);
  }

  .form-control:focus {
    outline: none;
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px var(--terracotta-bg);
  }

  .btn-add {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 10px 20px;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: white;
    background: var(--terracotta);
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--transition-fast);
    white-space: nowrap;
  }

  .btn-add:hover {
    background: var(--terracotta-dark);
    transform: translateY(-1px);
  }

  .btn-add:active {
    transform: translateY(0);
  }

  /* Table Container */
  .table-container {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .table-header {
    padding: 16px 20px;
    background: var(--gray-50);
    border-bottom: 1px solid var(--border-light);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .table-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .table-title i {
    color: var(--terracotta);
  }

  .category-count {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    background: var(--cream-dark);
    padding: 4px 12px;
    border-radius: var(--radius-full);
  }

  .categories-table {
    width: 100%;
    border-collapse: collapse;
  }

  .categories-table th {
    padding: 14px 20px;
    text-align: left;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    background: var(--gray-50);
    border-bottom: 1px solid var(--border-light);
  }

  .categories-table td {
    padding: 14px 20px;
    font-size: var(--text-sm);
    color: var(--text-primary);
    border-bottom: 1px solid var(--border-light);
    vertical-align: middle;
  }

  .categories-table tbody tr:last-child td {
    border-bottom: none;
  }

  .categories-table tbody tr:hover {
    background: var(--gray-50);
  }

  .category-name {
    font-weight: 600;
    color: var(--text-primary);
  }

  .category-description {
    color: var(--text-secondary);
  }

  /* Status Badge */
  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    font-size: var(--text-xs);
    font-weight: 500;
    border-radius: var(--radius-full);
  }

  .status-badge.active {
    background: var(--success-light);
    color: var(--success);
  }

  .status-badge.inactive {
    background: var(--gray-200);
    color: var(--text-secondary);
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: 60px 20px;
    color: var(--text-secondary);
  }

  .empty-state i {
    font-size: 3rem;
    color: var(--gray-300);
    margin-bottom: 16px;
  }

  .empty-state p {
    font-size: var(--text-sm);
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .page-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }

    .form-row {
      flex-direction: column;
    }

    .form-group {
      width: 100%;
    }

    .btn-add {
      width: 100%;
    }

    .table-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }

    .categories-table th,
    .categories-table td {
      padding: 12px 16px;
    }
  }
</style>

<div class="container categories-container">
  <!-- Page Header -->
  <div class="d-flex justify-content-between align-items-center page-header">
    <div>
      <h1 class="page-title">
        <i class="bi bi-list-check"></i>
        Manage Categories
      </h1>
      <p class="page-subtitle">Add and manage product categories for SKU generation</p>
    </div>
    <a href="/po-creator/operator/dashboard" class="btn-back">
      <i class="bi bi-arrow-left"></i>
      Back to Dashboard
    </a>
  </div>

  <!-- Add Category Form -->
  <div class="form-card">
    <h3 class="form-card-title">
      <i class="bi bi-plus-circle"></i>
      Add New Category
    </h3>
    <form id="addCategoryForm">
      <div class="form-row">
        <div class="form-group">
          <label for="name" class="form-label">Category Name</label>
          <input type="text" class="form-control" id="name" placeholder="e.g., MENSJEANS" required>
        </div>
        <div class="form-group">
          <label for="description" class="form-label">Description</label>
          <input type="text" class="form-control" id="description" placeholder="Optional description">
        </div>
        <div class="form-group small">
          <button type="submit" class="btn-add">
            <i class="bi bi-plus-lg"></i>
            Add Category
          </button>
        </div>
      </div>
    </form>
  </div>

  <!-- Categories Table -->
  <div class="table-container">
    <div class="table-header">
      <h3 class="table-title">
        <i class="bi bi-grid-3x3"></i>
        All Categories
      </h3>
      <span class="category-count"><%= categories.length %> categories</span>
    </div>
    <% if (categories.length > 0) { %>
      <table class="categories-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Description</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% categories.forEach(cat => { %>
            <tr>
              <td>
                <span class="category-name"><%= cat.name %></span>
              </td>
              <td>
                <span class="category-description"><%= cat.description || '-' %></span>
              </td>
              <td>
                <span class="status-badge <%= cat.is_active ? 'active' : 'inactive' %>">
                  <i class="bi bi-<%= cat.is_active ? 'check-circle' : 'x-circle' %>"></i>
                  <%= cat.is_active ? 'Active' : 'Inactive' %>
                </span>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } else { %>
      <div class="empty-state">
        <i class="bi bi-inbox"></i>
        <p>No categories found. Add your first category above.</p>
      </div>
    <% } %>
  </div>
</div>

<script>
  document.getElementById('addCategoryForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    try {
      const response = await fetch('/po-creator/operator/api/add-category', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: document.getElementById('name').value,
          description: document.getElementById('description').value
        })
      });
      if (response.ok) {
        alert('Category added successfully!');
        location.reload();
      } else {
        const data = await response.json();
        alert('Error: ' + (data.error || 'Failed to add category'));
      }
    } catch (error) {
      alert('Error: ' + error.message);
    }
  });
</script>

<%- include('../partials/footer') %>
