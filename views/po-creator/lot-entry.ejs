<%- include('../partials/header', { pageTitle: 'Lot Entry' }) %>
<%- include('../partials/navbar', { dashboardUrl: '/po-creator/dashboard' }) %>

<style>
  /* Page Layout - No sidebar, centered content */
  .page-wrapper {
    margin-top: var(--navbar-height);
    padding: 28px;
    min-height: calc(100vh - var(--navbar-height));
    background: var(--bg-page);
  }

  .page-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Page Header */
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 28px;
  }

  .page-header-left {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .page-header .page-title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    color: var(--text-primary);
    margin: 0;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .page-header .page-title i {
    color: var(--terracotta);
    font-size: var(--text-2xl);
  }

  /* Form Card */
  .form-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 28px;
    margin-bottom: 28px;
    box-shadow: var(--shadow-xs);
  }

  .form-card:hover {
    box-shadow: var(--shadow-sm);
  }

  /* Form Controls */
  .form-label {
    display: block;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 6px;
  }

  .form-control {
    width: 100%;
    padding: 10px 14px;
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--text-primary);
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }

  .form-control:hover {
    border-color: var(--border-medium);
  }

  .form-control:focus {
    outline: none;
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px var(--terracotta-bg);
  }

  .form-control::placeholder {
    color: var(--text-muted);
  }

  .form-hint {
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin-top: 4px;
  }

  /* Submit Button */
  .submit-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 24px;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    border-radius: var(--radius-md);
    border: none;
    cursor: pointer;
    transition: all var(--transition-fast);
    background: var(--terracotta);
    color: white;
  }

  .submit-btn:hover {
    background: var(--terracotta-dark);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  .submit-btn:focus {
    outline: none;
    box-shadow: 0 0 0 3px var(--terracotta-bg);
  }

  /* Back Button */
  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all var(--transition-fast);
    background: var(--bg-card);
    color: var(--text-primary);
    border: 1px solid var(--border-medium);
  }

  .back-btn:hover {
    background: var(--gray-100);
    border-color: var(--border-dark);
    color: var(--text-primary);
    text-decoration: none;
  }

  /* Table Card */
  .table-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-xs);
  }

  .table-card-header {
    padding: 18px 22px;
    border-bottom: 1px solid var(--border-light);
  }

  .table-card-header h5 {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--text-primary);
    margin: 0 0 4px 0;
  }

  .table-card-header small {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  /* Table Styles */
  .table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 0;
  }

  .table thead {
    background: var(--gray-50);
  }

  .table thead th {
    padding: 12px 16px;
    text-align: left;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-light);
  }

  .table td {
    padding: 14px 16px;
    font-size: var(--text-sm);
    color: var(--text-primary);
    border-bottom: 1px solid var(--border-light);
  }

  .table tbody tr:last-child td {
    border-bottom: none;
  }

  .table tbody tr:hover {
    background: var(--gray-50);
  }

  .empty-row td {
    text-align: center;
    padding: 48px 16px;
    color: var(--text-muted);
    font-style: italic;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .page-wrapper {
      padding: 20px 16px;
    }

    .page-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }

    .page-header .page-title {
      font-size: var(--text-2xl);
    }

    .form-card {
      padding: 20px;
    }
  }
</style>

<div class="page-wrapper">
  <div class="page-container">
    <!-- Page Header -->
    <div class="page-header">
      <div class="page-header-left">
        <h1 class="page-title">
          <i class="bi bi-tags"></i>
          Lot Entry
        </h1>
      </div>
      <a href="/po-creator/dashboard" class="back-btn">
        <i class="bi bi-arrow-left"></i> Back to Dashboard
      </a>
    </div>

    <!-- Flash Messages -->
    <%- include('../partials/flashMessages') %>

    <!-- Entry Form -->
    <div class="form-card">
      <form action="/po-creator/lot-entry" method="POST">
        <div class="row g-3">
          <div class="col-md-3">
            <label class="form-label">Lot Code *</label>
            <input type="text" name="lot_code" class="form-control" required>
          </div>
          <div class="col-md-3">
            <label class="form-label">Entry Date</label>
            <input type="date" name="entry_date" class="form-control" value="<%= todayDate %>">
            <div class="form-hint">Defaults to today if left unchanged.</div>
          </div>
          <div class="col-md-3">
            <label class="form-label">SKU *</label>
            <input type="text" name="sku" class="form-control" required>
          </div>
          <div class="col-md-3">
            <label class="form-label">Size (comma separated)</label>
            <input type="text" name="size" class="form-control" placeholder="e.g. S,M,L">
            <div class="form-hint">Enter sizes separated by commas to add quantities for each size.</div>
          </div>
          <div class="col-md-6">
            <label class="form-label">Quantity *</label>
            <div id="single-quantity">
              <input type="number" name="quantity" class="form-control" min="1" required>
            </div>
            <div id="size-quantity-list" class="row g-3 d-none"></div>
          </div>
        </div>
        <div class="mt-4">
          <button type="submit" class="submit-btn">
            <i class="bi bi-check2-circle"></i> Save Entry
          </button>
        </div>
      </form>
    </div>

    <!-- Recent Entries Table -->
    <div class="table-card">
      <div class="table-card-header">
        <h5>Recent Entries</h5>
        <small>Showing last 50 entries</small>
      </div>
      <div class="table-responsive">
        <table class="table">
          <thead>
            <tr>
              <th>Lot Code</th>
              <th>SKU</th>
              <th>Size</th>
              <th>Quantity</th>
              <th>Entry Date</th>
            </tr>
          </thead>
          <tbody>
            <% if (entries.length === 0) { %>
              <tr class="empty-row">
                <td colspan="5">No entries yet.</td>
              </tr>
            <% } else { %>
              <% entries.forEach(entry => { %>
                <tr>
                  <td><%= entry.lot_code %></td>
                  <td><%= entry.sku %></td>
                  <td><%= entry.size || '-' %></td>
                  <td><%= entry.quantity %></td>
                  <td><%= new Date(entry.display_date || entry.created_at).toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata' }) %></td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
  const sizeInput = document.querySelector('input[name="size"]');
  const singleQuantityWrapper = document.getElementById('single-quantity');
  const singleQuantityInput = singleQuantityWrapper.querySelector('input');
  const sizeQuantityList = document.getElementById('size-quantity-list');

  function buildSizeQuantityFields() {
    const sizes = sizeInput.value
      .split(',')
      .map(item => item.trim())
      .filter(Boolean);

    // Clear existing fields using DOM methods
    while (sizeQuantityList.firstChild) {
      sizeQuantityList.removeChild(sizeQuantityList.firstChild);
    }

    if (sizes.length === 0) {
      singleQuantityWrapper.classList.remove('d-none');
      singleQuantityInput.required = true;
      sizeQuantityList.classList.add('d-none');
      return;
    }

    singleQuantityWrapper.classList.add('d-none');
    singleQuantityInput.required = false;
    sizeQuantityList.classList.remove('d-none');

    sizes.forEach((sizeValue) => {
      const col = document.createElement('div');
      col.className = 'col-md-4';

      const label = document.createElement('label');
      label.className = 'form-label';
      label.textContent = 'Quantity (' + sizeValue + ')';

      const hiddenInput = document.createElement('input');
      hiddenInput.type = 'hidden';
      hiddenInput.name = 'size_values[]';
      hiddenInput.value = sizeValue;

      const quantityInput = document.createElement('input');
      quantityInput.type = 'number';
      quantityInput.name = 'size_quantities[]';
      quantityInput.className = 'form-control';
      quantityInput.min = '1';
      quantityInput.required = true;

      col.appendChild(label);
      col.appendChild(hiddenInput);
      col.appendChild(quantityInput);
      sizeQuantityList.appendChild(col);
    });
  }

  sizeInput.addEventListener('input', buildSizeQuantityFields);
</script>

<%- include('../partials/footer') %>
