<%- include('../partials/header', { pageTitle: 'PO Creator Dashboard' }) %>
<%- include('../partials/navbar', { user: user, dashboardUrl: '/po-creator/dashboard' }) %>

<!-- Main Content (no sidebar for this dashboard) -->
<main class="main-content" style="margin-left: 0;">
  <div class="container-fluid" style="max-width: 1400px; margin: 0 auto;">

    <!-- Page Header -->
    <div class="page-header">
      <h1 class="page-title">Welcome, <%= user.username %></h1>
      <p class="page-subtitle">Manage your cartons, SKUs, and outward entries</p>
    </div>

    <%- include('../partials/flashMessages') %>

    <!-- Action Cards Grid -->
    <div class="action-grid">

      <!-- Inward Entry -->
      <a href="/po-creator/inward" class="action-card">
        <div class="action-card-icon">
          <i class="bi bi-box-arrow-in-down"></i>
        </div>
        <div class="action-card-content">
          <h3 class="action-card-title">Inward Entry</h3>
          <p class="action-card-desc">Create new carton entries with multiple SKUs</p>
        </div>
        <div class="action-card-arrow">
          <i class="bi bi-arrow-right"></i>
        </div>
      </a>

      <!-- View Inward Data -->
      <a href="/po-creator/inward/view" class="action-card">
        <div class="action-card-icon action-card-icon--info">
          <i class="bi bi-list-ul"></i>
        </div>
        <div class="action-card-content">
          <h3 class="action-card-title">View Inward Data</h3>
          <p class="action-card-desc">See all your carton and SKU entries</p>
        </div>
        <div class="action-card-arrow">
          <i class="bi bi-arrow-right"></i>
        </div>
      </a>

      <!-- Outward Entry -->
      <a href="/po-creator/outward" class="action-card action-card--accent">
        <div class="action-card-icon action-card-icon--danger">
          <i class="bi bi-box-arrow-up"></i>
        </div>
        <div class="action-card-content">
          <h3 class="action-card-title">Outward Entry</h3>
          <p class="action-card-desc">Create PO and dispatch entries for your cartons</p>
        </div>
        <div class="action-card-arrow">
          <i class="bi bi-arrow-right"></i>
        </div>
      </a>

      <!-- Bulk Inward Upload -->
      <a href="/po-creator/inward#bulk-upload" class="action-card">
        <div class="action-card-icon action-card-icon--success">
          <i class="bi bi-cloud-arrow-up"></i>
        </div>
        <div class="action-card-content">
          <h3 class="action-card-title">Bulk Inward Upload</h3>
          <p class="action-card-desc">Upload an Excel template to create inward entries in bulk</p>
        </div>
        <div class="action-card-arrow">
          <i class="bi bi-arrow-right"></i>
        </div>
      </a>

      <!-- Lot Entry -->
      <a href="/po-creator/lot-entry" class="action-card">
        <div class="action-card-icon">
          <i class="bi bi-tags"></i>
        </div>
        <div class="action-card-content">
          <h3 class="action-card-title">Lot Entry</h3>
          <p class="action-card-desc">Enter lot code, SKU, size, and quantity</p>
        </div>
        <div class="action-card-arrow">
          <i class="bi bi-arrow-right"></i>
        </div>
      </a>

      <!-- Download Excel -->
      <a href="/po-creator/download/inward-excel" class="action-card">
        <div class="action-card-icon action-card-icon--success">
          <i class="bi bi-file-earmark-spreadsheet"></i>
        </div>
        <div class="action-card-content">
          <h3 class="action-card-title">Download Excel</h3>
          <p class="action-card-desc">Export your complete inward data</p>
        </div>
        <div class="action-card-arrow">
          <i class="bi bi-arrow-right"></i>
        </div>
      </a>

    </div>
  </div>
</main>

<style>
  /* PO Creator Dashboard Specific Styles */
  .action-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 20px;
  }

  .action-card {
    display: flex;
    align-items: center;
    gap: 18px;
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 24px;
    text-decoration: none;
    color: var(--text-primary);
    transition: all var(--transition-fast);
  }

  .action-card:hover {
    border-color: var(--terracotta);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    text-decoration: none;
    color: var(--text-primary);
  }

  .action-card--accent {
    border-left: 4px solid var(--terracotta);
  }

  .action-card-icon {
    width: 52px;
    height: 52px;
    border-radius: var(--radius-lg);
    background: var(--terracotta-bg);
    color: var(--terracotta);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    flex-shrink: 0;
    transition: all var(--transition-fast);
  }

  .action-card:hover .action-card-icon {
    background: var(--terracotta);
    color: white;
  }

  .action-card-icon--info {
    background: var(--info-light);
    color: var(--info);
  }

  .action-card:hover .action-card-icon--info {
    background: var(--info);
    color: white;
  }

  .action-card-icon--success {
    background: var(--success-light);
    color: var(--success);
  }

  .action-card:hover .action-card-icon--success {
    background: var(--success);
    color: white;
  }

  .action-card-icon--danger {
    background: var(--danger-light);
    color: var(--danger);
  }

  .action-card:hover .action-card-icon--danger {
    background: var(--danger);
    color: white;
  }

  .action-card-content {
    flex: 1;
    min-width: 0;
  }

  .action-card-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--text-primary);
    margin: 0 0 4px 0;
  }

  .action-card-desc {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.4;
  }

  .action-card-arrow {
    width: 32px;
    height: 32px;
    border-radius: var(--radius-full);
    background: var(--gray-100);
    color: var(--text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    flex-shrink: 0;
    transition: all var(--transition-fast);
  }

  .action-card:hover .action-card-arrow {
    background: var(--terracotta);
    color: white;
    transform: translateX(4px);
  }

  /* Responsive adjustments */
  @media (max-width: 576px) {
    .action-grid {
      grid-template-columns: 1fr;
    }

    .action-card {
      padding: 18px;
      gap: 14px;
    }

    .action-card-icon {
      width: 44px;
      height: 44px;
      font-size: 20px;
    }

    .action-card-title {
      font-size: var(--text-base);
    }

    .action-card-desc {
      font-size: var(--text-xs);
    }

    .action-card-arrow {
      display: none;
    }
  }
</style>

<%- include('../partials/footer') %>
