<%- include('../partials/header', { pageTitle: 'Outward Entry' }) %>
<%- include('../partials/navbar', { dashboardUrl: '/po-creator/dashboard' }) %>

<!-- Main Content -->
<main class="main-content" style="margin-left: 0;">
  <div class="container-fluid" style="max-width: 1200px; margin: 0 auto;">

    <!-- Page Header -->
    <div class="page-header">
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
          <div class="breadcrumbs">
            <a href="/po-creator/dashboard">Dashboard</a>
            <span class="separator">/</span>
            <span>Outward Entry</span>
          </div>
          <h1 class="page-title">
            <i class="bi bi-box-arrow-up me-2" style="color: var(--terracotta);"></i>Outward Entry
          </h1>
          <p class="page-subtitle">Dispatch cartons with PO details</p>
        </div>
        <a href="/po-creator/dashboard" class="btn btn-secondary">
          <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
      </div>
    </div>

    <!-- Flash Messages -->
    <%- include('../partials/flashMessages') %>

    <!-- Main Card -->
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">
          <i class="bi bi-truck me-2" style="color: var(--terracotta);"></i>Dispatch Details
        </h2>
      </div>
      <div class="card-body">
        <% if (cartons.length === 0) { %>
          <!-- Empty State -->
          <div class="empty-state">
            <div class="empty-state-icon">
              <i class="bi bi-inbox" style="font-size: 64px;"></i>
            </div>
            <h3 class="empty-state-title">No Cartons Available</h3>
            <p class="empty-state-text">
              All cartons have been dispatched or no cartons exist for outward entry.
            </p>
            <a href="/po-creator/dashboard" class="btn btn-primary mt-3">
              <i class="bi bi-arrow-left"></i> Go to Dashboard
            </a>
          </div>
        <% } else { %>
          <form id="outwardForm">
            <!-- Form Fields -->
            <div class="row mb-4">
              <div class="col-md-4 mb-3">
                <div class="form-group">
                  <label class="form-label">PO Number <span style="color: var(--danger);">*</span></label>
                  <input type="text" class="form-control form-input" id="poNumber" placeholder="Enter PO number" required>
                </div>
              </div>
              <div class="col-md-4 mb-3">
                <div class="form-group">
                  <label class="form-label">Dispatch Date <span style="color: var(--danger);">*</span></label>
                  <input type="date" class="form-control form-input" id="dispatchDate" required>
                </div>
              </div>
              <div class="col-md-4 mb-3">
                <div class="form-group">
                  <label class="form-label">Panel Name <span style="color: var(--danger);">*</span></label>
                  <input type="text" class="form-control form-input" id="panelName" placeholder="Enter panel name" required>
                </div>
              </div>
            </div>

            <!-- Cartons Selection -->
            <div class="mb-4">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 style="font-family: var(--font-display); margin: 0;">
                  <i class="bi bi-box-seam me-2" style="color: var(--terracotta);"></i>Select Cartons for Dispatch
                </h5>
                <span class="badge badge-neutral" id="selectedCount">0 selected</span>
              </div>

              <div id="cartonsList" class="cartons-grid">
                <% cartons.forEach(carton => { %>
                  <div class="carton-item" onclick="toggleCarton(<%= carton.id %>, this)">
                    <div class="carton-checkbox-wrapper">
                      <input type="checkbox" class="carton-checkbox" id="carton_<%= carton.id %>" value="<%= carton.id %>">
                      <div class="carton-check-icon">
                        <i class="bi bi-check-lg"></i>
                      </div>
                    </div>
                    <div class="carton-content">
                      <div class="carton-number"><%= carton.carton_number %></div>
                      <div class="carton-details">
                        <span><i class="bi bi-calendar3 me-1"></i> <%= new Date(carton.date_of_packing).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) %></span>
                        <span><i class="bi bi-person me-1"></i> <%= carton.packed_by %></span>
                      </div>
                    </div>
                  </div>
                <% }) %>
              </div>
            </div>

            <!-- Submit Button -->
            <div class="text-center pt-3" style="border-top: 1px solid var(--border-light);">
              <button type="submit" class="btn btn-primary btn-lg" id="submitBtn">
                <i class="bi bi-check-circle me-2"></i><span id="submitBtnText">Submit Outward Entry</span>
              </button>
            </div>
          </form>
        <% } %>
      </div>
    </div>

  </div>
</main>

<style>
  /* Page-specific styles */
  .cartons-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 12px;
  }

  .carton-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 18px;
    background: var(--bg-card);
    border: 2px solid var(--border-light);
    border-radius: var(--radius-lg);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .carton-item:hover {
    border-color: var(--terracotta-light);
    background: var(--terracotta-bg);
  }

  .carton-item.selected {
    border-color: var(--terracotta);
    background: var(--terracotta-bg);
  }

  .carton-checkbox-wrapper {
    position: relative;
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }

  .carton-checkbox {
    position: absolute;
    opacity: 0;
    width: 100%;
    height: 100%;
    cursor: pointer;
  }

  .carton-check-icon {
    width: 24px;
    height: 24px;
    border: 2px solid var(--border-medium);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-card);
    color: transparent;
    transition: all var(--transition-fast);
  }

  .carton-item.selected .carton-check-icon {
    background: var(--terracotta);
    border-color: var(--terracotta);
    color: white;
  }

  .carton-content {
    flex: 1;
    min-width: 0;
  }

  .carton-number {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--text-primary);
    margin-bottom: 4px;
  }

  .carton-details {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .carton-details span {
    display: flex;
    align-items: center;
  }

  /* Form input enhancements */
  .form-input {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    padding: 10px 14px;
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--text-primary);
    transition: all var(--transition-fast);
  }

  .form-input:hover {
    border-color: var(--border-medium);
  }

  .form-input:focus {
    outline: none;
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px var(--terracotta-bg);
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .cartons-grid {
      grid-template-columns: 1fr;
    }

    .carton-details {
      flex-direction: column;
      gap: 4px;
    }
  }
</style>

<script>
  // Toggle carton selection
  function toggleCarton(id, element) {
    const checkbox = document.getElementById('carton_' + id);
    checkbox.checked = !checkbox.checked;
    element.classList.toggle('selected', checkbox.checked);
    updateSelectedCount();
  }

  // Update selected count badge
  function updateSelectedCount() {
    const count = document.querySelectorAll('.carton-checkbox:checked').length;
    const badge = document.getElementById('selectedCount');
    if (badge) {
      badge.textContent = count + ' selected';
      badge.className = count > 0 ? 'badge badge-primary' : 'badge badge-neutral';
    }
  }

  // Form submission
  document.getElementById('outwardForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const selectedCartons = Array.from(document.querySelectorAll('.carton-checkbox:checked')).map(cb => parseInt(cb.value));

    if (selectedCartons.length === 0) {
      alert('Please select at least one carton');
      return;
    }

    const submitBtn = document.getElementById('submitBtn');
    const submitBtnText = document.getElementById('submitBtnText');
    const submitBtnIcon = submitBtn.querySelector('i');

    submitBtn.disabled = true;
    submitBtnText.textContent = 'Processing...';
    submitBtnIcon.className = 'spinner me-2';

    try {
      const response = await fetch('/po-creator/api/outward', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          carton_ids: selectedCartons,
          po_number: document.getElementById('poNumber').value,
          dispatch_date: document.getElementById('dispatchDate').value,
          panel_name: document.getElementById('panelName').value
        })
      });

      const data = await response.json();

      if (response.ok) {
        alert('Outward entry saved successfully!');
        window.location.href = '/po-creator/dashboard';
      } else {
        alert('Error: ' + (data.error || 'Failed to save outward entry'));
        submitBtn.disabled = false;
        submitBtnText.textContent = 'Submit Outward Entry';
        submitBtnIcon.className = 'bi bi-check-circle me-2';
      }
    } catch (error) {
      console.error('Error:', error);
      alert('Error submitting form');
      submitBtn.disabled = false;
      submitBtnText.textContent = 'Submit Outward Entry';
      submitBtnIcon.className = 'bi bi-check-circle me-2';
    }
  });

  // Set default date to today
  document.addEventListener('DOMContentLoaded', function() {
    const dateInput = document.getElementById('dispatchDate');
    if (dateInput && !dateInput.value) {
      dateInput.value = new Date().toISOString().split('T')[0];
    }
  });
</script>

<%- include('../partials/footer') %>
