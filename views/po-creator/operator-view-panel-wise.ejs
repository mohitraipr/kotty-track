<%- include('../partials/header', { pageTitle: 'Panel-wise View' }) %>
<%- include('../partials/navbar', { dashboardUrl: '/po-creator/operator/dashboard' }) %>

<!-- Main Content -->
<main class="main-content" style="margin-left: 0;">
  <div class="container-fluid" style="max-width: 1600px; margin: 0 auto;">

    <!-- Page Header -->
    <div class="page-header">
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
          <h1 class="page-title">
            <i class="bi bi-diagram-3 me-2" style="color: var(--terracotta);"></i>
            Panel-wise View
          </h1>
          <p class="page-subtitle">View dispatched panels grouped by panel name</p>
        </div>
        <a href="/po-creator/operator/dashboard" class="btn btn-secondary">
          <i class="bi bi-arrow-left"></i>
          Back to Dashboard
        </a>
      </div>
    </div>

    <% if (panelData.length === 0) { %>
      <!-- Empty State -->
      <div class="card">
        <div class="card-body text-center py-5">
          <div style="font-size: 4rem; color: var(--text-muted); margin-bottom: 1rem;">
            <i class="bi bi-inbox"></i>
          </div>
          <h3 style="font-family: var(--font-display); color: var(--text-primary); margin-bottom: 0.5rem;">No Panels Dispatched Yet</h3>
          <p style="color: var(--text-secondary); max-width: 400px; margin: 0 auto;">
            No outward data found. Panels will appear here once they have been dispatched.
          </p>
        </div>
      </div>
    <% } else { %>
      <!-- Search and Table Card -->
      <div class="card">
        <div class="card-header">
          <h2 class="card-title">
            <i class="bi bi-table me-2" style="color: var(--terracotta);"></i>
            Dispatched Panels
          </h2>
          <span class="badge" style="background: var(--terracotta-bg); color: var(--terracotta); padding: 6px 12px; border-radius: var(--radius-full); font-weight: 500;">
            <%= panelData.length %> Panel<%= panelData.length !== 1 ? 's' : '' %>
          </span>
        </div>
        <div class="card-body">
          <!-- Search Input -->
          <div class="mb-4">
            <div class="position-relative" style="max-width: 400px;">
              <i class="bi bi-search position-absolute" style="left: 14px; top: 50%; transform: translateY(-50%); color: var(--text-muted);"></i>
              <input
                type="text"
                id="searchInput"
                class="form-control"
                placeholder="Search panel, PO number, creator..."
                style="padding-left: 42px; border: 1px solid var(--border-light); border-radius: var(--radius-md);"
              >
            </div>
          </div>

          <!-- Table Container -->
          <div class="table-container" style="border: none;">
            <div class="table-responsive">
              <table class="table mb-0">
                <thead>
                  <tr>
                    <th>Panel Name</th>
                    <th>PO Number</th>
                    <th>Dispatch Date</th>
                    <th class="text-center">Cartons</th>
                    <th class="text-center">Total Qty</th>
                    <th>Creator</th>
                  </tr>
                </thead>
                <tbody id="panelTable">
                  <% panelData.forEach(panel => { %>
                    <tr>
                      <td>
                        <div class="d-flex align-items-center gap-2">
                          <div style="width: 32px; height: 32px; background: var(--terracotta-bg); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-box-seam" style="color: var(--terracotta); font-size: 14px;"></i>
                          </div>
                          <strong style="color: var(--text-primary);"><%= panel.panel_name %></strong>
                        </div>
                      </td>
                      <td>
                        <span style="font-family: var(--font-mono); font-size: 0.875rem; color: var(--text-secondary);">
                          <%= panel.po_number %>
                        </span>
                      </td>
                      <td>
                        <span style="color: var(--text-secondary);">
                          <%= new Date(panel.dispatch_date).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                        </span>
                      </td>
                      <td class="text-center">
                        <span class="badge" style="background: var(--gray-100); color: var(--text-primary); padding: 4px 10px; border-radius: var(--radius-full); font-weight: 500;">
                          <%= panel.carton_count %>
                        </span>
                      </td>
                      <td class="text-center">
                        <span style="font-weight: 600; color: var(--terracotta); font-size: 1rem;">
                          <%= panel.total_quantity || 0 %>
                        </span>
                      </td>
                      <td>
                        <div class="d-flex align-items-center gap-2">
                          <div style="width: 24px; height: 24px; background: var(--gray-200); border-radius: var(--radius-full); display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 600; color: var(--text-secondary);">
                            <%= panel.creator ? panel.creator.charAt(0).toUpperCase() : '?' %>
                          </div>
                          <span style="color: var(--text-secondary); font-size: 0.875rem;"><%= panel.creator %></span>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>

          <!-- No Results Message (hidden by default) -->
          <div id="noResults" class="text-center py-4" style="display: none;">
            <i class="bi bi-search" style="font-size: 2rem; color: var(--text-muted);"></i>
            <p class="mt-2 mb-0" style="color: var(--text-secondary);">No panels match your search criteria</p>
          </div>
        </div>
      </div>
    <% } %>

  </div>
</main>

<style>
  /* Table Styles */
  .table th {
    padding: 14px 16px;
    text-align: left;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    background: var(--gray-50);
    border-bottom: 1px solid var(--border-light);
  }

  .table td {
    padding: 14px 16px;
    vertical-align: middle;
    border-bottom: 1px solid var(--border-light);
    color: var(--text-primary);
  }

  .table tbody tr {
    transition: background-color 0.15s ease;
  }

  .table tbody tr:hover {
    background-color: var(--cream-dark);
  }

  .table tbody tr:last-child td {
    border-bottom: none;
  }

  /* Form Control Override */
  .form-control {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--text-primary);
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    padding: 10px 14px;
    transition: all 0.15s ease;
  }

  .form-control:hover {
    border-color: var(--border-medium);
  }

  .form-control:focus {
    outline: none;
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px var(--terracotta-bg);
  }

  .form-control::placeholder {
    color: var(--text-muted);
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .page-header .d-flex {
      flex-direction: column;
      align-items: flex-start !important;
    }

    .page-header .btn {
      width: 100%;
      justify-content: center;
    }

    .table-responsive {
      font-size: 0.875rem;
    }
  }
</style>

<script>
  // Search functionality
  const searchInput = document.getElementById('searchInput');
  const noResults = document.getElementById('noResults');

  if (searchInput) {
    searchInput.addEventListener('keyup', function() {
      const filter = this.value.toLowerCase();
      const rows = document.querySelectorAll('#panelTable tr');
      let visibleCount = 0;

      rows.forEach(row => {
        const text = row.textContent.toLowerCase();
        const isVisible = text.includes(filter);
        row.style.display = isVisible ? '' : 'none';
        if (isVisible) visibleCount++;
      });

      // Show/hide no results message
      if (noResults) {
        noResults.style.display = visibleCount === 0 && filter.length > 0 ? 'block' : 'none';
      }
    });
  }
</script>

<%- include('../partials/footer') %>
