<%- include('partials/header', { pageTitle: 'Assign Rewash' }) %>
<%- include('partials/navbar', { dashboardUrl: '/washingin' }) %>

<!-- Select2 CSS -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<style>
  /* Page-specific styles */
  .page-wrapper {
    min-height: calc(100vh - var(--navbar-height));
    padding-top: calc(var(--navbar-height) + 28px);
    padding-bottom: 40px;
    background: var(--bg-page);
  }

  .page-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Page Header */
  .page-header {
    margin-bottom: 28px;
  }

  .page-header .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-bottom: 12px;
  }

  .page-header .breadcrumbs a {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .page-header .breadcrumbs a:hover {
    color: var(--terracotta);
  }

  .page-header .breadcrumbs .separator {
    color: var(--border-medium);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    color: var(--text-primary);
    margin-bottom: 6px;
  }

  .page-subtitle {
    font-size: var(--text-base);
    color: var(--text-secondary);
    font-weight: 400;
  }

  /* Form Card */
  .form-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
  }

  .form-card-header {
    padding: 20px 24px;
    background: var(--charcoal);
    color: var(--text-inverse);
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .form-card-header .header-icon {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    background: var(--terracotta);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
  }

  .form-card-header h2 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    margin: 0;
    font-weight: 400;
  }

  .form-card-body {
    padding: 28px;
  }

  /* Form Group */
  .form-group {
    margin-bottom: 24px;
  }

  .form-group label {
    display: block;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 8px;
  }

  /* Select2 Custom Styling */
  .select2-container--default .select2-selection--single {
    height: 48px;
    padding: 10px 14px;
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--text-primary);
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }

  .select2-container--default .select2-selection--single:hover {
    border-color: var(--border-medium);
  }

  .select2-container--default.select2-container--focus .select2-selection--single,
  .select2-container--default.select2-container--open .select2-selection--single {
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px var(--terracotta-bg);
    outline: none;
  }

  .select2-container--default .select2-selection--single .select2-selection__rendered {
    line-height: 26px;
    color: var(--text-primary);
    padding-left: 0;
  }

  .select2-container--default .select2-selection--single .select2-selection__arrow {
    height: 46px;
    right: 8px;
  }

  .select2-container--default .select2-selection--single .select2-selection__placeholder {
    color: var(--text-muted);
  }

  .select2-dropdown {
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    margin-top: 4px;
  }

  .select2-container--default .select2-results__option--highlighted[aria-selected] {
    background-color: var(--terracotta);
  }

  .select2-container--default .select2-results__option[aria-selected=true] {
    background-color: var(--terracotta-bg);
    color: var(--terracotta);
  }

  .select2-search--dropdown .select2-search__field {
    padding: 10px 14px;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    font-family: var(--font-body);
  }

  .select2-search--dropdown .select2-search__field:focus {
    border-color: var(--terracotta);
    outline: none;
  }

  /* Size Section */
  #sizeSection {
    transition: all 0.3s ease-in-out;
    margin-top: 8px;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--text-primary);
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border-light);
  }

  /* Table Styling */
  .table-container {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .kotty-table {
    width: 100%;
    border-collapse: collapse;
    margin: 0;
  }

  .kotty-table th {
    padding: 14px 16px;
    text-align: left;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    background: var(--gray-50);
    border-bottom: 1px solid var(--border-light);
  }

  .kotty-table td {
    padding: 14px 16px;
    font-size: var(--text-sm);
    color: var(--text-primary);
    border-bottom: 1px solid var(--border-light);
    vertical-align: middle;
  }

  .kotty-table tbody tr:last-child td {
    border-bottom: none;
  }

  .kotty-table tbody tr:hover {
    background: var(--gray-50);
  }

  .kotty-table tfoot td {
    padding: 14px 16px;
    background: var(--gray-50);
    font-weight: 500;
  }

  .kotty-table .text-center {
    text-align: center;
  }

  .kotty-table .text-end {
    text-align: right;
  }

  /* Quantity Input */
  .qty-input {
    width: 80px;
    padding: 8px 12px;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--text-primary);
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    text-align: center;
    transition: all var(--transition-fast);
  }

  .qty-input:hover {
    border-color: var(--border-medium);
  }

  .qty-input:focus {
    outline: none;
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px var(--terracotta-bg);
  }

  .qty-input.is-invalid {
    border-color: var(--danger) !important;
    box-shadow: 0 0 0 3px var(--danger-light);
  }

  /* Total Display */
  .total-value {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--success);
  }

  /* Submit Button */
  .submit-section {
    margin-top: 28px;
  }

  .btn-submit {
    width: 100%;
    padding: 16px 24px;
    background: var(--terracotta);
    color: white;
    border: none;
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 500;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    transition: all var(--transition-fast);
  }

  .btn-submit:hover:not(:disabled) {
    background: var(--terracotta-dark);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  .btn-submit:disabled {
    background: var(--gray-300);
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  /* Empty State */
  .empty-row td {
    padding: 32px 16px;
    text-align: center;
    color: var(--text-muted);
    font-style: italic;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .page-container {
      padding: 0 16px;
    }

    .form-card-body {
      padding: 20px;
    }

    .page-title {
      font-size: var(--text-2xl);
    }
  }
</style>

<main class="page-wrapper">
  <div class="page-container">

    <!-- Page Header -->
    <div class="page-header">
      <div class="breadcrumbs">
        <a href="/washingin"><i class="bi bi-house-door"></i></a>
        <span class="separator">/</span>
        <span>Assign Rewash</span>
      </div>
      <h1 class="page-title">Create Rewash Request</h1>
      <p class="page-subtitle">Select an approved lot and specify quantities for rewashing</p>
    </div>

    <!-- Flash Messages -->
    <% if (error && error.length) { %>
      <div class="alert alert-danger">
        <i class="bi bi-exclamation-circle me-2"></i>
        <%- error.join('<br>') %>
      </div>
    <% } %>
    <% if (success && success.length) { %>
      <div class="alert alert-success">
        <i class="bi bi-check-circle me-2"></i>
        <%- success.join('<br>') %>
      </div>
    <% } %>

    <!-- Rewash Form Card -->
    <div class="form-card">
      <div class="form-card-header">
        <div class="header-icon">
          <i class="bi bi-arrow-repeat"></i>
        </div>
        <h2>Rewash Assignment</h2>
      </div>

      <div class="form-card-body">
        <form id="rewashForm" action="/washingin/assign-rewash" method="POST" class="needs-validation" novalidate>

          <!-- Lot Selection -->
          <div class="form-group">
            <label for="lotSelect">Select Approved Lot</label>
            <select id="lotSelect" name="selectedWashingDataId" class="form-select" required>
              <option value="">-- Choose a lot --</option>
              <% lots.forEach(l => { %>
              <option value="<%= l.washing_data_id %>">
                <%= l.lot_no %> | SKU: <%= l.sku %> | Total: <%= l.total_pieces %> | Rewash Bal: <%= l.available_for_rewash %>
              </option>
              <% }) %>
            </select>
            <div class="invalid-feedback">Please select a lot to proceed.</div>
          </div>

          <!-- Size Breakdown Section -->
          <section id="sizeSection" style="display:none;">
            <h3 class="section-title">Size Breakdown</h3>
            <div class="table-container">
              <table class="kotty-table">
                <thead>
                  <tr>
                    <th>Size</th>
                    <th class="text-center">Remaining</th>
                    <th class="text-center">Request Qty</th>
                  </tr>
                </thead>
                <tbody id="sizeBody"></tbody>
                <tfoot>
                  <tr>
                    <td colspan="2" class="text-end">Total Requested:</td>
                    <td class="text-center">
                      <span id="totalRequested" class="total-value">0</span>
                    </td>
                  </tr>
                </tfoot>
              </table>
            </div>
          </section>

          <!-- Submit Button -->
          <div class="submit-section">
            <button id="submitBtn" type="submit" class="btn-submit" disabled>
              <i class="bi bi-send"></i>
              Submit Rewash Request
            </button>
          </div>

        </form>
      </div>
    </div>

  </div>
</main>

<!-- jQuery (required for Select2) -->
<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<!-- Select2 JS -->
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

<script>
  const sizeSection = document.getElementById('sizeSection');
  const sizeBody = document.getElementById('sizeBody');
  const totalRequested = document.getElementById('totalRequested');
  const submitBtn = document.getElementById('submitBtn');

  $(document).ready(() => {
    const $lotSelect = $('#lotSelect').select2({
      placeholder: "-- Choose a lot --",
      allowClear: true,
      width: '100%'
    });

    $lotSelect.on('change', async function () {
      const selectedVal = $(this).val();

      sizeBody.textContent = '';
      totalRequested.textContent = '0';
      submitBtn.disabled = true;

      if (!selectedVal) {
        sizeSection.style.display = 'none';
        return;
      }

      try {
        const res = await fetch(`/washingin/assign-rewash/data/${selectedVal}`);
        const sizes = await res.json();

        if (!sizes.length) {
          const emptyRow = document.createElement('tr');
          emptyRow.className = 'empty-row';
          const emptyCell = document.createElement('td');
          emptyCell.colSpan = 3;
          emptyCell.textContent = 'No balance available for rewash.';
          emptyRow.appendChild(emptyCell);
          sizeBody.appendChild(emptyRow);
          totalRequested.textContent = '0';
          submitBtn.disabled = true;
          sizeSection.style.display = '';
          return;
        }

        sizes.forEach(s => {
          const row = document.createElement('tr');

          const sizeCell = document.createElement('td');
          sizeCell.style.fontWeight = '500';
          sizeCell.textContent = s.size_label;
          row.appendChild(sizeCell);

          const availableCell = document.createElement('td');
          availableCell.className = 'text-center';
          availableCell.textContent = s.available;
          row.appendChild(availableCell);

          const inputCell = document.createElement('td');
          inputCell.className = 'text-center';
          const input = document.createElement('input');
          input.type = 'number';
          input.name = `sizes[${s.id}]`;
          input.min = '0';
          input.max = s.available;
          input.value = '0';
          input.className = 'qty-input';
          input.dataset.available = s.available;
          input.addEventListener('input', handleQtyChange);
          inputCell.appendChild(input);
          row.appendChild(inputCell);

          sizeBody.appendChild(row);
        });

        sizeSection.style.display = '';
      } catch (err) {
        console.error('Failed to load sizes:', err);
        alert('Could not load size data. Please retry.');
      }
    });
  });

  function handleQtyChange(e) {
    const inp = e.target;
    const max = parseInt(inp.dataset.available, 10);
    let val = parseInt(inp.value || '0', 10);

    if (isNaN(val) || val < 0) val = 0;
    if (val > max) val = max;
    inp.value = val;

    inp.classList.toggle('is-invalid', val > max);

    let total = 0;
    sizeBody.querySelectorAll('input').forEach(i => total += parseInt(i.value || 0, 10));
    totalRequested.textContent = total;
    submitBtn.disabled = total === 0;
  }

  document.getElementById('rewashForm').addEventListener('keypress', e => {
    if (e.key === 'Enter' && !submitBtn.disabled) submitBtn.click();
  });
</script>

<%- include('partials/footer') %>
