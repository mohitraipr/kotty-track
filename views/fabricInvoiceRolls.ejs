<!-- views/fabricInvoiceRolls.ejs -->
<%- include('partials/header', { pageTitle: 'Fabric Invoice Rolls' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/fabric-manager/dashboard' }) %>

<style>
  .invoice-hero {
    background: linear-gradient(135deg, var(--charcoal) 0%, #2d2d2d 100%);
    color: var(--cream);
    padding: 2rem 0;
    margin-bottom: 2rem;
  }

  .invoice-hero h1 {
    font-family: 'DM Serif Display', serif;
    font-size: 2rem;
    margin: 0;
  }

  .invoice-badge {
    background: var(--terracotta);
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 50px;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .info-card {
    background: var(--cream);
    border: 1px solid rgba(26, 26, 26, 0.1);
    border-radius: 12px;
    padding: 1.5rem;
    height: 100%;
  }

  .info-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #666;
    margin-bottom: 0.25rem;
    font-weight: 500;
  }

  .info-value {
    font-size: 1rem;
    color: var(--charcoal);
    font-weight: 500;
  }

  .rolls-table {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .rolls-table thead {
    background: var(--charcoal);
    color: var(--cream);
  }

  .rolls-table thead th {
    font-weight: 500;
    font-size: 0.875rem;
    padding: 1rem;
    border: none;
    white-space: nowrap;
  }

  .rolls-table tbody td {
    padding: 0.875rem 1rem;
    vertical-align: middle;
    border-bottom: 1px solid rgba(26, 26, 26, 0.08);
  }

  .rolls-table tbody tr:hover {
    background: rgba(196, 92, 58, 0.05);
  }

  .rolls-table tbody tr:last-child td {
    border-bottom: none;
  }

  .action-card {
    background: white;
    border: 1px solid rgba(26, 26, 26, 0.1);
    border-radius: 12px;
    overflow: hidden;
  }

  .action-card-header {
    background: var(--charcoal);
    color: var(--cream);
    padding: 1rem 1.25rem;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .action-card-body {
    padding: 1.25rem;
  }

  .form-label-custom {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--charcoal);
    margin-bottom: 0.5rem;
  }

  .form-control-custom,
  .form-select-custom {
    border: 1px solid rgba(26, 26, 26, 0.2);
    border-radius: 8px;
    padding: 0.625rem 0.875rem;
    font-size: 0.9rem;
    transition: all 0.2s ease;
  }

  .form-control-custom:focus,
  .form-select-custom:focus {
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px rgba(196, 92, 58, 0.15);
    outline: none;
  }

  .btn-terracotta {
    background: var(--terracotta);
    color: white;
    border: none;
    padding: 0.625rem 1.25rem;
    border-radius: 8px;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .btn-terracotta:hover {
    background: #b5533a;
    color: white;
    transform: translateY(-1px);
  }

  .btn-outline-charcoal {
    border: 1px solid var(--charcoal);
    color: var(--charcoal);
    background: transparent;
    padding: 0.625rem 1.25rem;
    border-radius: 8px;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .btn-outline-charcoal:hover {
    background: var(--charcoal);
    color: var(--cream);
  }

  .bulk-action-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1rem;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.2s ease;
    font-weight: 500;
  }

  .bulk-action-btn.primary {
    background: rgba(196, 92, 58, 0.1);
    color: var(--terracotta);
    border: 1px solid rgba(196, 92, 58, 0.2);
  }

  .bulk-action-btn.primary:hover {
    background: var(--terracotta);
    color: white;
    border-color: var(--terracotta);
  }

  .bulk-action-btn.secondary {
    background: rgba(26, 26, 26, 0.05);
    color: var(--charcoal);
    border: 1px solid rgba(26, 26, 26, 0.1);
  }

  .bulk-action-btn.secondary:hover {
    background: var(--charcoal);
    color: var(--cream);
  }

  .entry-defaults {
    background: rgba(196, 92, 58, 0.06);
    border: 1px dashed rgba(196, 92, 58, 0.3);
    border-radius: 10px;
    padding: 1rem;
  }

  .entry-summary {
    background: rgba(40, 167, 69, 0.08);
    border: 1px solid rgba(40, 167, 69, 0.2);
    border-radius: 8px;
    padding: 0.625rem 0.875rem;
    color: #1e7e34;
    font-size: 0.9rem;
  }

  .empty-state {
    text-align: center;
    padding: 3rem 1rem;
    color: #666;
  }

  .empty-state i {
    font-size: 3rem;
    color: #ccc;
    margin-bottom: 1rem;
  }

  @media print {
    .no-print {
      display: none !important;
    }

    .invoice-hero {
      background: none !important;
      color: var(--charcoal) !important;
      padding: 1rem 0 !important;
      border-bottom: 2px solid var(--charcoal);
    }

    .rolls-table thead {
      background: #f5f5f5 !important;
      color: var(--charcoal) !important;
    }

    body {
      background: white !important;
    }
  }

  @media (max-width: 768px) {
    .invoice-hero h1 {
      font-size: 1.5rem;
    }

    .info-card {
      padding: 1rem;
    }

    .rolls-table thead th,
    .rolls-table tbody td {
      padding: 0.625rem 0.5rem;
      font-size: 0.8rem;
    }
  }
</style>

<!-- Invoice Hero Section -->
<div class="invoice-hero no-print">
  <div class="container">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
      <div>
        <h1><i class="bi bi-file-earmark-text me-2"></i>Fabric Invoice Rolls</h1>
        <p class="mb-0 mt-2 opacity-75">Invoice #<%= invoice.invoice_no %></p>
      </div>
      <span class="invoice-badge">
        <i class="bi bi-stack me-1"></i> <span id="rollCount"><%= rolls.length %></span> Roll<span id="rollCountPlural"><%= rolls.length !== 1 ? 's' : '' %></span>
      </span>
    </div>
  </div>
</div>

<div class="container py-4">
  <!-- Include Flash Messages Partial -->
  <%- include('partials/flashMessages') %>

  <!-- Invoice Information Cards -->
  <div class="row g-4 mb-4">
    <div class="col-md-6">
      <div class="info-card">
        <h6 class="mb-3" style="font-family: 'DM Serif Display', serif; color: var(--charcoal);">
          <i class="bi bi-building me-2"></i>Vendor Information
        </h6>
        <div class="row g-3">
          <div class="col-12">
            <div class="info-label">Vendor Name</div>
            <div class="info-value"><%= invoice.vendor_name %></div>
          </div>
          <div class="col-6">
            <div class="info-label">Invoice Date</div>
            <div class="info-value"><%= invoice.date_invoice.toLocaleDateString('en-CA') %></div>
          </div>
          <div class="col-6">
            <div class="info-label">Received Date</div>
            <div class="info-value"><%= invoice.date_received.toLocaleDateString('en-CA') %></div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="info-card">
        <h6 class="mb-3" style="font-family: 'DM Serif Display', serif; color: var(--charcoal);">
          <i class="bi bi-box-seam me-2"></i>Fabric Details
        </h6>
        <div class="row g-3">
          <div class="col-6">
            <div class="info-label">Total Rolls</div>
            <div class="info-value"><%= invoice.total_roll_quantity %></div>
          </div>
          <div class="col-6">
            <div class="info-label">Fabric Type</div>
            <div class="info-value"><%= invoice.fabric_type || 'N/A' %></div>
          </div>
          <div class="col-4">
            <div class="info-label">Invoice Weight</div>
            <div class="info-value"><%= invoice.invoice_weight || 'N/A' %></div>
          </div>
          <div class="col-4">
            <div class="info-label">Short Weight</div>
            <div class="info-value"><%= invoice.short_weight || 'N/A' %></div>
          </div>
          <div class="col-4">
            <div class="info-label">Received Weight</div>
            <div class="info-value"><%= invoice.received_weight || 'N/A' %></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Action Buttons -->
  <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4 no-print">
    <a href="/fabric-manager/invoice/<%= invoice.id %>/download-rolls" class="btn-outline-charcoal" style="text-decoration: none;">
      <i class="bi bi-download me-2"></i>Download Excel
    </a>
    <button class="btn-outline-charcoal" onclick="window.print()">
      <i class="bi bi-printer me-2"></i>Print
    </button>
  </div>

  <!-- Rolls Table -->
  <div class="rolls-table mb-4">
    <div class="table-responsive">
      <table class="table mb-0">
        <thead>
          <tr>
            <th><i class="bi bi-hash me-1"></i>ID</th>
            <th><i class="bi bi-123 me-1"></i>Roll No</th>
            <th><i class="bi bi-speedometer2 me-1"></i>Weight</th>
            <th><i class="bi bi-palette me-1"></i>Color</th>
            <th><i class="bi bi-upc me-1"></i>GR No</th>
            <th><i class="bi bi-rulers me-1"></i>Unit</th>
            <th><i class="bi bi-person me-1"></i>Created By</th>
          </tr>
        </thead>
        <tbody id="rollsTableBody">
          <% if (rolls.length === 0) { %>
            <tr id="emptyRollsRow">
              <td colspan="7">
                <div class="empty-state">
                  <i class="bi bi-inbox"></i>
                  <p class="mb-0">No rolls found for this invoice.</p>
                  <small>Add rolls using the form below.</small>
                </div>
              </td>
            </tr>
          <% } else { %>
            <% rolls.forEach(roll => { %>
              <tr data-roll-no="<%= roll.roll_no %>">
                <td><strong>#<%= roll.id %></strong></td>
                <td><%= roll.roll_no %></td>
                <td><%= roll.per_roll_weight %></td>
                <td><%= roll.color || '<span class="text-muted">N/A</span>' %></td>
                <td><%= roll.gr_no_by_vendor || '<span class="text-muted">N/A</span>' %></td>
                <td><span class="badge bg-secondary"><%= roll.unit %></span></td>
                <td><%= roll.created_by %></td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Action Cards Row -->
  <div class="row g-4 no-print">
    <!-- Add Roll Form -->
    <div class="col-lg-7">
      <div class="action-card h-100">
        <div class="action-card-header">
          <i class="bi bi-lightning-charge"></i>
          Live Roll Entry
        </div>
        <div class="action-card-body">
          <input type="hidden" id="invoice_id" value="<%= invoice.id %>">

          <!-- Sticky defaults: set once, change anytime the color changes -->
          <div class="entry-defaults">
            <div class="row g-3 align-items-end">
              <div class="col-7">
                <label for="defaultColor" class="form-label-custom">Color</label>
                <input type="text" class="form-control form-control-custom" id="defaultColor" placeholder="e.g. Navy">
              </div>
              <div class="col-5">
                <label for="defaultUnit" class="form-label-custom">Unit</label>
                <select id="defaultUnit" class="form-select form-select-custom" required>
                  <option value="" disabled selected>Select</option>
                  <option value="METER">METER</option>
                  <option value="KG">KG</option>
                </select>
              </div>
            </div>
            <small class="text-muted d-block mt-2">
              <i class="bi bi-info-circle me-1"></i>Set once. Change Color/Unit anytime the fabric changes &mdash; new rolls inherit it.
            </small>
          </div>

          <hr class="my-3">

          <!-- Per-roll entry: type, press Enter / Add, repeat -->
          <div class="row g-3 align-items-end">
            <div class="col-md-4">
              <label for="entry_roll_no" class="form-label-custom">Roll Number</label>
              <input type="number" class="form-control form-control-custom" id="entry_roll_no" min="1">
            </div>
            <div class="col-md-4">
              <label for="entry_weight" class="form-label-custom">Per Roll Weight</label>
              <input type="number" step="0.01" class="form-control form-control-custom" id="entry_weight">
            </div>
            <div class="col-md-4">
              <label for="entry_gr_no" class="form-label-custom">GR No by Vendor</label>
              <input type="text" class="form-control form-control-custom" id="entry_gr_no" placeholder="Optional">
            </div>
            <div class="col-12">
              <button type="button" id="addRollBtn" class="btn-terracotta w-100">
                <i class="bi bi-plus-lg me-2"></i>Add Roll
              </button>
            </div>
          </div>

          <!-- Inline feedback -->
          <div id="entryError" class="alert alert-danger mt-3 mb-0 py-2 px-3" style="display:none; font-size:0.875rem;"></div>

          <!-- Session summary -->
          <div id="sessionSummary" class="entry-summary mt-3" style="display:none;">
            <i class="bi bi-check2-circle me-1"></i>
            This session: <strong id="sessionCount">0</strong> roll<span id="sessionPlural"></span>
            &middot; <strong id="sessionWeight">0.00</strong> total
          </div>
        </div>
      </div>
    </div>

    <!-- Bulk Actions -->
    <div class="col-lg-5">
      <div class="action-card h-100">
        <div class="action-card-header">
          <i class="bi bi-lightning"></i>
          Quick Actions
        </div>
        <div class="action-card-body d-flex flex-column gap-3">
          <a href="/fabric-manager/bulk-upload/rolls" class="bulk-action-btn primary">
            <i class="bi bi-file-earmark-excel"></i>
            Bulk Upload Fabric Invoice Rolls
          </a>
          <a href="/fabric-manager/dashboard" class="bulk-action-btn secondary">
            <i class="bi bi-arrow-left"></i>
            Back to Dashboard
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  const invoiceId   = document.getElementById('invoice_id').value;
  const defColor    = document.getElementById('defaultColor');
  const defUnit     = document.getElementById('defaultUnit');
  const rollNoEl    = document.getElementById('entry_roll_no');
  const weightEl    = document.getElementById('entry_weight');
  const grNoEl      = document.getElementById('entry_gr_no');
  const addBtn      = document.getElementById('addRollBtn');
  const errBox      = document.getElementById('entryError');
  const tableBody   = document.getElementById('rollsTableBody');
  const rollCountEl = document.getElementById('rollCount');
  const rollPluralEl= document.getElementById('rollCountPlural');
  const summaryBox  = document.getElementById('sessionSummary');
  const sessCountEl = document.getElementById('sessionCount');
  const sessPluralEl= document.getElementById('sessionPlural');
  const sessWeightEl= document.getElementById('sessionWeight');

  let sessionCount = 0;
  let sessionWeight = 0;

  // Track roll numbers already present (existing + added this session) for a fast client-side dup guard.
  const knownRolls = new Set();
  tableBody.querySelectorAll('tr[data-roll-no]').forEach(tr => {
    knownRolls.add(String(tr.getAttribute('data-roll-no')));
  });

  function esc(str) {
    const d = document.createElement('div');
    d.textContent = str;
    return d.innerHTML;
  }

  function showError(msg) {
    errBox.textContent = msg;
    errBox.style.display = 'block';
  }
  function clearError() {
    errBox.style.display = 'none';
    errBox.textContent = '';
  }

  function prependRow(roll) {
    const empty = document.getElementById('emptyRollsRow');
    if (empty) empty.remove();

    const tr = document.createElement('tr');
    tr.setAttribute('data-roll-no', roll.roll_no);
    const colorCell = roll.color ? esc(roll.color) : '<span class="text-muted">N/A</span>';
    const grCell    = roll.gr_no_by_vendor ? esc(roll.gr_no_by_vendor) : '<span class="text-muted">N/A</span>';
    tr.innerHTML =
      '<td><strong>#' + roll.id + '</strong></td>' +
      '<td>' + esc(String(roll.roll_no)) + '</td>' +
      '<td>' + esc(String(roll.per_roll_weight)) + '</td>' +
      '<td>' + colorCell + '</td>' +
      '<td>' + grCell + '</td>' +
      '<td><span class="badge bg-secondary">' + esc(roll.unit) + '</span></td>' +
      '<td>' + esc(roll.created_by || '') + '</td>';
    tableBody.insertBefore(tr, tableBody.firstChild);
  }

  function updateCounts(weight) {
    // Header total = all rows in the table (existing + new)
    const total = tableBody.querySelectorAll('tr[data-roll-no]').length;
    rollCountEl.textContent = total;
    rollPluralEl.textContent = total !== 1 ? 's' : '';

    // Session summary = only rolls added in this browser session
    sessionCount += 1;
    sessionWeight += weight;
    sessCountEl.textContent = sessionCount;
    sessPluralEl.textContent = sessionCount !== 1 ? 's' : '';
    sessWeightEl.textContent = sessionWeight.toFixed(2);
    summaryBox.style.display = 'block';
  }

  async function addRoll() {
    clearError();

    const roll_no = rollNoEl.value.trim();
    const weight  = weightEl.value.trim();
    const unit    = defUnit.value;
    const color   = defColor.value.trim();
    const gr_no   = grNoEl.value.trim();

    if (!unit) { showError('Select a Unit first.'); defUnit.focus(); return; }
    if (!roll_no) { showError('Enter a roll number.'); rollNoEl.focus(); return; }
    if (!weight) { showError('Enter the per-roll weight.'); weightEl.focus(); return; }
    if (knownRolls.has(String(roll_no))) {
      showError('Roll number ' + roll_no + ' is already entered.');
      rollNoEl.focus(); rollNoEl.select();
      return;
    }

    addBtn.disabled = true;
    const original = addBtn.innerHTML;
    addBtn.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>Saving...';

    try {
      const resp = await fetch('/fabric-manager/insert/roll/ajax', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          invoice_id: invoiceId,
          roll_no: roll_no,
          per_roll_weight: weight,
          color: color,
          gr_no_by_vendor: gr_no,
          unit: unit
        })
      });
      const data = await resp.json().catch(() => ({}));

      if (!resp.ok) {
        showError(data.error || 'Could not save the roll. Please try again.');
        return;
      }

      knownRolls.add(String(data.roll.roll_no));
      prependRow(data.roll);
      updateCounts(parseFloat(weight) || 0);

      // Clear per-roll inputs, keep sticky defaults, refocus roll no.
      rollNoEl.value = '';
      weightEl.value = '';
      grNoEl.value = '';
      rollNoEl.focus();
    } catch (e) {
      showError('Network error. Roll not saved — please retry.');
    } finally {
      addBtn.disabled = false;
      addBtn.innerHTML = original;
    }
  }

  addBtn.addEventListener('click', addRoll);

  // Enter on any per-roll input triggers Add.
  [rollNoEl, weightEl, grNoEl].forEach(el => {
    el.addEventListener('keydown', function (ev) {
      if (ev.key === 'Enter') { ev.preventDefault(); addRoll(); }
    });
  });
})();
</script>

<%- include('partials/footer') %>
