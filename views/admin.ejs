<%- include('partials/header', { pageTitle: 'Admin Dashboard' }) %>
<%- include('partials/navbar', { user: user, dashboardUrl: '/admin' }) %>

<style>
  /* Admin Page Specific Styles */
  .admin-container {
    padding-top: calc(var(--navbar-height) + 28px);
    padding-bottom: 40px;
    min-height: 100vh;
  }

  /* Tab Navigation */
  .admin-tabs {
    display: flex;
    gap: 4px;
    border-bottom: 1px solid var(--border-light);
    margin-bottom: 28px;
    overflow-x: auto;
    padding-bottom: 0;
  }

  .admin-tabs .tab-btn {
    padding: 12px 20px;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-secondary);
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    transition: all var(--transition-fast);
    white-space: nowrap;
    margin-bottom: -1px;
  }

  .admin-tabs .tab-btn:hover {
    color: var(--text-primary);
    background: var(--gray-50);
  }

  .admin-tabs .tab-btn.active {
    color: var(--terracotta);
    border-bottom-color: var(--terracotta);
  }

  /* Section Headers */
  .section-header {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--text-primary);
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border-light);
  }

  /* Tables */
  .admin-table-container {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: 28px;
  }

  .admin-table {
    width: 100%;
    border-collapse: collapse;
  }

  .admin-table th {
    padding: 14px 18px;
    text-align: left;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    background: var(--gray-50);
    border-bottom: 1px solid var(--border-light);
  }

  .admin-table td {
    padding: 14px 18px;
    font-size: var(--text-sm);
    color: var(--text-primary);
    border-bottom: 1px solid var(--border-light);
    vertical-align: middle;
  }

  .admin-table tbody tr:last-child td {
    border-bottom: none;
  }

  .admin-table tbody tr:hover {
    background: var(--gray-50);
  }

  /* Collapse Row for Inline Editing */
  .collapse-row {
    background: var(--cream-dark);
  }

  .collapse-row td {
    padding: 20px 18px;
  }

  .collapse-row .row {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }

  /* Action Buttons in Table */
  .action-btns {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .btn-edit {
    background: var(--info-light);
    color: var(--info);
    border: 1px solid var(--info);
    padding: 6px 12px;
    font-size: var(--text-xs);
    font-weight: 500;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .btn-edit:hover {
    background: var(--info);
    color: white;
  }

  .btn-delete {
    background: var(--danger-light);
    color: var(--danger);
    border: 1px solid var(--danger);
    padding: 6px 12px;
    font-size: var(--text-xs);
    font-weight: 500;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .btn-delete:hover {
    background: var(--danger);
    color: white;
  }

  .btn-update-role {
    background: var(--gray-100);
    color: var(--text-secondary);
    border: 1px solid var(--border-medium);
    padding: 6px 12px;
    font-size: var(--text-xs);
    font-weight: 500;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .btn-update-role:hover {
    background: var(--gray-200);
    color: var(--text-primary);
  }

  /* Form Cards */
  .form-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 28px;
    margin-top: 20px;
  }

  .form-card .form-group {
    margin-bottom: 20px;
  }

  .form-card .form-label {
    display: block;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 8px;
  }

  .form-card .form-control,
  .form-card .form-select {
    width: 100%;
    padding: 10px 14px;
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--text-primary);
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }

  .form-card .form-control:hover,
  .form-card .form-select:hover {
    border-color: var(--border-medium);
  }

  .form-card .form-control:focus,
  .form-card .form-select:focus {
    outline: none;
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px var(--terracotta-bg);
  }

  .form-card textarea.form-control {
    min-height: 120px;
    resize: vertical;
  }

  .form-card .form-check {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .form-card .form-check-input {
    width: 18px;
    height: 18px;
    accent-color: var(--terracotta);
    cursor: pointer;
  }

  .form-card .form-check-label {
    font-size: var(--text-sm);
    color: var(--text-primary);
    cursor: pointer;
  }

  /* Existing Tables List */
  .tables-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 12px;
  }

  .table-item {
    padding: 12px 16px;
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    color: var(--text-primary);
    font-family: var(--font-mono);
    transition: all var(--transition-fast);
  }

  .table-item:hover {
    border-color: var(--terracotta);
    background: var(--terracotta-bg);
  }

  /* Password Toggle */
  .password-input-group {
    position: relative;
    display: flex;
  }

  .password-input-group .form-control {
    padding-right: 44px;
  }

  .toggle-password {
    position: absolute;
    right: 1px;
    top: 1px;
    bottom: 1px;
    width: 42px;
    background: var(--gray-50);
    border: none;
    border-left: 1px solid var(--border-light);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all var(--transition-fast);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .toggle-password:hover {
    background: var(--gray-100);
    color: var(--text-primary);
  }

  /* Badge Styles */
  .role-badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    font-size: var(--text-xs);
    font-weight: 500;
    border-radius: var(--radius-full);
    background: var(--terracotta-bg);
    color: var(--terracotta);
  }

  .can-update-badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    font-size: var(--text-xs);
    font-weight: 500;
    border-radius: var(--radius-full);
  }

  .can-update-badge.yes {
    background: var(--success-light);
    color: var(--success);
  }

  .can-update-badge.no {
    background: var(--gray-200);
    color: var(--text-secondary);
  }

  /* Tab Content */
  .tab-pane {
    display: none;
  }

  .tab-pane.active {
    display: block;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .admin-tabs {
      padding: 0;
    }

    .admin-tabs .tab-btn {
      padding: 10px 14px;
      font-size: var(--text-xs);
    }

    .admin-table th,
    .admin-table td {
      padding: 10px 12px;
    }

    .form-card {
      padding: 20px;
    }

    .action-btns {
      flex-direction: column;
      gap: 6px;
    }
  }
</style>

<div class="container admin-container">
  <!-- Flash Messages -->
  <% if (typeof error !== 'undefined' && error.length) { %>
    <div class="alert alert-danger alert-permanent">
      <i class="bi bi-exclamation-circle me-2"></i>
      <%= error %>
    </div>
  <% } %>
  <% if (typeof success !== 'undefined' && success.length) { %>
    <div class="alert alert-success alert-permanent">
      <i class="bi bi-check-circle me-2"></i>
      <%= success %>
    </div>
  <% } %>

  <!-- Page Header -->
  <div class="page-header">
    <h1 class="page-title">Admin Dashboard</h1>
    <p class="page-subtitle">Manage users, roles, dashboards, and view audit logs</p>
  </div>

  <!-- Tab Navigation -->
  <div class="admin-tabs" role="tablist">
    <button class="tab-btn active" id="overview-tab" data-tab="overview" type="button" role="tab">
      <i class="bi bi-grid-3x3-gap me-2"></i>Overview
    </button>
    <button class="tab-btn" id="createDashboard-tab" data-tab="createDashboard" type="button" role="tab">
      <i class="bi bi-plus-square me-2"></i>Create Dashboard
    </button>
    <button class="tab-btn" id="createRole-tab" data-tab="createRole" type="button" role="tab">
      <i class="bi bi-person-badge me-2"></i>Create Role
    </button>
    <button class="tab-btn" id="createUser-tab" data-tab="createUser" type="button" role="tab">
      <i class="bi bi-person-plus me-2"></i>Create User
    </button>
    <button class="tab-btn" id="auditLogs-tab" data-tab="auditLogs" type="button" role="tab">
      <i class="bi bi-journal-text me-2"></i>Audit Logs
    </button>
  </div>

  <!-- Tab Content -->
  <div class="tab-content">
    <!-- Overview Tab -->
    <div class="tab-pane active" id="overview" role="tabpanel">
      <!-- Users Section -->
      <h3 class="section-header">
        <i class="bi bi-people me-2"></i>Users
      </h3>
      <div class="admin-table-container">
        <table class="admin-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Username</th>
              <th>Role</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(function(userItem) { %>
              <tr>
                <td><strong>#<%= userItem.id %></strong></td>
                <td><%= userItem.username %></td>
                <td>
                  <span class="role-badge"><%= userItem.role_name ? userItem.role_name : 'N/A' %></span>
                </td>
                <td>
                  <div class="action-btns">
                    <button class="btn-edit" type="button" data-bs-toggle="collapse" data-bs-target="#editUser-<%= userItem.id %>">
                      <i class="bi bi-pencil me-1"></i>Edit
                    </button>
                    <form action="/admin/delete-user" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to delete user <%= userItem.username %>?');">
                      <input type="hidden" name="user_id" value="<%= userItem.id %>">
                      <button type="submit" class="btn-delete">
                        <i class="bi bi-trash me-1"></i>Delete
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
              <!-- Inline Edit Row for User -->
              <tr class="collapse collapse-row" id="editUser-<%= userItem.id %>">
                <td colspan="4">
                  <form action="/admin/update-user" method="POST">
                    <input type="hidden" name="user_id" value="<%= userItem.id %>">
                    <div class="row g-3 align-items-end">
                      <div class="col-md-4">
                        <label for="username-<%= userItem.id %>" class="form-label">Username</label>
                        <input type="text" class="form-control" id="username-<%= userItem.id %>" name="username" value="<%= userItem.username %>" required>
                      </div>
                      <div class="col-md-4">
                        <label for="password-<%= userItem.id %>" class="form-label">New Password (optional)</label>
                        <div class="password-input-group">
                          <input type="password" class="form-control" id="password-<%= userItem.id %>" name="password" placeholder="Leave blank to keep current">
                          <button type="button" class="toggle-password" data-target="#password-<%= userItem.id %>">
                            <i class="bi bi-eye"></i>
                          </button>
                        </div>
                      </div>
                      <div class="col-md-4">
                        <button type="submit" class="btn btn-success">
                          <i class="bi bi-check-lg me-1"></i>Save Changes
                        </button>
                      </div>
                    </div>
                  </form>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <!-- Dashboards Section -->
      <h3 class="section-header">
        <i class="bi bi-layout-text-window-reverse me-2"></i>Dashboards
      </h3>
      <div class="admin-table-container">
        <table class="admin-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Name</th>
              <th>Table Name</th>
              <th>Role</th>
              <th>Can Update</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% dashboards.forEach(function(dashboard) { %>
              <tr>
                <td><strong>#<%= dashboard.id %></strong></td>
                <td><%= dashboard.name %></td>
                <td><code style="background: var(--gray-100); padding: 2px 8px; border-radius: var(--radius-sm); font-size: var(--text-xs);"><%= dashboard.table_name %></code></td>
                <td>
                  <span class="role-badge"><%= dashboard.role_name ? dashboard.role_name : 'N/A' %></span>
                </td>
                <td>
                  <span class="can-update-badge <%= dashboard.can_update ? 'yes' : 'no' %>">
                    <i class="bi bi-<%= dashboard.can_update ? 'check-circle' : 'x-circle' %> me-1"></i>
                    <%= dashboard.can_update ? 'Yes' : 'No' %>
                  </span>
                </td>
                <td>
                  <button class="btn-update-role" type="button" data-bs-toggle="collapse" data-bs-target="#editDashboard-<%= dashboard.id %>">
                    <i class="bi bi-arrow-repeat me-1"></i>Update Role
                  </button>
                </td>
              </tr>
              <!-- Inline Edit Row for Dashboard Role -->
              <tr class="collapse collapse-row" id="editDashboard-<%= dashboard.id %>">
                <td colspan="6">
                  <form action="/admin/update-dashboard-role" method="POST">
                    <input type="hidden" name="dashboardId" value="<%= dashboard.id %>">
                    <div class="row g-3 align-items-end">
                      <div class="col-md-6">
                        <label for="dashboardRoleId-<%= dashboard.id %>" class="form-label">Select Role</label>
                        <select class="form-select" id="dashboardRoleId-<%= dashboard.id %>" name="roleId" required>
                          <% roles.forEach(function(role) { %>
                            <option value="<%= role.id %>" <%= dashboard.role_id == role.id ? 'selected' : '' %>><%= role.name %></option>
                          <% }); %>
                        </select>
                      </div>
                      <div class="col-md-6">
                        <button type="submit" class="btn btn-success">
                          <i class="bi bi-check-lg me-1"></i>Update Role
                        </button>
                      </div>
                    </div>
                  </form>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <!-- Existing Tables Section -->
      <h3 class="section-header">
        <i class="bi bi-database me-2"></i>Existing Tables
      </h3>
      <div class="tables-list">
        <% existingTables.forEach(function(table) { %>
          <div class="table-item">
            <i class="bi bi-table me-2" style="color: var(--terracotta);"></i><%= table %>
          </div>
        <% }); %>
      </div>
    </div>

    <!-- Create Dashboard Tab -->
    <div class="tab-pane" id="createDashboard" role="tabpanel">
      <h3 class="section-header">
        <i class="bi bi-plus-square me-2"></i>Create New Dashboard
      </h3>
      <div class="form-card">
        <form action="/admin/create-dashboard" method="POST">
          <div class="form-group">
            <label for="dashboardName" class="form-label">Dashboard Name</label>
            <input type="text" class="form-control" id="dashboardName" name="dashboardName" required placeholder="e.g., Inventory Dashboard">
          </div>
          <div class="form-group">
            <label for="tableName" class="form-label">Table Name</label>
            <input type="text" class="form-control" id="tableName" name="tableName" required placeholder="Letters, numbers & underscores only (e.g., inventory_data)">
          </div>
          <div class="form-group">
            <label for="roleId" class="form-label">Assign Role</label>
            <select class="form-select" id="roleId" name="roleId" required>
              <% roles.forEach(function(role) { %>
                <option value="<%= role.id %>"><%= role.name %></option>
              <% }); %>
            </select>
          </div>
          <div class="form-group">
            <div class="form-check">
              <input type="checkbox" class="form-check-input" id="canUpdate" name="canUpdate">
              <label class="form-check-label" for="canUpdate">Allow Updates</label>
            </div>
          </div>
          <div class="form-group">
            <label for="columns" class="form-label">Columns (JSON Array)</label>
            <textarea class="form-control" id="columns" name="columns" rows="5" placeholder='[{"name": "column1", "type": "VARCHAR(255)", "isNotNull": true}, {"name": "column2", "type": "INT", "isNotNull": false}]' required></textarea>
            <small class="text-muted mt-2 d-block">Define table columns as a JSON array with name, type, and isNotNull properties.</small>
          </div>
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Create Dashboard
          </button>
        </form>
      </div>
    </div>

    <!-- Create Role Tab -->
    <div class="tab-pane" id="createRole" role="tabpanel">
      <h3 class="section-header">
        <i class="bi bi-person-badge me-2"></i>Create New Role
      </h3>
      <div class="form-card">
        <form action="/admin/create-role" method="POST">
          <div class="form-group">
            <label for="roleName" class="form-label">Role Name</label>
            <input type="text" class="form-control" id="roleName" name="roleName" required placeholder="e.g., Manager, Supervisor, Operator">
          </div>
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Create Role
          </button>
        </form>
      </div>
    </div>

    <!-- Create User Tab -->
    <div class="tab-pane" id="createUser" role="tabpanel">
      <h3 class="section-header">
        <i class="bi bi-person-plus me-2"></i>Create New User
      </h3>
      <div class="form-card">
        <form action="/admin/create-user" method="POST">
          <div class="form-group">
            <label for="newUsername" class="form-label">Username</label>
            <input type="text" class="form-control" id="newUsername" name="username" required placeholder="Enter username">
          </div>
          <div class="form-group">
            <label for="newPassword" class="form-label">Password</label>
            <div class="password-input-group">
              <input type="password" class="form-control" id="newPassword" name="password" required placeholder="Enter password">
              <button type="button" class="toggle-password" data-target="#newPassword">
                <i class="bi bi-eye"></i>
              </button>
            </div>
          </div>
          <div class="form-group">
            <label for="newRoleId" class="form-label">Assign Role</label>
            <select class="form-select" id="newRoleId" name="role_id" required>
              <% roles.forEach(function(role) { %>
                <option value="<%= role.id %>"><%= role.name %></option>
              <% }); %>
            </select>
          </div>
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Create User
          </button>
        </form>
      </div>
    </div>

    <!-- Audit Logs Tab -->
    <div class="tab-pane" id="auditLogs" role="tabpanel">
      <h3 class="section-header">
        <i class="bi bi-journal-text me-2"></i>Audit Logs (Latest 100)
      </h3>
      <div class="admin-table-container">
        <table class="admin-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>User</th>
              <th>Action</th>
              <th>Details</th>
              <th>Performed At</th>
            </tr>
          </thead>
          <tbody>
            <% if (auditLogs && auditLogs.length > 0) { %>
              <% auditLogs.forEach(function(log) { %>
                <tr>
                  <td><strong>#<%= log.id %></strong></td>
                  <td>
                    <span class="role-badge"><%= log.username %></span>
                  </td>
                  <td><%= log.action %></td>
                  <td style="max-width: 300px; overflow: hidden; text-overflow: ellipsis;"><%= log.details %></td>
                  <td><%= log.performed_at %></td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr>
                <td colspan="5" class="text-center text-muted" style="padding: 40px;">
                  <i class="bi bi-journal-x" style="font-size: 2rem; display: block; margin-bottom: 10px;"></i>
                  No audit logs found
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
  // Tab Navigation
  document.querySelectorAll('.tab-btn').forEach(function(tabBtn) {
    tabBtn.addEventListener('click', function() {
      var tabId = this.getAttribute('data-tab');

      // Remove active class from all tabs and panes
      document.querySelectorAll('.tab-btn').forEach(function(btn) { btn.classList.remove('active'); });
      document.querySelectorAll('.tab-pane').forEach(function(pane) { pane.classList.remove('active'); });

      // Add active class to clicked tab and corresponding pane
      this.classList.add('active');
      document.getElementById(tabId).classList.add('active');
    });
  });

  // Toggle password view/hide
  document.querySelectorAll('.toggle-password').forEach(function(button) {
    button.addEventListener('click', function() {
      var targetSelector = this.getAttribute('data-target');
      var input = document.querySelector(targetSelector);
      var icon = this.querySelector('i');
      if (input.getAttribute('type') === 'password') {
        input.setAttribute('type', 'text');
        icon.classList.remove('bi-eye');
        icon.classList.add('bi-eye-slash');
      } else {
        input.setAttribute('type', 'password');
        icon.classList.remove('bi-eye-slash');
        icon.classList.add('bi-eye');
      }
    });
  });
</script>

<%- include('partials/footer') %>
