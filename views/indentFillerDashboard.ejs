<%- include('partials/header', { pageTitle: 'Indent Dashboard' }) %>
<%- include('partials/navbar') %>

<!-- Main Content (No Sidebar) -->
<main class="main-content" style="margin-left: 0;">
  <div style="max-width: 1200px; margin: 0 auto;">

    <!-- Page Header -->
    <div class="page-header">
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
          <h1 class="page-title">Indent Request Desk</h1>
          <p class="page-subtitle">Submit and track your indent requests</p>
        </div>
        <div class="d-flex align-items-center gap-3">
          <span class="badge badge-primary" style="font-size: var(--text-sm); padding: 8px 16px;">
            <i class="bi bi-person me-1"></i><%= user.username %> - Indent Filler
          </span>
        </div>
      </div>
    </div>

    <%- include('partials/flashMessages') %>

    <!-- Raise Requirement Card -->
    <div class="card mb-4">
      <div class="card-header">
        <h2 class="card-title">
          <i class="bi bi-plus-circle me-2 text-terracotta"></i>Raise a Requirement
        </h2>
      </div>
      <div class="card-body">
        <p class="text-secondary mb-4">
          Submit a clear description so the store manager can act on it quickly.
        </p>
        <form action="/indent/create" method="POST" id="indentForm">
          <div class="row g-4">
            <div class="col-md-6">
              <div class="form-group mb-0">
                <label class="form-label" for="goodsDescription">Goods & Description</label>
                <textarea
                  class="form-control form-textarea"
                  id="goodsDescription"
                  name="goodsDescription"
                  placeholder="e.g. Thread cones 40/2 for Line A"
                  rows="3"
                  required
                  style="resize: vertical; min-height: 90px;"
                ></textarea>
              </div>
            </div>
            <div class="col-md-6">
              <div class="row g-3">
                <div class="col-6">
                  <div class="form-group mb-0">
                    <label class="form-label" for="quantity">Quantity</label>
                    <input
                      type="number"
                      class="form-control form-input"
                      id="quantity"
                      name="quantity"
                      min="0"
                      step="0.01"
                      placeholder="0"
                      required
                    />
                  </div>
                </div>
                <div class="col-6">
                  <div class="form-group mb-0">
                    <label class="form-label" for="requestDate">Date Needed</label>
                    <input
                      type="date"
                      class="form-control form-input"
                      id="requestDate"
                      name="requestDate"
                      required
                    />
                  </div>
                </div>
                <div class="col-6">
                  <div class="form-group mb-0">
                    <label class="form-label" for="usedLastMonth">Used in last 30 days</label>
                    <input
                      type="number"
                      class="form-control form-input"
                      id="usedLastMonth"
                      name="usedLastMonth"
                      min="0"
                      placeholder="0"
                    />
                  </div>
                </div>
                <div class="col-6">
                  <div class="form-group mb-0">
                    <label class="form-label" for="usedLastSevenDays">Used in last 7 days</label>
                    <input
                      type="number"
                      class="form-control form-input"
                      id="usedLastSevenDays"
                      name="usedLastSevenDays"
                      min="0"
                      placeholder="0"
                    />
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="d-flex justify-content-end mt-4">
            <button class="btn btn-primary btn-lg" type="submit" id="submitBtn">
              <i class="bi bi-send me-2"></i>Submit Request
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Recent Activity Card -->
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">
          <i class="bi bi-clock-history me-2 text-terracotta"></i>Recent Activity
        </h2>
        <% if (requests && requests.length > 0) { %>
          <span class="badge badge-neutral"><%= requests.length %> requests</span>
        <% } %>
      </div>
      <div class="card-body p-0">
        <% if (!requests || !requests.length) { %>
          <div class="empty-state">
            <div class="empty-state-icon">
              <i class="bi bi-inbox" style="font-size: 48px;"></i>
            </div>
            <h3 class="empty-state-title">No requests yet</h3>
            <p class="empty-state-text">
              Your submitted indent requests will appear here. Start by raising a new requirement above.
            </p>
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table mb-0">
              <thead>
                <tr>
                  <th>Goods & Description</th>
                  <th>Qty</th>
                  <th>Request Date</th>
                  <th>Status</th>
                  <th>Proceed Date</th>
                  <th>Arrival Date</th>
                  <th>Final Qty</th>
                  <th>Remarks</th>
                </tr>
              </thead>
              <tbody>
                <% requests.forEach(item => { %>
                <tr>
                  <td>
                    <strong class="text-primary"><%= item.goods_description %></strong>
                  </td>
                  <td><%= item.quantity_requested %></td>
                  <td>
                    <%= item.request_date ? new Date(item.request_date).toLocaleDateString('en-IN') : '-' %>
                  </td>
                  <td>
                    <% if (item.status === 'open') { %>
                      <span class="badge badge-warning">
                        <i class="bi bi-hourglass-split me-1"></i>Open
                      </span>
                    <% } else if (item.status === 'proceeding') { %>
                      <span class="badge badge-info">
                        <i class="bi bi-arrow-repeat me-1"></i>Proceeding
                      </span>
                    <% } else if (item.status === 'arrived') { %>
                      <span class="badge badge-success">
                        <i class="bi bi-check-circle me-1"></i>Arrived
                      </span>
                    <% } else { %>
                      <span class="badge badge-neutral"><%= item.status %></span>
                    <% } %>
                  </td>
                  <td>
                    <%= item.proceed_date ? new Date(item.proceed_date).toLocaleDateString('en-IN') : '-' %>
                  </td>
                  <td>
                    <%= item.arrival_date ? new Date(item.arrival_date).toLocaleDateString('en-IN') : '-' %>
                  </td>
                  <td><%= item.final_quantity || '-' %></td>
                  <td>
                    <span class="text-secondary"><%= item.remark || '-' %></span>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>

  </div>
</main>

<!-- Page-specific Scripts -->
<script>
  // Set default date to today
  const dateInput = document.getElementById('requestDate');
  if (dateInput && !dateInput.value) {
    const today = new Date();
    dateInput.value = today.toISOString().substring(0, 10);
  }

  // Close alert buttons
  document.querySelectorAll('.btn-close').forEach(btn => {
    btn.addEventListener('click', () => {
      if (btn.parentElement) {
        btn.parentElement.remove();
      }
    });
  });

  // Prevent duplicate form submissions
  document.querySelector('#indentForm').addEventListener('submit', function(e) {
    const btn = this.querySelector('button[type="submit"]');
    if (btn.disabled) {
      e.preventDefault();
      return false;
    }
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Submitting...';
  });
</script>

<%- include('partials/footer') %>
